@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:episode01-translations-324-330 a owl:Ontology .
# Translation variants for lines 324-330

:TV_Line_324_En a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_324 ;
  :text "CREON. Grumble over this then: if you can’t track down"^^xsd:string .

:TV_Line_325_En a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_325 ;
  :text "The criminal who’s done this, you’ll find that 325"^^xsd:string .

:TV_Line_326_En a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_326 ;
  :text "Your ill-gotten gains bring you only misery."^^xsd:string .

:TV_Line_327_En a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_327 ;
  :text "GUARD. O ye gods, may this outlaw be found! Yet it is all one, whether he"^^xsd:string .

:TV_Line_328_En a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_328 ;
  :text "Be caught or be he not—as such is solely in fate’s domain—"^^xsd:string .

:TV_Line_329_En a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_329 ;
  :text "Surely, I shall not be seen here again! O ye gods,"^^xsd:string .

:TV_Line_330_En a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_330 ;
  :text "For now, beyond my hope and contrary to my expectation,"^^xsd:string .

  

:TV_Line_324_Gr a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_324 ;
  :text "ΚΡΕΩΝ. Καλά, κρύψου εσύ πίσω απ’ το «κρίμα»."^^xsd:string .

:TV_Line_325_Gr a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_325 ;
  :text "Αν δεν μου φανερώσετε ποιος έκρινε σωστό να κάνει τέτοιο πράγμα, 320"^^xsd:string .

:TV_Line_326_Gr a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_326 ;
  :text "θα σας μάθω τι σημαίνει άτιμο κέρδος και δίκαιη τιμωρία."^^xsd:string .

:TV_Line_327_Gr a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_327 ;
  :text "ΣΚΟΠΟΣ. Εύχομαι ν’ αποκαλυφθεί. Όμως εμένα,"^^xsd:string .

:TV_Line_328_Gr a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_328 ;
  :text "συλληφθεί δεν συλληφθεί -αυτό βέβαια θα το κρίνει η τύχη"^^xsd:string .

:TV_Line_329_Gr a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_329 ;
  :text "δεν θα με ξαναδείς μπροστά σου."^^xsd:string .

:TV_Line_330_Gr a owl:NamedIndividual, :TranslationVariant ; :relatedTo :Line_330 ;
  :text "Ακόμα δεν μπορώ να το πιστέψω πώς με γλίτωσαν οι θεοί. 325"^^xsd:string .

:TV_Line_324_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_324 ;
  :text "Κόμψευέ νυν τὴν δόξαν· εἰ δὲ ταῦτα μὴ"^^xsd:string .

:TV_Line_325_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_325 ;
  :text "φανεῖτέ μοι τοὺς δρῶντας, ἐξερεῖθ ̓ ὅτι"^^xsd:string .

:TV_Line_326_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_326 ;
  :text "τὰ δειλὰ κέρδη πημονὰς ἐργάζεται."^^xsd:string .

:TV_Line_327_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_327 ;
  :text "Ἀλλ ̓ εὑρεθείη μὲν μάλιστ ̓· ἐὰν δέ τοι"^^xsd:string .

:TV_Line_328_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_328 ;
  :text "ληφθῇ τε καὶ μή, τοῦτο γὰρ τύχη κρινεῖ,"^^xsd:string .

:TV_Line_329_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_329 ;
  :text "οὐκ ἔσθ ̓ ὅπως ὄψει σὺ δεῦρ ̓ ἐλθόντα με."^^xsd:string .

:TV_Line_330_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_330 ;
  :text "Καὶ νῦν γὰρ ἐκτὸς ἐλπίδος γνώμης τ ̓ ἐμῆς"^^xsd:string .

