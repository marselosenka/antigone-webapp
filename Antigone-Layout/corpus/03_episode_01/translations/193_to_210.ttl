@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:episode01-translations-193-210 a owl:Ontology .

:TV_Line_193_en a :TranslationVariant ;
:text "To all the citizens regarding the children of Oedipus:"^^xsd:string ;
:relatedTo :Line_193 .

:TV_Line_194_en a :TranslationVariant ;
:text "Eteocles, who died fighting"^^xsd:string ;
:relatedTo :Line_194 ;
:relatedTo :Antigone_Character_Eteocles .

:TV_Line_195_en a :TranslationVariant ;
:text "For this city—our greatest warrior by far—"^^xsd:string ;
:relatedTo :Line_195 ;
:hasTheme :Theme_JusticeByMerit ;
:relatedTo :Event_EteoclesDefendsCityDies .

:TV_Line_196_en a :TranslationVariant ;
:text "Shall be buried and honored with all the proper rites"^^xsd:string ;
:relatedTo :Line_196 ;
:hasTheme :Theme_BurialHonorAndDisgrace ;
:relatedTo :MoralDecision_BuryEteoclesWithHonors .

:TV_Line_197_en a :TranslationVariant ;
:text "That are due when one of our best men has fallen;"^^xsd:string ;
:relatedTo :Line_197 ;
:hasTheme :Theme_BurialHonorAndDisgrace ;
:relatedTo :MoralDecision_BuryEteoclesWithHonors .

:TV_Line_198_en a :TranslationVariant ;
:text "As for his brother (Polyneices):"^^xsd:string ;
:relatedTo :Line_198 ;
:relatedTo :Antigone_Character_Polyneices .

:TV_Line_199_en a :TranslationVariant ;
:text "He was exiled from this city, but returned to burn"^^xsd:string ;
:relatedTo :Line_199 ;
:hasTheme :Theme_PunishmentOfTreason ;
:relatedTo :Event_PolyneicesAttacksFatherland .

:TV_Line_200_en a :TranslationVariant ;
:text "The land of his father and the gods of his family line"^^xsd:string ;
:relatedTo :Line_200 ;
:relatedTo :Event_PolyneicesAttacksFatherland .

:TV_Line_201_en a :TranslationVariant ;
:text "To the ground. He wanted to drink the blood"^^xsd:string ;
:relatedTo :Line_201 ;
:relatedTo :Event_PolyneicesAttacksFatherland .

:TV_Line_202_en a :TranslationVariant ;
:text "Of his kin and enslave the rest of us."^^xsd:string ;
:relatedTo :Line_202 ;
:hasTheme :Theme_PunishmentOfTreason ;
:relatedTo :Event_PolyneicesAttacksFatherland .

:TV_Line_203_en a :TranslationVariant ;
:text "It has been proclaimed throughout the city"^^xsd:string ;
:relatedTo :Line_203 ;
:relatedTo :MoralDecision_DenyBurialToPolyneices ;
:relatedTo :Event_CreonProclaimsDecree .

:TV_Line_204_en a :TranslationVariant ;
:text "That no one shall mourn this man nor give him"^^xsd:string ;
:relatedTo :Line_204 ;
:hasTheme :Theme_BurialHonorAndDisgrace ;
:relatedTo :MoralDecision_DenyBurialToPolyneices .

:TV_Line_205_en a :TranslationVariant ;
:text "A proper burial. He should be left for all to see, unburied,"^^xsd:string ;
:relatedTo :Line_205 ;
:hasTheme :Theme_BurialHonorAndDisgrace ;
:relatedTo :MoralDecision_DenyBurialToPolyneices .

:TV_Line_206_en a :TranslationVariant ;
:text "His body ripped to shreds by vultures and wild dogs."^^xsd:string ;
:relatedTo :Line_206 ;
:hasTheme :Theme_BurialHonorAndDisgrace ;
:relatedTo :MoralDecision_DenyBurialToPolyneices .

:TV_Line_207_en a :TranslationVariant ;
:text "This is my intention: never will I allow"^^xsd:string ;
:relatedTo :Line_207 ;
:experiencesEmotion :Emotion_SternResolve .

:TV_Line_208_en a :TranslationVariant ;
:text "Criminals to be honored before law-abiding citizens."^^xsd:string ;
:relatedTo :Line_208 ;
:hasTheme :Theme_JusticeByMerit ;
:hasConflict :Conflict_HonorWickedVsJust ;
:relatedTo :EthicalPrinciple_NoHonorForWickedOverJust .

:TV_Line_209_en a :TranslationVariant ;
:text "But anyone who means well for this city"^^xsd:string ;
:relatedTo :Line_209 ;
:hasTheme :Theme_PatriotismAndCivicLoyalty ;
:relatedTo :MoralDecision_HonorLoyalToCityLivingAndDead .

:TV_Line_210_en a :TranslationVariant ;
:text "I will honor in death as in life."^^xsd:string ;
:relatedTo :Line_210 ;
:hasTheme :Theme_PatriotismAndCivicLoyalty ;
:relatedTo :MoralDecision_HonorLoyalToCityLivingAndDead .
