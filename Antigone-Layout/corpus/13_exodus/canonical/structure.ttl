@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:exodus-structure a owl:Ontology .


:Line_1155 a :Line ; 
    :lineNumber 1155 ; 
    :canonicalReference "1155"^^xsd:string .


:Line_1156 a :Line ; 
    :lineNumber 1156 ; 
    :canonicalReference "1156"^^xsd:string .


:Line_1157 a :Line ; 
    :lineNumber 1157 ; 
    :canonicalReference "1157"^^xsd:string .

:Line_1158 a :Line ; 
    :lineNumber 1158 ; 
    :text "τύχη γὰρ ὀρθοῖ καὶ τύχη καταρρέπει"^^xsd:string ; 
    :hasTheme :Theme_InstabilityOfFortune .

:Line_1159 a :Line ; 
    :lineNumber 1159 ; 
    :text "τὸν εὐτυχοῦντα τόν τε δυστυχοῦντ ̓ ἀεί·"^^xsd:string .

:Line_1160 a :Line ; 
    :lineNumber 1160 ; 
    :text "καὶ μάντις οὐδεὶς τῶν καθεστώτων βροτοῖς."^^xsd:string .

:Line_1161 a :Line ; 
    :lineNumber 1161 ; 
    :text "Κρέων γὰρ ἦν ζηλωτός, ὡς ἐμοί, ποτέ,"^^xsd:string .

:Line_1162 a :Line ; 
    :lineNumber 1162 ; 
    :text "σώσας μὲν ἐχθρῶν τήνδε Καδμείαν χθόνα,"^^xsd:string .

:Line_1163 a :Line ; 
    :lineNumber 1163 ; 
    :text "λαβών τε χώρας παντελῆ μοναρχίαν"^^xsd:string .

:Line_1164 a :Line ; 
    :lineNumber 1164 ; 
    :text "ηὔθυνε, θάλλων εὐγενεῖ τέκνων σπορᾷ·"^^xsd:string .

:Line_1165 a :Line ; 
    :lineNumber 1165 ; 
    :text "καὶ νῦν ἀφεῖται πάντα. Τὰς γὰρ ἡδονὰς"^^xsd:string .

:Line_1166 a :Line ; 
    :lineNumber 1166 ; 
    :text "ὅταν προδῶσιν ἄνδρες, οὐ τίθημ ̓ ἐγὼ"^^xsd:string .

:Line_1167 a :Line ; 
    :lineNumber 1167 ; 
    :text "ζῆν τοῦτον, ἀλλ ̓ ἔμψυχον ἡγοῦμαι νεκρόν."^^xsd:string ; 
    :hasTheme :Theme_LivingDeath .

:Line_1168 a :Line ; 
    :lineNumber 1168 ; 
    :text "Πλούτει τε γὰρ κατ ̓ οἶκον, εἰ βούλει, μέγα,"^^xsd:string .

:Line_1169 a :Line ; 
    :lineNumber 1169 ; 
    :text "καὶ ζῆ τύραννον σχῆμ ̓ ἔχων, ἐὰν δ ̓ ἀπῇ"^^xsd:string .

:Line_1170 a :Line ; 
    :lineNumber 1170 ; 
    :text "τούτων τὸ χαίρειν, τἄλλ ̓ ἐγὼ καπνοῦ σκιᾶς"^^xsd:string .

:Line_1171 a :Line ; 
    :lineNumber 1171 ; 
    :text "οὐκ ἂν πριαίμην ἀνδρὶ πρὸς τὴν ἡδονήν."^^xsd:string .

:Line_1172 a :Line ; 
    :lineNumber 1172 ; 
    :text "Τί δ ̓ αὖ τόδ ̓ ἄχθος βασιλέων ἥκεις φέρων;"^^xsd:string .

:Line_1173 a :Line ; 
    :lineNumber 1173 ; 
    :text "Τεθνᾶσιν· οἱ δὲ ζῶντες αἴτιοι θανεῖν."^^xsd:string .

:Line_1174 a :Line ; 
    :lineNumber 1174 ; 
    :text "Καὶ τίς φονεύει; τίς δ ̓ ὁ κείμενος; λέγε."^^xsd:string .

:Line_1175 a :Line ; 
    :lineNumber 1175 ; 
    :text "Αἵμων ὄλωλεν· αὐτόχειρ δ ̓ αἱμάσσεται."^^xsd:string .

:Line_1176 a :Line ; 
    :lineNumber 1176 ; 
    :text "Πότερα πατρῴας ἢ πρὸς οἰκείας χερός;"^^xsd:string .

:Line_1177 a :Line ; 
    :lineNumber 1177 ; 
    :text "Αὐτὸς πρὸς αὑτοῦ, πατρὶ μηνίσας φόνου."^^xsd:string .

:Line_1178 a :Line ; 
    :lineNumber 1178 ; 
    :text "Ὦ μάντι, τοὔπος ὡς ἄρ ̓ ὀρθὸν ἤνυσας."^^xsd:string .

:Line_1179 a :Line ; 
    :lineNumber 1179 ; 
    :text "Ὡς ὧδ ̓ ἐχόντων τἄλλα βουλεύειν πάρα."^^xsd:string .

:Line_1180 a :Line ; 
    :lineNumber 1180 ; 
    :text "Καὶ μὴν ὁρῶ τάλαιναν Εὐρυδίκην ὁμοῦ"^^xsd:string .

:Line_1181 a :Line ; 
    :lineNumber 1181 ; 
    :text "δάμαρτα τὴν Κρέοντος· ἐκ δὲ δωμάτων"^^xsd:string .

:Line_1182 a :Line ; 
    :lineNumber 1182 ; 
    :text "ἤτοι κλύουσα παιδὸς ἢ τύχῃ περᾷ."^^xsd:string .

:Line_1183 a :Line ; 
    :lineNumber 1183 ; 
    :canonicalReference "1183" ; 
    :text "Ὦ πάντες ἀστοί, τῶν λόγων ἐπῃσθόμην"^^xsd:string .

:Line_1184 a :Line ; 
    :lineNumber 1184 ; 
    :canonicalReference "1184" ; 
    :text "πρὸς ἔξοδον στείχουσα, Παλλάδος θεᾶς"^^xsd:string .

:Line_1185 a :Line ; 
    :lineNumber 1185 ; 
    :canonicalReference "1185" ; 
    :text "ὅπως ἱκοίμην εὐγμάτων προσήγορος."^^xsd:string .

:Line_1186 a :Line ; 
    :lineNumber 1186 ; 
    :canonicalReference "1186" ; 
    :text "Καὶ τυγχάνω τε κλῇθρ ̓ ἀνασπαστοῦ πύλης"^^xsd:string .

:Line_1187 a :Line ; 
    :lineNumber 1187 ; 
    :canonicalReference "1187" ; 
    :text "χαλῶσα, καί με φθόγγος οἰκείου κακοῦ"^^xsd:string .

:Line_1188 a :Line ; 
    :lineNumber 1188 ; 
    :canonicalReference "1188" ; 
    :text "βάλλει δι ̓ ὤτων· ὑπτία δὲ κλίνομαι"^^xsd:string ; 
    :hasTheme :Theme_DivineMiasma .

:Line_1189 a :Line ; 
    :lineNumber 1189 ; 
    :canonicalReference "1189" ; 
    :text "δείσασα πρὸς δμωαῖσι κἀποπλήσσομαι."^^xsd:string .

:Line_1190 a :Line ; 
    :lineNumber 1190 ; 
    :canonicalReference "1190" ; 
    :text "Ἀλλ ̓ ὅστις ἦν ὁ μῦθος αὖθις εἴπατε·"^^xsd:string .

:Line_1191 a :Line ; 
    :lineNumber 1191 ; 
    :canonicalReference "1191" ; 
    :text "κακῶν γὰρ οὐκ ἄπειρος οὖσ ̓ ἀκούσομαι."^^xsd:string .

:Line_1192 a :Line ; 
    :lineNumber 1192 ; 
    :canonicalReference "1192" ; 
    :text "ΑΓ. Ἐγώ, φίλη δέσποινα, καὶ παρὼν ἐρῶ,"^^xsd:string .

:Line_1193 a :Line ; 
    :lineNumber 1193 ; 
    :canonicalReference "1193" ; 
    :text "κοὐδὲν παρήσω τῆς ἀληθείας ἔπος·"^^xsd:string .

:Line_1194 a :Line ; 
    :lineNumber 1194 ; 
    :canonicalReference "1194" ; 
    :text "τί γάρ σε μαλθάσσοιμ ̓ ἂν ὧν ἐς ὕστερον"^^xsd:string .

:Line_1195 a :Line ; 
    :lineNumber 1195 ; 
    :canonicalReference "1195" ; 
    :text "ψεῦσται φανούμεθ ̓; ὀρθὸν ἁλήθει ̓ ἀεί."^^xsd:string ; 
    :hasTheme :Theme_UnerringTruth .

:Line_1196 a :Line ; 
    :lineNumber 1196 ; 
    :canonicalReference "1196" ; 
    :text "Ἐγὼ δὲ σῷ ποδαγὸς ἑσπόμην πόσει"^^xsd:string .
:Line_1197 a :Line ; 
    :lineNumber 1197 ; 
    :canonicalReference "1197" ; 
    :text "πεδίον ἐπ ̓ ἄκρον, ἔνθ ̓ ἔκειτο νηλεὲς"^^xsd:string .

:Line_1198 a :Line ; 
    :lineNumber 1198 ; 
    :canonicalReference "1198" ; 
    :text "κυνοσπάρακτον σῶμα Πολυνείκους ἔτι·"^^xsd:string ; 
    :hasTheme :Theme_PiousBurial .

:Line_1199 a :Line ; 
    :lineNumber 1199 ; 
    :canonicalReference "1199" ; 
    :text "καὶ τὸν μέν, αἰτήσαντες ἐνοδίαν θεὸν"^^xsd:string .

:Line_1200 a :Line ; 
    :lineNumber 1200 ; 
    :canonicalReference "1200" ; 
    :text "Πλούτωνά τ ̓ ὀργὰς εὐμενεῖς κατασχεθεῖν,"^^xsd:string .

:Line_1201 a :Line ; 
    :lineNumber 1201 ; 
    :canonicalReference "1201" ; 
    :text "λούσαντες ἁγνὸν λουτρόν, ἐν νεοσπάσιν"^^xsd:string .

:Line_1202 a :Line ; 
    :lineNumber 1202 ; 
    :canonicalReference "1202" ; 
    :text "θαλλοῖς ὃ δὴ λέλειπτο συγκατῄθομεν,"^^xsd:string .

:Line_1203 a :Line ; 
    :lineNumber 1203 ; 
    :canonicalReference "1203" ; 
    :text "καὶ τύμβον ὀρθόκρανον οἰκείας χθονὸς"^^xsd:string .

:Line_1204 a :Line ; 
    :lineNumber 1204 ; 
    :canonicalReference "1204" ; 
    :text "χώσαντες αὖθις πρὸς λιθόστρωτον κόρης"^^xsd:string .

:Line_1205 a :Line ; 
    :lineNumber 1205 ; 
    :canonicalReference "1205" ; 
    :text "νυμφεῖον Ἅιδου κοῖλον εἰσεβαίνομεν."^^xsd:string ; 
    :hasTheme :Theme_MarriageToDeath .

:Line_1206 a :Line ; 
    :lineNumber 1206 ; 
    :canonicalReference "1206" ; 
    :text "Φωνῆς δ ̓ ἄπωθεν ὀρθίων κωκυμάτων"^^xsd:string .

:Line_1207 a :Line ; 
    :lineNumber 1207 ; 
    :canonicalReference "1207" ; 
    :text "κλύει τις ἀκτέριστον ἀμφὶ παστάδα,"^^xsd:string .
:Line_1208 a :Line ; 
    :lineNumber 1208 ; 
    :canonicalReference "1208" ; 
    :text "καὶ δεσπότῃ Κρέοντι σημαίνει μολών·"^^xsd:string .

:Line_1209 a :Line ; 
    :lineNumber 1209 ; 
    :canonicalReference "1209" ; 
    :text "τῷ δ ̓ ἀθλίας ἄσημα περιβαίνει βοῆς"^^xsd:string .
    
:Line_1210 a :Line ; 
    :lineNumber 1210 ; 
    :canonicalReference "1210" ; 
    :text "ἕρποντι μᾶλλον ἆσσον, οἰμώξας δ ̓ ἔπος"^^xsd:string .

:Line_1211 a :Line ; 
    :lineNumber 1211 ; 
    :canonicalReference "1211" ; 
    :text "ἵησι δυσθρήνητον· Ὢ τάλας ἐγώ,"^^xsd:string .

:Line_1212 a :Line ; 
    :lineNumber 1212 ; 
    :canonicalReference "1212" ; 
    :text "ἆρ ̓ εἰμὶ μάντις; ἆρα δυστυχεστάτην"^^xsd:string .

:Line_1213 a :Line ; 
    :lineNumber 1213 ; 
    :canonicalReference "1213" ; 
    :text "κέλευθον ἕρπω τῶν παρελθουσῶν ὁδῶν;"^^xsd:string .

:Line_1214 a :Line ; 
    :lineNumber 1214 ; 
    :canonicalReference "1214" ; 
    :text "παιδός με σαίνει φθόγγος. Ἀλλά, πρόσπολοι,"^^xsd:string .

:Line_1215 a :Line ; 
    :lineNumber 1215 ; 
    :canonicalReference "1215" ; 
    :text "ἴτ ̓ ἆσσον ὠκεῖς, καὶ παραστάντες τάφῳ"^^xsd:string .

:Line_1216 a :Line ; 
    :lineNumber 1216 ; 
    :canonicalReference "1216" ; 
    :text "ἀθρήσαθ ̓, ἁρμὸν χώματος λιθοσπαδῆ"^^xsd:string .

:Line_1217 a :Line ; 
    :lineNumber 1217 ; 
    :canonicalReference "1217" ; 
    :text "δύντες πρὸς αὐτὸ στόμιον, εἰ τὸν Αἵμονος"^^xsd:string .

:Line_1218 a :Line ; 
    :lineNumber 1218 ; 
    :canonicalReference "1218" ; 
    :text "φθόγγον συνίημ ̓, ἢ θεοῖσι κλέπτομαι."^^xsd:string .

:Line_1219 a :Line ; 
    :lineNumber 1219 ; 
    :canonicalReference "1219" ; 
    :text "Τάδ ̓ ἐξ ἀθύμου δεσπότου κελευσμάτων"^^xsd:string .

:Line_1220 a :Line ; 
    :lineNumber 1220 ; 
    :canonicalReference "1220" ; 
    :text "ἠθροῦμεν· ἐν δὲ λοισθίῳ τυμβεύματι"^^xsd:string .

:Line_1221 a :Line ; 
    :lineNumber 1221 ; 
    :canonicalReference "1221" ; 
    :text "τὴν μὲν κρεμαστὴν αὐχένος κατείδομεν,"^^xsd:string .

:Line_1222 a :Line ; 
    :lineNumber 1222 ; 
    :canonicalReference "1222" ; 
    :text "βρόχῳ μιτώδει σινδόνος καθημμένην,"^^xsd:string .

:Line_1223 a :Line ; 
    :lineNumber 1223 ; 
    :canonicalReference "1223" ; 
    :text "τὸν δ ̓ ἀμφὶ μέσσῃ περιπετῆ προσκείμενον,"^^xsd:string .

:Line_1224 a :Line ; 
    :lineNumber 1224 ; 
    :canonicalReference "1224" ; 
    :text "εὐνῆς ἀποιμώζοντα τῆς κάτω φθορὰν"^^xsd:string .

:Line_1225 a :Line ; 
    :lineNumber 1225 ; 
    :canonicalReference "1225" ; 
    :text "καὶ πατρὸς ἔργα καὶ τὸ δύστηνον λέχος."^^xsd:string .

:Line_1226 a :Line ; 
    :lineNumber 1226 ; 
    :canonicalReference "1226" ; 
    :text "Ὁ δ ̓ ὡς ὁρᾷ σφε, στυγνὸν οἰμώξας ἔσω"^^xsd:string .

:Line_1227 a :Line ; 
    :lineNumber 1227 ; 
    :canonicalReference "1227" ; 
    :text "χωρεῖ πρὸς αὐτὸν κἀνακωκύσας καλεῖ·"^^xsd:string .

:Line_1228 a :Line ;
    :lineNumber 1228 ; 
    :canonicalReference "1228" ; 
    :text "Ὦ τλῆμον, οἷον ἔργον εἴργασαι· τίνα"^^xsd:string .
    
:Line_1229 a :Line ;   
    :lineNumber 1229 ; 
    :canonicalReference "1229" ; 
    :text "νοῦν ἔσχες; ἐν τῷ συμφορᾶς διεφθάρης;"^^xsd:string .

:Line_1230 a :Line ; 
    :lineNumber 1230 ; 
    :canonicalReference "1230" ; 
    :text "Ἔξελθε, τέκνον, ἱκέσιός σε λίσσομαι."^^xsd:string .

:Line_1231 a :Line ; 
    :lineNumber 1231 ; 
    :canonicalReference "1231" ; 
    :text "Τὸν δ ̓ ἀγρίοις ὄσσοισι παπτήνας ὁ παῖς,"^^xsd:string ; 
    :hasConflict :Conflict_HaemonVsCreon_Violence .

:Line_1232 a :Line ; 
    :lineNumber 1232 ; 
    :canonicalReference "1232" ; 
    :text "πτύσας προσώπῳ κοὐδὲν ἀντειπών, ξίφους"^^xsd:string .

:Line_1233 a :Line ; 
    :lineNumber 1233 ; 
    :canonicalReference "1233" ; 
    :text "ἕλκει διπλοῦς κνώδοντας, ἐκ δ ̓ ὁρμωμένου"^^xsd:string .

:Line_1234 a :Line ; 
    :lineNumber 1234 ; 
    :canonicalReference "1234" ; 
    :text "πατρὸς φυγαῖσιν ἤμπλακ ̓· εἶθ ̓ ὁ δύσμορος"^^xsd:string .

:Line_1235 a :Line ; 
    :lineNumber 1235 ; 
    :canonicalReference "1235" ; 
    :text "αὑτῷ χολωθείς, ὥσπερ εἶχ ̓, ἐπενταθεὶς"^^xsd:string .

:Line_1236 a :Line ; 
    :lineNumber 1236 ; 
    :canonicalReference "1236" ; 
    :text "ἤρεισε πλευραῖς μέσσον ἔγχος, ἐς δ ̓ ὑγρὸν"^^xsd:string .

:Line_1237 a :Line ; 
    :lineNumber 1237 ; 
    :canonicalReference "1237" ; 
    :text "ἀγκῶν ̓ ἔτ ̓ ἔμφρων παρθένῳ προσπτύσσεται·"^^xsd:string .

:Line_1238 a :Line ; 
    :lineNumber 1238 ; 
    :canonicalReference "1238" ; 
    :text "καὶ φυσιῶν ὀξεῖαν ἐκβάλλει ῥοὴν"^^xsd:string .

:Line_1239 a :Line ; 
    :lineNumber 1239 ; 
    :canonicalReference "1239" ; 
    :text "λευκῇ παρειᾷ φοινίου σταλάγματος."^^xsd:string .

:Line_1240 a :Line ; 
    :lineNumber 1240 ; 
    :canonicalReference "1240" ; 
    :text "Κεῖται δὲ νεκρὸς περὶ νεκρῷ, τὰ νυμφικὰ"^^xsd:string ; 
    :hasTheme :Theme_MarriageToDeath .

:Line_1241 a :Line ; 
    :lineNumber 1241 ; 
    :canonicalReference "1241" ; 
    :text "τέλη λαχὼν δείλαιος εἰν Ἅιδου δόμοις,"^^xsd:string .

:Line_1242 a :Line ; 
    :lineNumber 1242 ; 
    :canonicalReference "1242" ; 
    :text "δείξας ἐν ἀνθρώποισι τὴν ἀβουλίαν"^^xsd:string ; 
    :hasTheme :Theme_Aboulia .

:Line_1243 a :Line ; 
    :lineNumber 1243 ; 
    :canonicalReference "1243" ; 
    :text "ὅσῳ μέγιστον ἀνδρὶ πρόσκειται κακόν."^^xsd:string .


:Line_1244 a :Line ; 
    :lineNumber 1244 ; 
    :text "ΧΟ. Τί τοῦτ ̓ ἂν εἰκάσειας; ἡ γυνὴ πάλιν"^^xsd:string .

:Line_1245 a :Line ; 
    :lineNumber 1245 ; 
    :text "φρούδη, πρὶν εἰπεῖν ἐσθλὸν ἢ κακὸν λόγον."^^xsd:string .

:Line_1246 a :Line ; 
    :lineNumber 1246 ; 
    :text "ΑΓ. Καὐτὸς τεθάμβηκ ̓· ἐλπίσιν δὲ βόσκομαι"^^xsd:string .

:Line_1247 a :Line ; 
    :lineNumber 1247 ; 
    :text "ἄχη τέκνου κλύουσαν ἐς πόλιν γόου"^^xsd:string .

:Line_1248 a :Line ; 
    :lineNumber 1248 ; 
    :text "οὐκ ἀξιώσειν, ἀλλ ̓ ὑπὸ στέγης ἔσω"^^xsd:string .

:Line_1249 a :Line ; 
    :lineNumber 1249 ; 
    :text "δμωαῖς προθήσειν πένθος οἰκεῖον στένειν."^^xsd:string .

:Line_1250 a :Line ;
    :lineNumber 1250 ; 
    :text "Γνώμης γὰρ οὐκ ἄπειρος, ὥσθ ̓ ἁμαρτάνειν."^^xsd:string .

:Line_1251 a :Line ; 
    :lineNumber 1251 ; 
    :text "ΧΟ. Οὐκ οἶδ ̓· ἐμοὶ δ ̓ οὖν ἥ τ ̓ ἄγαν σιγὴ βαρὺ"^^xsd:string .

:Line_1252 a :Line ; 
    :lineNumber 1252 ; 
    :text "δοκεῖ προσεῖναι χἠ μάτην πολλὴ βοή."^^xsd:string .

:Line_1253 a :Line ; 
    :lineNumber 1253 ; 
    :text "ΑΓ. Ἀλλ ̓ εἰσόμεσθα μή τι καὶ κατάσχετον"^^xsd:string .

:Line_1254 a :Line ; 
    :lineNumber 1254 ; 
    :text "κρυφῇ καλύπτει καρδίᾳ θυμουμένῃ,"^^xsd:string .

:Line_1255 a :Line ; 
    :lineNumber 1255 ; 
    :text "δόμους παραστείχοντες· εὖ γὰρ οὖν λέγεις·"^^xsd:string .

:Line_1256 a :Line ; 
    :lineNumber 1256 ; 
    :text "καὶ τῆς ἄγαν γάρ ἐστί που σιγῆς βάρος."^^xsd:string .

:Line_1257 a :Line ; 
    :lineNumber 1257 ; 
    :text "ΧΟ. Καὶ μὴν ὅδ ̓ ἄναξ αὐτὸς ἐφήκει"^^xsd:string .

:Line_1258 a :Line ;
    :lineNumber 1258 ; 
    :text "μνῆμ ̓ ἐπίσημον διὰ χειρὸς ἔχων,"^^xsd:string .


:Line_1259 a :Line ; 
    :lineNumber 1259 ; 
    :text "εἰ θέμις εἰπεῖν, οὐκ ἀλλοτρίαν"^^xsd:string .

:Line_1260 a :Line ; 
    :lineNumber 1260 ; 
    :text "ἄτην, ἀλλ ̓ αὐτὸς ἁμαρτών."^^xsd:string .

:Line_1261 a :Line ; 
    :lineNumber 1261 ; 
    :text "ΚΡ. Ἰὼ φρενῶν δυσφρόνων ἁμαρτήματα"^^xsd:string ; 
    :hasTheme :Theme_Misjudgment .

:Line_1262 a :Line ; 
    :lineNumber 1262 ; 
    :text "στερεὰ θανατόεντ ̓,"^^xsd:string .

:Line_1263 a :Line ; 
    :lineNumber 1263 ; 
    :text "ὦ κτανόντας τε καὶ"^^xsd:string .

:Line_1264 a :Line ; 
    :lineNumber 1264 ; 
    :text "θανόντας βλέποντες ἐμφυλίους."^^xsd:string .

:Line_1265 a :Line ; 
    :lineNumber 1265 ; 
    :text "Ὤμοι ἐμῶν ἄνολβα βουλευμάτων."^^xsd:string .

:Line_1266 a :Line ; 
    :lineNumber 1266 ; 
    :text "Ἰὼ παῖ, νέος νέῳ ξὺν μόρῳ,"^^xsd:string .

:Line_1267 a :Line ; 
    :lineNumber 1267 ; 
    :text "αἰαῖ αἰαῖ,"^^xsd:string .

:Line_1268 a :Line ; 
    :lineNumber 1268 ; 
    :text "ἔθανες, ἀπελύθης,"^^xsd:string .

:Line_1269 a :Line ; 
    :lineNumber 1269 ; 
    :text "ἐμαῖς οὐδὲ σαῖσι δυσβουλίαις."^^xsd:string .

:Line_1270 a :Line ; 
    :lineNumber 1270 ; 
    :text "ΧΟ. Οἴμ ̓ ὡς ἔοικας ὀψὲ τὴν δίκην ἰδεῖν."^^xsd:string ; 
    :hasTheme :Theme_LateJustice .

:Line_1271 a :Line ; 
    :lineNumber 1271 ; 
    :text "ΚΡ. Οἴμοι,"^^xsd:string .

:Line_1272 a :Line ; 
    :lineNumber 1272 ; 
    :text "ἔχω μαθὼν δείλαιος· ἐν δ ̓ ἐμῷ κάρᾳ"^^xsd:string .

:Line_1273 a :Line ; 
    :lineNumber 1273 ; 
    :text "θεὸς τότ ̓ ἄρα τότε μέγα βάρος μ ̓ ἔχων"^^xsd:string ; 
    :hasTheme :Theme_DivineRetribution .

:Line_1274 a :Line ; 
    :lineNumber 1274 ; 
    :text "ἔπαισεν, ἐν δ ̓ ἔσεισεν ἀγρίαις ὁδοῖς,"^^xsd:string .

:Line_1275 a :Line ; 
    :lineNumber 1275 ; 
    :text "οἴμοι, λακπάτητον ἀντρέπων χαράν."^^xsd:string .

:Line_1276 a :Line ; 
    :lineNumber 1276 ; 
    :text "Φεῦ φεῦ, ἰὼ πόνοι βροτῶν δύσπονοι."^^xsd:string .

:Line_1277 a :Line ; 
    :lineNumber 1277 ; 
    :canonicalReference "1277" ; 
    :text "Ὦ δέσποθ ̓, ὡς ἔχων τε καὶ κεκτημένος,"^^xsd:string .

:Line_1278 a :Line ; 
    :lineNumber 1278 ; 
    :canonicalReference "1278" ; 
    :text "τὰ μὲν πρὸ χειρῶν τάδε φέρειν, τὰ δ ̓ ἐν δόμοις"^^xsd:string .

:Line_1280 a :Line ; 
    :lineNumber 1280 ; 
    :canonicalReference "1280" ; 
    :text "ἔοικας ἥκων καὶ τάχ ̓ ὄψεσθαι κακά."^^xsd:string .

:Line_1281 a :Line ; 
    :lineNumber 1281 ; 
    :canonicalReference "1281" ; 
    :text "Τί δ; ἔστιν αὖ κάκιον ἐκ κακῶν ἔτι;"^^xsd:string .

:Line_1282 a :Line ; 
    :lineNumber 1282 ; 
    :canonicalReference "1282" ; 
    :text "ΕΞ. Γυνὴ τέθνηκεν, τοῦδε παμμήτωρ νεκρού,"^^xsd:string .

:Line_1283 a :Line ; 
    :lineNumber 1283 ; 
    :canonicalReference "1283" ; 
    :text "δύστηνος, ἄρτι νεοτόμοισι πλήγμασιν."^^xsd:string .

:Line_1284 a :Line ; 
    :lineNumber 1284 ; 
    :canonicalReference "1284" ; 
    :text "ΚΡ. Ἰὼ, ἰὼ δυσκάθαρτος Ἅιδου λιμήν,"^^xsd:string ; 
    :hasTheme :Theme_HadesHarbor .

:Line_1285 a :Line ; 
    :lineNumber 1285 ; 
    :canonicalReference "1285" ; 
    :text "τί μ ̓ ἄρα τί μ ̓ ὀλέκεις;"^^xsd:string .

:Line_1286 a :Line ; 
    :lineNumber 1286 ; 
    :canonicalReference "1286" ; 
    :text "Ὦ κακάγγελτά μοι"^^xsd:string .

:Line_1287 a :Line ; 
    :lineNumber 1287 ; 
    :canonicalReference "1287" ; 
    :text "προπέμψας ἄχη, τίνα θροεῖς λόγον;"^^xsd:string .

:Line_1288 a :Line ; 
    :lineNumber 1288 ; 
    :canonicalReference "1288" ; 
    :text "Αἰαῖ, ὀλωλότ ̓ ἄνδρ ̓ ἐπεξειργάσω."^^xsd:string .

:Line_1289 a :Line ; 
    :lineNumber 1289 ; 
    :canonicalReference "1289" ; 
    :text "Τί φῄς, ὦ παῖ; τίνα λέγεις μοι νέον,"^^xsd:string .

:Line_1290 a :Line ; 
    :lineNumber 1290 ; 
    :canonicalReference "1290" ; 
    :text "αἰαῖ, αἰαῖ,"^^xsd:string .

:Line_1291 a :Line ; 
    :lineNumber 1291 ; 
    :canonicalReference "1291" ; 
    :text "σφάγιον ἐπ ̓ ὀλέθρῳ,"^^xsd:string .
:Line_1292 a :Line ; :lineNumber 1292 ; :canonicalReference "1292" ; :text "γυναικεῖον ἀμφικεῖσθαι μόρον;"^^xsd:string .
:Line_1293 a :Line ; :lineNumber 1293 ; :canonicalReference "1293" ; :text "ΧΟ. Ὁρᾶν πάρεστιν· οὐ γὰρ ἐν μυχοῖς ἔτι."^^xsd:string .
:Line_1294 a :Line ; :lineNumber 1294 ; :canonicalReference "1294" ; :text "ΚΡ. Οἴμοι,"^^xsd:string .
:Line_1295 a :Line ; :lineNumber 1295 ; :canonicalReference "1295" ; :text "κακὸν τόδ ̓ ἄλλο δεύτερον βλέπω τάλας"^^xsd:string .
:Line_1296 a :Line ; :lineNumber 1296 ; :canonicalReference "1296" ; :text "Τίς ἄρα, τίς με πότμος ἔτι περιμένει;"^^xsd:string .
:Line_1297 a :Line ; :lineNumber 1297 ; :canonicalReference "1297" ; :text "Ἔχω μὲν ἐν χείρεσσιν ἀρτίως τέκνον,"^^xsd:string .
:Line_1299 a :Line ; :lineNumber 1299 ; :canonicalReference "1299" ; :text "τάλας, τὸν δ ̓ ἔναντα προσβλέπω νεκρόν."^^xsd:string ; :hasTheme :Theme_DoubleWoe .
:Line_1300 a :Line ; :lineNumber 1300 ; :canonicalReference "1300" ; :text "Φεῦ φεῦ μᾶτερ ἀθλία, φεῦ τέκνον."^^xsd:string .
:Line_1301 a :Line ; :lineNumber 1301 ; :canonicalReference "1301" ; :text "Ἡ δ ̓ ὀξύπληκτος ἡμένη βωμία"^^xsd:string .
:Line_1302 a :Line ; :lineNumber 1302 ; :canonicalReference "1302" ; :text "λύει κελαινὰ βλέφαρα, κωκύσασα μὲν"^^xsd:string .
:Line_1303 a :Line ; :lineNumber 1303 ; :canonicalReference "1303" ; :text "τοῦ πρὶν θανόντος Μεγαρέως κενὸν λέχος,"^^xsd:string .
:Line_1304 a :Line ; :lineNumber 1304 ; :canonicalReference "1304" ; :text "αὖθις δὲ τοῦδε, λοίσθιον δὲ σοὶ κακὰς"^^xsd:string .
:Line_1305 a :Line ; :lineNumber 1305 ; :canonicalReference "1305" ; :text "πράξεις ἐφυμνήσασα τῷ παιδοκτόνῳ."^^xsd:string ; :hasTheme :Theme_ChildSlayer .


:Line_1306 a :Line ; :lineNumber 1306 ; :canonicalReference "1306" ; :text "ΚΡ. Αἰαῖ αἰαῖ, στροφή β ́"^^xsd:string .
:Line_1307 a :Line ; :lineNumber 1307 ; :canonicalReference "1307" ; :text "ἀνέπταν φόβῳ. Τί μ ̓ οὐκ ἀνταίαν"^^xsd:string .
:Line_1308 a :Line ; :lineNumber 1308 ; :canonicalReference "1308" ; :text "ἔπαισέν τις ἀμφιθήκτῳ ξίφει;"^^xsd:string .
:Line_1309 a :Line ; :lineNumber 1309 ; :canonicalReference "1309" ; :text "δείλαιος ἐγώ, αἰαῖ,"^^xsd:string .
:Line_1311 a :Line ; :lineNumber 1311 ; :canonicalReference "1311" ; :text "δειλαίᾳ δὲ συγκέκραμαι δύᾳ."^^xsd:string .
:Line_1312 a :Line ; :lineNumber 1312 ; :canonicalReference "1312" ; :text "ΕΞ. Ὡς αἰτίαν γε τῶνδε κἀκείνων ἔχων"^^xsd:string .
:Line_1313 a :Line ; :lineNumber 1313 ; :canonicalReference "1313" ; :text "πρὸς τῆς θανούσης τῆσδ ̓ ἐπεσκήπτου μόρων."^^xsd:string .
:Line_1314 a :Line ; :lineNumber 1314 ; :canonicalReference "1314" ; :text "ΚΡ. Ποίῳ δὲ κἀπελύετ ̓ ἐν φοναῖς τρόπῳ;"^^xsd:string .
:Line_1315 a :Line ; :lineNumber 1315 ; :canonicalReference "1315" ; :text "ΕΞ. Παίσασ ̓ ὑφ ἧπαρ αὐτόχειρ αὑτήν, ὅπως"^^xsd:string .
:Line_1316 a :Line ; :lineNumber 1316 ; :canonicalReference "1316" ; :text "παιδὸς τόδ ̓ ᾔσθετ ̓ ὀξυκώκυτον πάθος."^^xsd:string .
:Line_1317 a :Line ; :lineNumber 1317 ; :canonicalReference "1317" ; :text "ᬬμοι μοι, τάδ ̓ οὐκ ἐπ ̓ ἄλλον βροτῶν"^^xsd:string .
:Line_1318 a :Line ; :lineNumber 1318 ; :canonicalReference "1318" ; :text "ἐμᾶς ἁρμόσει ποτ ̓ ἐξ αἰτίας."^^xsd:string .
:Line_1319 a :Line ; :lineNumber 1319 ; :canonicalReference "1319" ; :text "Ἐγὼ γάρ σ ̓ ἐγώ σ ̓ ἔκανον, ὢ μέλεος,"^^xsd:string ; :hasTheme :Theme_FullConfession .
:Line_1320 a :Line ; :lineNumber 1320 ; :canonicalReference "1320" ; :text "ἐγώ, φάμ ̓ ἔτυμον. Ἰὼ πρόσπολοι,"^^xsd:string .
:Line_1321 a :Line ; :lineNumber 1321 ; :canonicalReference "1321" ; :text "ἀπάγετέ μ ̓ ὅτι τάχος,"^^xsd:string .
:Line_1322 a :Line ; :lineNumber 1322 ; :canonicalReference "1322" ; :text "ἄγετέ μ ̓ ἐκποδών,"^^xsd:string .
:Line_1325 a :Line ; :lineNumber 1325 ; :canonicalReference "1325" ; :text "τὸν οὐκ ὄντα μᾶλλον ἢ μηδένα."^^xsd:string .
:Line_1326 a :Line ; :lineNumber 1326 ; :canonicalReference "1326" ; :text "ΧΟ. Κέρδη παραινεῖς, εἴ τι κέρδος ἐν κακοῖς·"^^xsd:string .
:Line_1327 a :Line ; :lineNumber 1327 ; :canonicalReference "1327" ; :text "βράχιστα γὰρ κράτιστα τἀν ποσὶν κακά."^^xsd:string .
:Line_1328 a :Line ; :lineNumber 1328 ; :canonicalReference "1328" ; :text "ΚΡ. Ἴτω ἴτω, αντιστρ. β ́"^^xsd:string .
:Line_1329 a :Line ; :lineNumber 1329 ; :canonicalReference "1329" ; :text "φανήτω μόρων ὁ κάλλιστ ̓ ἐμῶν"^^xsd:string .
:Line_1330 a :Line ; :lineNumber 1330 ; :canonicalReference "1330" ; :text "ἐμοὶ τερμίαν ἄγων ἁμέραν"^^xsd:string .
:Line_1331 a :Line ; :lineNumber 1331 ; :canonicalReference "1331" ; :text "ὕπατος· ἴτω, ἴτω,"^^xsd:string .
:Line_1332 a :Line ; :lineNumber 1332 ; :canonicalReference "1332" ; :text "ὅπως μηκέτ ἆμαρ ἄλλ ̓ εἰσίδω."^^xsd:string .
:Line_1334 a :Line ; :lineNumber 1334 ; :canonicalReference "1334" ; :text "ΧΟ. Μέλλοντα ταῦτα. Τῶν προκειμένων τι χρὴ"^^xsd:string .
:Line_1335 a :Line ; :lineNumber 1335 ; :canonicalReference "1335" ; :text "πράσσειν· μέλει γὰρ τῶνδ ̓ ὅτοισι χρὴ μέλειν."^^xsd:string .
:Line_1336 a :Line ; :lineNumber 1336 ; :canonicalReference "1336" ; :text "ΚΡ. Ἀλλ ̓ ὧν ἐρῶμεν ταῦτα συγκατηυξάμην."^^xsd:string .
:Line_1337 a :Line ; :lineNumber 1337 ; :canonicalReference "1337" ; :text "ΧΟ. Μή νυν προσεύχου μηδέν· ὡς πεπρωμένης"^^xsd:string ; :hasTheme :Theme_InevitabilityOfFate .
:Line_1338 a :Line ; :lineNumber 1338 ; :canonicalReference "1338" ; :text "οὐκ ἔστι θνητοῖς συμφορᾶς ἀπαλλαγή."^^xsd:string .
:Line_1339 a :Line ; :lineNumber 1339 ; :canonicalReference "1339" ; :text "ΚΡ. Ἄγοιτ ἂν μάταιον ἄνδρ ̓ ἐκποδών,"^^xsd:string .
:Line_1340 a :Line ; :lineNumber 1340 ; :canonicalReference "1340" ; :text "ὅς, ὦ παῖ, σέ τ ̓ οὐχ ἑκὼν κατέκανον"^^xsd:string .
:Line_1341 a :Line ; :lineNumber 1341 ; :canonicalReference "1341" ; :text "σέ τ ̓ αὖ τάνδ ̓, ὤμοι μέλεος,"^^xsd:string .
:Line_1342 a :Line ; :lineNumber 1342 ; :canonicalReference "1342" ; :text "οὐδ ̓ ἔχω"^^xsd:string .
:Line_1343 a :Line ; :lineNumber 1343 ; :canonicalReference "1343" ; :text "πρὸς πότερον ἴδω, πᾷ κλιθῶ·"^^xsd:string .
:Line_1344 a :Line ; :lineNumber 1344 ; :canonicalReference "1344" ; :text "πάντα γὰρ"^^xsd:string .
:Line_1345 a :Line ; :lineNumber 1345 ; :canonicalReference "1345" ; :text "λέχρια τἀν χεροῖν,"^^xsd:string .
:Line_1346 a :Line ; :lineNumber 1346 ; :canonicalReference "1346" ; :text "τὰ δ ̓ ἐπὶ κρατί μοι πότμος δυσκόμιστος εἰσήλατο."^^xsd:string .
:Line_1347 a :Line ; :lineNumber 1347 ; :canonicalReference "1347" ; :text "ΧΟ. Πολλῷ τὸ φρονεῖν εὐδαιμονίας"^^xsd:string ; :hasTheme :Theme_WisdomThroughSuffering .
:Line_1348 a :Line ; :lineNumber 1348 ; :canonicalReference "1348" ; :text "πρῶτον ὑπάρχει· χρὴ δὲ τά γ ̓ εἰς θεοὺς"^^xsd:string ; :hasTheme :Theme_Piety .
:Line_1349 a :Line ; :lineNumber 1349 ; :canonicalReference "1349" ; :text "μηδὲν ἀσεπτεῖν; μεγάλοι δὲ λόγοι"^^xsd:string .
:Line_1350 a :Line ; :lineNumber 1350 ; :canonicalReference "1350" ; :text "μεγάλας πληγὰς τῶν ὑπεραύχων"^^xsd:string .
:Line_1351 a :Line ; :lineNumber 1351 ; :canonicalReference "1351" ; :text "ἀποτείσαντες"^^xsd:string .
:Line_1352 a :Line ; :lineNumber 1352 ; :canonicalReference "1352" ; :text "γήρᾳ τὸ φρονεῖν ἐδίδαξαν."^^xsd:string .
