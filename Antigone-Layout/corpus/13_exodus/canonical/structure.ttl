@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:exodus-structure a owl:Ontology .


# --- 1183 ---
:Line_1183 a :Line ;
    :lineNumber 1183 ;
    :canonicalReference "1183" ;
    :text "Ὦ πάντες ἀστοί, τῶν λόγων ἐπῃσθόμην"^^xsd:string .

# --- 1184 ---
:Line_1184 a :Line ;
    :lineNumber 1184 ;
    :canonicalReference "1184" ;
    :text "πρὸς ἔξοδον στείχουσα, Παλλάδος θεᾶς"^^xsd:string .

# --- 1185 ---
:Line_1185 a :Line ;
    :lineNumber 1185 ;
    :canonicalReference "1185" ;
    :text "ὅπως ἱκοίμην εὐγμάτων προσήγορος."^^xsd:string .

# --- 1186 ---
:Line_1186 a :Line ;
    :lineNumber 1186 ;
    :canonicalReference "1186" ;
    :text "Καὶ τυγχάνω τε κλῇθρ ̓ ἀνασπαστοῦ πύλης"^^xsd:string .

# --- 1187 ---
:Line_1187 a :Line ;
    :lineNumber 1187 ;
    :canonicalReference "1187" ;
    :text "χαλῶσα, καί με φθόγγος οἰκείου κακοῦ"^^xsd:string .

# --- 1188 ---
:Line_1188 a :Line ;
    :lineNumber 1188 ;
    :canonicalReference "1188" ;
    :text "βάλλει δι ̓ ὤτων· ὑπτία δὲ κλίνομαι"^^xsd:string ;
    :hasTheme :Theme_DivineMiasma .

# --- 1189 ---
:Line_1189 a :Line ;
    :lineNumber 1189 ;
    :canonicalReference "1189" ;
    :text "δείσασα πρὸς δμωαῖσι κἀποπλήσσομαι."^^xsd:string .

# --- 1190 ---
:Line_1190 a :Line ;
    :lineNumber 1190 ;
    :canonicalReference "1190" ;
    :text "Ἀλλ ̓ ὅστις ἦν ὁ μῦθος αὖθις εἴπατε·"^^xsd:string .

# --- 1191 ---
:Line_1191 a :Line ;
    :lineNumber 1191 ;
    :canonicalReference "1191" ;
    :text "κακῶν γὰρ οὐκ ἄπειρος οὖσ ̓ ἀκούσομαι."^^xsd:string .

# --- 1192 ---
:Line_1192 a :Line ;
    :lineNumber 1192 ;
    :canonicalReference "1192" ;
    :text "ΑΓ. Ἐγώ, φίλη δέσποινα, καὶ παρὼν ἐρῶ,"^^xsd:string .

# --- 1193 ---
:Line_1193 a :Line ;
    :lineNumber 1193 ;
    :canonicalReference "1193" ;
    :text "κοὐδὲν παρήσω τῆς ἀληθείας ἔπος·"^^xsd:string .

# --- 1194 ---
:Line_1194 a :Line ;
    :lineNumber 1194 ;
    :canonicalReference "1194" ;
    :text "τί γάρ σε μαλθάσσοιμ ̓ ἂν ὧν ἐς ὕστερον"^^xsd:string .

# --- 1195 ---
:Line_1195 a :Line ;
    :lineNumber 1195 ;
    :canonicalReference "1195" ;
    :text "ψεῦσται φανούμεθ ̓; ὀρθὸν ἁλήθει ̓ ἀεί."^^xsd:string ;
    :hasTheme :Theme_UnerringTruth .

# --- 1196 ---
:Line_1196 a :Line ;
    :lineNumber 1196 ;
    :canonicalReference "1196" ;
    :text "Ἐγὼ δὲ σῷ ποδαγὸς ἑσπόμην πόσει"^^xsd:string .

# --- 1197 ---
:Line_1197 a :Line ;
    :lineNumber 1197 ;
    :canonicalReference "1197" ;
    :text "πεδίον ἐπ ̓ ἄκρον, ἔνθ ̓ ἔκειτο νηλεὲς"^^xsd:string .

# --- 1198 ---
:Line_1198 a :Line ;
    :lineNumber 1198 ;
    :canonicalReference "1198" ;
    :text "κυνοσπάρακτον σῶμα Πολυνείκους ἔτι·"^^xsd:string ;
    :hasTheme :Theme_PiousBurial .

# --- 1199 ---
:Line_1199 a :Line ;
    :lineNumber 1199 ;
    :canonicalReference "1199" ;
    :text "καὶ τὸν μέν, αἰτήσαντες ἐνοδίαν θεὸν"^^xsd:string .

# --- 1200 ---
:Line_1200 a :Line ;
    :lineNumber 1200 ;
    :canonicalReference "1200" ;
    :text "Πλούτωνά τ ̓ ὀργὰς εὐμενεῖς κατασχεθεῖν,"^^xsd:string .

# --- 1201 ---
:Line_1201 a :Line ;
    :lineNumber 1201 ;
    :canonicalReference "1201" ;
    :text "λούσαντες ἁγνὸν λουτρόν, ἐν νεοσπάσιν"^^xsd:string .

# --- 1202 ---
:Line_1202 a :Line ;
    :lineNumber 1202 ;
    :canonicalReference "1202" ;
    :text "θαλλοῖς ὃ δὴ λέλειπτο συγκατῄθομεν,"^^xsd:string .

# --- 1203 ---
:Line_1203 a :Line ;
    :lineNumber 1203 ;
    :canonicalReference "1203" ;
    :text "καὶ τύμβον ὀρθόκρανον οἰκείας χθονὸς"^^xsd:string .

# --- 1204 ---
:Line_1204 a :Line ;
    :lineNumber 1204 ;
    :canonicalReference "1204" ;
    :text "χώσαντες αὖθις πρὸς λιθόστρωτον κόρης"^^xsd:string .

# --- 1205 ---
:Line_1205 a :Line ;
    :lineNumber 1205 ;
    :canonicalReference "1205" ;
    :text "νυμφεῖον Ἅιδου κοῖλον εἰσεβαίνομεν."^^xsd:string ;
    :hasTheme :Theme_MarriageToDeath .

# --- 1206 ---
:Line_1206 a :Line ;
    :lineNumber 1206 ;
    :canonicalReference "1206" ;
    :text "Φωνῆς δ ̓ ἄπωθεν ὀρθίων κωκυμάτων"^^xsd:string .

# --- 1207 ---
:Line_1207 a :Line ;
    :lineNumber 1207 ;
    :canonicalReference "1207" ;
    :text "κλύει τις ἀκτέριστον ἀμφὶ παστάδα,"^^xsd:string .

# --- 1208 ---
:Line_1208 a :Line ;
    :lineNumber 1208 ;
    :canonicalReference "1208" ;
    :text "καὶ δεσπότῃ Κρέοντι σημαίνει μολών·"^^xsd:string .

# --- 1209 ---
:Line_1209 a :Line ;
    :lineNumber 1209 ;
    :canonicalReference "1209" ;
    :text "τῷ δ ̓ ἀθλίας ἄσημα περιβαίνει βοῆς"^^xsd:string .

# --- 1210 ---
:Line_1210 a :Line ;
    :lineNumber 1210 ;
    :canonicalReference "1210" ;
    :text "ἕρποντι μᾶλλον ἆσσον, οἰμώξας δ ̓ ἔπος"^^xsd:string .

# --- 1211 ---
:Line_1211 a :Line ;
    :lineNumber 1211 ;
    :canonicalReference "1211" ;
    :text "ἵησι δυσθρήνητον· Ὢ τάλας ἐγώ,"^^xsd:string .

# --- 1212 ---
:Line_1212 a :Line ;
    :lineNumber 1212 ;
    :canonicalReference "1212" ;
    :text "ἆρ ̓ εἰμὶ μάντις; ἆρα δυστυχεστάτην"^^xsd:string .

# --- 1213 ---
:Line_1213 a :Line ;
    :lineNumber 1213 ;
    :canonicalReference "1213" ;
    :text "κέλευθον ἕρπω τῶν παρελθουσῶν ὁδῶν;"^^xsd:string .

# --- 1214 ---
:Line_1214 a :Line ;
    :lineNumber 1214 ;
    :canonicalReference "1214" ;
    :text "παιδός με σαίνει φθόγγος. Ἀλλά, πρόσπολοι,"^^xsd:string .

# --- 1215 ---
:Line_1215 a :Line ;
    :lineNumber 1215 ;
    :canonicalReference "1215" ;
    :text "ἴτ ̓ ἆσσον ὠκεῖς, καὶ παραστάντες τάφῳ"^^xsd:string .

# --- 1216 ---
:Line_1216 a :Line ;
    :lineNumber 1216 ;
    :canonicalReference "1216" ;
    :text "ἀθρήσαθ ̓, ἁρμὸν χώματος λιθοσπαδῆ"^^xsd:string .

# --- 1217 ---
:Line_1217 a :Line ;
    :lineNumber 1217 ;
    :canonicalReference "1217" ;
    :text "δύντες πρὸς αὐτὸ στόμιον, εἰ τὸν Αἵμονος"^^xsd:string .

# --- 1218 ---
:Line_1218 a :Line ;
    :lineNumber 1218 ;
    :canonicalReference "1218" ;
    :text "φθόγγον συνίημ ̓, ἢ θεοῖσι κλέπτομαι."^^xsd:string .

# --- 1219 ---
:Line_1219 a :Line ;
    :lineNumber 1219 ;
    :canonicalReference "1219" ;
    :text "Τάδ ̓ ἐξ ἀθύμου δεσπότου κελευσμάτων"^^xsd:string .

# --- 1220 ---
:Line_1220 a :Line ;
    :lineNumber 1220 ;
    :canonicalReference "1220" ;
    :text "ἠθροῦμεν· ἐν δὲ λοισθίῳ τυμβεύματι"^^xsd:string .

# --- 1221 ---
:Line_1221 a :Line ;
    :lineNumber 1221 ;
    :canonicalReference "1221" ;
    :text "τὴν μὲν κρεμαστὴν αὐχένος κατείδομεν,"^^xsd:string .

# --- 1222 ---
:Line_1222 a :Line ;
    :lineNumber 1222 ;
    :canonicalReference "1222" ;
    :text "βρόχῳ μιτώδει σινδόνος καθημμένην,"^^xsd:string .

# --- 1223 ---
:Line_1223 a :Line ;
    :lineNumber 1223 ;
    :canonicalReference "1223" ;
    :text "τὸν δ ̓ ἀμφὶ μέσσῃ περιπετῆ προσκείμενον,"^^xsd:string .

# --- 1224 ---
:Line_1224 a :Line ;
    :lineNumber 1224 ;
    :canonicalReference "1224" ;
    :text "εὐνῆς ἀποιμώζοντα τῆς κάτω φθορὰν"^^xsd:string .

# --- 1225 ---
:Line_1225 a :Line ;
    :lineNumber 1225 ;
    :canonicalReference "1225" ;
    :text "καὶ πατρὸς ἔργα καὶ τὸ δύστηνον λέχος."^^xsd:string .

# --- 1226 ---
:Line_1226 a :Line ;
    :lineNumber 1226 ;
    :canonicalReference "1226" ;
    :text "Ὁ δ ̓ ὡς ὁρᾷ σφε, στυγνὸν οἰμώξας ἔσω"^^xsd:string .

# --- 1227 ---
:Line_1227 a :Line ;
    :lineNumber 1227 ;
    :canonicalReference "1227" ;
    :text "χωρεῖ πρὸς αὐτὸν κἀνακωκύσας καλεῖ·"^^xsd:string .

# --- 1228 ---
:Line_1228 a :Line ;
    :lineNumber 1228 ;
    :canonicalReference "1228" ;
    :text "Ὦ τλῆμον, οἷον ἔργον εἴργασαι· τίνα"^^xsd:string .

# --- 1229 ---
:Line_1229 a :Line ;
    :lineNumber 1229 ;
    :canonicalReference "1229" ;
    :text "νοῦν ἔσχες; ἐν τῷ συμφορᾶς διεφθάρης;"^^xsd:string .

# --- 1230 ---
:Line_1230 a :Line ;
    :lineNumber 1230 ;
    :canonicalReference "1230" ;
    :text "Ἔξελθε, τέκνον, ἱκέσιός σε λίσσομαι."^^xsd:string .

# --- 1231 ---
:Line_1231 a :Line ;
    :lineNumber 1231 ;
    :canonicalReference "1231" ;
    :text "Τὸν δ ̓ ἀγρίοις ὄσσοισι παπτήνας ὁ παῖς,"^^xsd:string ;
    :hasConflict :Conflict_HaemonVsCreon_Violence .

# --- 1232 ---
:Line_1232 a :Line ;
    :lineNumber 1232 ;
    :canonicalReference "1232" ;
    :text "πτύσας προσώπῳ κοὐδὲν ἀντειπών, ξίφους"^^xsd:string .

# --- 1233 ---
:Line_1233 a :Line ;
    :lineNumber 1233 ;
    :canonicalReference "1233" ;
    :text "ἕλκει διπλοῦς κνώδοντας, ἐκ δ ̓ ὁρμωμένου"^^xsd:string .

# --- 1234 ---
:Line_1234 a :Line ;
    :lineNumber 1234 ;
    :canonicalReference "1234" ;
    :text "πατρὸς φυγαῖσιν ἤμπλακ ̓· εἶθ ̓ ὁ δύσμορος"^^xsd:string .

# --- 1235 ---
:Line_1235 a :Line ;
    :lineNumber 1235 ;
    :canonicalReference "1235" ;
    :text "αὑτῷ χολωθείς, ὥσπερ εἶχ ̓, ἐπενταθεὶς"^^xsd:string .

# --- 1236 ---
:Line_1236 a :Line ;
    :lineNumber 1236 ;
    :canonicalReference "1236" ;
    :text "ἤρεισε πλευραῖς μέσσον ἔγχος, ἐς δ ̓ ὑγρὸν"^^xsd:string .

# --- 1237 ---
:Line_1237 a :Line ;
    :lineNumber 1237 ;
    :canonicalReference "1237" ;
    :text "ἀγκῶν ̓ ἔτ ̓ ἔμφρων παρθένῳ προσπτύσσεται·"^^xsd:string .

# --- 1238 ---
:Line_1238 a :Line ;
    :lineNumber 1238 ;
    :canonicalReference "1238" ;
    :text "καὶ φυσιῶν ὀξεῖαν ἐκβάλλει ῥοὴν"^^xsd:string .

# --- 1239 ---
:Line_1239 a :Line ;
    :lineNumber 1239 ;
    :canonicalReference "1239" ;
    :text "λευκῇ παρειᾷ φοινίου σταλάγματος."^^xsd:string .

# --- 1240 ---
:Line_1240 a :Line ;
    :lineNumber 1240 ;
    :canonicalReference "1240" ;
    :text "Κεῖται δὲ νεκρὸς περὶ νεκρῷ, τὰ νυμφικὰ"^^xsd:string ;
    :hasTheme :Theme_MarriageToDeath .

# --- 1241 ---
:Line_1241 a :Line ;
    :lineNumber 1241 ;
    :canonicalReference "1241" ;
    :text "τέλη λαχὼν δείλαιος εἰν Ἅιδου δόμοις,"^^xsd:string .

# --- 1242 ---
:Line_1242 a :Line ;
    :lineNumber 1242 ;
    :canonicalReference "1242" ;
    :text "δείξας ἐν ἀνθρώποισι τὴν ἀβουλίαν"^^xsd:string ;
    :hasTheme :Theme_Aboulia .

# --- 1243 ---
:Line_1243 a :Line ;
    :lineNumber 1243 ;
    :canonicalReference "1243" ;
    :text "ὅσῳ μέγιστον ἀνδρὶ πρόσκειται κακόν."^^xsd:string .

# --- 1244 ---
:Line_1244 a :Line ;
    :lineNumber 1244 ;
    :canonicalReference "1244" ;
    :text "ΧΟ. Τί τοῦτ ̓ ἂν εἰκάσειας; ἡ γυνὴ πάλιν"^^xsd:string .

# --- 1245 ---
:Line_1245 a :Line ;
    :lineNumber 1245 ;
    :canonicalReference "1245" ;
    :text "φρούδη, πρὶν εἰπεῖν ἐσθλὸν ἢ κακὸν λόγον."^^xsd:string .

# --- 1246 ---
:Line_1246 a :Line ;
    :lineNumber 1246 ;
    :canonicalReference "1246" ;
    :text "ΑΓ. Καὐτὸς τεθάμβηκ ̓· ἐλπίσιν δὲ βόσκομαι"^^xsd:string .

# --- 1247 ---
:Line_1247 a :Line ;
    :lineNumber 1247 ;
    :canonicalReference "1247" ;
    :text "ἄχη τέκνου κλύουσαν ἐς πόλιν γόου"^^xsd:string .

# --- 1248 ---
:Line_1248 a :Line ;
    :lineNumber 1248 ;
    :canonicalReference "1248" ;
    :text "οὐκ ἀξιώσειν, ἀλλ ̓ ὑπὸ στέγης ἔσω"^^xsd:string .

# --- 1249 ---
:Line_1249 a :Line ;
    :lineNumber 1249 ;
    :canonicalReference "1249" ;
    :text "δμωαῖς προθήσειν πένθος οἰκεῖον στένειν."^^xsd:string .

# --- 1250 ---
:Line_1250 a :Line ;
    :lineNumber 1250 ;
    :canonicalReference "1250" ;
    :text "Γνώμης γὰρ οὐκ ἄπειρος, ὥσθ ̓ ἁμαρτάνειν."^^xsd:string .

# --- 1251 ---
:Line_1251 a :Line ;
    :lineNumber 1251 ;
    :canonicalReference "1251" ;
    :text "ΧΟ. Οὐκ οἶδ ̓· ἐμοὶ δ ̓ οὖν ἥ τ ̓ ἄγαν σιγὴ βαρὺ"^^xsd:string .

# --- 1252 ---
:Line_1252 a :Line ;
    :lineNumber 1252 ;
    :canonicalReference "1252" ;
    :text "δοκεῖ προσεῖναι χἠ μάτην πολλὴ βοή."^^xsd:string .

# --- 1253 ---
:Line_1253 a :Line ;
    :lineNumber 1253 ;
    :canonicalReference "1253" ;
    :text "ΑΓ. Ἀλλ ̓ εἰσόμεσθα μή τι καὶ κατάσχετον"^^xsd:string .

# --- 1254 ---
:Line_1254 a :Line ;
    :lineNumber 1254 ;
    :canonicalReference "1254" ;
    :text "κρυφῇ καλύπτει καρδίᾳ θυμουμένῃ,"^^xsd:string .

# --- 1255 ---
:Line_1255 a :Line ;
    :lineNumber 1255 ;
    :canonicalReference "1255" ;
    :text "δόμους παραστείχοντες· εὖ γὰρ οὖν λέγεις·"^^xsd:string .

# --- 1256 ---
:Line_1256 a :Line ;
    :lineNumber 1256 ;
    :canonicalReference "1256" ;
    :text "καὶ τῆς ἄγαν γάρ ἐστί που σιγῆς βάρος."^^xsd:string .

# --- 1257 ---
:Line_1257 a :Line ;
    :lineNumber 1257 ;
    :canonicalReference "1257" ;
    :text "ΧΟ. Καὶ μὴν ὅδ ̓ ἄναξ αὐτὸς ἐφήκει"^^xsd:string .

# --- 1258 ---
:Line_1258 a :Line ;
    :lineNumber 1258 ;
    :canonicalReference "1258" ;
    :text "μνῆμ ̓ ἐπίσημον διὰ χειρὸς ἔχων,"^^xsd:string .

# --- 1259 ---
:Line_1259 a :Line ;
    :lineNumber 1259 ;
    :canonicalReference "1259" ;
    :text "εἰ θέμις εἰπεῖν, οὐκ ἀλλοτρίαν"^^xsd:string .

# --- 1260 ---
:Line_1260 a :Line ;
    :lineNumber 1260 ;
    :canonicalReference "1260" ;
    :text "ἄτην, ἀλλ ̓ αὐτὸς ἁμαρτών."^^xsd:string .

# --- 1261 ---
:Line_1261 a :Line ;
    :lineNumber 1261 ;
    :canonicalReference "1261" ;
    :text "ΚΡ. Ἰὼ φρενῶν δυσφρόνων ἁμαρτήματα"^^xsd:string ;
    :hasTheme :Theme_Misjudgment .

# --- 1262 ---
:Line_1262 a :Line ;
    :lineNumber 1262 ;
    :canonicalReference "1262" ;
    :text "στερεὰ θανατόεντ ̓,"^^xsd:string .

# --- 1263 ---
:Line_1263 a :Line ;
    :lineNumber 1263 ;
    :canonicalReference "1263" ;
    :text "ὦ κτανόντας τε καὶ"^^xsd:string .

# --- 1264 ---
:Line_1264 a :Line ;
    :lineNumber 1264 ;
    :canonicalReference "1264" ;
    :text "θανόντας βλέποντες ἐμφυλίους."^^xsd:string .

# --- 1265 ---
:Line_1265 a :Line ;
    :lineNumber 1265 ;
    :canonicalReference "1265" ;
    :text "Ὤμοι ἐμῶν ἄνολβα βουλευμάτων."^^xsd:string .

# --- 1266 ---
:Line_1266 a :Line ;
    :lineNumber 1266 ;
    :canonicalReference "1266" ;
    :text "Ἰὼ παῖ, νέος νέῳ ξὺν μόρῳ,"^^xsd:string .

# --- 1267 ---
:Line_1267 a :Line ;
    :lineNumber 1267 ;
    :canonicalReference "1267" ;
    :text "αἰαῖ αἰαῖ,"^^xsd:string .

# --- 1268 ---
:Line_1268 a :Line ;
    :lineNumber 1268 ;
    :canonicalReference "1268" ;
    :text "ἔθανες, ἀπελύθης,"^^xsd:string .

# --- 1269 ---
:Line_1269 a :Line ;
    :lineNumber 1269 ;
    :canonicalReference "1269" ;
    :text "ἐμαῖς οὐδὲ σαῖσι δυσβουλίαις."^^xsd:string .

# --- 1270 ---
:Line_1270 a :Line ;
    :lineNumber 1270 ;
    :canonicalReference "1270" ;
    :text "ΧΟ. Οἴμ ̓ ὡς ἔοικας ὀψὲ τὴν δίκην ἰδεῖν."^^xsd:string ;
    :hasTheme :Theme_LateJustice .

# --- 1271 ---
:Line_1271 a :Line ;
    :lineNumber 1271 ;
    :canonicalReference "1271" ;
    :text "ΚΡ. Οἴμοι,"^^xsd:string .

# --- 1272 ---
:Line_1272 a :Line ;
    :lineNumber 1272 ;
    :canonicalReference "1272" ;
    :text "ἔχω μαθὼν δείλαιος· ἐν δ ̓ ἐμῷ κάρᾳ"^^xsd:string .

# --- 1273 ---
:Line_1273 a :Line ;
    :lineNumber 1273 ;
    :canonicalReference "1273" ;
    :text "θεὸς τότ ̓ ἄρα τότε μέγα βάρος μ ̓ ἔχων"^^xsd:string ;
    :hasTheme :Theme_DivineRetribution .

# --- 1274 ---
:Line_1274 a :Line ;
    :lineNumber 1274 ;
    :canonicalReference "1274" ;
    :text "ἔπαισεν, ἐν δ ̓ ἔσεισεν ἀγρίαις ὁδοῖς,"^^xsd:string .

# --- 1275 ---
:Line_1275 a :Line ;
    :lineNumber 1275 ;
    :canonicalReference "1275" ;
    :text "οἴμοι, λακπάτητον ἀντρέπων χαράν."^^xsd:string .

# --- 1276 ---
:Line_1276 a :Line ;
    :lineNumber 1276 ;
    :canonicalReference "1276" ;
    :text "Φεῦ φεῦ, ἰὼ πόνοι βροτῶν δύσπονοι."^^xsd:string .



# --- 1278 ---
:Line_1278 a :Line ;
    :lineNumber 1278 ;
    :canonicalReference "1278" ;
    :text "Ὦ δέσποθ ̓, ὡς ἔχων τε καὶ κεκτημένος,"^^xsd:string .

# --- 1279 ---
:Line_1279 a :Line ;
    :lineNumber 1279 ;
    :canonicalReference "1279" ;
    :text "τὰ μὲν πρὸ χειρῶν τάδε φέρειν, τὰ δ ̓ ἐν δόμοις"^^xsd:string .

# --- 1280 ---
:Line_1280 a :Line ;
    :lineNumber 1280 ;
    :canonicalReference "1280" ;
    :text "ἔοικας ἥκων καὶ τάχ ̓ ὄψεσθαι κακά."^^xsd:string .

# --- 1281 ---
:Line_1281 a :Line ;
    :lineNumber 1281 ;
    :canonicalReference "1281" ;
    :text "Τί δ; ἔστιν αὖ κάκιον ἐκ κακῶν ἔτι;"^^xsd:string .

# --- 1282 ---
:Line_1282 a :Line ;
    :lineNumber 1282 ;
    :canonicalReference "1282" ;
    :text "ΕΞ. Γυνὴ τέθνηκεν, τοῦδε παμμήτωρ νεκρού,"^^xsd:string .

# --- 1283 ---
:Line_1283 a :Line ;
    :lineNumber 1283 ;
    :canonicalReference "1283" ;
    :text "δύστηνος, ἄρτι νεοτόμοισι πλήγμασιν."^^xsd:string .

# --- 1284 ---
:Line_1284 a :Line ;
    :lineNumber 1284 ;
    :canonicalReference "1284" ;
    :text "ΚΡ. Ἰὼ, ἰὼ δυσκάθαρτος Ἅιδου λιμήν,"^^xsd:string ;
    :hasTheme :Theme_HadesHarbor .

# --- 1285 ---
:Line_1285 a :Line ;
    :lineNumber 1285 ;
    :canonicalReference "1285" ;
    :text "τί μ ̓ ἄρα τί μ ̓ ὀλέκεις;"^^xsd:string .

# --- 1286 ---
:Line_1286 a :Line ;
    :lineNumber 1286 ;
    :canonicalReference "1286" ;
    :text "Ὦ κακάγγελτά μοι"^^xsd:string .

# --- 1287 ---
:Line_1287 a :Line ;
    :lineNumber 1287 ;
    :canonicalReference "1287" ;
    :text "προπέμψας ἄχη, τίνα θροεῖς λόγον;"^^xsd:string .

# --- 1288 ---
:Line_1288 a :Line ;
    :lineNumber 1288 ;
    :canonicalReference "1288" ;
    :text "Αἰαῖ, ὀλωλότ ̓ ἄνδρ ̓ ἐπεξειργάσω."^^xsd:string .

# --- 1289 ---
:Line_1289 a :Line ;
    :lineNumber 1289 ;
    :canonicalReference "1289" ;
    :text "Τί φῄς, ὦ παῖ; τίνα λέγεις μοι νέον,"^^xsd:string .

# --- 1290 ---
:Line_1290 a :Line ;
    :lineNumber 1290 ;
    :canonicalReference "1290" ;
    :text "αἰαῖ, αἰαῖ,"^^xsd:string .

# --- 1291 ---
:Line_1291 a :Line ;
    :lineNumber 1291 ;
    :canonicalReference "1291" ;
    :text "σφάγιον ἐπ ̓ ὀλέθρῳ,"^^xsd:string .

# --- 1292 ---
:Line_1292 a :Line ;
    :lineNumber 1292 ;
    :canonicalReference "1292" ;
    :text "γυναικεῖον ἀμφικεῖσθαι μόρον;"^^xsd:string .

# --- 1293 ---
:Line_1293 a :Line ;
    :lineNumber 1293 ;
    :canonicalReference "1293" ;
    :text "ΧΟ. Ὁρᾶν πάρεστιν· οὐ γὰρ ἐν μυχοῖς ἔτι."^^xsd:string .

# --- 1294 ---
:Line_1294 a :Line ;
    :lineNumber 1294 ;
    :canonicalReference "1294" ;
    :text "ΚΡ. Οἴμοι,"^^xsd:string .

# --- 1295 ---
:Line_1295 a :Line ;
    :lineNumber 1295 ;
    :canonicalReference "1295" ;
    :text "κακὸν τόδ ̓ ἄλλο δεύτερον βλέπω τάλας"^^xsd:string .

# --- 1296 ---
:Line_1296 a :Line ;
    :lineNumber 1296 ;
    :canonicalReference "1296" ;
    :text "Τίς ἄρα, τίς με πότμος ἔτι περιμένει;"^^xsd:string .

# --- 1297 ---
:Line_1297 a :Line ;
    :lineNumber 1297 ;
    :canonicalReference "1297" ;
    :text "Ἔχω μὲν ἐν χείρεσσιν ἀρτίως τέκνον,"^^xsd:string .

# --- 1298 ---
:Line_1298 a :Line ;
    :lineNumber 1298 ;
    :canonicalReference "1298" ;
    :text "τάλας, τὸν δ ̓ ἔναντα προσβλέπω νεκρόν."^^xsd:string ;
    :hasTheme :Theme_DoubleWoe .

# 1299 does nto exist in the text.

# --- 1300 ---
:Line_1300 a :Line ;
    :lineNumber 1300 ;
    :canonicalReference "1300" ;
    :text "Φεῦ φεῦ μᾶτερ ἀθλία, φεῦ τέκνον."^^xsd:string .

# --- 1301 ---
:Line_1301 a :Line ;
    :lineNumber 1301 ;
    :canonicalReference "1301" ;
    :text "Ἡ δ ̓ ὀξύπληκτος ἡμένη βωμία"^^xsd:string .

# --- 1302 ---
:Line_1302 a :Line ;
    :lineNumber 1302 ;
    :canonicalReference "1302" ;
    :text "λύει κελαινὰ βλέφαρα, κωκύσασα μὲν"^^xsd:string .

# --- 1303 ---
:Line_1303 a :Line ;
    :lineNumber 1303 ;
    :canonicalReference "1303" ;
    :text "τοῦ πρὶν θανόντος Μεγαρέως κενὸν λέχος,"^^xsd:string .

# --- 1304 ---
:Line_1304 a :Line ;
    :lineNumber 1304 ;
    :canonicalReference "1304" ;
    :text "αὖθις δὲ τοῦδε, λοίσθιον δὲ σοὶ κακὰς"^^xsd:string .

# --- 1305 ---
:Line_1305 a :Line ;
    :lineNumber 1305 ;
    :canonicalReference "1305" ;
    :text "πράξεις ἐφυμνήσασα τῷ παιδοκτόνῳ."^^xsd:string ;
    :hasTheme :Theme_ChildSlayer .

# --- 1306 ---
:Line_1306 a :Line ;
    :lineNumber 1306 ;
    :canonicalReference "1306" ;
    :text "ΚΡ. Αἰαῖ αἰαῖ, "^^xsd:string .

# --- 1307 ---
:Line_1307 a :Line ;
    :lineNumber 1307 ;
    :canonicalReference "1307" ;
    :text "ἀνέπταν φόβῳ. Τί μ ̓ οὐκ ἀνταίαν"^^xsd:string .

# --- 1308 ---
:Line_1308 a :Line ;
    :lineNumber 1308 ;
    :canonicalReference "1308" ;
    :text "ἔπαισέν τις ἀμφιθήκτῳ ξίφει;"^^xsd:string .

# --- 1310 ---
:Line_1310 a :Line ;
    :lineNumber 1310 ;
    :canonicalReference "1310" ;
    :text "δείλαιος ἐγώ, αἰαῖ,"^^xsd:string .

# --- 1311 ---
:Line_1311 a :Line ;
    :lineNumber 1311 ;
    :canonicalReference "1311" ;
    :text "δειλαίᾳ δὲ συγκέκραμαι δύᾳ."^^xsd:string .

# --- 1312 ---
:Line_1312 a :Line ;
    :lineNumber 1312 ;
    :canonicalReference "1312" ;
    :text "ΕΞ. Ὡς αἰτίαν γε τῶνδε κἀκείνων ἔχων"^^xsd:string .

# --- 1313 ---
:Line_1313 a :Line ;
    :lineNumber 1313 ;
    :canonicalReference "1313" ;
    :text "πρὸς τῆς θανούσης τῆσδ ̓ ἐπεσκήπτου μόρων."^^xsd:string .

# --- 1314 ---
:Line_1314 a :Line ;
    :lineNumber 1314 ;
    :canonicalReference "1314" ;
    :text "ΚΡ. Ποίῳ δὲ κἀπελύετ ̓ ἐν φοναῖς τρόπῳ;"^^xsd:string .

# --- 1315 ---
:Line_1315 a :Line ;
    :lineNumber 1315 ;
    :canonicalReference "1315" ;
    :text "ΕΞ. Παίσασ ̓ ὑφ ἧπαρ αὐτόχειρ αὑτήν, ὅπως"^^xsd:string .

# --- 1316 ---
:Line_1316 a :Line ;
    :lineNumber 1316 ;
    :canonicalReference "1316" ;
    :text "παιδὸς τόδ ̓ ᾔσθετ ̓ ὀξυκώκυτον πάθος."^^xsd:string .

# --- 1317 ---
:Line_1317 a :Line ;
    :lineNumber 1317 ;
    :canonicalReference "1317" ;
    :text "ᾶμοι μοι, τάδ ̓ οὐκ ἐπ ̓ ἄλλον βροτῶν"^^xsd:string .

# --- 1318 ---
:Line_1318 a :Line ;
    :lineNumber 1318 ;
    :canonicalReference "1318" ;
    :text "ἐμᾶς ἁρμόσει ποτ ̓ ἐξ αἰτίας."^^xsd:string .

# --- 1319 ---
:Line_1319 a :Line ;
    :lineNumber 1319 ;
    :canonicalReference "1319" ;
    :text "Ἐγὼ γάρ σ ̓ ἐγώ σ ̓ ἔκανον, ὢ μέλεος,"^^xsd:string ;
    :hasTheme :Theme_FullConfession .

# --- 1320 ---
:Line_1320 a :Line ;
    :lineNumber 1320 ;
    :canonicalReference "1320" ;
    :text "ἐγώ, φάμ ̓ ἔτυμον. Ἰὼ πρόσπολοι,"^^xsd:string .

# --- 1321 ---
:Line_1321 a :Line ;
    :lineNumber 1321 ;
    :canonicalReference "1321" ;
    :text "ἀπάγετέ μ ̓ ὅτι τάχος, ἄγετέ μ ̓ ἐκποδών,"^^xsd:string .

# 1322, 1323, 1324 do not exist in the text.

# --- 1325 ---
:Line_1325 a :Line ;
    :lineNumber 1325 ;
    :canonicalReference "1325" ;
    :text "τὸν οὐκ ὄντα μᾶλλον ἢ μηδένα. "^^xsd:string .

# --- 1326 ---
:Line_1326 a :Line ;
    :lineNumber 1326 ;
    :canonicalReference "1326" ;
    :text "ΧΟ. Κέρδη παραινεῖς, εἴ τι κέρδος ἐν κακοῖς· "^^xsd:string .

# --- 1327 ---
:Line_1327 a :Line ;
    :lineNumber 1327 ;
    :canonicalReference "1327" ;
    :text "βράχιστα γὰρ κράτιστα τἀν ποσὶν κακά. "^^xsd:string .

# --- 1328 ---
:Line_1328 a :Line ;
    :lineNumber 1328 ;
    :canonicalReference "1328" ;
    :text "ΚΡ. Ἴτω ἴτω, "^^xsd:string .

# --- 1329 ---
:Line_1329 a :Line ;
    :lineNumber 1329 ;
    :canonicalReference "1329" ;
    :text "φανήτω μόρων ὁ κάλλιστ ̓ ἐμῶν "^^xsd:string .

# --- 1330 ---
:Line_1330 a :Line ;
    :lineNumber 1330 ;
    :canonicalReference "1330" ;
    :text "ἐμοὶ τερμίαν ἄγων ἁμέραν "^^xsd:string .

# --- 1331 ---
:Line_1331 a :Line ;
    :lineNumber 1331 ;
    :canonicalReference "1331" ;
    :text "ὕπατος· ἴτω, ἴτω, "^^xsd:string .

# --- 1332 ---
:Line_1332 a :Line ;
    :lineNumber 1332 ;
    :canonicalReference "1332" ;
    :text "ὅπως μηκέτ ἆμαρ ἄλλ ̓ εἰσίδω. "^^xsd:string .


# --- 1334 ---
:Line_1334 a :Line ;
    :lineNumber 1334 ;
    :canonicalReference "1334" ;
    :text "ΧΟ. Μέλλοντα ταῦτα. Τῶν προκειμένων τι χρὴ"^^xsd:string .

# --- 1335 ---
:Line_1335 a :Line ;
    :lineNumber 1335 ;
    :canonicalReference "1335" ;
    :text "πράσσειν· μέλει γὰρ τῶνδ ̓ ὅτοισι χρὴ μέλειν."^^xsd:string .

# --- 1336 ---
:Line_1336 a :Line ;
    :lineNumber 1336 ;
    :canonicalReference "1336" ;
    :text "ΚΡ. Ἀλλ ̓ ὧν ἐρῶμεν ταῦτα συγκατηυξάμην."^^xsd:string .

# --- 1337 ---
:Line_1337 a :Line ;
    :lineNumber 1337 ;
    :canonicalReference "1337" ;
    :text "ΧΟ. Μή νυν προσεύχου μηδέν· ὡς πεπρωμένης"^^xsd:string ;
    :hasTheme :Theme_InevitabilityOfFate .

# --- 1338 ---
:Line_1338 a :Line ;
    :lineNumber 1338 ;
    :canonicalReference "1338" ;
    :text "οὐκ ἔστι θνητοῖς συμφορᾶς ἀπαλλαγή."^^xsd:string .

# --- 1339 ---
:Line_1339 a :Line ;
    :lineNumber 1339 ;
    :canonicalReference "1339" ;
    :text "ΚΡ. Ἄγοιτ ἂν μάταιον ἄνδρ ̓ ἐκποδών,"^^xsd:string .

# --- 1340 ---
:Line_1340 a :Line ;
    :lineNumber 1340 ;
    :canonicalReference "1340" ;
    :text "ὅς, ὦ παῖ, σέ τ ̓ οὐχ ἑκὼν κατέκανον"^^xsd:string .

# --- 1341 ---
:Line_1341 a :Line ;
    :lineNumber 1341 ;
    :canonicalReference "1341" ;
    :text "σέ τ ̓ αὖ τάνδ ̓, ὤμοι μέλεος, οὐδ ̓ ἔχω"^^xsd:string .

# --- 1342 ---
:Line_1342 a :Line ;
    :lineNumber 1342 ;
    :canonicalReference "1342" ;
    :text "πρὸς πότερον ἴδω, πᾷ κλιθῶ· πάντα γὰρ"^^xsd:string .

# 1343, 1344 do not exist in the text.

# --- 1345 ---
:Line_1345 a :Line ;
    :lineNumber 1345 ;
    :canonicalReference "1345" ;
    :text "λέχρια τἀν χεροῖν, τὰ δ ̓ ἐπὶ κρατί μοι"^^xsd:string .

# --- 1346 ---
:Line_1346 a :Line ;
    :lineNumber 1346 ;
    :canonicalReference "1346" ;
    :text "πότμος δυσκόμιστος εἰσήλατο."^^xsd:string .

# --- 1347 ---
:Line_1347 a :Line ;
    :lineNumber 1347 ;
    :canonicalReference "1347" ;
    :text "ΧΟ. Πολλῷ τὸ φρονεῖν εὐδαιμονίας"^^xsd:string ;
    :hasTheme :Theme_WisdomThroughSuffering .

# --- 1348 ---
:Line_1348 a :Line ;
    :lineNumber 1348 ;
    :canonicalReference "1348" ;
    :text "πρῶτον ὑπάρχει· χρὴ δὲ τά γ ̓ εἰς θεοὺς"^^xsd:string ;
    :hasTheme :Theme_Piety .

# --- 1350 ---
:Line_1350 a :Line ;
    :lineNumber 1350 ;
    :canonicalReference "1350" ;
    :text "μηδὲν ἀσεπτεῖν· μεγάλοι δὲ λόγοι"^^xsd:string .

# --- 1351 ---
:Line_1351 a :Line ;
    :lineNumber 1351 ;
    :canonicalReference "1351" ;
    :text "μεγάλας πληγὰς τῶν ὑπεραύχων"^^xsd:string .

# --- 1352 ---
:Line_1352 a :Line ;
    :lineNumber 1352 ;
    :canonicalReference "1352" ;
    :text "ἀποτείσαντες"^^xsd:string .

# --- 1353 ---
:Line_1353 a :Line ;
    :lineNumber 1353 ;
    :canonicalReference "1353" ;
    :text "γήρᾳ τὸ φρονεῖν ἐδίδαξαν."^^xsd:string .