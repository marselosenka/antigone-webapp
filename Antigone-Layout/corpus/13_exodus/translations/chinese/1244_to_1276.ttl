@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:exodus-translations-1244-1276-chinese a owl:Ontology .

:TV_Line_1244_zh a :TranslationVariant ; :relatedTo :Line_1244 ;
  :text "你怎么看？那女人又回去了，"^^xsd:string .
:TV_Line_1245_zh a :TranslationVariant ; :relatedTo :Line_1245 ;
  :text "一句话也没说，无论好坏。"^^xsd:string .
:TV_Line_1246_zh a :TranslationVariant ; :relatedTo :Line_1246 ;
  :text "我也疑惑；但我仍盼望"^^xsd:string .
:TV_Line_1247_zh a :TranslationVariant ; :relatedTo :Line_1247 ;
  :text "她听到儿子的噩耗传入城中后，"^^xsd:string .
:TV_Line_1248_zh a :TranslationVariant ; :relatedTo :Line_1248 ;
  :text "不会认为该在众人前哀号，"^^xsd:string .
:TV_Line_1249_zh a :TranslationVariant ; :relatedTo :Line_1249 ;
  :text "而会在屋里让侍女为家族之丧而哭。"^^xsd:string .
:TV_Line_1250_zh a :TranslationVariant ; :relatedTo :Line_1250 ;
  :text "因为她并不缺乏分寸，不至于失态。"^^xsd:string .
:TV_Line_1251_zh a :TranslationVariant ; :relatedTo :Line_1251 ;
  :text "我却不知道；在我看来，过度沉默"^^xsd:string .
:TV_Line_1252_zh a :TranslationVariant ; :relatedTo :Line_1252 ;
  :text "并不比过度号哭更少凶兆。"^^xsd:string .
:TV_Line_1253_zh a :TranslationVariant ; :relatedTo :Line_1253 ;
  :text "那我们就会知道，她是否把某种难驯之念"^^xsd:string .
:TV_Line_1254_zh a :TranslationVariant ; :relatedTo :Line_1254 ;
  :text "压在隐秘心里，带怒而忍；"^^xsd:string .
:TV_Line_1255_zh a :TranslationVariant ; :relatedTo :Line_1255 ;
  :text "我们去屋里就明白。你说得确实对："^^xsd:string .
:TV_Line_1256_zh a :TranslationVariant ; :relatedTo :Line_1256 ;
  :text "过度沉默也有危险。"^^xsd:string .
:TV_Line_1257_zh a :TranslationVariant ; :relatedTo :Line_1257 ;
  :text "看，王自己来了，"^^xsd:string .
:TV_Line_1258_zh a :TranslationVariant ; :relatedTo :Line_1258 ;
  :text "手里拿着清楚可见的记号，"^^xsd:string .
:TV_Line_1259_zh a :TranslationVariant ; :relatedTo :Line_1259 ;
  :text "若可直说，这灾祸并非外人所加，"^^xsd:string .
:TV_Line_1260_zh a :TranslationVariant ; :relatedTo :Line_1260 ;
  :text "而是出自他自己的错失。"^^xsd:string .
:TV_Line_1261_zh a :TranslationVariant ; :relatedTo :Line_1261 ;
  :text "啊，偏执心思的过错，"^^xsd:string .
:TV_Line_1262_zh a :TranslationVariant ; :relatedTo :Line_1262 ;
  :text "残酷而致命，"^^xsd:string .
:TV_Line_1263_zh a :TranslationVariant ; :relatedTo :Line_1263 ;
  :text "在同一血脉里看见"^^xsd:string .
:TV_Line_1264_zh a :TranslationVariant ; :relatedTo :Line_1264 ;
  :text "杀人的与被杀的！"^^xsd:string .
:TV_Line_1265_zh a :TranslationVariant ; :relatedTo :Line_1265 ;
  :text "唉，我那些不幸的决断啊。"^^xsd:string .
:TV_Line_1266_zh a :TranslationVariant ; :relatedTo :Line_1266 ;
  :text "我的孩子，你新死于新祸之中，"^^xsd:string .
:TV_Line_1267_zh a :TranslationVariant ; :relatedTo :Line_1267 ;
  :text "哀哉，哀哉，"^^xsd:string .
:TV_Line_1268_zh a :TranslationVariant ; :relatedTo :Line_1268 ;
  :text "你死了，你失去了，"^^xsd:string .
:TV_Line_1269_zh a :TranslationVariant ; :relatedTo :Line_1269 ;
  :text "不是因你的愚妄，而是因我的愚妄。"^^xsd:string .
:TV_Line_1270_zh a :TranslationVariant ; :relatedTo :Line_1270 ;
  :text "唉，你似乎太迟才看见正道。"^^xsd:string .
:TV_Line_1271_zh a :TranslationVariant ; :relatedTo :Line_1271 ;
  :text "哀哉！"^^xsd:string .
:TV_Line_1272_zh a :TranslationVariant ; :relatedTo :Line_1272 ;
  :text "我知道了，苦命的我；就在那时，"^^xsd:string .
:TV_Line_1273_zh a :TranslationVariant ; :relatedTo :Line_1273 ;
  :text "神把沉重压顶的担子放在我头上，"^^xsd:string .
:TV_Line_1274_zh a :TranslationVariant ; :relatedTo :Line_1274 ;
  :text "击打我，把我掀入狂烈歧路，"^^xsd:string .
:TV_Line_1275_zh a :TranslationVariant ; :relatedTo :Line_1275 ;
  :text "唉，把我破碎的欢喜彻底翻覆。"^^xsd:string .
:TV_Line_1276_zh a :TranslationVariant ; :relatedTo :Line_1276 ;
  :text "唉，唉，凡人的重痛真难承受。"^^xsd:string .
