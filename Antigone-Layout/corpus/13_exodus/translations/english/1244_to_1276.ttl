@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:exodus-translations-1244-1276-english a owl:Ontology .
# English translation variants extracted from 1244_to_1276.ttl

:TV_Line_1244_en a :TranslationVariant ; :relatedTo :Line_1244 ; :text "What would you make of this? The woman"^^xsd:string .
:TV_Line_1245_en a :TranslationVariant ; :relatedTo :Line_1245 ; :text "Is gone again, before speaking a word, good or bad."^^xsd:string .

:TV_Line_1246_en a :TranslationVariant ; :relatedTo :Line_1246 ; :text "I too am astonished; yet I nourish the hope"^^xsd:string .
:TV_Line_1247_en a :TranslationVariant ; :relatedTo :Line_1247 ; :text "That, hearing of her son’s grief as he comes into the city,"^^xsd:string .

:TV_Line_1248_en a :TranslationVariant ; :relatedTo :Line_1248 ; :text "She will not think it fitting to lament aloud,"^^xsd:string .
:TV_Line_1249_en a :TranslationVariant ; :relatedTo :Line_1249 ; :text "But inside the house will set her servants to mourn the family sorrow."^^xsd:string .

:TV_Line_1250_en a :TranslationVariant ; :relatedTo :Line_1250 ; :text "For she is not without sense, so as to go astray."^^xsd:string .
:TV_Line_1251_en a :TranslationVariant ; :relatedTo :Line_1251 ; :text "I do not know; but to me excessive silence"^^xsd:string .

:TV_Line_1252_en a :TranslationVariant ; :relatedTo :Line_1252 ; :text "Seems no less ominous than much vain crying aloud."^^xsd:string .
:TV_Line_1253_en a :TranslationVariant ; :relatedTo :Line_1253 ; :text "Then we shall know whether she hides something uncontrollable"^^xsd:string .

:TV_Line_1254_en a :TranslationVariant ; :relatedTo :Line_1254 ; :text "In her secret heart, angry and restraining herself,"^^xsd:string .
:TV_Line_1255_en a :TranslationVariant ; :relatedTo :Line_1255 ; :text "As we pass toward the house; for indeed you speak well:"^^xsd:string .

:TV_Line_1256_en a :TranslationVariant ; :relatedTo :Line_1256 ; :text "There is surely a danger too in excessive silence."^^xsd:string .
:TV_Line_1257_en a :TranslationVariant ; :relatedTo :Line_1257 ; :text "And here indeed the king himself is coming,"^^xsd:string .

:TV_Line_1258_en a :TranslationVariant ; :relatedTo :Line_1258 ; :text "Holding in his hands a plain token of remembrance,"^^xsd:string .
:TV_Line_1259_en a :TranslationVariant ; :relatedTo :Line_1259 ; :text "If it is lawful to say so, a ruin not caused by others’ hands"^^xsd:string .

:TV_Line_1260_en a :TranslationVariant ; :relatedTo :Line_1260 ; :text "But brought on by his own error."^^xsd:string .
:TV_Line_1261_en a :TranslationVariant ; :relatedTo :Line_1261 ; :text "Ah, the errors of a misguided mind,"^^xsd:string .

:TV_Line_1262_en a :TranslationVariant ; :relatedTo :Line_1262 ; :text "Hard and deadly,"^^xsd:string .
:TV_Line_1263_en a :TranslationVariant ; :relatedTo :Line_1263 ; :text "That behold killers and killed"^^xsd:string .

:TV_Line_1264_en a :TranslationVariant ; :relatedTo :Line_1264 ; :text "Among one’s own kin!"^^xsd:string .
:TV_Line_1265_en a :TranslationVariant ; :relatedTo :Line_1265 ; :text "Alas for my ill-starred counsels."^^xsd:string .

:TV_Line_1266_en a :TranslationVariant ; :relatedTo :Line_1266 ; :text "O child, young in a young doom,"^^xsd:string .
:TV_Line_1267_en a :TranslationVariant ; :relatedTo :Line_1267 ; :text "Alas, alas,"^^xsd:string .

:TV_Line_1268_en a :TranslationVariant ; :relatedTo :Line_1268 ; :text "You have died, you are gone,"^^xsd:string .
:TV_Line_1269_en a :TranslationVariant ; :relatedTo :Line_1269 ; :text "Through my folly, not your own."^^xsd:string .

:TV_Line_1270_en a :TranslationVariant ; :relatedTo :Line_1270 ; :text "Alas, it seems you have seen justice too late."^^xsd:string .
:TV_Line_1271_en a :TranslationVariant ; :relatedTo :Line_1271 ; :text "Alas!"^^xsd:string .

:TV_Line_1272_en a :TranslationVariant ; :relatedTo :Line_1272 ; :text "I have learned it, wretched man; then upon my head"^^xsd:string .
:TV_Line_1273_en a :TranslationVariant ; :relatedTo :Line_1273 ; :text "A god laid a great crushing weight,"^^xsd:string .

:TV_Line_1274_en a :TranslationVariant ; :relatedTo :Line_1274 ; :text "And struck me, shaking me onto savage paths,"^^xsd:string .
:TV_Line_1275_en a :TranslationVariant ; :relatedTo :Line_1275 ; :text "Alas, overturning my trampled joy."^^xsd:string .

:TV_Line_1276_en a :TranslationVariant ; :relatedTo :Line_1276 ; :text "Ah, ah, the grievous labors of mortals, hard to bear."^^xsd:string .

################################################################
# MODERN GREEK TRANSLATION VARIANTS (Lines 1244 - 1276)
################################################################

:TV_Line_1244_Gr a :TranslationVariant ; :relatedTo :Line_1244 ; :text "Τι λες γι’ αυτό; Έφυγε η γυναίκα"^^xsd:string .
