@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

################################################################
# ENGLISH TRANSLATION VARIANTS (Lines 1155 - 1182)
################################################################

:TV_Line_1155_en a :TranslationVariant ; :relatedTo :Line_1155 ; :text "Neighbors of the House of Cadmus and Amphion,"^^xsd:string .
:TV_Line_1156_en a :TranslationVariant ; :relatedTo :Line_1156 ; :text "No life’s path is ever so straight that"^^xsd:string .
:TV_Line_1157_en a :TranslationVariant ; :relatedTo :Line_1157 ; :text "I would dare speak well or ill of it."^^xsd:string .
:TV_Line_1158_en a :TranslationVariant ; :relatedTo :Line_1158 ; :text "For fortune is always lifting up and"^^xsd:string .
:TV_Line_1159_en a :TranslationVariant ; :relatedTo :Line_1159 ; :text "Knocking down the lucky and the unlucky alike:"^^xsd:string .
:TV_Line_1160_en a :TranslationVariant ; :relatedTo :Line_1160 ; :text "There is no prophet to tell mortal man his fate."^^xsd:string .
:TV_Line_1161_en a :TranslationVariant ; :relatedTo :Line_1161 ; :text "Creon was blessed, as far as I can tell—"^^xsd:string .
:TV_Line_1162_en a :TranslationVariant ; :relatedTo :Line_1162 ; :text "He saved the land of Cadmus from its enemies,"^^xsd:string .
:TV_Line_1163_en a :TranslationVariant ; :relatedTo :Line_1163 ; :text "He took sole dominion of this country, he ruled it well,"^^xsd:string .
:TV_Line_1164_en a :TranslationVariant ; :relatedTo :Line_1164 ; :text "He fathered many noble children."^^xsd:string .
:TV_Line_1165_en a :TranslationVariant ; :relatedTo :Line_1165 ; :text "But now everything’s lost. When a man"^^xsd:string .
:TV_Line_1166_en a :TranslationVariant ; :relatedTo :Line_1166 ; :text "Has kissed all his joy goodbye, I don’t consider him"^^xsd:string .
:TV_Line_1167_en a :TranslationVariant ; :relatedTo :Line_1167 ; :text "Alive—he is a living corpse."^^xsd:string .
:TV_Line_1168_en a :TranslationVariant ; :relatedTo :Line_1168 ; :text "Fill your home with riches, if you wish!"^^xsd:string .
:TV_Line_1169_en a :TranslationVariant ; :relatedTo :Line_1169 ; :text "Look to all the world like some great tyrant!"^^xsd:string .
:TV_Line_1170_en a :TranslationVariant ; :relatedTo :Line_1170 ; :text "If there’s no joy in those things,"^^xsd:string .
:TV_Line_1171_en a :TranslationVariant ; :relatedTo :Line_1171 ; :text "I wouldn’t even pay the shadow of smoke for all of that."^^xsd:string .
:TV_Line_1172_en a :TranslationVariant ; :relatedTo :Line_1172 ; :text "What’s the latest report on the royal family’s troubles?"^^xsd:string .
:TV_Line_1173_en a :TranslationVariant ; :relatedTo :Line_1173 ; :text "They’re dead, and the living are to blame."^^xsd:string .
:TV_Line_1174_en a :TranslationVariant ; :relatedTo :Line_1174 ; :text "And who did the killing? Who lies dead? Say it!"^^xsd:string .
:TV_Line_1175_en a :TranslationVariant ; :relatedTo :Line_1175 ; :text "Haemon is finished, bloodied by his own hand."^^xsd:string .
:TV_Line_1176_en a :TranslationVariant ; :relatedTo :Line_1176 ; :text "His father’s hand or his own?"^^xsd:string .
:TV_Line_1177_en a :TranslationVariant ; :relatedTo :Line_1177 ; :text "His own, to spite his murderous father."^^xsd:string .
:TV_Line_1178_en a :TranslationVariant ; :relatedTo :Line_1178 ; :text "Oh prophet, how true your words ring now!"^^xsd:string .
:TV_Line_1179_en a :TranslationVariant ; :relatedTo :Line_1179 ; :text "With things the way they are, there’s more for you to consider."^^xsd:string .
:TV_Line_1180_en a :TranslationVariant ; :relatedTo :Line_1180 ; :text "Look, I see poor Eurydice nearby,"^^xsd:string .
:TV_Line_1181_en a :TranslationVariant ; :relatedTo :Line_1181 ; :text "Creon’s wife—either she knows what her son has done,"^^xsd:string .
:TV_Line_1182_en a :TranslationVariant ; :relatedTo :Line_1182 ; :text "Or she’s just leaving home by chance."^^xsd:string .

################################################################
# MODERN GREEK TRANSLATION VARIANTS (Lines 1155 - 1182)
################################################################

:TV_Line_1155_Gr a :TranslationVariant ; :relatedTo :Line_1155 ; :text "Κοιτάξτε γύρω σας. Στην πόλη"^^xsd:string .
:TV_Line_1156_Gr a :TranslationVariant ; :relatedTo :Line_1156 ; :text "που έχτισαν ο Κάδμος κι ο Αμφίων ευτυχήσαμε να ζούμε."^^xsd:string .
:TV_Line_1157_Gr a :TranslationVariant ; :relatedTo :Line_1157 ; :text "Μεγάλη πόλη, ισχυρή. Λοιπόν;"^^xsd:string .
:TV_Line_1158_Gr a :TranslationVariant ; :relatedTo :Line_1158 ; :text "Λοιπόν, εγώ λέω πως κανείς δεν είναι"^^xsd:string .
:TV_Line_1159_Gr a :TranslationVariant ; :relatedTo :Line_1159 ; :text "σε θέση να εκτιμήσει την ανθρώπινη ζωή."^^xsd:string .
:TV_Line_1160_Gr a :TranslationVariant ; :relatedTo :Line_1160 ; :text "Τι πάει να πει ευτυχία και δυστυχία;"^^xsd:string .
:TV_Line_1161_Gr a :TranslationVariant ; :relatedTo :Line_1161 ; :text "Μόνο η μοίρα ξέρει το πάνω και το κάτω."^^xsd:string .
:TV_Line_1162_Gr a :TranslationVariant ; :relatedTo :Line_1162 ; :text "Εμείς απλά ακολουθούμε. Τι να πεις!"^^xsd:string .
:TV_Line_1163_Gr a :TranslationVariant ; :relatedTo :Line_1163 ; :text "Ποιος δεν ζήλεψε όσα πέτυχε ο Κρέων;"^^xsd:string .
:TV_Line_1164_Gr a :TranslationVariant ; :relatedTo :Line_1164 ; :text "Έδιωξε απ’ τον τόπο τους εχθρούς,"^^xsd:string .
:TV_Line_1165_Gr a :TranslationVariant ; :relatedTo :Line_1165 ; :text "ανέλαβε την εξουσία, κυβέρνησε όπως ήθελε,"^^xsd:string .
:TV_Line_1166_Gr a :TranslationVariant ; :relatedTo :Line_1166 ; :text "ευτύχησε να έχει καλά παιδιά... Και τώρα; Τι απομένει;"^^xsd:string .
:TV_Line_1167_Gr a :TranslationVariant ; :relatedTo :Line_1167 ; :text "Τίποτα! Δεν ζει, ο άνθρωπος όταν χάσει όσα του δίνουν"^^xsd:string .
:TV_Line_1168_Gr a :TranslationVariant ; :relatedTo :Line_1168 ; :text "χαρά. Πεθαίνει κάθε μέρα την ζωή του."^^xsd:string .
:TV_Line_1169_Gr a :TranslationVariant ; :relatedTo :Line_1169 ; :text "Συσσώρευσε όσα πλούτη θες,"^^xsd:string .
:TV_Line_1170_Gr a :TranslationVariant ; :relatedTo :Line_1170 ; :text "απέκτησε όση εξουσία φιλοδοξείς... Χαρά· έχεις χαρά;"^^xsd:string .
:TV_Line_1171_Gr a :TranslationVariant ; :relatedTo :Line_1171 ; :text "Τα υπόλοιπα δεν είναι ούτε καπνού σκιά."^^xsd:string .
:TV_Line_1172_Gr a :TranslationVariant ; :relatedTo :Line_1172 ; :text "Τι έπαθε πάλι η εξουσία. Καινούργια συμφορά;"^^xsd:string .
:TV_Line_1173_Gr a :TranslationVariant ; :relatedTo :Line_1173 ; :text "Τους σκότωσαν, τους σκότωσαν. Και ζουν ακόμα οι αίτιοι."^^xsd:string .
:TV_Line_1174_Gr a :TranslationVariant ; :relatedTo :Line_1174 ; :text "Ποιος σκότωσε ποιον κι ακόμα ζει; Μίλα!"^^xsd:string .
:TV_Line_1175_Gr a :TranslationVariant ; :relatedTo :Line_1175 ; :text "Πνίγηκε στο αίμα του ο Αίμων κι αυτοκτόνησε εκείνη."^^xsd:string .
:TV_Line_1176_Gr a :TranslationVariant ; :relatedTo :Line_1176 ; :text "Τον Αίμονα ποιος... ο πατέρας του; Ή κι αυτός..."^^xsd:string .
:TV_Line_1177_Gr a :TranslationVariant ; :relatedTo :Line_1177 ; :text "Κι αυτός, για να εκδικηθεί τον φόνο που διέπραξε ο πατέρας του."^^xsd:string ; :relatedTo :HaemonDecision_SuicideRevenge .
:TV_Line_1178_Gr a :TranslationVariant ; :relatedTo :Line_1178 ; :text "Α, Τειρεσία, βγήκαν τα λόγια σου αληθινά."^^xsd:string ; :relatedTo :Tiresias_Character_Tiresias .
:TV_Line_1179_Gr a :TranslationVariant ; :relatedTo :Line_1179 ; :text "Και πόσα ακόμα!"^^xsd:string .
:TV_Line_1180_Gr a :TranslationVariant ; :relatedTo :Line_1180 ; :text "Πάψτε· έρχεται η γυναίκα του Κρέοντα."^^xsd:string .
:TV_Line_1181_Gr a :TranslationVariant ; :relatedTo :Line_1181 ; :text "Άκουσε τίποτα για το παιδί της;"^^xsd:string .
:TV_Line_1182_Gr a :TranslationVariant ; :relatedTo :Line_1182 ; :text "Αχ, δύστυχη Ευρυδίκη!"^^xsd:string .

################################################################
# ANCIENT GREEK VARIANTS (Lines 1155 - 1182)
################################################################

:TV_Line_1155_grc a :TranslationVariant ; :relatedTo :Line_1155 ; :text "Κάδμου πάροικοι καὶ δόμων Ἀμφίονος,"^^xsd:string .
:TV_Line_1156_grc a :TranslationVariant ; :relatedTo :Line_1156 ; :text "οὐκ ἔσθ ̓ ὁποῖον στάντ ̓ ἂν ἀνθρώπου βίον"^^xsd:string .
:TV_Line_1157_grc a :TranslationVariant ; :relatedTo :Line_1157 ; :text "οὔτ ̓ αἰνέσαιμ ̓ ἂν οὔτε μεμψαίμην ποτέ·"^^xsd:string .
:TV_Line_1158_grc a :TranslationVariant ; :relatedTo :Line_1158 ; :text "τύχη γὰρ ὀρθοῖ καὶ τύχη καταρρέπει"^^xsd:string ; :hasTheme :Theme_InstabilityOfFortune .
:TV_Line_1159_grc a :TranslationVariant ; :relatedTo :Line_1159 ; :text "τὸν εὐτυχοῦντα τόν τε δυστυχοῦντ ̓ ἀεί·"^^xsd:string .
:TV_Line_1160_grc a :TranslationVariant ; :relatedTo :Line_1160 ; :text "καὶ μάντις οὐδεὶς τῶν καθεστώτων βροτοῖς."^^xsd:string .
:TV_Line_1161_grc a :TranslationVariant ; :relatedTo :Line_1161 ; :text "Κρέων γὰρ ἦν ζηλωτός, ὡς ἐμοί, ποτέ,"^^xsd:string .
:TV_Line_1162_grc a :TranslationVariant ; :relatedTo :Line_1162 ; :text "σώσας μὲν ἐχθρῶν τήνδε Καδμείαν χθόνα,"^^xsd:string .
:TV_Line_1163_grc a :TranslationVariant ; :relatedTo :Line_1163 ; :text "λαβών τε χώρας παντελῆ μοναρχίαν"^^xsd:string .
:TV_Line_1164_grc a :TranslationVariant ; :relatedTo :Line_1164 ; :text "ηὔθυνε, θάλλων εὐγενεῖ τέκνων σπορᾷ·"^^xsd:string .
:TV_Line_1165_grc a :TranslationVariant ; :relatedTo :Line_1165 ; :text "καὶ νῦν ἀφεῖται πάντα. Τὰς γὰρ ἡδονὰς"^^xsd:string .
:TV_Line_1166_grc a :TranslationVariant ; :relatedTo :Line_1166 ; :text "ὅταν προδῶσιν ἄνδρες, οὐ τίθημ ̓ ἐγὼ"^^xsd:string .
:TV_Line_1167_grc a :TranslationVariant ; :relatedTo :Line_1167 ; :text "ζῆν τοῦτον, ἀλλ ̓ ἔμψυχον ἡγοῦμαι νεκρόν."^^xsd:string ; :hasTheme :Theme_LivingDeath .
:TV_Line_1168_grc a :TranslationVariant ; :relatedTo :Line_1168 ; :text "Πλούτει τε γὰρ κατ ̓ οἶκον, εἰ βούλει, μέγα,"^^xsd:string .
:TV_Line_1169_grc a :TranslationVariant ; :relatedTo :Line_1169 ; :text "καὶ ζῆ τύραννον σχῆμ ̓ ἔχων, ἐὰν δ ̓ ἀπῇ"^^xsd:string .
:TV_Line_1170_grc a :TranslationVariant ; :relatedTo :Line_1170 ; :text "τούτων τὸ χαίρειν, τἄλλ ̓ ἐγὼ καπνοῦ σκιᾶς"^^xsd:string .
:TV_Line_1171_grc a :TranslationVariant ; :relatedTo :Line_1171 ; :text "οὐκ ἂν πριαίμην ἀνδρὶ πρὸς τὴν ἡδονήν."^^xsd:string .
:TV_Line_1172_grc a :TranslationVariant ; :relatedTo :Line_1172 ; :text "Τί δ ̓ αὖ τόδ ̓ ἄχθος βασιλέων ἥκεις φέρων;"^^xsd:string .
:TV_Line_1173_grc a :TranslationVariant ; :relatedTo :Line_1173 ; :text "Τεθνᾶσιν· οἱ δὲ ζῶντες αἴτιοι θανεῖν."^^xsd:string .
:TV_Line_1174_grc a :TranslationVariant ; :relatedTo :Line_1174 ; :text "Καὶ τίς φονεύει; τίς δ ̓ ὁ κείμενος; λέγε."^^xsd:string .
:TV_Line_1175_grc a :TranslationVariant ; :relatedTo :Line_1175 ; :text "Αἵμων ὄλωλεν· αὐτόχειρ δ ̓ αἱμάσσεται."^^xsd:string .
:TV_Line_1176_grc a :TranslationVariant ; :relatedTo :Line_1176 ; :text "Πότερα πατρῴας ἢ πρὸς οἰκείας χερός;"^^xsd:string .
:TV_Line_1177_grc a :TranslationVariant ; :relatedTo :Line_1177 ; :text "Αὐτὸς πρὸς αὑτοῦ, πατρὶ μηνίσας φόνου."^^xsd:string .
:TV_Line_1178_grc a :TranslationVariant ; :relatedTo :Line_1178 ; :text "Ὦ μάντι, τοὔπος ὡς ἄρ ̓ ὀρθὸν ἤνυσας."^^xsd:string .
:TV_Line_1179_grc a :TranslationVariant ; :relatedTo :Line_1179 ; :text "Ὡς ὧδ ̓ ἐχόντων τἄλλα βουλεύειν πάρα."^^xsd:string .
:TV_Line_1180_grc a :TranslationVariant ; :relatedTo :Line_1180 ; :text "Καὶ μὴν ὁρῶ τάλαιναν Εὐρυδίκην ὁμοῦ"^^xsd:string .
:TV_Line_1181_grc a :TranslationVariant ; :relatedTo :Line_1181 ; :text "δάμαρτα τὴν Κρέοντος· ἐκ δὲ δωμάτων"^^xsd:string .
:TV_Line_1182_grc a :TranslationVariant ; :relatedTo :Line_1182 ; :text "ἤτοι κλύουσα παιδὸς ἢ τύχῃ περᾷ."^^xsd:string .