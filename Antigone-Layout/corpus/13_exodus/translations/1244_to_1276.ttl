@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

################################################################
# ENGLISH TRANSLATION VARIANTS (Lines 1244 - 1276)
################################################################

:TV_Line_1244_en a :TranslationVariant ; :relatedTo :Line_1244 ; :text "What do you make of this? The woman"^^xsd:string .
:TV_Line_1245_en a :TranslationVariant ; :relatedTo :Line_1245 ; :text "Left without saying a word."^^xsd:string .
:TV_Line_1246_en a :TranslationVariant ; :relatedTo :Line_1246 ; :text "I am astounded. And yet, I hope it’s that,"^^xsd:string .
:TV_Line_1247_en a :TranslationVariant ; :relatedTo :Line_1247 ; :text "Upon hearing the pain of her son, she won’t allow herself"^^xsd:string .
:TV_Line_1248_en a :TranslationVariant ; :relatedTo :Line_1248 ; :text "To weep in public, but only under her own roof,"^^xsd:string .
:TV_Line_1249_en a :TranslationVariant ; :relatedTo :Line_1249 ; :text "and she’s going to order her servants to start lamenting there."^^xsd:string .
:TV_Line_1250_en a :TranslationVariant ; :relatedTo :Line_1250 ; :text "She’s just too modest to misstep like that."^^xsd:string .
:TV_Line_1251_en a :TranslationVariant ; :relatedTo :Line_1251 ; :text "I don’t know, but it seems to me that a long silence"^^xsd:string .
:TV_Line_1252_en a :TranslationVariant ; :relatedTo :Line_1252 ; :text "Can mean as much trouble as the loudest wailing."^^xsd:string .
:TV_Line_1253_en a :TranslationVariant ; :relatedTo :Line_1253 ; :text "Then I’ll go to the house and find out"^^xsd:string .
:TV_Line_1254_en a :TranslationVariant ; :relatedTo :Line_1254 ; :text "If she’s concealing some secret plan"^^xsd:string .
:TV_Line_1255_en a :TranslationVariant ; :relatedTo :Line_1255 ; :text "In her passionate, grief-stricken heart."^^xsd:string .
:TV_Line_1256_en a :TranslationVariant ; :relatedTo :Line_1256 ; :text "You’re right: too much silence does not bode well."^^xsd:string .
:TV_Line_1257_en a :TranslationVariant ; :relatedTo :Line_1257 ; :text "Behold! The king himself comes,"^^xsd:string .
:TV_Line_1258_en a :TranslationVariant ; :relatedTo :Line_1258 ; :text "Holding a clear evidence that,"^^xsd:string .
:TV_Line_1259_en a :TranslationVariant ; :relatedTo :Line_1259 ; :text "If it can be said, the mistake"^^xsd:string .
:TV_Line_1260_en a :TranslationVariant ; :relatedTo :Line_1260 ; :text "Was his own, and no other’s."^^xsd:string .
:TV_Line_1261_en a :TranslationVariant ; :relatedTo :Line_1261 ; :text "Oh! The cruel and deadly mistakes"^^xsd:string .
:TV_Line_1262_en a :TranslationVariant ; :relatedTo :Line_1262 ; :text "Of a thoughtless mind!"^^xsd:string .
:TV_Line_1263_en a :TranslationVariant ; :relatedTo :Line_1263 ; :text "O elders, you watched kinsfolk"^^xsd:string .
:TV_Line_1264_en a :TranslationVariant ; :relatedTo :Line_1264 ; :text "Kill and be killed."^^xsd:string .
:TV_Line_1265_en a :TranslationVariant ; :relatedTo :Line_1265 ; :text "Ah! The wretched ends of my plans!"^^xsd:string .
:TV_Line_1266_en a :TranslationVariant ; :relatedTo :Line_1266 ; :text "Oh child, a young man with a young death!"^^xsd:string .
:TV_Line_1267_en a :TranslationVariant ; :relatedTo :Line_1267 ; :text "Oh! Oh! You died, bound"^^xsd:string .
:TV_Line_1268_en a :TranslationVariant ; :relatedTo :Line_1268 ; :text "Not by your own foolishness, but by mine!"^^xsd:string .
:TV_Line_1269_en a :TranslationVariant ; :relatedTo :Line_1269 ; :text "You died, bound not by your own foolishness, but by mine!"^^xsd:string .
:TV_Line_1270_en a :TranslationVariant ; :relatedTo :Line_1270 ; :text "Alas, how late you’ve come to see justice!"^^xsd:string .
:TV_Line_1271_en a :TranslationVariant ; :relatedTo :Line_1271 ; :text "Ah me!"^^xsd:string .
:TV_Line_1272_en a :TranslationVariant ; :relatedTo :Line_1272 ; :text "I’ve learned to be sorry. A god is toying with my mind,"^^xsd:string .
:TV_Line_1273_en a :TranslationVariant ; :relatedTo :Line_1273 ; :text "pinning me with a crushing weight"^^xsd:string .
:TV_Line_1274_en a :TranslationVariant ; :relatedTo :Line_1274 ; :text "Here and there, driving me down wild paths."^^xsd:string .
:TV_Line_1275_en a :TranslationVariant ; :relatedTo :Line_1275 ; :text "Ah me! Tripping over trampled joy!"^^xsd:string .
:TV_Line_1276_en a :TranslationVariant ; :relatedTo :Line_1276 ; :text "Oh the horrible pain of mortal man!"^^xsd:string .

################################################################
# MODERN GREEK TRANSLATION VARIANTS (Lines 1244 - 1276)
################################################################

:TV_Line_1244_Gr a :TranslationVariant ; :relatedTo :Line_1244 ; :text "Τι λες γι’ αυτό; Έφυγε η γυναίκα"^^xsd:string .
:TV_Line_1245_Gr a :TranslationVariant ; :relatedTo :Line_1245 ; :text "χωρίς να βγάλει λέξη."^^xsd:string .
:TV_Line_1246_Gr a :TranslationVariant ; :relatedTo :Line_1246 ; :text "Όντως, πολύ παράξενο. Ας ελπίσουμε"^^xsd:string .
:TV_Line_1247_Gr a :TranslationVariant ; :relatedTo :Line_1247 ; :text "πως δεν θέλει να την δει η πόλη να θρηνεί"^^xsd:string .
:TV_Line_1248_Gr a :TranslationVariant ; :relatedTo :Line_1248 ; :text "τον γιο της. Μες στο σπίτι θα τον κλάψει"^^xsd:string .
:TV_Line_1249_Gr a :TranslationVariant ; :relatedTo :Line_1249 ; :text "με τις δούλες. Είναι συνετή γυναίκα."^^xsd:string .
:TV_Line_1250_Gr a :TranslationVariant ; :relatedTo :Line_1250 ; :text "επικίνδυνο πράγμα η σιωπή με τόσο πόνο."^^xsd:string ; :hasTheme :Theme_DangerousSilence .
:TV_Line_1251_Gr a :TranslationVariant ; :relatedTo :Line_1251 ; :text "Δεν ξέρω. Καμιά φορά η απόλυτη σιωπή"^^xsd:string .
:TV_Line_1252_Gr a :TranslationVariant ; :relatedTo :Line_1252 ; :text "σημαίνει πως ο θρήνος δεν είναι αρκετός."^^xsd:string .
:TV_Line_1253_Gr a :TranslationVariant ; :relatedTo :Line_1253 ; :text "Έχεις δίκιο:"^^xsd:string .
:TV_Line_1254_Gr a :TranslationVariant ; :relatedTo :Line_1254 ; :text "επικίνδυνο πράγμα η σιωπή με τόσο πόνο."^^xsd:string .
:TV_Line_1255_Gr a :TranslationVariant ; :relatedTo :Line_1255 ; :text "Πάω μέσα μήπως κρύβει"^^xsd:string .
:TV_Line_1256_Gr a :TranslationVariant ; :relatedTo :Line_1256 ; :text "καμιάν άλλη συμφορά."^^xsd:string .
:TV_Line_1257_Gr a :TranslationVariant ; :relatedTo :Line_1257 ; :text "Να ο άρχοντας κι ο θάνατος."^^xsd:string .
:TV_Line_1258_Gr a :TranslationVariant ; :relatedTo :Line_1258 ; :text "Να ο άρχοντας κι ο θάνατος... είναι μάταιο να προσπαθεί να κρατηθεί απ’ το έγκλημά του."^^xsd:string .
:TV_Line_1259_Gr a :TranslationVariant ; :relatedTo :Line_1259 ; :text "αλλά είναι μάταιο να προσπαθεί"^^xsd:string .
:TV_Line_1260_Gr a :TranslationVariant ; :relatedTo :Line_1260 ; :text "να κρατηθεί απ’ το έγκλημά του."^^xsd:string .
:TV_Line_1261_Gr a :TranslationVariant ; :relatedTo :Line_1261 ; :text "Ανάθεμά με· ανάθεμά σε, αγύριστο κεφάλι μου, αδίστακτε φονιά."^^xsd:string ; :relatedTo :CreonEmotion_SelfLoathing .
:TV_Line_1262_Gr a :TranslationVariant ; :relatedTo :Line_1262 ; :text "αγύριστο κεφάλι μου, αδίστακτε φονιά."^^xsd:string .
:TV_Line_1263_Gr a :TranslationVariant ; :relatedTo :Line_1263 ; :text "Για δείτε εδώ· για δείτε"^^xsd:string .
:TV_Line_1264_Gr a :TranslationVariant ; :relatedTo :Line_1264 ; :text "εμφύλιο σπαραγμό:"^^xsd:string .
:TV_Line_1265_Gr a :TranslationVariant ; :relatedTo :Line_1265 ; :text "θύτης και θύμα, μια γενιά."^^xsd:string .
:TV_Line_1266_Gr a :TranslationVariant ; :relatedTo :Line_1266 ; :text "Δείτε ανόητο κυβερνήτη,"^^xsd:string .
:TV_Line_1267_Gr a :TranslationVariant ; :relatedTo :Line_1267 ; :text "πατέρα δολοφόνο."^^xsd:string .
:TV_Line_1268_Gr a :TranslationVariant ; :relatedTo :Line_1268 ; :text "Αχ, παιδί μου,"^^xsd:string .
:TV_Line_1269_Gr a :TranslationVariant ; :relatedTo :Line_1269 ; :text "σου στέρησα τα νιάτα σου."^^xsd:string .
:TV_Line_1270_Gr a :TranslationVariant ; :relatedTo :Line_1270 ; :text "Άργησες πολύ, δυστυχισμένε."^^xsd:string .
:TV_Line_1271_Gr a :TranslationVariant ; :relatedTo :Line_1271 ; :text "Άργησες πολύ, δυστυχισμένε."^^xsd:string ; :hasTheme :Theme_LateWisdom .
:TV_Line_1272_Gr a :TranslationVariant ; :relatedTo :Line_1272 ; :text "κάποιος θεός με τρέλανε,"^^xsd:string .
:TV_Line_1273_Gr a :TranslationVariant ; :relatedTo :Line_1273 ; :text "κάποιος θεός με τρέλανε, αγρίμι μ’ έκανε κι έπεσα πάνω σε ό,τι μου έδινε χαρά"^^xsd:string ; :relatedTo :FateConcept_DivineAte .
:TV_Line_1274_Gr a :TranslationVariant ; :relatedTo :Line_1274 ; :text "σε ό,τι μου έδινε χαρά"^^xsd:string .
:TV_Line_1275_Gr a :TranslationVariant ; :relatedTo :Line_1275 ; :text "να το σπαράξω."^^xsd:string .
:TV_Line_1276_Gr a :TranslationVariant ; :relatedTo :Line_1276 ; :text "Α, του ανθρώπου αφόρητο φορτίο!"^^xsd:string ; :relatedTo :CreonEmotion_Agony .

################################################################
# ANCIENT GREEK VARIANTS (Lines 1244 - 1276)
################################################################

:TV_Line_1244_grc a :TranslationVariant ; :relatedTo :Line_1244 ; :text "ΧΟ. Τί τοῦτ ̓ ἂν εἰκάσειας; ἡ γυνὴ πάλιν"^^xsd:string .
:TV_Line_1245_grc a :TranslationVariant ; :relatedTo :Line_1245 ; :text "φρούδη, πρὶν εἰπεῖν ἐσθλὸν ἢ κακὸν λόγον."^^xsd:string .
:TV_Line_1246_grc a :TranslationVariant ; :relatedTo :Line_1246 ; :text "ΑΓ. Καὐτὸς τεθάμβηκ ̓· ἐλπίσιν δὲ βόσκομαι"^^xsd:string .
:TV_Line_1247_grc a :TranslationVariant ; :relatedTo :Line_1247 ; :text "ἄχη τέκνου κλύουσαν ἐς πόλιν γόου"^^xsd:string .
:TV_Line_1248_grc a :TranslationVariant ; :relatedTo :Line_1248 ; :text "οὐκ ἀξιώσειν, ἀλλ ̓ ὑπὸ στέγης ἔσω"^^xsd:string .
:TV_Line_1249_grc a :TranslationVariant ; :relatedTo :Line_1249 ; :text "δμωαῖς προθήσειν πένθος οἰκεῖον στένειν."^^xsd:string .
:TV_Line_1250_grc a :TranslationVariant ; :relatedTo :Line_1250 ; :text "Γνώμης γὰρ οὐκ ἄπειρος, ὥσθ ̓ ἁμαρτάνειν."^^xsd:string .
:TV_Line_1251_grc a :TranslationVariant ; :relatedTo :Line_1251 ; :text "ΧΟ. Οὐκ οἶδ ̓· ἐμοὶ δ ̓ οὖν ἥ τ ̓ ἄγαν σιγὴ βαρὺ"^^xsd:string .
:TV_Line_1252_grc a :TranslationVariant ; :relatedTo :Line_1252 ; :text "δοκεῖ προσεῖναι χἠ μάτην πολλὴ βοή."^^xsd:string .
:TV_Line_1253_grc a :TranslationVariant ; :relatedTo :Line_1253 ; :text "ΑΓ. Ἀλλ ̓ εἰσόμεσθα μή τι καὶ κατάσχετον"^^xsd:string .
:TV_Line_1254_grc a :TranslationVariant ; :relatedTo :Line_1254 ; :text "κρυφῇ καλύπτει καρδίᾳ θυμουμένῃ,"^^xsd:string .
:TV_Line_1255_grc a :TranslationVariant ; :relatedTo :Line_1255 ; :text "δόμους παραστείχοντες· εὖ γὰρ οὖν λέγεις·"^^xsd:string .
:TV_Line_1256_grc a :TranslationVariant ; :relatedTo :Line_1256 ; :text "καὶ τῆς ἄγαν γάρ ἐστί που σιγῆς βάρος."^^xsd:string .
:TV_Line_1257_grc a :TranslationVariant ; :relatedTo :Line_1257 ; :text "ΧΟ. Καὶ μὴν ὅδ ̓ ἄναξ αὐτὸς ἐφήκει"^^xsd:string .
:TV_Line_1258_grc a :TranslationVariant ; :relatedTo :Line_1258 ; :text "μνῆμ ̓ ἐπίσημον διὰ χειρὸς ἔχων,"^^xsd:string .
:TV_Line_1259_grc a :TranslationVariant ; :relatedTo :Line_1259 ; :text "εἰ θέμις εἰπεῖν, οὐκ ἀλλοτρίαν"^^xsd:string .
:TV_Line_1260_grc a :TranslationVariant ; :relatedTo :Line_1260 ; :text "ἄτην, ἀλλ ̓ αὐτὸς ἁμαρτών."^^xsd:string .
:TV_Line_1261_grc a :TranslationVariant ; :relatedTo :Line_1261 ; :text "ΚΡ. Ἰὼ φρενῶν δυσφρόνων ἁμαρτήματα"^^xsd:string .
:TV_Line_1262_grc a :TranslationVariant ; :relatedTo :Line_1262 ; :text "στερεὰ θανατόεντ ̓,"^^xsd:string .
:TV_Line_1263_grc a :TranslationVariant ; :relatedTo :Line_1263 ; :text "ὦ κτανόντας τε καὶ"^^xsd:string .
:TV_Line_1264_grc a :TranslationVariant ; :relatedTo :Line_1264 ; :text "θανόντας βλέποντες ἐμφυλίους."^^xsd:string .
:TV_Line_1265_grc a :TranslationVariant ; :relatedTo :Line_1265 ; :text "Ὤμοι ἐμῶν ἄνολβα βουλευμάτων."^^xsd:string .
:TV_Line_1266_grc a :TranslationVariant ; :relatedTo :Line_1266 ; :text "Ἰὼ παῖ, νέος νέῳ ξὺν μόρῳ,"^^xsd:string .
:TV_Line_1267_grc a :TranslationVariant ; :relatedTo :Line_1267 ; :text "αἰαῖ αἰαῖ,"^^xsd:string .
:TV_Line_1268_grc a :TranslationVariant ; :relatedTo :Line_1268 ; :text "ἔθανες, ἀπελύθης,"^^xsd:string .
:TV_Line_1269_grc a :TranslationVariant ; :relatedTo :Line_1269 ; :text "ἐμαῖς οὐδὲ σαῖσι δυσβουλίαις."^^xsd:string .
:TV_Line_1270_grc a :TranslationVariant ; :relatedTo :Line_1270 ; :text "ΧΟ. Οἴμ ̓ ὡς ἔοικας ὀψὲ τὴν δίκην ἰδεῖν."^^xsd:string .
:TV_Line_1271_grc a :TranslationVariant ; :relatedTo :Line_1271 ; :text "ΚΡ. Οἴμοι,"^^xsd:string .
:TV_Line_1272_grc a :TranslationVariant ; :relatedTo :Line_1272 ; :text "ἔχω μαθὼν δείλαιος· ἐν δ ̓ ἐμῷ κάρᾳ"^^xsd:string .
:TV_Line_1273_grc a :TranslationVariant ; :relatedTo :Line_1273 ; :text "θεὸς τότ ̓ ἄρα τότε μέγα βάρος μ ̓ ἔχων"^^xsd:string .
:TV_Line_1274_grc a :TranslationVariant ; :relatedTo :Line_1274 ; :text "ἔπαισεν, ἐν δ ̓ ἔσεισεν ἀγρίαις ὁδοῖς,"^^xsd:string .
:TV_Line_1275_grc a :TranslationVariant ; :relatedTo :Line_1275 ; :text "οἴμοι, λακπάτητον ἀντρέπων χαράν."^^xsd:string .
:TV_Line_1276_grc a :TranslationVariant ; :relatedTo :Line_1276 ; :text "Φεῦ φεῦ, ἰὼ πόνοι βροτῶν δύσπονοι."^^xsd:string .