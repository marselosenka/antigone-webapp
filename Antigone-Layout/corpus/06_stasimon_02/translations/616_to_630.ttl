@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Translation variants for lines 616-630 of Antigone.

:TV_Line_616_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Behold that much-wandering hope; to many a benefit, yet to others a trick of thoughtless lust."^^xsd:string ;
    :relatedTo :Line_616 ;
    :hasTheme :Theme_FalseHope .

:TV_Line_617_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Its victim is unknowing, before he touches his foot to a blazing fire."^^xsd:string ;
    :relatedTo :Line_617 ;
    :relatedTo :Cause_FalseHope .

:TV_Line_620_en a owl:NamedIndividual, :TranslationVariant ;
    :text "For with wisdom was the famous saying once revealed:"^^xsd:string ;
    :relatedTo :Line_620 ;
    :relatedTo :Effect_UnexpectedPain ;
    :hasTheme :Theme_DivineMadness .

:TV_Line_621_en a owl:NamedIndividual, :TranslationVariant ;
    :text "That evil can sometimes seem good to the one"^^xsd:string ;
    :relatedTo :Line_621 ;
    :relatedTo :Effect_MoralBlindness ;
    :hasConflict :Conflict_EvilAppearingAsGood .

:TV_Line_622_en a owl:NamedIndividual, :TranslationVariant ;
    :text "whose mind and senses"^^xsd:string ;
    :relatedTo :Line_622 ;
    :relatedTo :Cause_DivineDeception .

:TV_Line_623_en a owl:NamedIndividual, :TranslationVariant ;
    :text "the gods are leading toward ruin."^^xsd:string ;
    :relatedTo :Line_623 .

:TV_Line_625_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Yet he goes about free from destruction for only the shortest time."^^xsd:string ;
    :relatedTo :Line_625 ;
    :relatedTo :Effect_InevitableRuin .

:TV_Line_626_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Behold! Here is Haemon, the youngest of your children;"^^xsd:string ;
    :relatedTo :Line_626 .

:TV_Line_627_en a owl:NamedIndividual, :TranslationVariant ;
    :text "does he come grieving for the fate"^^xsd:string ;
    :relatedTo :Line_627 .

:TV_Line_628_en a owl:NamedIndividual, :TranslationVariant ;
    :text "of his promised bride, Antigone,"^^xsd:string ;
    :relatedTo :Line_628 ;
    :hasMotivation :Motivation_MournBride .

:TV_Line_630_en a owl:NamedIndividual, :TranslationVariant ;
    :text "anguished by the deception of his marriage bed?"^^xsd:string ;
    :relatedTo :Line_630 ;
    :experiencesEmotion :Emotion_Grief .