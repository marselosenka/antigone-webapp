:Theme_DivineLaw a :Theme ;
  :description "Antigone privileges unwritten divine law over royal decree."^^xsd:string .

:Theme_HumanLaw a :Theme ;
  :description "Creon enforces civic authority as absolute state law."^^xsd:string .

:Theme_FamilyDuty a :Theme ;
  :description "Burial and kinship obligations shape decisions and conflict."^^xsd:string .

:Theme_Authority a :Theme ;
  :description "Political power, coercion, and resistance structure the episode."^^xsd:string .

:Theme_BurialRites a :Theme ;
  :description "Burial is treated as a sacred and politically contested act."^^xsd:string .

:Conflict_DivineVsHumanLaw a :Conflict ;
  :description "Moral collision between divine ordinance and state decree."^^xsd:string .

:Conflict_AntigoneVsCreon a :Conflict ;
  :description "Direct confrontation between personal piety and political sovereignty."^^xsd:string .

:Conflict_AntigoneVsIsmene a :Conflict ;
  :description "Sisterly disagreement over courage, complicity, and shared fate."^^xsd:string .
