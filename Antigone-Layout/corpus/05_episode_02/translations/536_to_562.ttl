@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Translation variants for lines 536-562


:TV_Line_536_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_536 ;
  :text "I did the deed, if she’ll agree,"^^xsd:string .

:TV_Line_537_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_537 ;
  :text "I both share in the deed and bear the blame."^^xsd:string .

:TV_Line_538_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_538 ;
  :text "But justice won’t let you, since you refused help,"^^xsd:string .

:TV_Line_539_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_539 ;
  :text "And I did not consult with you."^^xsd:string .

:TV_Line_540_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_540 ;
  :text "I’m not ashamed to sail alongside you"^^xsd:string .

:TV_Line_541_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_541 ;
  :text "Through your ocean of perils."^^xsd:string .

:TV_Line_542_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_542 ;
  :text "Hades and the dead below know whose deed this is."^^xsd:string .

:TV_Line_543_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_543 ;
  :text "A friend in words alone is no friend of mine."^^xsd:string .

:TV_Line_544_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_544 ;
  :text "At least, sister, you should not strip me of the honor"^^xsd:string .

:TV_Line_545_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_545 ;
  :text "to die with you and to sanctify the dead."^^xsd:string .

:TV_Line_546_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_546 ;
  :text "Don’t die for my sake, and don’t claim something"^^xsd:string .


:TV_Line_547_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_547 ;
  :text "make yours. I, dying, will be enough."^^xsd:string .

:TV_Line_548_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_548 ;
  :text "And what would my life be without you?"^^xsd:string .

:TV_Line_549_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_549 ;
  :text "Ask Creon! Your concern clearly lies with him!"^^xsd:string .

:TV_Line_550_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_550 ;
  :text "Why are you mocking me like this? It’s not helpful at all."^^xsd:string .

:TV_Line_551_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_551 ;
  :text "If I mock you, I do so with a pained heart."^^xsd:string .

:TV_Line_552_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_552 ;
  :text "But really! Even now, what can I do to help you?"^^xsd:string .

:TV_Line_553_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_553 ;
  :text "Save yourself. I will not resent your escape."^^xsd:string .

:TV_Line_554_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_554 ;
  :text "Oh misery! Will I not share in your fate?"^^xsd:string .

:TV_Line_555_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_555 ;
  :text "You chose to live, and I chose to die."^^xsd:string .


:TV_Line_556_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_556 ;
  :text "But not without me having spoken my words."^^xsd:string .

:TV_Line_557_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_557 ;
  :text "You seemed wise to some, but I to others."^^xsd:string .

:TV_Line_558_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_558 ;
  :text "But both of us have equal guilt!"^^xsd:string .

:TV_Line_559_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_559 ;
  :text "Take heart: you live, but my soul long ago"^^xsd:string .

:TV_Line_560_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_560 ;
  :text "has died, so that it might serve the dead."^^xsd:string .

:TV_Line_561_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_561 ;
  :text "I say these two children—one has just now"^^xsd:string .

:TV_Line_562_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_562 ;
  :text "shown herself a fool, the other from her birth."^^xsd:string .
