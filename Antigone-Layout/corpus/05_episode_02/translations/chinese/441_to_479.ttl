@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:episode_02-translations-441-479-chinese a owl:Ontology .

:TV_Line_441_zh a :TranslationVariant ; :relatedTo :Line_441 ; :text "喂，你——低着头看地的那个，"^^xsd:string .
:TV_Line_442_zh a :TranslationVariant ; :relatedTo :Line_442 ; :text "你承认还是否认这事是你做的？"^^xsd:string .
:TV_Line_443_zh a :TranslationVariant ; :relatedTo :Line_443 ; :text "我承认是我做的，我不否认。"^^xsd:string .
:TV_Line_444_zh a :TranslationVariant ; :relatedTo :Line_444 ; :text "你可以爱去哪儿就去哪儿，"^^xsd:string .
:TV_Line_445_zh a :TranslationVariant ; :relatedTo :Line_445 ; :text "免除重罪，自行离开。"^^xsd:string .
:TV_Line_446_zh a :TranslationVariant ; :relatedTo :Line_446 ; :text "至于你，告诉我——别长篇，只要简短——"^^xsd:string .
:TV_Line_447_zh a :TranslationVariant ; :relatedTo :Line_447 ; :text "你知不知道这事已被公告禁止？"^^xsd:string .
:TV_Line_448_zh a :TranslationVariant ; :relatedTo :Line_448 ; :text "我知道。我怎么会不知道？那是公开的。"^^xsd:string .
:TV_Line_449_zh a :TranslationVariant ; :relatedTo :Line_449 ; :text "可你竟还敢越过这些法令？"^^xsd:string .
:TV_Line_450_zh a :TranslationVariant ; :relatedTo :Line_450 ; :text "是，因为发布这禁令的并不是宙斯，"^^xsd:string .
:TV_Line_451_zh a :TranslationVariant ; :relatedTo :Line_451 ; :text "也不是与地下诸神同居的正义女神，"^^xsd:string .
:TV_Line_452_zh a :TranslationVariant ; :relatedTo :Line_452 ; :text "他们并未为凡人立下这等法。"^^xsd:string .
:TV_Line_453_zh a :TranslationVariant ; :relatedTo :Line_453 ; :text "我也不认为你的敕令有那样力量，"^^xsd:string .
:TV_Line_454_zh a :TranslationVariant ; :relatedTo :Line_454 ; :text "能让你这个凡人去凌驾"^^xsd:string .
:TV_Line_455_zh a :TranslationVariant ; :relatedTo :Line_455 ; :text "诸神不成文且不朽的律法。"^^xsd:string .
:TV_Line_456_zh a :TranslationVariant ; :relatedTo :Line_456 ; :text "这些法并非今有昨无，而是自古长存，"^^xsd:string .
:TV_Line_457_zh a :TranslationVariant ; :relatedTo :Line_457 ; :text "也无人知其最初显现于何时。"^^xsd:string .
:TV_Line_458_zh a :TranslationVariant ; :relatedTo :Line_458 ; :text "我不会因惧怕任何人的骄横，"^^xsd:string .
:TV_Line_459_zh a :TranslationVariant ; :relatedTo :Line_459 ; :text "就为此在诸神面前受罚。"^^xsd:string .
:TV_Line_460_zh a :TranslationVariant ; :relatedTo :Line_460 ; :text "我知道自己终须一死——这还用说吗？——"^^xsd:string .
:TV_Line_461_zh a :TranslationVariant ; :relatedTo :Line_461 ; :text "即使没有你的诏令也一样。可若我"^^xsd:string .
:TV_Line_462_zh a :TranslationVariant ; :relatedTo :Line_462 ; :text "早于时日而死，我反把它算作所得。"^^xsd:string .
:TV_Line_463_zh a :TranslationVariant ; :relatedTo :Line_463 ; :text "像我这样活在重重苦难里的人，"^^xsd:string .
:TV_Line_464_zh a :TranslationVariant ; :relatedTo :Line_464 ; :text "死了怎会不是一种得益？"^^xsd:string .
:TV_Line_465_zh a :TranslationVariant ; :relatedTo :Line_465 ; :text "所以对我而言，遭此命运"^^xsd:string .
:TV_Line_466_zh a :TranslationVariant ; :relatedTo :Line_466 ; :text "并不足为痛；但若我竟容许我母亲的"^^xsd:string .
:TV_Line_467_zh a :TranslationVariant ; :relatedTo :Line_467 ; :text "儿子死后横陈而无人埋葬，"^^xsd:string .
:TV_Line_468_zh a :TranslationVariant ; :relatedTo :Line_468 ; :text "那才会使我痛苦；至于这件事，我并不悲伤。"^^xsd:string .
:TV_Line_469_zh a :TranslationVariant ; :relatedTo :Line_469 ; :text "若你现在觉得我行事愚妄，"^^xsd:string .
:TV_Line_470_zh a :TranslationVariant ; :relatedTo :Line_470 ; :text "那也许只是愚人给我定了愚罪。"^^xsd:string .
:TV_Line_471_zh a :TranslationVariant ; :relatedTo :Line_471 ; :text "这姑娘的刚烈性情，显然出自刚烈的父亲；"^^xsd:string .
:TV_Line_472_zh a :TranslationVariant ; :relatedTo :Line_472 ; :text "她不懂得在祸患前屈服。"^^xsd:string .
:TV_Line_473_zh a :TranslationVariant ; :relatedTo :Line_473 ; :text "可你要知道，最顽固的心性"^^xsd:string .
:TV_Line_474_zh a :TranslationVariant ; :relatedTo :Line_474 ; :text "往往最先折断；最坚硬的铁，"^^xsd:string .
:TV_Line_475_zh a :TranslationVariant ; :relatedTo :Line_475 ; :text "在火中淬到极硬之后，"^^xsd:string .
:TV_Line_476_zh a :TranslationVariant ; :relatedTo :Line_476 ; :text "你最常见的恰是它崩裂粉碎。"^^xsd:string .
:TV_Line_477_zh a :TranslationVariant ; :relatedTo :Line_477 ; :text "我见过烈性的马匹"^^xsd:string .
:TV_Line_478_zh a :TranslationVariant ; :relatedTo :Line_478 ; :text "也会被一枚小小马嚼驯服；因为"^^xsd:string .
:TV_Line_479_zh a :TranslationVariant ; :relatedTo :Line_479 ; :text "做他人奴仆的人，不配怀抱高傲心思。"^^xsd:string .

