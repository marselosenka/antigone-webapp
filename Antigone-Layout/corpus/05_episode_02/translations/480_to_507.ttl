@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Translation variants for lines 480-507

:TV_Line_480_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_480 ;
  :text "Αυτή όμως το καλοήξερε τότε να μας βρίζει"^^xsd:string .

:TV_Line_481_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_481 ;
  :text "με το να παραβαίνει τους βαλμένους νόμους."^^xsd:string .

:TV_Line_482_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_482 ;
  :text "Κι είναι δεύτερη προσβολή —μια ήταν σαν το ᾽κανε— "^^xsd:string .

:TV_Line_483_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_483 ;
  :text "για τούτο κιόλας να καυχιέται και να γελάει που το ᾽πραξε."^^xsd:string .

:TV_Line_484_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_484 ;
  :text "Εγώ βέβαια τώρα δεν είμαι άντρας, παρά ο άντρας είναι αυτή,"^^xsd:string .

:TV_Line_485_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_485 ;
  :text "αν της περάσει αυτηνής να κάνει το θέλημά της ατιμώρητα."^^xsd:string .

:TV_Line_486_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_486 ;
  :text "Μα είτε της αδελφής μου είναι"^^xsd:string .

:TV_Line_487_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_487 ;
  :text "είτε και πιο στενή του αίματος συγγένισσά μου απ᾽ όλους όσους φυλάει ο σπιτικός μας Ζευς,"^^xsd:string .

:TV_Line_488_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_488 ;
  :text "αυτή και η αδελφή της"^^xsd:string .

:TV_Line_489_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_489 ;
  :text "δεν θα ξεφύγουνε την πιο χειρότερη μοίρα· γιατί κι εκείνη άλλο τόσο την κατηγοράω"^^xsd:string .

:TV_Line_490_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_490 ;
  :text "πως μελέτησε αυτόν τον τάφο."^^xsd:string .

:TV_Line_491_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_491 ;
  :text "Φωνάξετέ την εδώ τώρα, ότι την είδα μες στο σπίτι να μανίζει"^^xsd:string .

:TV_Line_492_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_492 ;
  :text "έξω απ᾽ τα λογικά της."^^xsd:string .

:TV_Line_493_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_493 ;
  :text "Συχνά η ψυχή του ανθρώπου μπροστύτερα προδίνεται σαν κλέφτρα,"^^xsd:string .

:TV_Line_494_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_494 ;
  :text "για τα άνομα που στα σκοτάδια κρυφογένονται,"^^xsd:string .

:TV_Line_495_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_495 ;
  :text "αλλά και τ᾽ άλλο ίδια το μισώ, όταν κανείς που πιάστηκε στο κρίμα του απάνω"^^xsd:string .

:TV_Line_496_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_496 ;
  :text "έπειτα θέλει να το παραστήσει ομορφύτερο."^^xsd:string .

:TV_Line_497_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_497 ;
  :text "Μήπως θέλεις να μου κάνεις πιο μεγαλύτερο, αφού μ᾽ έπιασες, παρά να με σκοτώσεις;"^^xsd:string .

:TV_Line_498_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_498 ;
  :text "Εγώ άλλο δεν θέλω, μ᾽ ετούτο τα ᾽χω όλα."^^xsd:string .

:TV_Line_499_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_499 ;
  :text "Τί κάθεσαι λοιπόν; όπως κι εμένα κανέν᾽ από τα λόγια σου"^^xsd:string .

:TV_Line_500_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_500 ;
  :text "δεν μου είν᾽ ευχάριστο και ποτέ δεν θα μ᾽ αρέσει"^^xsd:string .

:TV_Line_501_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_501 ;
  :text "έτσι κι εσένα φυσικά τα δικά μου σ᾽ ενοχλούν."^^xsd:string .

:TV_Line_502_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_502 ;
  :text "Και πούθε θα μου ᾽ρχονταν τόση τιμή και δόξα,"^^xsd:string .

:TV_Line_503_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_503 ;
  :text "παρά που έβαλα σε τάφο τον αυτάδελφό μου;"^^xsd:string .

:TV_Line_504_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_504 ;
  :text "Όλοι τους εδώ θα το ᾽λεγαν πως καλό το βρίσκουνε,"^^xsd:string .

:TV_Line_505_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_505 ;
  :text "αν δεν τους έδενε τη γλώσσα ο φόβος."^^xsd:string .

:TV_Line_506_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_506 ;
  :text "Έχουν οι βασιλιάδες κι άλλα πολλά που τους καλὄρχονται"^^xsd:string .

:TV_Line_507_el
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_507 ;
  :text "και μπορούν να κάνουν και να λένε ό,τι θέλουν."^^xsd:string .

:TV_Line_480_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_480 ;
  :text "This girl knew full well how to commit a crime,"^^xsd:string .

:TV_Line_481_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_481 ;
  :text "And she has transgressed the law that I established:"^^xsd:string .

:TV_Line_482_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_482 ;
  :text "But she’s committed a second outrage"^^xsd:string .

:TV_Line_483_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_483 ;
  :text "By being proud of what she’s done and laughing with self-congratulation."^^xsd:string .

:TV_Line_484_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_484 ;
  :text "Now either I’m no man, or she’s become one,"^^xsd:string .

:TV_Line_485_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_485 ;
  :text "If she’s to win such a victory without any retribution."^^xsd:string .

:TV_Line_486_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_486 ;
  :text "I don’t care that she’s my sister’s child—"^^xsd:string .

:TV_Line_487_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_487 ;
  :text "And even if she were closer to me than my own wife or son,"^^xsd:string .

:TV_Line_488_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_488 ;
  :text "She and her sister"^^xsd:string .

:TV_Line_489_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_489 ;
  :text "will never avoid this horrible fate—"^^xsd:string .

:TV_Line_490_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_490 ;
  :text "I think her sister holds an equal share Of the blame for plotting this burial."^^xsd:string .

:TV_Line_491_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_491 ;
  :text "Go! Summon her! For I see her now,"^^xsd:string .

:TV_Line_492_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_492 ;
  :text "Raving about in there like she’s lost her mind."^^xsd:string .

:TV_Line_493_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_493 ;
  :text "When someone’s concocting a villainous scheme,"^^xsd:string .

:TV_Line_494_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_494 ;
  :text "Their mind will often betray"^^xsd:string .

:TV_Line_495_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_495 ;
  :text "Their guilt before the act is done."^^xsd:string .

:TV_Line_496_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_496 ;
  :text "I hate it, too, when a criminal Who’s been caught tries to glorify their crime."^^xsd:string .

:TV_Line_497_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_497 ;
  :text "What more do you want than my death?"^^xsd:string .

:TV_Line_498_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_498 ;
  :text "Nothing: once I have that, I’ll have everything."^^xsd:string .

:TV_Line_499_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_499 ;
  :text "Why then do you delay?"^^xsd:string .

:TV_Line_500_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_500 ;
  :text "Nothing you say pleases me—"^^xsd:string .

:TV_Line_501_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_501 ;
  :text "And I hope it never does—And nothing I do pleases you."^^xsd:string .

:TV_Line_502_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_502 ;
  :text "What greater glory could I have gained"^^xsd:string .

:TV_Line_503_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_503 ;
  :text "Than placing my own brother In his grave."^^xsd:string .

:TV_Line_504_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_504 ;
  :text "You could tell that everyone here Is happy to hear this,"^^xsd:string .

:TV_Line_505_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_505 ;
  :text "if fear did not shut their mouths."^^xsd:string .

:TV_Line_506_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_506 ;
  :text "But tyranny has many blessings—"^^xsd:string .

:TV_Line_507_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_507 ;
  :text "In particular it can do and say whatever it wants."^^xsd:string .

:TV_Line_480_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_480 ;
  :text "Αὕτη δ ̓ ὑβρίζειν μὲν τότ ̓ ἐξηπίστατο,"^^xsd:string .

:TV_Line_481_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_481 ;
  :text "νόμους ὑπερβαίνουσα τοὺς προκειμένους·"^^xsd:string .

:TV_Line_482_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_482 ;
  :text "ὕβρις δ ̓, ἐπεὶ δέδρακεν, ἥδε δευτέρα,"^^xsd:string .

:TV_Line_483_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_483 ;
  :text "τούτοις ἐπαυχεῖν καὶ δεδρακυῖαν γελᾶν."^^xsd:string .

:TV_Line_484_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_484 ;
  :text "Ἦ νῦν ἐγὼ μὲν οὐκ ἀνήρ, αὕτη δ ̓ ἀνήρ,"^^xsd:string .

:TV_Line_486_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_486 ;
  :text "Ἀλλ ̓ εἴτ ̓ ἀδελφῆς εἴθ ̓ ὁμαιμονεστέρα"^^xsd:string .

:TV_Line_487_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_487 ;
  :text "τοῦ παντὸς ἡμῖν Ζηνὸς Ἑρκείου κυρεῖ,"^^xsd:string .

:TV_Line_488_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_488 ;
  :text "αὐτή τε χἠ ξύναιμος οὐκ ἀλύξετον"^^xsd:string .

:TV_Line_489_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_489 ;
  :text "μόρου κακίστου· καὶ γὰρ οὖν κείνην ἴσον"^^xsd:string .

:TV_Line_490_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_490 ;
  :text "ἐπαιτιῶμαι τοῦδε βουλεῦσαι τάφου."^^xsd:string .

:TV_Line_491_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_491 ;
  :text "Καί νιν καλεῖτ ̓· ἔσω γὰρ εἶδον ἀρτίως"^^xsd:string .

:TV_Line_492_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_492 ;
  :text "λυσσῶσαν αὐτὴν οὐδ ̓ ἐπήβολον φρενῶν."^^xsd:string .

:TV_Line_493_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_493 ;
  :text "Φιλεῖ δ ̓ ὁ θυμὸς πρόσθεν ᾑρῆσθαι κλοπεὺς"^^xsd:string .

:TV_Line_494_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_494 ;
  :text "τῶν μηδὲν ὀρθῶς ἐν σκότῳ τεχνωμένων."^^xsd:string .

:TV_Line_495_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_495 ;
  :text "Μισῶ γε μέντοι χὤταν ἐν κακοῖσί τις"^^xsd:string .

:TV_Line_496_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_496 ;
  :text "ἁλοὺς ἔπειτα τοῦτο καλλύνειν θέλῃ."^^xsd:string .

:TV_Line_497_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_497 ;
  :text "Θέλεις τι μεῖζον ἢ κατακτεῖναί μ ̓ ἑλών;"^^xsd:string .

:TV_Line_498_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_498 ;
  :text "Ἐγὼ μὲν οὐδέν· τοῦτ ̓ ἔχων ἅπαντ ̓ ἔχω."^^xsd:string .

:TV_Line_499_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_499 ;
  :text "Τί δῆτα μέλλεις; ὡς ἐμοὶ τῶν σῶν λόγων"^^xsd:string .

:TV_Line_500_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_500 ;
  :text "ἀρεστὸν οὐδέν, μηδ ̓ ἀρεσθείη ποτέ,"^^xsd:string .

:TV_Line_501_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_501 ;
  :text "οὕτω δὲ καὶ σοὶ τἄμ ̓ ἀφανδάνοντ ̓ ἔφυ."^^xsd:string .

:TV_Line_502_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_502 ;
  :text "Καίτοι πόθεν κλέος γ ̓ ἂν εὐκλεέστερον"^^xsd:string .

:TV_Line_503_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_503 ;
  :text "κατέσχον ἢ τὸν αὐτάδελφον ἐν τάφῳ"^^xsd:string .

:TV_Line_504_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_504 ;
  :text "τιθεῖσα; τούτοις τοῦτο πᾶσιν ἁνδάνειν"^^xsd:string .

:TV_Line_505_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_505 ;
  :text "λέγοιτ ̓ ἄν, εἰ μὴ γλῶσσαν ἐγκλῄοι φόβος."^^xsd:string .

:TV_Line_506_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_506 ;
  :text "Ἀλλ ̓ ἡ τυραννὶς πολλά τ ̓ ἄλλ ̓ εὐδαιμονεῖ"^^xsd:string .

:TV_Line_507_grc
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_507 ;
  :text "κἄξεστιν αὐτῇ δρᾶν λέγειν θ ̓ ἃ βούλεται."^^xsd:string .

