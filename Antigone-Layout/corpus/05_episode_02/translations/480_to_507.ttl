@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Translation variants for lines 480-507


:TV_Line_480_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_480 ;
  :text "This girl knew full well how to commit a crime,"^^xsd:string .

:TV_Line_481_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_481 ;
  :text "And she has transgressed the law that I established:"^^xsd:string .

:TV_Line_482_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_482 ;
  :text "But she’s committed a second outrage"^^xsd:string .

:TV_Line_483_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_483 ;
  :text "By being proud of what she’s done and laughing with self-congratulation."^^xsd:string .

:TV_Line_484_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_484 ;
  :text "Now either I’m no man, or she’s become one,"^^xsd:string .

:TV_Line_485_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_485 ;
  :text "If she’s to win such a victory without any retribution."^^xsd:string .

:TV_Line_486_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_486 ;
  :text "I don’t care that she’s my sister’s child—"^^xsd:string .

:TV_Line_487_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_487 ;
  :text "And even if she were closer to me than my own wife or son,"^^xsd:string .

:TV_Line_488_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_488 ;
  :text "She and her sister"^^xsd:string .

:TV_Line_489_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_489 ;
  :text "will never avoid this horrible fate—"^^xsd:string .

:TV_Line_490_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_490 ;
  :text "I think her sister holds an equal share Of the blame for plotting this burial."^^xsd:string .

:TV_Line_491_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_491 ;
  :text "Go! Summon her! For I see her now,"^^xsd:string .

:TV_Line_492_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_492 ;
  :text "Raving about in there like she’s lost her mind."^^xsd:string .

:TV_Line_493_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_493 ;
  :text "When someone’s concocting a villainous scheme,"^^xsd:string .

:TV_Line_494_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_494 ;
  :text "Their mind will often betray"^^xsd:string .

:TV_Line_495_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_495 ;
  :text "Their guilt before the act is done."^^xsd:string .

:TV_Line_496_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_496 ;
  :text "I hate it, too, when a criminal Who’s been caught tries to glorify their crime."^^xsd:string .

:TV_Line_497_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_497 ;
  :text "What more do you want than my death?"^^xsd:string .

:TV_Line_498_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_498 ;
  :text "Nothing: once I have that, I’ll have everything."^^xsd:string .

:TV_Line_499_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_499 ;
  :text "Why then do you delay?"^^xsd:string .

:TV_Line_500_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_500 ;
  :text "Nothing you say pleases me—"^^xsd:string .

:TV_Line_501_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_501 ;
  :text "And I hope it never does—And nothing I do pleases you."^^xsd:string .

:TV_Line_502_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_502 ;
  :text "What greater glory could I have gained"^^xsd:string .

:TV_Line_503_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_503 ;
  :text "Than placing my own brother In his grave."^^xsd:string .

:TV_Line_504_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_504 ;
  :text "You could tell that everyone here Is happy to hear this,"^^xsd:string .

:TV_Line_505_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_505 ;
  :text "if fear did not shut their mouths."^^xsd:string .

:TV_Line_506_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_506 ;
  :text "But tyranny has many blessings—"^^xsd:string .

:TV_Line_507_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_507 ;
  :text "In particular it can do and say whatever it wants."^^xsd:string .
