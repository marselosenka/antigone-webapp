@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Translation variants for lines 563-581

:TV_Line_563_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_563 ;
  :text "For never, my lord, does the reason that is born with us remain"^^xsd:string .

:TV_Line_564_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_564 ;
  :text "for those who fare ill, but it departs."^^xsd:string .

:TV_Line_565_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_565 ;
  :text "Certainly for you, when you chose to do such evil things with such evil people."^^xsd:string .

:TV_Line_566_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_566 ;
  :text "What kind of life could I live, alone, separated from her?"^^xsd:string .

:TV_Line_567_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_567 ;
  :text "But as for 'this woman,' speak not; for she exists no longer."^^xsd:string .

:TV_Line_568_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_568 ;
  :text "You’re really going to kill your own son’s bride?"^^xsd:string .

:TV_Line_569_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_569 ;
  :text "For there are other fields for him to plow."^^xsd:string .

:TV_Line_570_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_570 ;
  :text "No one is as well matched to him as she is."^^xsd:string .

:TV_Line_571_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_571 ;
  :text "I hate it when sons take horrid wives."^^xsd:string .

:TV_Line_572_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_572 ;
  :text "O Haemon dear, how your father insults you!"^^xsd:string .

:TV_Line_573_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_573 ;
  :text "You and your marriage-talk are an excessive grief to me."^^xsd:string .

:TV_Line_574_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_574 ;
  :text "Will you really deprive your son of his own wife?"^^xsd:string .

:TV_Line_575_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_575 ;
  :text "It is Hades who shall put a stop to these marriages."^^xsd:string .

:TV_Line_576_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_576 ;
  :text "It’s settled, then. She is to die."^^xsd:string .

:TV_Line_577_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_577 ;
  :text "To you and to me. No more delays! But now,"^^xsd:string .

:TV_Line_578_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_578 ;
  :text "servants, take them inside; from this time forth"^^xsd:string .

:TV_Line_579_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_579 ;
  :text "these women must be kept bound and not left free."^^xsd:string .

:TV_Line_580_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_580 ;
  :text "For even the brave flee, whenever they see"^^xsd:string .

:TV_Line_581_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_581 ;
  :text "Hades already standing close to their life."^^xsd:string .
