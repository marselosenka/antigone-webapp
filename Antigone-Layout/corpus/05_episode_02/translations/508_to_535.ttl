@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# Translation variants for lines 508-535


:TV_Line_508_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_508 ;
  :text "You’re the only one in Thebes who sees things this way."^^xsd:string .

:TV_Line_509_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_509 ;
  :text "They all see it but they hold their tongues for you."^^xsd:string .

:TV_Line_510_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_510 ;
  :text "Wouldn’t you be ashamed if they disagreed with you?"^^xsd:string .

:TV_Line_511_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_511 ;
  :text "There’s no shame in respecting one’s own flesh and blood."^^xsd:string .

:TV_Line_512_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_512 ;
  :text "Didn’t he die fighting his own flesh and blood?"^^xsd:string .

:TV_Line_513_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_513 ;
  :text "A brother from the same mother and the same father, yes."^^xsd:string .

:TV_Line_514_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_514 ;
  :text "Then how can you heap praises on someone so godless?"^^xsd:string .

:TV_Line_515_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_515 ;
  :text "The dead man would not agree with that."^^xsd:string .


:TV_Line_516_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_516 ;
  :text "If you honor him equally with the impious one."^^xsd:string .

:TV_Line_517_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_517 ;
  :text "It was his brother, not some slave who perished."^^xsd:string .

:TV_Line_518_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_518 ;
  :text "The one ravaging this land, the other standing in its defense."^^xsd:string .


:TV_Line_519_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_519 ;
  :text "Nevertheless, Hades demands these rites."^^xsd:string .

:TV_Line_520_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_520 ;
  :text "But the good man does not deserve a lot equal to the wicked."^^xsd:string .

:TV_Line_521_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_521 ;
  :text "Who knows what the gods consider holy?"^^xsd:string .

:TV_Line_522_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_522 ;
  :text "Your enemy’s never your friend, not even when he’s dead."^^xsd:string .

:TV_Line_523_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_523 ;
  :text "I was born to join in love, not in hate."^^xsd:string .

:TV_Line_524_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_524 ;
  :text "Go then below, and if you must love, love those there;"^^xsd:string .


:TV_Line_525_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_525 ;
  :text "but while I live, no woman shall rule me."^^xsd:string .

:TV_Line_526_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_526 ;
  :text "Behold! Ismene before the palace gates,"^^xsd:string .

:TV_Line_527_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_527 ;
  :text "Letting her brother-loving tears flow:"^^xsd:string .

:TV_Line_528_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_528 ;
  :text "And a cloud over her brows drops a bloody"^^xsd:string .

:TV_Line_529_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_529 ;
  :text "stain upon her face,"^^xsd:string .

:TV_Line_530_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_530 ;
  :text "drenching her fair cheek."^^xsd:string .

:TV_Line_531_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_531 ;
  :text "You, sitting in the palace like a viper, lurking,"^^xsd:string .


:TV_Line_532_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_532 ;
  :text "draining me in secret, and I did not realize"^^xsd:string .


:TV_Line_533_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_533 ;
  :text "I was nurturing two ruins and subverters of the throne."^^xsd:string .

:TV_Line_534_en a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_534 ;
  :text "Come, tell me now, do you also in this burial"^^xsd:string .

:TV_Line_535_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_535 ;
  :text "or will you swear you knew nothing of it?"^^xsd:string .
