# ==========================
# Characters & Entities
# ==========================

:Antigone_Character_Chorus
    a :Character ;
    :role "Chorus of Theban Elders"^^xsd:string ;
    :hasMotivation :Motivation_CleanseThebes, :Motivation_InvokeHealer ;
    :experiencesEmotion :Emotion_ReligiousFervor, :Emotion_DesperateHope, :Emotion_DesperateReverence ;
    :referencesMyth :Myth_Semele, :Myth_DragonsTeeth, :Myth_Nysa .

:Antigone_Character_Dionysus
    a :Character ;
    :role "Deity (Invoked)"^^xsd:string ;
    :description "The god Dionysus (Bacchus, Iacchus), protector and patron of Thebes, invoked to heal the city."^^xsd:string .

# ==========================
# Themes & Motivations
# ==========================

:Theme_DivineIntervention
    a :Theme ;
    :description "The reliance on gods to cure civic ailments (plague/miasma) that human agency cannot fix."^^xsd:string .

:Theme_CivicPollution
    a :Theme ;
    :description "Miasma: The concept of the city being infected by a moral or physical disease mirroring the royal house's corruption."^^xsd:string .

:Theme_DionysianWorship
    a :Theme ;
    :description "Ritualistic elements: dancing, fire, night-wandering, and frenzy associated with Bacchus."^^xsd:string .

:Theme_Hope
    a :Theme ;
    :description "The desperate anticipation for divine salvation."^^xsd:string .

:Motivation_CleanseThebes
    a :Motivation ;
    :description "The urgent desire to purify the city and invoke a healer to remove the curse."^^xsd:string .

:Motivation_InvokeHealer
    a :Motivation ;
    :description "The specific act of calling upon Dionysus to come with 'cleansing foot'."^^xsd:string .

# ==========================
# Emotions & Myths
# ==========================

:Emotion_ReligiousFervor
    a :Emotion ;
    :description "Intense, frenzied devotion and praise directed at the deity."^^xsd:string .

:Emotion_DesperateHope
    a :Emotion ;
    :description "Anxiety mixed with the reverence and hope that the god will arrive in time."^^xsd:string .

:Myth_Semele
    a :MythologicalBackground ;
    :description "Semele, the Cadmean bride and mother of Bacchus, associated with the city's divine lineage."^^xsd:string .

:Myth_DragonsTeeth
    a :MythologicalBackground ;
    :description "The founding myth of Thebes (Ismenian) involving the slaying of the dragon and the sowing of the Spartoi."^^xsd:string .

:Myth_Nysa
    a :MythologicalBackground ;
    :description "The ivy-clad slopes of Nysa associated with the raising and epiphany of Dionysus."^^xsd:string .

# ==========================
# Context & Conventions
# ==========================

:Convention_ChoralOde
    a :AthenianTragedyConvention ;
    :description "Lyric song performed by the Chorus, providing religious elevation and community voice."^^xsd:string .

:Context_ThebanPlague
    a :HistoricalContext ;
    :description "The sickness affecting Thebes, requiring ritual purification (Catharsis)."^^xsd:string .

:Conflict_ThebesVsPlague
    a :Conflict ;
    :description "The struggle between the city's survival and the spreading spiritual/physical pollution."^^xsd:string .