@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:episode_04-translations-872-928-english a owl:Ontology .
# English translation variants extracted from 872_to_928.ttl

:TV_Line_872_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Your prayers may be reverent,"^^xsd:string ;
    :relatedTo :Line_872 .

:TV_Line_873_en a owl:NamedIndividual, :TranslationVariant ;
    :text "But they are in no way tolerable to those in power."^^xsd:string ;
    :relatedTo :Line_873 .

:TV_Line_875_en a owl:NamedIndividual, :TranslationVariant ;
    :text "The rage you wished for has ruined you."^^xsd:string ;
    :relatedTo :Line_875 .

:TV_Line_876_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Unwept, unloved, unwed,"^^xsd:string ;
    :relatedTo :Line_876 .

:TV_Line_877_en a owl:NamedIndividual, :TranslationVariant ;
    :text "I am led in misery"^^xsd:string ;
    :relatedTo :Line_877 .

:TV_Line_878_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Down this final path."^^xsd:string ;
    :relatedTo :Line_878 .

:TV_Line_879_en a owl:NamedIndividual, :TranslationVariant ;
    :text "No more can I, unhappy girl,"^^xsd:string ;
    :relatedTo :Line_879 .

:TV_Line_880_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Behold the sacred eye of the flaming sun."^^xsd:string ;
    :relatedTo :Line_880 .

:TV_Line_881_en a owl:NamedIndividual, :TranslationVariant ;
    :text "No friend moans in grief"^^xsd:string ;
    :relatedTo :Line_881 .

:TV_Line_882_en a owl:NamedIndividual, :TranslationVariant ;
    :text "And no tears are wept for my fate."^^xsd:string ;
    :relatedTo :Line_882 .

:TV_Line_883_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Who would end their dying song"^^xsd:string ;
    :relatedTo :Line_883 .

:TV_Line_884_en a owl:NamedIndividual, :TranslationVariant ;
    :text "If they knew the final note would be their last?"^^xsd:string ;
    :relatedTo :Line_884 .

:TV_Line_885_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Bring her as fast as you can, and leave her"^^xsd:string ;
    :relatedTo :Line_885 .

:TV_Line_886_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Alone, sealed in that shadowy tomb—as I’ve ordered you to."^^xsd:string ;
    :relatedTo :Line_886 .

:TV_Line_887_en a owl:NamedIndividual, :TranslationVariant ;
    :text "She’ll either die right then and there,"^^xsd:string ;
    :relatedTo :Line_887 .

:TV_Line_888_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Or she’ll live entombed in that room—the decision is hers."^^xsd:string ;
    :relatedTo :Line_888 .

:TV_Line_889_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Our hands are clean as far as this girl is concerned."^^xsd:string ;
    :relatedTo :Line_889 .

:TV_Line_890_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Her place on this earth is gone."^^xsd:string ;
    :relatedTo :Line_890 .

:TV_Line_891_en a owl:NamedIndividual, :TranslationVariant ;
    :text "O tomb, o bridal chamber, o deep-dug"^^xsd:string ;
    :relatedTo :Line_891 .

:TV_Line_892_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Everlasting home, the place I go"^^xsd:string ;
    :relatedTo :Line_892 .

:TV_Line_893_en a owl:NamedIndividual, :TranslationVariant ;
    :text "To join my own, a greatest number of whom"^^xsd:string ;
    :relatedTo :Line_893 .

:TV_Line_894_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Persephone has welcomed among the dead;"^^xsd:string ;
    :relatedTo :Line_894 .

:TV_Line_895_en a owl:NamedIndividual, :TranslationVariant ;
    :text "I am the last of them and I will descend most shamefully"^^xsd:string ;
    :relatedTo :Line_895 .

:TV_Line_896_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Before my time on earth can be properly spent."^^xsd:string ;
    :relatedTo :Line_896 .

:TV_Line_897_en a owl:NamedIndividual, :TranslationVariant ;
    :text "But when I go, I cherish the thought"^^xsd:string ;
    :relatedTo :Line_897 .

:TV_Line_898_en a owl:NamedIndividual, :TranslationVariant ;
    :text "That I will go dear to my father, and dear to you,"^^xsd:string ;
    :relatedTo :Line_898 .

:TV_Line_899_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Mother, and dear to you, my brother."^^xsd:string ;
    :relatedTo :Line_899 .

:TV_Line_900_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Since when each of you died I washed you"^^xsd:string ;
    :relatedTo :Line_900 .

:TV_Line_901_en a owl:NamedIndividual, :TranslationVariant ;
    :text "With my own hands, and adorned you, and poured out"^^xsd:string ;
    :relatedTo :Line_901 .

:TV_Line_902_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Funeral libations—and now, Polyneices,"^^xsd:string ;
    :relatedTo :Line_902 .

:TV_Line_903_en a owl:NamedIndividual, :TranslationVariant ;
    :text "This is my reward for burying you!"^^xsd:string ;
    :relatedTo :Line_903 .

:TV_Line_904_en a owl:NamedIndividual, :TranslationVariant ;
    :text "And yet, in the eyes of the wise, I honored you well."^^xsd:string ;
    :relatedTo :Line_904 .

:TV_Line_905_en a owl:NamedIndividual, :TranslationVariant ;
    :text "If I were a mother of children,"^^xsd:string ;
    :relatedTo :Line_905 .

:TV_Line_906_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Or if my husband rotted away dead,"^^xsd:string ;
    :relatedTo :Line_906 .

:TV_Line_907_en a owl:NamedIndividual, :TranslationVariant ;
    :text "I would never have taken on this burden without public support."^^xsd:string ;
    :relatedTo :Line_907 .

:TV_Line_908_en a owl:NamedIndividual, :TranslationVariant ;
    :text "But what law am I saying all this for?"^^xsd:string ;
    :relatedTo :Line_908 .

:TV_Line_909_en a owl:NamedIndividual, :TranslationVariant ;
    :text "If my husband had died, I could’ve found another,"^^xsd:string ;
    :relatedTo :Line_909 .

:TV_Line_910_en a owl:NamedIndividual, :TranslationVariant ;
    :text "And if I had lost my first child, another man could’ve fathered my second,"^^xsd:string ;
    :relatedTo :Line_910 .

:TV_Line_911_en a owl:NamedIndividual, :TranslationVariant ;
    :text "But with my mother and my father both sealed away in Hades,"^^xsd:string ;
    :relatedTo :Line_911 .

:TV_Line_912_en a owl:NamedIndividual, :TranslationVariant ;
    :text "I can never have a new brother."^^xsd:string ;
    :relatedTo :Line_912 .

:TV_Line_913_en a owl:NamedIndividual, :TranslationVariant ;
    :text "For such a law I honored you above all others,"^^xsd:string ;
    :relatedTo :Line_913 .

:TV_Line_914_en a owl:NamedIndividual, :TranslationVariant ;
    :text "But to Creon I seemed to act wrongfully"^^xsd:string ;
    :relatedTo :Line_914 .

:TV_Line_915_en a owl:NamedIndividual, :TranslationVariant ;
    :text "And to be terribly reckless, dear brother!"^^xsd:string ;
    :relatedTo :Line_915 .

:TV_Line_916_en a owl:NamedIndividual, :TranslationVariant ;
    :text "And now he leads me thus by the hands,"^^xsd:string ;
    :relatedTo :Line_916 .

:TV_Line_917_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Without a marriage bed, without a bridal song, receiving no share"^^xsd:string ;
    :relatedTo :Line_917 .

:TV_Line_918_en a owl:NamedIndividual, :TranslationVariant ;
    :text "In marriage or the nurture of children,"^^xsd:string ;
    :relatedTo :Line_918 .

:TV_Line_919_en a owl:NamedIndividual, :TranslationVariant ;
    :text "But in this way, deserted by loved ones, ill-fated,"^^xsd:string ;
    :relatedTo :Line_919 .

:TV_Line_920_en a owl:NamedIndividual, :TranslationVariant ;
    :text "I come living to the graves of the dead."^^xsd:string ;
    :relatedTo :Line_920 .

:TV_Line_921_en a owl:NamedIndividual, :TranslationVariant ;
    :text "What holy law did I violate?"^^xsd:string ;
    :relatedTo :Line_921 .

:TV_Line_922_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Why must I, unhappy girl, still look to the gods?"^^xsd:string ;
    :relatedTo :Line_922 .

:TV_Line_923_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Who should I call my ally, when pious behavior"^^xsd:string ;
    :relatedTo :Line_923 .

:TV_Line_924_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Has incurred me the charge of impiety."^^xsd:string ;
    :relatedTo :Line_924 .

:TV_Line_925_en a owl:NamedIndividual, :TranslationVariant ;
    :text "But if these things please the gods,"^^xsd:string ;
    :relatedTo :Line_925 .

:TV_Line_927_en a owl:NamedIndividual, :TranslationVariant ;
    :text "After my suffering I will come to know what I have done wrong."^^xsd:string ;
    :relatedTo :Line_927 .

:TV_Line_928_en a owl:NamedIndividual, :TranslationVariant ;
    :text "But if my judges are found guilty, may they suffer no more greatly than I have suffered at their unjust hands."^^xsd:string ;
    :relatedTo :Line_928 .
