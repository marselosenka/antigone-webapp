@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:episode_04-translations-806-822-english a owl:Ontology .
# English translation variants extracted from 806_to_822.ttl

:TV_Line_806_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Look at me, o citizens of my fatherland, as I set out"^^xsd:string ;
    :relatedTo :Line_806 .

:TV_Line_807_en a owl:NamedIndividual, :TranslationVariant ;
    :text "on my last journey, as I gaze upon my last sunlight,"^^xsd:string ;
    :relatedTo :Line_807 .

:TV_Line_810_en a owl:NamedIndividual, :TranslationVariant ;
    :text "But Hades, who puts all to sleep, leads me, still living,"^^xsd:string ;
    :relatedTo :Line_810 .

:TV_Line_811_en a owl:NamedIndividual, :TranslationVariant ;
    :text "To Acheron’s shore, without the bridal song"^^xsd:string ;
    :relatedTo :Line_811 .

:TV_Line_812_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Which I was due."^^xsd:string ;
    :relatedTo :Line_812 .

:TV_Line_815_en a owl:NamedIndividual, :TranslationVariant ;
    :text "No song has been sung for me at my marriage, but instead I shall wed Acheron."^^xsd:string ;
    :relatedTo :Line_815 .

:TV_Line_817_en a owl:NamedIndividual, :TranslationVariant ;
    :text "And so in renown and with praise"^^xsd:string ;
    :relatedTo :Line_817 .

:TV_Line_818_en a owl:NamedIndividual, :TranslationVariant ;
    :text "You journey to the corpse-filled depths,"^^xsd:string ;
    :relatedTo :Line_818 .

:TV_Line_819_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Neither lashed by flesh-wasting plague"^^xsd:string ;
    :relatedTo :Line_819 .

:TV_Line_820_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Nor chancing upon death by sword;"^^xsd:string ;
    :relatedTo :Line_820 .

:TV_Line_821_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Rather, living alone and self-determined,"^^xsd:string ;
    :relatedTo :Line_821 .

:TV_Line_822_en a owl:NamedIndividual, :TranslationVariant ;
    :text "You attain for yourself the Death of mortals."^^xsd:string ;
    :relatedTo :Line_822 .
