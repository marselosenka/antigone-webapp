@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:episode_04-translations-806-822-greek a owl:Ontology .

:TV_Line_806_gr a :TranslationVariant ;
    :text "Δείτε με, πολίτες της πατρικής μου γης, να βαδίζω την τελευταία οδό"^^xsd:string ;
    :relatedTo :Line_806 .

:TV_Line_807_gr a :TranslationVariant ;
    :text "και να κοιτάζω το τελευταίο φως του ήλιου,"^^xsd:string ;
    :relatedTo :Line_807 .

:TV_Line_810_gr a :TranslationVariant ;
    :text "ποτέ πια ξανά· αλλά ο Άδης που όλους κοιμίζει με οδηγεί ζωντανή"^^xsd:string ;
    :relatedTo :Line_810 .

:TV_Line_811_gr a :TranslationVariant ;
    :text "στην ακτή"^^xsd:string ;
    :relatedTo :Line_811 .

:TV_Line_812_gr a :TranslationVariant ;
    :text "του Αχέροντα, χωρίς μερίδιο σε γαμήλιο ύμνο, ούτε σε νυφικό κρεβάτι."^^xsd:string ;
    :relatedTo :Line_812 .

:TV_Line_815_gr a :TranslationVariant ;
    :text "Κανένας ύμνος δεν υμνήθηκε ποτέ για μένα στους γάμους· τον Αχέροντα θα νυμφευτώ."^^xsd:string ;
    :relatedTo :Line_815 .

:TV_Line_817_gr a :TranslationVariant ;
    :text "Άρα, με δόξα και έπαινο"^^xsd:string ;
    :relatedTo :Line_817 .

:TV_Line_818_gr a :TranslationVariant ;
    :text "πηγαίνεις σε αυτό το βάθος των νεκρών,"^^xsd:string ;
    :relatedTo :Line_818 .

:TV_Line_819_gr a :TranslationVariant ;
    :text "χωρίς να έχεις χτυπηθεί από φθισική αρρώστια"^^xsd:string ;
    :relatedTo :Line_819 .

:TV_Line_820_gr a :TranslationVariant ;
    :text "ούτε να έχεις λάχει θάνατο από ξίφος,"^^xsd:string ;
    :relatedTo :Line_820 .

:TV_Line_821_gr a :TranslationVariant ;
    :text "αλλά αυτόνομη, ζωντανή, μόνη,"^^xsd:string ;
    :relatedTo :Line_821 .

:TV_Line_822_gr a :TranslationVariant ;
    :text "θα κατεβείς στον Άδη όπως κανένας θνητός."^^xsd:string ;
    :relatedTo :Line_822 .

