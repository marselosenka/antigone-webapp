@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:episode_04-translations-929-943-greek a owl:Ontology .

:TV_Line_929_gr a :TranslationVariant ;
    :text "Ακόμα οι ίδιες ριπές των ανέμων"^^xsd:string ;
    :relatedTo :Line_929 .

:TV_Line_930_gr a :TranslationVariant ;
    :text "κρατούν αυτή την ψυχή."^^xsd:string ;
    :relatedTo :Line_930 .

:TV_Line_931_gr a :TranslationVariant ;
    :text "Γι’ αυτό, σε όσους την οδηγούν,"^^xsd:string ;
    :relatedTo :Line_931 .

:TV_Line_932_gr a :TranslationVariant ;
    :text "θα πέσουν κλάματα για τη βραδύτητά τους."^^xsd:string ;
    :relatedTo :Line_932 .

:TV_Line_933_gr a :TranslationVariant ;
    :text "Αλίμονο, ο λόγος αυτός"^^xsd:string ;
    :relatedTo :Line_933 .

:TV_Line_934_gr a :TranslationVariant ;
    :text "έφτασε πάρα πολύ κοντά στον θάνατο."^^xsd:string ;
    :relatedTo :Line_934 .

:TV_Line_935_gr a :TranslationVariant ;
    :text "Δεν έχω καμιά παρηγοριά να σας δώσω,"^^xsd:string ;
    :relatedTo :Line_935 .

:TV_Line_936_gr a :TranslationVariant ;
    :text "πως δεν θα της συμβούν αυτά."^^xsd:string ;
    :relatedTo :Line_936 .

:TV_Line_937_gr a :TranslationVariant ;
    :text "Ω πόλη της πατρικής Θήβας"^^xsd:string ;
    :relatedTo :Line_937 .

:TV_Line_938_gr a :TranslationVariant ;
    :text "και θεοί προγεννήτορες,"^^xsd:string ;
    :relatedTo :Line_938 .

:TV_Line_939_gr a :TranslationVariant ;
    :text "με οδηγούν τώρα και δεν καθυστερώ άλλο."^^xsd:string ;
    :relatedTo :Line_939 .

:TV_Line_940_gr a :TranslationVariant ;
    :text "Κοιτάξτε, άρχοντες της Θήβας,"^^xsd:string ;
    :relatedTo :Line_940 .

:TV_Line_941_gr a :TranslationVariant ;
    :text "την τελευταία που έμεινε από τη βασιλική γενιά,"^^xsd:string ;
    :relatedTo :Line_941 .

:TV_Line_942_gr a :TranslationVariant ;
    :text "τι πάσχω, και από ποιους ανθρώπους,"^^xsd:string ;
    :relatedTo :Line_942 .

:TV_Line_943_gr a :TranslationVariant ;
    :text "επειδή σεβάστηκα την ευσέβεια!"^^xsd:string ;
    :relatedTo :Line_943 .

