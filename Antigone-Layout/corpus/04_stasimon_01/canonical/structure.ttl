@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:stasimon01-structure a owl:Ontology .


# --- 331 ---
:Line_331 a owl:NamedIndividual, :Line ; 
    :lineNumber 331 ; 
    :canonicalReference "331"^^xsd:string ;
    :text "σωθεὶς ὀφείλω τοῖς θεοῖς πολλὴν χάριν."^^xsd:string .

# --- 332 ---
:Line_332 a owl:NamedIndividual, :Line ; 
    :lineNumber 332 ; 
    :canonicalReference "332"^^xsd:string ;
    :text "Πολλὰ τὰ δεινὰ κοὐδὲν"^^xsd:string . # Group 32

# --- 333 ---
:Line_333 a owl:NamedIndividual, :Line ; 
    :lineNumber 333 ; 
    :canonicalReference "333"^^xsd:string ;
    :text "ανθρώπου δεινότερον πέλει·"^^xsd:string .

# --- 334 ---
:Line_334 a owl:NamedIndividual, :Line ; 
    :lineNumber 334 ; 
    :canonicalReference "334"^^xsd:string ;
    :text "τοῦτο καὶ πολιοῦ πέραν"^^xsd:string .

# --- 335 ---
:Line_335 a owl:NamedIndividual, :Line ; 
    :lineNumber 335 ; 
    :canonicalReference "335"^^xsd:string ;
    :text "πόντου χειμερίῳ νότῳ"^^xsd:string .

# --- 336 ---
:Line_336 a owl:NamedIndividual, :Line ; 
    :lineNumber 336 ; 
    :canonicalReference "336"^^xsd:string ;
    :text "χωρεῖ, περιβρυχίοισιν"^^xsd:string .

# --- 337 ---
:Line_337 a owl:NamedIndividual, :Line ; 
    :lineNumber 337 ; 
    :canonicalReference "337"^^xsd:string ;
    :text "περῶν ὑπ ̓ οἴδμασιν, θεῶν"^^xsd:string .

# --- 338 ---
:Line_338 a owl:NamedIndividual, :Line ; 
    :lineNumber 338 ; 
    :canonicalReference "338"^^xsd:string ;
    :text "τε τὰν ὑπερτάταν, Γᾶν"^^xsd:string .

# --- 339 ---
:Line_339 a owl:NamedIndividual, :Line ; 
    :lineNumber 339 ; 
    :canonicalReference "339"^^xsd:string ;
    :text "ἄφθιτον, ἀκαμάταν, ἀποτρύεται,"^^xsd:string .

# --- 340 ---
:Line_340 a owl:NamedIndividual, :Line ; 
    :lineNumber 340 ; 
    :canonicalReference "340"^^xsd:string ;
    :text "ἰλλομένων ἀρότρων ἔτος εἰς ἔτος,"^^xsd:string .

# --- 341 ---
:Line_341 a owl:NamedIndividual, :Line ; 
    :lineNumber 341 ; 
    :canonicalReference "341"^^xsd:string ;
    :text "ἱππείῳ γένει πολεύων."^^xsd:string .

# --- 342 ---
:Line_342 a owl:NamedIndividual, :Line ; 
    :lineNumber 342 ; 
    :canonicalReference "342"^^xsd:string ;
    :text "Κουφονόων τε φῦλον ὀρ-"^^xsd:string .

# --- 343 ---
:Line_343 a owl:NamedIndividual, :Line ; 
    :lineNumber 343 ; 
    :canonicalReference "343"^^xsd:string ;
    :text "νίθων ἀμφιβαλὼν ἀγρεῖ"^^xsd:string .

# --- 344 ---
:Line_344 a owl:NamedIndividual, :Line ; 
    :lineNumber 344 ; 
    :canonicalReference "344"^^xsd:string ;
    :text "καὶ θηρῶν ἀγρίων ἔθνη"^^xsd:string .

# --- 345 ---
:Line_345 a owl:NamedIndividual, :Line ; 
    :lineNumber 345 ; 
    :canonicalReference "345"^^xsd:string ;
    :text "πόντου τ ̓ εἰναλίαν φύσιν"^^xsd:string .

# --- 346 ---
:Line_346 a owl:NamedIndividual, :Line ; 
    :lineNumber 346 ; 
    :canonicalReference "346"^^xsd:string ;
    :text "σπείραισι δικτυοκλώστοις,"^^xsd:string .

# --- 347 ---
:Line_347 a owl:NamedIndividual, :Line ; 
    :lineNumber 347 ; 
    :canonicalReference "347"^^xsd:string ;
    :text "περιφραδὴς ἀνήρ· κρατεῖ"^^xsd:string .

# --- 348 ---
:Line_348 a owl:NamedIndividual, :Line ; 
    :lineNumber 348 ; 
    :canonicalReference "348"^^xsd:string ;
    :text "δὲ μηχαναῖς ἀγραύλου"^^xsd:string .

# --- 349 ---
#:Line_349 a owl:NamedIndividual, :Line ; 
#    :lineNumber 349 ; 
#    :canonicalReference "349"^^xsd:string ;
#    :text "θηρὸς ὀρεσσιβάτα, λασιαύχενά θ ̓"^^xsd:string .

# --- 350 ---
:Line_350 a owl:NamedIndividual, :Line ; 
    :lineNumber 350 ; 
    :canonicalReference "350"^^xsd:string ;
    :text "θηρὸς ὀρεσσιβάτα, λασιαύχενά θ᾽"^^xsd:string .

# --- 351 ---
:Line_351 a owl:NamedIndividual, :Line ; 
    :lineNumber 351 ; 
    :canonicalReference "351"^^xsd:string ;
    :text "ἵππον ὑπαξέμεν ἀμφίλοφον ζυγὸν"^^xsd:string .

# --- 352 ---
:Line_352 a owl:NamedIndividual, :Line ; 
    :lineNumber 352 ; 
    :canonicalReference "352"^^xsd:string ;
    :text "οὔρειόν τʼ ἀκμῆτα ταῦρον."^^xsd:string .

# --- 353 ---
#:Line_353 a owl:NamedIndividual, :Line ; 
#    :lineNumber 353 ; 
#    :canonicalReference "353"^^xsd:string ;
#    :text "φρόνημα καὶ ἀστυνόμους"^^xsd:string .

# --- 354 ---
#:Line_354 a owl:NamedIndividual, :Line ; 
#    :lineNumber 354 ; 
#    :canonicalReference "354"^^xsd:string ;
#    :text "ὀργὰς ἐδιδάξατο, καὶ δυσαύλων"^^xsd:string .

# --- 355 ---
:Line_355 a owl:NamedIndividual, :Line ; 
    :lineNumber 355 ; 
    :canonicalReference "355"^^xsd:string ;
    :text "καὶ φθέγμα καὶ ἀνεμόεν φρόνημα καὶ ἀστυνόμους"^^xsd:string .

# --- 356 ---
:Line_356 a owl:NamedIndividual, :Line ; 
    :lineNumber 356 ; 
    :canonicalReference "356"^^xsd:string ;
    :text "ὀργὰς ἐδιδάξατο καὶ δυσαύλων"^^xsd:string .

# --- 357 ---
:Line_357 a owl:NamedIndividual, :Line ; 
    :lineNumber 357 ; 
    :canonicalReference "357"^^xsd:string ;
    :text "πάγων ὑπαίθρεια καὶ δύσομβρα φεύγειν βέλη"^^xsd:string .

# --- 358 ---
:Line_358 a owl:NamedIndividual, :Line ; 
    :lineNumber 358 ; 
    :canonicalReference "358"^^xsd:string ;
    :text "παντοπόρος· ἄπορος ἐπʼ οὐδὲν ἔρχεται"^^xsd:string .

# --- 359 ---
#:Line_359 a owl:NamedIndividual, :Line ; 
#    :lineNumber 359 ; 
#    :canonicalReference "359"^^xsd:string ;
#    :text "φεῦξιν οὐκ ἐπάξεται·"^^xsd:string .

# --- 360 ---
:Line_360 a owl:NamedIndividual, :Line ; 
    :lineNumber 360 ; 
    :canonicalReference "360"^^xsd:string ;
    :text "τὸ μέλλον· Ἅιδα μόνον φεῦξιν οὐκ ἐπάξεται·"^^xsd:string .

# --- 361 ---
:Line_361 a owl:NamedIndividual, :Line ; 
    :lineNumber 361 ; 
    :canonicalReference "361"^^xsd:string ;
    :text "νόσων δʼ ἀμηχάνων φυγὰς ξυμπέφρασται."^^xsd:string .

# 362-365 does not exist in Anigone.

# --- 366 ---
:Line_366 a owl:NamedIndividual, :Line ;
  :lineNumber 366 ; 
  :canonicalReference "366"^^xsd:string ;
  :text "τοτὲ μὲν κακόν, ἄλλοτʼ ἐπʼ ἐσθλὸν ἕρπει,"^^xsd:string .

# --- 367 ---
:Line_367 a owl:NamedIndividual, :Line ;
  :lineNumber 367 ; 
  :canonicalReference "367"^^xsd:string ;
  :text "νόμους γεραίρων χθονὸς θεῶν τʼ ἔνορκον δίκαν,"^^xsd:string .

# --- 368 ---
#:Line_368 a owl:NamedIndividual, :Line ;
#  :lineNumber 368 ; 
#  :canonicalReference "368"^^xsd:string ;

# --- 369 ---
#:Line_369 a owl:NamedIndividual, :Line ;
#  :lineNumber 369 ; 
#  :canonicalReference "369"^^xsd:string ;
#  :text "τόδε· πῶς εἰδὼς ἀντιλογήσω"^^xsd:string .

# --- 370 ---
:Line_370 a owl:NamedIndividual, :Line ;
  :lineNumber 370 ; 
  :canonicalReference "370"^^xsd:string ;
  :text "ὑψίπολις· ἄπολις ὅτῳ τὸ μὴ καλὸν"^^xsd:string .


# --- 371 ---
:Line_371 a owl:NamedIndividual, :Line ;
  :lineNumber 371 ; 
  :canonicalReference "371"^^xsd:string ;
  :text "ξύνεστι τόλμας χάριν. μήτʼ ἐμοὶ παρέστιος"^^xsd:string .

# --- 372 ---
#:Line_372 a owl:NamedIndividual, :Line ;
#  :lineNumber 372 ; 
#  :canonicalReference "372"^^xsd:string .

# --- 373 ---
#:Line_373 a owl:NamedIndividual, :Line ;
#  :lineNumber 373 ; 
#  :canonicalReference "373"^^xsd:string .

# --- 374 ---
#:Line_374 a owl:NamedIndividual, :Line ;
#  :lineNumber 374 ; 
#  :canonicalReference "374"^^xsd:string .

# --- 375 ---
:Line_375 a owl:NamedIndividual, :Line ;
  :lineNumber 375 ; 
  :canonicalReference "375"^^xsd:string ;
  :text "γένοιτο μήτʼ ἴσον φρονῶν ὃς τάδʼ ἔρδει."^^xsd:string .

# --- 376 ---
:Line_376 a owl:NamedIndividual, :Line ;
  :lineNumber 376 ; 
  :canonicalReference "376"^^xsd:string ;
  :text "ἐς δαιμόνιον τέρας ἀμφινοῶ"^^xsd:string .

# --- 377 ---
:Line_377 a owl:NamedIndividual, :Line ;
  :lineNumber 377 ; 
  :canonicalReference "377"^^xsd:string ;
  :text "τόδε· πῶς εἰδὼς ἀντιλογήσω"^^xsd:string .

# --- 378 ---
:Line_378 a owl:NamedIndividual, :Line ;
  :lineNumber 378 ; 
  :canonicalReference "378"^^xsd:string ;
  :text "τήν δʼ οὐκ εἶναι παῖδʼ Ἀντιγόνην."^^xsd:string .

# --- 379 ---
:Line_379 a owl:NamedIndividual, :Line ;
  :lineNumber 379 ; 
  :canonicalReference "379"^^xsd:string ;
  :text "ὦ δύστηνος"^^xsd:string .

# --- 380 ---
:Line_380 a owl:NamedIndividual, :Line ;
  :lineNumber 380 ; 
  :canonicalReference "380"^^xsd:string ;
  :text "καὶ δυστήνου πατρὸς Οἰδιπόδα,"^^xsd:string .

# --- 381 ---
:Line_381 a owl:NamedIndividual, :Line ;
  :lineNumber 381 ; 
  :canonicalReference "381"^^xsd:string ;
  :text "τί ποτʼ; οὐ δή που σέ γʼ ἀπιστοῦσαν"^^xsd:string .

# --- 382 ---
:Line_382 a owl:NamedIndividual, :Line ;
  :lineNumber 382 ; 
  :canonicalReference "382"^^xsd:string ;
  :text "τοῖς βασιλείοισιν ἄγουσι νόμοις"^^xsd:string .

# --- 383 ---
:Line_383 a owl:NamedIndividual, :Line ;
  :lineNumber 383 ; 
  :canonicalReference "383"^^xsd:string ;
  :text "καὶ ἐν ἀφροσύνῃ καθελόντες;"^^xsd:string .
