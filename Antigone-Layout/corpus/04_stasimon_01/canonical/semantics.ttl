:stasimon01-semantics a owl:Ontology .

:Antigone_Scene_Stasimon_1_331_383
  a :Scene ;
  :sceneNumber "Stasimon 1 (331-383)"^^xsd:string ;
  :hasSpeech :Speech_Guard_327_331,
             :Speech_Chorus_332_361,
             :Speech_Chorus_362_382,
             :Speech_Guard_383 ;
  :developsTheme :Theme_HumanPowerAndLimits,
                 :Theme_LawAndCity,
                 :Theme_ForeshadowingAntigone .

