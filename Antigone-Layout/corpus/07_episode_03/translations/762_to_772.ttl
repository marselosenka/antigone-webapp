@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:TV_Line_762_en a owl:NamedIndividual, :TranslationVariant ;
    :text "No, don’t hold your breath on that—"^^xsd:string ;
    :relatedTo :Line_762 .

:TV_Line_763_en a owl:NamedIndividual, :TranslationVariant ;
    :text "She will not die beside me, and you will never"^^xsd:string ;
    :relatedTo :Line_763 ;
    :makesMoralDecision :MoralDecision_LeaveCreon .

:TV_Line_764_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Look upon this face again with your two eyes,"^^xsd:string ;
    :relatedTo :Line_764 ;
    :hasMotivation :Motivation_AbandonFather ;
    :hasConflict :Conflict_FatherVsSon .

:TV_Line_765_en a owl:NamedIndividual, :TranslationVariant ;
    :text "As you rant and rave to whatever friends will let you."^^xsd:string ;
    :relatedTo :Line_765 ;
    :experiencesEmotion :Emotion_Ranting ;
    :hasTheme :Theme_TyrantIsolation .

:TV_Line_766_en a owl:NamedIndividual, :TranslationVariant ;
    :text "The boy, your majesty, stormed out in anger."^^xsd:string ;
    :relatedTo :Line_766 ;
    :experiencesEmotion :Emotion_Anger ;
    :relatedTo :Event_StormingOut .

:TV_Line_767_en a owl:NamedIndividual, :TranslationVariant ;
    :text "At his age the mind grows resentful when it feels pain."^^xsd:string ;
    :relatedTo :Line_767 ;
    :experiencesEmotion :Emotion_Resentment ;
    :experiencesEmotion :Emotion_Pain ;
    :relatedTo :Event_YouthfulPain ;
    :relatedTo :Event_Resentment ;
    :hasTheme :Theme_YouthfulRashness .

:TV_Line_768_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Let him go, let him concoct some superhuman plan:"^^xsd:string ;
    :relatedTo :Line_768 .

:TV_Line_769_en a owl:NamedIndividual, :TranslationVariant ;
    :text "He will not free these two girls from their fate."^^xsd:string ;
    :relatedTo :Line_769 ;
    :hasMotivation :Motivation_EnsureExecution .

:TV_Line_770_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Do you intend to kill them both?"^^xsd:string ;
    :relatedTo :Line_770 .

:TV_Line_771_en a owl:NamedIndividual, :TranslationVariant ;
    :text "You have a point. Not the one who kept her hands clean."^^xsd:string ;
    :relatedTo :Line_771 ;
    :makesMoralDecision :MoralDecision_SpareIsmene ;
    :advocatesFor :EthicalPrinciple_SpareTheInnocent ;
    :relatedTo :Cause_KeptHandsClean ;
    :relatedTo :Effect_SparedFromDeath ;
    :hasTheme :Theme_GuiltAndInnocence .

:TV_Line_772_en a owl:NamedIndividual, :TranslationVariant ;
    :text "And how do you plan to kill the other?"^^xsd:string ;
    :relatedTo :Line_772 .