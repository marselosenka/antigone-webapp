@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:episode_03-translations-635-680-greek a owl:Ontology .

:TV_Line_637_gr a :TranslationVariant ;
    :text "γιατί κανένας γάμος για μένα δεν θα θεωρηθεί"^^xsd:string ;
    :relatedTo :Line_637 .

:TV_Line_638_gr a :TranslationVariant ;
    :text "σημαντικότερος από το να με καθοδηγείς σωστά εσύ."^^xsd:string ;
    :relatedTo :Line_638 .

:TV_Line_639_gr a :TranslationVariant ;
    :text "έτσι πρέπει, παιδί μου, να το κρατάς βαθιά στο στήθος,"^^xsd:string ;
    :relatedTo :Line_639 .

:TV_Line_640_gr a :TranslationVariant ;
    :text "γι' αυτό οι άντρες εύχονται να αποκτήσουν παιδιά"^^xsd:string ;
    :relatedTo :Line_640 .

:TV_Line_642_gr a :TranslationVariant ;
    :text "και να τα έχουν στο σπίτι υπάκουα,"^^xsd:string ;
    :relatedTo :Line_642 .

:TV_Line_643_gr a :TranslationVariant ;
    :text "ώστε να ανταποδίδουν στον εχθρό κακό με κακό"^^xsd:string ;
    :relatedTo :Line_643 .

:TV_Line_644_gr a :TranslationVariant ;
    :text "και να τιμούν τον φίλο ισάξια, όπως ο πατέρας."^^xsd:string ;
    :relatedTo :Line_644 .

:TV_Line_645_gr a :TranslationVariant ;
    :text "κι αυτόν τι άλλο θα έλεγες, παρά ότι γεννά για τον εαυτό του συμφορές"^^xsd:string ;
    :relatedTo :Line_645 .

:TV_Line_647_gr a :TranslationVariant ;
    :text "παγωμένη αγκαλιά γίνεται αυτό,"^^xsd:string ;
    :relatedTo :Line_647 .

:TV_Line_651_gr a :TranslationVariant ;
    :text "μπορεί να υπάρξει μεγαλύτερη πληγή από έναν κακό φίλο;"^^xsd:string ;
    :relatedTo :Line_651 .

:TV_Line_653_gr a :TranslationVariant ;
    :text "αυτή την κόρη να τη νυμφεύσει κάποιος στον Άδη."^^xsd:string ;
    :relatedTo :Line_653 .

:TV_Line_655_gr a :TranslationVariant ;
    :text "αυτήν, τη μόνη απ’ όλη την πόλη, που απείστησε,"^^xsd:string ;
    :relatedTo :Line_655 .

:TV_Line_657_gr a :TranslationVariant ;
    :text "δεν θα φανώ εγώ ψεύτης μέσα στην πόλη,"^^xsd:string ;
    :relatedTo :Line_657 .

:TV_Line_658_gr a :TranslationVariant ;
    :text "γιατί όποιος είναι άντρας στα ίδια του τα οικεία"^^xsd:string ;
    :relatedTo :Line_658 .

:TV_Line_662_gr a :TranslationVariant ;
    :text "κι όποιος παραβαίνει ή βιάζει τους νόμους,"^^xsd:string ;
    :relatedTo :Line_662 .

:TV_Line_664_gr a :TranslationVariant ;
    :text "ή νομίζει πως θα διατάζει αυτούς που κρατούν την εξουσία,"^^xsd:string ;
    :relatedTo :Line_664 .

:TV_Line_665_gr a :TranslationVariant ;
    :text "αυτός δεν μπορεί να πάρει έπαινο από μένα."^^xsd:string ;
    :relatedTo :Line_665 .

:TV_Line_666_gr a :TranslationVariant ;
    :text "και στα μικρά και στα δίκαια και στα αντίθετά τους."^^xsd:string ;
    :relatedTo :Line_666 .

:TV_Line_668_gr a :TranslationVariant ;
    :text "κι αυτόν τον άντρα εγώ θα τον εμπιστευόμουν"^^xsd:string ;
    :relatedTo :Line_668 .

:TV_Line_669_gr a :TranslationVariant ;
    :text "και να άρχει καλά και να θέλει να άρχεται σωστά,"^^xsd:string ;
    :relatedTo :Line_669 .

:TV_Line_670_gr a :TranslationVariant ;
    :text "και μέσα στη θύελλα του δόρατος, στη θέση του"^^xsd:string ;
    :relatedTo :Line_670 .

:TV_Line_671_gr a :TranslationVariant ;
    :text "να στέκεται δίκαιος και γενναίος παραστάτης."^^xsd:string ;
    :relatedTo :Line_671 .

:TV_Line_672_gr a :TranslationVariant ;
    :text "η αναρχία γκρεμίζει σπίτια, και το συμμαχικό δόρυ"^^xsd:string ;
    :relatedTo :Line_672 .

:TV_Line_675_gr a :TranslationVariant ;
    :text "σπάει και συντρίβει τις παρατάξεις· ενώ όσοι στέκουν όρθιοι,"^^xsd:string ;
    :relatedTo :Line_675 .

:TV_Line_676_gr a :TranslationVariant ;
    :text "αυτοί σώζονται όταν υπάρχει τάξη και πειθαρχία."^^xsd:string ;
    :relatedTo :Line_676 .

:TV_Line_678_gr a :TranslationVariant ;
    :text "γιατί καλύτερα, αν χρειαστεί, να πέσουμε από άντρα,"^^xsd:string ;
    :relatedTo :Line_678 .

:TV_Line_680_gr a :TranslationVariant ;
    :text "παρά να ακουστεί πως μας νίκησε γυναίκα."^^xsd:string ;
    :relatedTo :Line_680 .
