@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:episode_03-translations-681-723-chinese a owl:Ontology .

:TV_Line_681_zh a :TranslationVariant ; :relatedTo :Line_681 ; :text "若不是年老使我神智不清，"^^xsd:string .
:TV_Line_682_zh a :TranslationVariant ; :relatedTo :Line_682 ; :text "那你说得确实有理。"^^xsd:string .
:TV_Line_683_zh a :TranslationVariant ; :relatedTo :Line_683 ; :text "父亲，诸神赐人理性，"^^xsd:string .
:TV_Line_684_zh a :TranslationVariant ; :relatedTo :Line_684 ; :text "那是人可得诸品质中最尊者。"^^xsd:string .
:TV_Line_685_zh a :TranslationVariant ; :relatedTo :Line_685 ; :text "我不敢说，也不愿说"^^xsd:string .
:TV_Line_686_zh a :TranslationVariant ; :relatedTo :Line_686 ; :text "你处理此事全然不当……"^^xsd:string .
:TV_Line_687_zh a :TranslationVariant ; :relatedTo :Line_687 ; :text "但不同意见中也许有可取之益。"^^xsd:string .
:TV_Line_688_zh a :TranslationVariant ; :relatedTo :Line_688 ; :text "而我作为你的儿子，有责任替你留心"^^xsd:string .
:TV_Line_689_zh a :TranslationVariant ; :relatedTo :Line_689 ; :text "每当有人言语、行动，或把手指向你之时。"^^xsd:string .
:TV_Line_690_zh a :TranslationVariant ; :relatedTo :Line_690 ; :text "你的目光令平民畏惧，叫他不得不"^^xsd:string .
:TV_Line_691_zh a :TranslationVariant ; :relatedTo :Line_691 ; :text "把你不愿听的话吞回去。"^^xsd:string .
:TV_Line_692_zh a :TranslationVariant ; :relatedTo :Line_692 ; :text "可我在暗处倾听，听见"^^xsd:string .
:TV_Line_693_zh a :TranslationVariant ; :relatedTo :Line_693 ; :text "全城都在为这少女哀叹，"^^xsd:string .
:TV_Line_694_zh a :TranslationVariant ; :relatedTo :Line_694 ; :text "说众女子之中最不该死得如此可耻的，"^^xsd:string .
:TV_Line_695_zh a :TranslationVariant ; :relatedTo :Line_695 ; :text "正是她，只因她做了善行，"^^xsd:string .
:TV_Line_696_zh a :TranslationVariant ; :relatedTo :Line_696 ; :text "只因她不肯让自己的兄弟"^^xsd:string .
:TV_Line_697_zh a :TranslationVariant ; :relatedTo :Line_697 ; :text "横尸血泊而无人掩埋，"^^xsd:string .
:TV_Line_698_zh a :TranslationVariant ; :relatedTo :Line_698 ; :text "任食肉恶犬与猛禽撕食。"^^xsd:string .
:TV_Line_699_zh a :TranslationVariant ; :relatedTo :Line_699 ; :text "她难道不配得镀金般的荣耀吗？"^^xsd:string .
:TV_Line_700_zh a :TranslationVariant ; :relatedTo :Line_700 ; :text "这些低语在本沉默的城中流转。"^^xsd:string .
:TV_Line_701_zh a :TranslationVariant ; :relatedTo :Line_701 ; :text "我想不出有何珍宝比你的安泰"^^xsd:string .
:TV_Line_702_zh a :TranslationVariant ; :relatedTo :Line_702 ; :text "更为宝贵，父亲。"^^xsd:string .
:TV_Line_703_zh a :TranslationVariant ; :relatedTo :Line_703 ; :text "对孩子来说，还有什么荣誉能大过"^^xsd:string .
:TV_Line_704_zh a :TranslationVariant ; :relatedTo :Line_704 ; :text "父亲昌盛之名；对父亲来说，也同样如此？"^^xsd:string .
:TV_Line_705_zh a :TranslationVariant ; :relatedTo :Line_705 ; :text "所以别只把一种看法锁在心里，"^^xsd:string .
:TV_Line_706_zh a :TranslationVariant ; :relatedTo :Line_706 ; :text "说只有这一种是对，其余都错。"^^xsd:string .
:TV_Line_707_zh a :TranslationVariant ; :relatedTo :Line_707 ; :text "自以为自己见识无人能及的人，"^^xsd:string .
:TV_Line_708_zh a :TranslationVariant ; :relatedTo :Line_708 ; :text "或自认舌辩、心智无人可比的人，"^^xsd:string .
:TV_Line_709_zh a :TranslationVariant ; :relatedTo :Line_709 ; :text "一旦剖开，往往只显空虚。"^^xsd:string .
:TV_Line_710_zh a :TranslationVariant ; :relatedTo :Line_710 ; :text "人即便有智慧，也不以"^^xsd:string .
:TV_Line_711_zh a :TranslationVariant ; :relatedTo :Line_711 ; :text "偏离己见并从中学习为耻。"^^xsd:string .
:TV_Line_712_zh a :TranslationVariant ; :relatedTo :Line_712 ; :text "你看河岸上的树，肯弯下细枝"^^xsd:string .
:TV_Line_713_zh a :TranslationVariant ; :relatedTo :Line_713 ; :text "让湍急雪水之流通过，便能自保；"^^xsd:string .
:TV_Line_714_zh a :TranslationVariant ; :relatedTo :Line_714 ; :text "而太刚硬的树则被连根拔去。"^^xsd:string .
:TV_Line_715_zh a :TranslationVariant ; :relatedTo :Line_715 ; :text "同样，船长若把帆绷得"^^xsd:string .
:TV_Line_716_zh a :TranslationVariant ; :relatedTo :Line_716 ; :text "紧到一丝不让，最终桅杆折断，"^^xsd:string .
:TV_Line_717_zh a :TranslationVariant ; :relatedTo :Line_717 ; :text "余程便只能弃帆划桨。"^^xsd:string .
:TV_Line_718_zh a :TranslationVariant ; :relatedTo :Line_718 ; :text "所以请让步，让怒气平息。"^^xsd:string .
:TV_Line_719_zh a :TranslationVariant ; :relatedTo :Line_719 ; :text "若我可以有意见（虽我年少），"^^xsd:string .
:TV_Line_720_zh a :TranslationVariant ; :relatedTo :Line_720 ; :text "我以为最好不过的是，人人生来"^^xsd:string .
:TV_Line_721_zh a :TranslationVariant ; :relatedTo :Line_721 ; :text "都满有智慧与知识。"^^xsd:string .
:TV_Line_722_zh a :TranslationVariant ; :relatedTo :Line_722 ; :text "但若这不可能，且通常并非如此，"^^xsd:string .
:TV_Line_723_zh a :TranslationVariant ; :relatedTo :Line_723 ; :text "那就应当学会听从说得对的话。"^^xsd:string .

