@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:episode_03-translations-635-680-chinese a owl:Ontology .

:TV_Line_635_zh a :TranslationVariant ; :relatedTo :Line_635 ; :text "父亲，我是你的儿子，你也最了解我，"^^xsd:string .
:TV_Line_636_zh a :TranslationVariant ; :relatedTo :Line_636 ; :text "你把我引上正路，我正循此而行。"^^xsd:string .
:TV_Line_637_zh a :TranslationVariant ; :relatedTo :Line_637 ; :text "我绝不会把任何婚姻"^^xsd:string .
:TV_Line_638_zh a :TranslationVariant ; :relatedTo :Line_638 ; :text "置于你明智教导之上。"^^xsd:string .
:TV_Line_639_zh a :TranslationVariant ; :relatedTo :Line_639 ; :text "好，因为事情就该这样处置，"^^xsd:string .
:TV_Line_640_zh a :TranslationVariant ; :relatedTo :Line_640 ; :text "而你必须始终支持你父亲的判断。"^^xsd:string .
:TV_Line_641_zh a :TranslationVariant ; :relatedTo :Line_641 ; :text "这正是父母祈求"^^xsd:string .
:TV_Line_642_zh a :TranslationVariant ; :relatedTo :Line_642 ; :text "儿女顺从的缘故："^^xsd:string .
:TV_Line_643_zh a :TranslationVariant ; :relatedTo :Line_643 ; :text "好叫他们能与敌人针锋相对，"^^xsd:string .
:TV_Line_644_zh a :TranslationVariant ; :relatedTo :Line_644 ; :text "并像父亲那样敬重亲人。"^^xsd:string .
:TV_Line_645_zh a :TranslationVariant ; :relatedTo :Line_645 ; :text "若养出无用之子，"^^xsd:string .
:TV_Line_646_zh a :TranslationVariant ; :relatedTo :Line_646 ; :text "还能说他做了什么，除了给自己"^^xsd:string .
:TV_Line_647_zh a :TranslationVariant ; :relatedTo :Line_647 ; :text "添更多祸患，并给敌人"^^xsd:string .
:TV_Line_648_zh a :TranslationVariant ; :relatedTo :Line_648 ; :text "提供嘲笑把柄？所以我儿，切莫"^^xsd:string .
:TV_Line_649_zh a :TranslationVariant ; :relatedTo :Line_649 ; :text "为女人之欢而失去理智："^^xsd:string .
:TV_Line_650_zh a :TranslationVariant ; :relatedTo :Line_650 ; :text "你会看见这曾经挚爱的女子变得冰冷，"^^xsd:string .
:TV_Line_651_zh a :TranslationVariant ; :relatedTo :Line_651 ; :text "在你床上、在你家中都成了祸患。"^^xsd:string .
:TV_Line_652_zh a :TranslationVariant ; :relatedTo :Line_652 ; :text "还有什么比虚伪朋友更深地刺伤人？"^^xsd:string .
:TV_Line_653_zh a :TranslationVariant ; :relatedTo :Line_653 ; :text "把这女子当作敌人一样弃绝吧，"^^xsd:string .
:TV_Line_654_zh a :TranslationVariant ; :relatedTo :Line_654 ; :text "让她去与冥府里的人成婚。"^^xsd:string .
:TV_Line_655_zh a :TranslationVariant ; :relatedTo :Line_655 ; :text "我当场抓到她公开违抗"^^xsd:string .
:TV_Line_656_zh a :TranslationVariant ; :relatedTo :Line_656 ; :text "我的命令（在全城中唯她一人）。"^^xsd:string .
:TV_Line_657_zh a :TranslationVariant ; :relatedTo :Line_657 ; :text "我绝不允许人在我城中把谎言混同法度……"^^xsd:string .
:TV_Line_658_zh a :TranslationVariant ; :relatedTo :Line_658 ; :text "我会杀了她。让她去向宙斯祈祷吧，"^^xsd:string .
:TV_Line_659_zh a :TranslationVariant ; :relatedTo :Line_659 ; :text "那位守护家族的神。若我竟容许我自己的亲族"^^xsd:string .
:TV_Line_660_zh a :TranslationVariant ; :relatedTo :Line_660 ; :text "骑在我头上，那人人都会效法："^^xsd:string .
:TV_Line_661_zh a :TranslationVariant ; :relatedTo :Line_661 ; :text "一个连自家都管不好的人，"^^xsd:string .
:TV_Line_662_zh a :TranslationVariant ; :relatedTo :Line_662 ; :text "谁还会信他能治理城邦？"^^xsd:string .
:TV_Line_663_zh a :TranslationVariant ; :relatedTo :Line_663 ; :text "凡破坏、轻贱法令，或自以为"^^xsd:string .
:TV_Line_664_zh a :TranslationVariant ; :relatedTo :Line_664 ; :text "可以命令当权者的人，"^^xsd:string .
:TV_Line_665_zh a :TranslationVariant ; :relatedTo :Line_665 ; :text "在我这里永不可能得到赞许。"^^xsd:string .
:TV_Line_666_zh a :TranslationVariant ; :relatedTo :Line_666 ; :text "人人都必须服从城邦所立的统治者，"^^xsd:string .
:TV_Line_667_zh a :TranslationVariant ; :relatedTo :Line_667 ; :text "无论大事小事、正义或不义之令。"^^xsd:string .
:TV_Line_668_zh a :TranslationVariant ; :relatedTo :Line_668 ; :text "我确信，能把自己"^^xsd:string .
:TV_Line_669_zh a :TranslationVariant ; :relatedTo :Line_669 ; :text "治理好的人，也能治理城邦。"^^xsd:string .
:TV_Line_670_zh a :TranslationVariant ; :relatedTo :Line_670 ; :text "你可信赖那在矛雨下"^^xsd:string .
:TV_Line_671_zh a :TranslationVariant ; :relatedTo :Line_671 ; :text "仍守其位的士兵，那才是真正可靠的人。"^^xsd:string .
:TV_Line_672_zh a :TranslationVariant ; :relatedTo :Line_672 ; :text "没有比不服从更大的罪："^^xsd:string .
:TV_Line_673_zh a :TranslationVariant ; :relatedTo :Line_673 ; :text "它倾覆城邦，使家族"^^xsd:string .
:TV_Line_674_zh a :TranslationVariant ; :relatedTo :Line_674 ; :text "流离失所，使军队溃散。"^^xsd:string .
:TV_Line_675_zh a :TranslationVariant ; :relatedTo :Line_675 ; :text "而在秩序井然之时，"^^xsd:string .
:TV_Line_676_zh a :TranslationVariant ; :relatedTo :Line_676 ; :text "服从权威能保全许多生命。"^^xsd:string .
:TV_Line_677_zh a :TranslationVariant ; :relatedTo :Line_677 ; :text "人必须捍卫社会秩序，"^^xsd:string .
:TV_Line_678_zh a :TranslationVariant ; :relatedTo :Line_678 ; :text "所以不能让自己被女人诱惑。"^^xsd:string .
:TV_Line_679_zh a :TranslationVariant ; :relatedTo :Line_679 ; :text "若真要被推翻，宁可由男人推翻，"^^xsd:string .
:TV_Line_680_zh a :TranslationVariant ; :relatedTo :Line_680 ; :text "也不可被人正当地称作弱于女人。"^^xsd:string .

