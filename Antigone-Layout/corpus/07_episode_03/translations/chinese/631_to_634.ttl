:TV_Line_631_zh a :TranslationVariant ; :relatedTo :Line_631 ;
  :text "我们很快就会看得比先知还清楚。"^^xsd:string .
:TV_Line_632_zh a :TranslationVariant ; :relatedTo :Line_632 ;
