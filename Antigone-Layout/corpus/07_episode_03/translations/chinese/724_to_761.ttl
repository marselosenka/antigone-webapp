@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:episode_03-translations-724-761-chinese a owl:Ontology .

:TV_Line_724_zh a :TranslationVariant ; :relatedTo :Line_724 ; :text "主上，若他说得合宜，你该听他；海蒙，你也当听他：两边都说得有理。"^^xsd:string .
:TV_Line_725_zh a :TranslationVariant ; :relatedTo :Line_725 ; :text "主上，若他说得合宜，你该听他；海蒙，你也当听他：两边都说得有理。"^^xsd:string .
:TV_Line_726_zh a :TranslationVariant ; :relatedTo :Line_726 ; :text "难道我们老到这地步，竟要"^^xsd:string .
:TV_Line_727_zh a :TranslationVariant ; :relatedTo :Line_727 ; :text "由年轻人来教我们？"^^xsd:string .
:TV_Line_728_zh a :TranslationVariant ; :relatedTo :Line_728 ; :text "这并不对：即便我年轻，"^^xsd:string .
:TV_Line_729_zh a :TranslationVariant ; :relatedTo :Line_729 ; :text "也该凭我的行为，不仅凭年纪来判断我。"^^xsd:string .
:TV_Line_730_zh a :TranslationVariant ; :relatedTo :Line_730 ; :text "去尊敬叛逆者，有什么用？"^^xsd:string .
:TV_Line_731_zh a :TranslationVariant ; :relatedTo :Line_731 ; :text "我也不会叫别人去尊敬叛逆者。"^^xsd:string .
:TV_Line_732_zh a :TranslationVariant ; :relatedTo :Line_732 ; :text "她难道不正患了这种病吗？"^^xsd:string .
:TV_Line_733_zh a :TranslationVariant ; :relatedTo :Line_733 ; :text "全底比斯都不同意你。"^^xsd:string .
:TV_Line_734_zh a :TranslationVariant ; :relatedTo :Line_734 ; :text "如今要由城邦来教我怎么统治？"^^xsd:string .
:TV_Line_735_zh a :TranslationVariant ; :relatedTo :Line_735 ; :text "你看不出你说得多幼稚吗？"^^xsd:string .
:TV_Line_736_zh a :TranslationVariant ; :relatedTo :Line_736 ; :text "难道我该按别人的意见来治理此地？"^^xsd:string .
:TV_Line_737_zh a :TranslationVariant ; :relatedTo :Line_737 ; :text "若城只属于一人，那便不叫城。"^^xsd:string .
:TV_Line_738_zh a :TranslationVariant ; :relatedTo :Line_738 ; :text "城难道不该由执政者来统治？"^^xsd:string .
:TV_Line_739_zh a :TranslationVariant ; :relatedTo :Line_739 ; :text "我看你在荒野里统治会很风光。"^^xsd:string .
:TV_Line_740_zh a :TranslationVariant ; :relatedTo :Line_740 ; :text "看来这家伙站到女人那边去了。"^^xsd:string .
:TV_Line_741_zh a :TranslationVariant ; :relatedTo :Line_741 ; :text "是啊，若你就是女人。我其实是在帮你。"^^xsd:string .
:TV_Line_742_zh a :TranslationVariant ; :relatedTo :Line_742 ; :text "忘恩负义的孩子，竟把你父亲推上被告席！"^^xsd:string .
:TV_Line_743_zh a :TranslationVariant ; :relatedTo :Line_743 ; :text "只因为我看见你犯了错。"^^xsd:string .
:TV_Line_744_zh a :TranslationVariant ; :relatedTo :Line_744 ; :text "我维护自身权威，算是错误吗？"^^xsd:string .
:TV_Line_745_zh a :TranslationVariant ; :relatedTo :Line_745 ; :text "不，但你不能在践踏众神时还敬奉你自己。"^^xsd:string .
:TV_Line_746_zh a :TranslationVariant ; :relatedTo :Line_746 ; :text "肮脏的东西，被女人驱使的奴仆！"^^xsd:string .
:TV_Line_747_zh a :TranslationVariant ; :relatedTo :Line_747 ; :text "你永远不会见我让情欲遮蔽判断。"^^xsd:string .
:TV_Line_748_zh a :TranslationVariant ; :relatedTo :Line_748 ; :text "可你说的每句话都在替她辩护。"^^xsd:string .
:TV_Line_749_zh a :TranslationVariant ; :relatedTo :Line_749 ; :text "也在替你、替我、替地下诸神辩护。"^^xsd:string .
:TV_Line_750_zh a :TranslationVariant ; :relatedTo :Line_750 ; :text "只要她还活着，你就永远不可能娶她。"^^xsd:string .
:TV_Line_751_zh a :TranslationVariant ; :relatedTo :Line_751 ; :text "那她死时会带走另一个人。"^^xsd:string .
:TV_Line_752_zh a :TranslationVariant ; :relatedTo :Line_752 ; :text "你竟敢说出如此狂妄的威胁？"^^xsd:string .
:TV_Line_753_zh a :TranslationVariant ; :relatedTo :Line_753 ; :text "把你的愚妄打算说破，哪算什么威胁？"^^xsd:string .
:TV_Line_754_zh a :TranslationVariant ; :relatedTo :Line_754 ; :text "你一边说一边抱怨，因为你无智。"^^xsd:string .
:TV_Line_755_zh a :TranslationVariant ; :relatedTo :Line_755 ; :text "若你不是我父亲，我会说你疯了。"^^xsd:string .
:TV_Line_756_zh a :TranslationVariant ; :relatedTo :Line_756 ; :text "别在我面前夸口——你是女人的奴隶！"^^xsd:string .
:TV_Line_757_zh a :TranslationVariant ; :relatedTo :Line_757 ; :text "所以你只想自己说，不愿听别人说？"^^xsd:string .
:TV_Line_758_zh a :TranslationVariant ; :relatedTo :Line_758 ; :text "是吗？以奥林波斯起誓，"^^xsd:string .
:TV_Line_759_zh a :TranslationVariant ; :relatedTo :Line_759 ; :text "你高兴就用这些侮辱来骂我吧。"^^xsd:string .
:TV_Line_760_zh a :TranslationVariant ; :relatedTo :Line_760 ; :text "把那可憎的女人立刻带到他眼前，"^^xsd:string .
:TV_Line_761_zh a :TranslationVariant ; :relatedTo :Line_761 ; :text "让她死在他面前，而这新郎只能眼睁睁看着。"^^xsd:string .

