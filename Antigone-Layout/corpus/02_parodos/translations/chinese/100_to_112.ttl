@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:parodos-translations-100-112-chinese a owl:Ontology .

:TV_Line_100_zh a :TranslationVariant ;
    :text "太阳的光芒啊，最美的光，"^^xsd:string ;
    :relatedTo :Line_100 .

:TV_Line_101_zh a :TranslationVariant ;
    :text "曾照耀七门底比斯的光，"^^xsd:string ;
    :relatedTo :Line_101 .

:TV_Line_102_zh a :TranslationVariant ;
    :text "终于显现出来的光啊，"^^xsd:string ;
    :relatedTo :Line_102 .

:TV_Line_103_zh a :TranslationVariant ;
    :text "黄金白昼之眼，"^^xsd:string ;
    :relatedTo :Line_103 .

:TV_Line_104_zh a :TranslationVariant ;
    :text "照耀在狄耳刻河流之上，"^^xsd:string ;
    :relatedTo :Line_104 .

:TV_Line_105_zh a :TranslationVariant ;
    :text "你升临在她奔流的水面之上，"^^xsd:string ;
    :relatedTo :Line_105 .

:TV_Line_106_zh a :TranslationVariant ;
    :text "把来自阿尔戈斯的白盾战士"^^xsd:string ;
    :relatedTo :Line_106 .

:TV_Line_107_zh a :TranslationVariant ;
    :text "那全副武装来攻我们的敌人驱走，"^^xsd:string ;
    :relatedTo :Line_107 .

:TV_Line_108_zh a :TranslationVariant ;
    :text "使他仓皇急退、掉头奔逃，"^^xsd:string ;
    :relatedTo :Line_108 .

:TV_Line_109_zh a :TranslationVariant ;
    :text "被更锐利的缰绳驱迫，"^^xsd:string ;
    :relatedTo :Line_109 .

:TV_Line_110_zh a :TranslationVariant ;
    :text "那是波吕涅刻斯带来的敌军，"^^xsd:string ;
    :relatedTo :Line_110 .

:TV_Line_111_zh a :TranslationVariant ;
    :text "在苦涩纷争中对我邦而来，"^^xsd:string ;
    :relatedTo :Line_111 .

:TV_Line_112_zh a :TranslationVariant ;
    :text "尖啸着，像一只鹰。"^^xsd:string ;
    :relatedTo :Line_112 .

