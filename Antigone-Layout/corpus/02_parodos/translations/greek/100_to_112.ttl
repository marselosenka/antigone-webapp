@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:parodos-translations-100-112-greek a owl:Ontology .

:TV_Line_100_gr a :TranslationVariant ;
    :text "Αχτίδα του ήλιου, το πιο όμορφο"^^xsd:string ;
    :relatedTo :Line_100 .

:TV_Line_101_gr a :TranslationVariant ;
    :text "φως που φάνηκε στην επτάπυλη"^^xsd:string ;
    :relatedTo :Line_101 .

:TV_Line_102_gr a :TranslationVariant ;
    :text "Θήβα, φως από παλιά,"^^xsd:string ;
    :relatedTo :Line_102 .

:TV_Line_103_gr a :TranslationVariant ;
    :text "φάνηκες κάποτε, ω βλέφαρο της χρυσής"^^xsd:string ;
    :relatedTo :Line_103 .

:TV_Line_104_gr a :TranslationVariant ;
    :text "ημέρας, πάνω από τα ρεύματα"^^xsd:string ;
    :relatedTo :Line_104 .

:TV_Line_105_gr a :TranslationVariant ;
    :text "της Δίρκης ερχόμενη,"^^xsd:string ;
    :relatedTo :Line_105 .

:TV_Line_106_gr a :TranslationVariant ;
    :text "και τον λευκάσπιδο άντρα από το Άργος"^^xsd:string ;
    :relatedTo :Line_106 .

:TV_Line_107_gr a :TranslationVariant ;
    :text "που ήρθε με πανάρματο εξοπλισμό"^^xsd:string ;
    :relatedTo :Line_107 .

:TV_Line_108_gr a :TranslationVariant ;
    :text "τον έτρεψες σε φυγή, δραπέτη μπροστά,"^^xsd:string ;
    :relatedTo :Line_108 .

:TV_Line_109_gr a :TranslationVariant ;
    :text "κινώντας τον με πιο κοφτερό χαλινάρι."^^xsd:string ;
    :relatedTo :Line_109 .

:TV_Line_110_gr a :TranslationVariant ;
    :text "Αυτόν, πάνω στη γη μας, ο Πολυνείκης"^^xsd:string ;
    :relatedTo :Line_110 .

:TV_Line_111_gr a :TranslationVariant ;
    :text "τον έφερε, σηκωμένος από διπλές έριδες,"^^xsd:string ;
    :relatedTo :Line_111 .

:TV_Line_112_gr a :TranslationVariant ;
    :text "ως εχθρό· κι εκείνος, κράζοντας οξιά,"^^xsd:string ;
    :relatedTo :Line_112 .
