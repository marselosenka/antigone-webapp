    :hasMotivation :Motivation_KeepPlanSecret ; 
    :makesMoralDecision :MoralDecision_RequestSecrecy ; 
    :hasConflict :Conflict_SecrecyVsWitness ;
    :text "Ἀλλ ̓ οὖν προμηνύσῃς γε τοῦτο μηδενὶ"^^xsd:string .

# --- 085 ---
:Line_085 a :Line ; 
    :lineNumber 85 ; 
    :canonicalReference "85"^^xsd:string ;
    :hasTheme :Theme_SecrecyVsPublicDeclaration ; 
    :hasMotivation :Motivation_KeepPlanSecret ; 
    :hasConflict :Conflict_SecrecyVsWitness ;
    :text "τοὔργον, κρυφῇ δὲ κεῦθε, σὺν δ ̓ αὔτως ἐγώ."^^xsd:string .

# --- 086 ---
:Line_086 a :Line ; 
    :lineNumber 86 ; 
    :canonicalReference "86"^^xsd:string ;
    :hasTheme :Theme_SecrecyVsPublicDeclaration ; 
    :experiencesEmotion :Emotion_ContemptForSilence ; 
    :hasMotivation :Motivation_PublicWitnessForJustice ; 
    :hasConflict :Conflict_SecrecyVsWitness ;
    :text "Οἴμοι, καταύδα· πολλὸν ἐχθίων ἔσῃ"^^xsd:string .

# --- 087 ---
:Line_087 a :Line ; 
    :lineNumber 87 ; 
    :canonicalReference "87"^^xsd:string ;
    :hasTheme :Theme_SecrecyVsPublicDeclaration ; 
    :hasMotivation :Motivation_PublicWitnessForJustice ; 
    :hasConflict :Conflict_SecrecyVsWitness ;
    :text "σιγῶσ ̓, ἐὰν μὴ πᾶσι κηρύξῃς τάδε."^^xsd:string .

# --- 088 ---
:Line_088 a :Line ; 
    :lineNumber 88 ; 
    :canonicalReference "88"^^xsd:string ;
    :hasTheme :Theme_SisterlyCare ; 
    :experiencesEmotion :Emotion_WarmHeartedConcern ;
    :text "Θερμὴν ἐπὶ ψυχροῖσι καρδίαν ἔχεις."^^xsd:string .

