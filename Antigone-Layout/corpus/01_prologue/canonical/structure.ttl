# --- 095 ---
:Line_095 a :Line ; 
    :lineNumber 95 ; 
    :canonicalReference "95"^^xsd:string ; 
    :partOfScene :Antigone_Scene_DialogueAndParodos_90_113 ;
    :hasTheme :Theme_NobleDeath ; 
    :hasMotivation :Motivation_AntigoneAcceptConsequences ; 
    :experiencesEmotion :Emotion_AntigoneResolve ;
    :text "Ἀλλ ̓ ἔα με καὶ τὴν ἐξ ἐμοῦ δυσβουλίαν"^^xsd:string .

# --- 096 ---
:Line_096 a :Line ; 
    :lineNumber 96 ; 
    :canonicalReference "96"^^xsd:string ; 
    :partOfScene :Antigone_Scene_DialogueAndParodos_90_113 ;
    :hasTheme :Theme_NobleDeath ; 
    :hasMotivation :Motivation_AntigoneAcceptConsequences ; 
    :hasConflict :Conflict_LoyaltyToDeadVsFear ;
    :text "παθεῖν τὸ δεινὸν τοῦτο· πείσομαι γὰρ οὐ"^^xsd:string .

# --- 097 ---
:Line_097 a :Line ; 
    :lineNumber 97 ; 
    :canonicalReference "97"^^xsd:string ; 
    :partOfScene :Antigone_Scene_DialogueAndParodos_90_113 ;
