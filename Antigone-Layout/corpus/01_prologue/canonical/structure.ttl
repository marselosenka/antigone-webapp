    :lineNumber 78 ; 
    :canonicalReference "78"^^xsd:string ;
    :hasTheme :Theme_DivineLaw ; 
    :experiencesEmotion :Emotion_Resignation ;
    :text "Ἐγὼ μὲν οὐκ ἄτιμα ποιοῦμαι, τὸ δὲ"^^xsd:string .

# --- 079 ---
:Line_079 a :Line ; 
    :lineNumber 79 ; 
    :canonicalReference "79"^^xsd:string ;
    :hasTheme :Theme_ObedienceToAuthority ; 
    :hasMotivation :Motivation_AvoidForcedAction ; 
    :experiencesEmotion :Emotion_Resignation ; 
    :relatedTo :Law_CivicBurialBan ;
    :text "βίᾳ πολιτῶν δρᾶν ἔφυν ἀμήχανος."^^xsd:string .

# --- 080 ---
