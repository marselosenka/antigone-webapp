    :experiencesEmotion :Emotion_IsmeneConcern ; 
    :hasConflict :Conflict_PrudenceVsHonor ;
    :text "Εἰ καὶ δυνήσῃ γ ̓· ἀλλ ̓ ἀμηχάνων ἐρᾷς."^^xsd:string .

# --- 091 ---
:Line_091 a :Line ; 
    :lineNumber 91 ; 
    :canonicalReference "91"^^xsd:string ; 
    :partOfScene :Antigone_Scene_DialogueAndParodos_90_113 ;
    :hasTheme :Theme_NobleDeath ; 
    :hasMotivation :Motivation_AntigonePersistUntilNoStrength ; 
    :experiencesEmotion :Emotion_AntigoneResolve ;
    :text "Οὐκοῦν, ὅταν δὴ μὴ σθένω, πεπαύσομαι."^^xsd:string .

# --- 092 ---
:Line_092 a :Line ; 
    :lineNumber 92 ; 
    :canonicalReference "92"^^xsd:string ; 
    :partOfScene :Antigone_Scene_DialogueAndParodos_90_113 ;
    :hasTheme :Theme_ImpossibleAction ; 
    :hasMotivation :Motivation_IsmeneDiscourageImpossible ;
    :text "Ἀρχὴν δὲ θηρᾶν οὐ πρέπει τἀμήχανα."^^xsd:string .

# --- 093 ---
:Line_093 a :Line ; 
    :lineNumber 93 ; 
    :canonicalReference "93"^^xsd:string ; 
    :partOfScene :Antigone_Scene_DialogueAndParodos_90_113 ;
    :hasTheme :Theme_SisterlyConflict ; 
    :experiencesEmotion :Emotion_AntigoneDefiance ;
    :text "Εἰ ταῦτα λέξεις, ἐχθαρῇ μὲν ἐξ ἐμοῦ,"^^xsd:string .

# --- 094 ---
:Line_094 a :Line ; 
    :lineNumber 94 ; 
    :canonicalReference "94"^^xsd:string ; 
    :partOfScene :Antigone_Scene_DialogueAndParodos_90_113 ;
    :hasTheme :Theme_HonorDead ; 
    :advocatesFor :EthicalPrinciple_HonorDead ; 
    :hasConflict :Conflict_PrudenceVsHonor ;
