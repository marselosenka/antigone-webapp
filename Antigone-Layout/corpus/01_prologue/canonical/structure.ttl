    :lineNumber 80 ; 
    :canonicalReference "80"^^xsd:string ;
    :hasTheme :Theme_BurialDuty ; 
    :hasConflict :Conflict_SisterlyDivision ; 
    :experiencesEmotion :Emotion_Resolve ;
    :text "Σὺ μὲν τάδ ̓ ἂν προὔχοι ̓· ἐγὼ δὲ δὴ τάφον"^^xsd:string .

# --- 081 ---
:Line_081 a :Line ; 
    :lineNumber 81 ; 
    :canonicalReference "81"^^xsd:string ;
    :hasTheme :Theme_BurialDuty ; 
    :hasMotivation :Motivation_BuryBrotherDespiteRisk ; 
    :makesMoralDecision :MoralDecision_BuryBrotherAndAcceptDeath ; 
    :experiencesEmotion :Emotion_Resolve ;
    :text "χώσουσ ̓ ἀδελφῷ φιλτάτῳ πορεύσομαι."^^xsd:string .

# --- 082 ---
:Line_082 a :Line ; 
    :lineNumber 82 ; 
    :canonicalReference "82"^^xsd:string ;
    :experiencesEmotion :Emotion_FearForAntigone ; 
    :hasTheme :Theme_SisterlyCare ;
    :text "Οἴμοι ταλαίνης ὡς ὑπερδέδοικά σου."^^xsd:string .

# --- 083 ---
:Line_083 a :Line ; 
    :lineNumber 83 ; 
    :canonicalReference "83"^^xsd:string ;
    :hasTheme :Theme_SisterlyDivision ; 
    :experiencesEmotion :Emotion_DefiantCourage ;
    :text "Μὴ  ̓μοῦ προτάρβει· τὸν σὸν ἐξόρθου πότμον."^^xsd:string .

# --- 084 ---
:Line_084 a :Line ; 
    :lineNumber 84 ; 
    :canonicalReference "84"^^xsd:string ;
