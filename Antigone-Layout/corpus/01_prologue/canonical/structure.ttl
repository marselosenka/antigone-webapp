    :makesMoralDecision :MoralDecision_DieNoblyForHonor ; 
    :experiencesEmotion :Emotion_AntigoneResolve ;
    :text "τοσοῦτον οὐδὲν ὥστε μὴ οὐ καλῶς θανεῖν."^^xsd:string .

# --- 098 ---
:Line_098 a :Line ; 
    :lineNumber 98 ; 
    :canonicalReference "98"^^xsd:string ; 
    :partOfScene :Antigone_Scene_DialogueAndParodos_90_113 ;
    :hasTheme :Theme_SisterlyConflict ; 
    :experiencesEmotion :Emotion_IsmeneConcern ;
    :text "Ἀλλ ̓, εἰ δοκεῖ σοι, στεῖχε· τοῦτο δ ̓ ἴσθ ̓ ὅτι"^^xsd:string .

