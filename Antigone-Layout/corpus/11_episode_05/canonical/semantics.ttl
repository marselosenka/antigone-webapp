# ==========================
# Episode 5 Scene Structure
# ==========================

:Antigone_Scene_Episode5
    a :Scene ;
    :sceneNumber "Episode 5"^^xsd:string ;
    :hasSpeech :Speech_Teiresias_Ep5_Part1, :Speech_Creon_Ep5_Part1, :Speech_Teiresias_Ep5_Part2 ;
    :developsTheme :Theme_BlindnessVsSight, :Theme_CivicPollution, :Theme_DivineSilence, :Theme_WisdomFlexibility ;
    :hasConflict :Conflict_StateVsDivinity .

:Antigone_Scene_Episode5_Cont
    a :Scene ;
    :sceneNumber "Episode 5 (Continued)"^^xsd:string ;
    :hasSpeech :Speech_Creon_Ep5_Defense, :Speech_Stichomythia_Ep5 ;
    :developsTheme :Theme_Hybris, :Theme_Corruption, :Theme_WisdomVsFolly, :Theme_StateVsProphecy ;
    :hasConflict :Conflict_KingVsSeer, :Conflict_ProfitVsTruth .

:Antigone_Scene_Episode5_Climax
    a :Scene ;
    :sceneNumber "Episode 5 (Climax)"^^xsd:string ;
    :hasSpeech :Speech_Teiresias_Ep5_Prophecy, :Speech_Chorus_Ep5_Reflection, :Speech_Creon_Ep5_Reversal ;
    :developsTheme :Theme_DivineRetribution, :Theme_Peripeteia, :Theme_CivicPollution, :Theme_NaturalOrder ;
    :hasConflict :Conflict_UpperLowerWorlds, :Conflict_InternalCreon .

