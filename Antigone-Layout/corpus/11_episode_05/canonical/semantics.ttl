# ==========================
# Characters
# ==========================

:Antigone_Character_Teiresias
    a :Character ;
    :role "Seer/Prophet"^^xsd:string ;
    :status "Priest"^^xsd:string ;
    :hasMotivation :Motivation_WarnCreon, :Motivation_RestoreRitualOrder, :Motivation_RevealTruth, :Motivation_PronounceDoom ;
    :experiencesEmotion :Emotion_PropheticDread, :Emotion_Indignation, :Emotion_RighteousAnger ;
    :advocatesFor :Ethical_Amends, :Principle_PrimacyOfReason .

:Antigone_Character_Creon
    a :Character ;
    :role "King of Thebes"^^xsd:string ;
    :hasMotivation :Motivation_HeedProphet, :Motivation_DismissProphecy, :Motivation_AssertAuthority, :Motivation_AvoidRuin ;
    :experiencesEmotion :Emotion_TremblingFear, :Emotion_Paranoia, :Emotion_DefensiveAnger, :Emotion_TerrifiedHesitation, :Emotion_Regret ;
    :makesMoralDecision :Decision_ListenToSeer, :Decision_RevokeEdict ;
    :advocatesFor :Principle_DivineInvulnerability, :Ethical_TraditionalLaws ;
    :tragicFlaw "Stubbornness/Hybris"^^xsd:string ;
    :relatedTo :Event_Peripeteia .

:Antigone_Character_Hephaestus
    a :Character ;
    :role "God of Fire/Forge"^^xsd:string ;
    :description "Ἥφαιστος (Hephaestus), metonymy for the sacrificial fire that failed to ignite."^^xsd:string .

:Antigone_Character_Boy
    a :Character ;
    :role "Guide to Teiresias"^^xsd:string ;
    :description "The eyes for the blind prophet."^^xsd:string .

:Antigone_Character_Polyneices
    a :Character ;
    :role "Deceased"^^xsd:string ;
    :description "The unburied corpse causing the miasma/pollution."^^xsd:string .

:Antigone_Character_Furies
    a :Character ;
    :role "Deities of Vengeance"^^xsd:string ;
    :description "θεῶν Ἐρινύες (Furies), vengeful executioners of Hades who lie in ambush."^^xsd:string .

:Antigone_Character_Haemon
    a :Character ;
    :description "The 'corpse sprung from your own flesh' prophesied by Teiresias."^^xsd:string .

# ==========================
# Themes & Principles
# ==========================

:Theme_BlindnessVsSight
    a :Theme ;
    :description "The paradox where the blind seer sees the truth while the seeing king is blind to reality."^^xsd:string .

:Theme_CivicPollution
    a :Theme ;
    :description "Miasma: The spiritual infection of the city caused by the unburied corpse carried by birds/dogs to altars."^^xsd:string .

:Theme_Hybris
    a :Theme ;
    :description "Creon's arrogance in claiming his will supersedes ritual pollution, even daring Zeus's eagles."^^xsd:string .

:Theme_WisdomVsFolly
    a :Theme ;
    :description "The debate over whether 'reason' (εὐβουλία) is the greatest good and 'thoughtlessness' (μὴ φρονεῖν) the greatest disease."^^xsd:string .

:Principle_DivineInvulnerability
    a :EthicalPrinciple ;
    :description "Creon's misconception that human actions cannot pollute the gods (θεοὺς μιαίνειν οὔτις ἀνθρώπων σθένει)."^^xsd:string .

:Principle_PrimacyOfReason
    a :PhilosophicalConcept ;
    :description "The assertion that sound judgment (εὐβουλία) is the most valuable possession."^^xsd:string .

# ==========================
# Rhetorical Devices & Symbols
# ==========================

:Device_Metaphor_RazorEdge
    a :RhetoricalDevice ;
    :description "The metaphor 'ἐπὶ ξυροῦ τύχης' (on the razor's edge of fortune)."^^xsd:string .

:Device_Simile_Archers
    a :MetaphorSimile ;
    :description "Comparison of the prophet's accusations to a team of archers shooting at a target (τοξόται σκοποῦ)."^^xsd:string .

:Device_Hyperbole_Eagles
    a :RhetoricalDevice ;
    :description "Exaggeration that even if Zeus's eagles (Ζηνὸς αἰετοὶ) carried carrion to the throne, Creon would not yield."^^xsd:string .

:Symbol_FightingBirds
    a :Symbol ;
    :description "The barbarous shrieking and fighting of birds (φθόγγον ὀρνίθων), symbolizing civil breakdown."^^xsd:string .

:Symbol_FailedSacrifice
    a :Symbol ;
    :description "The failure of burnt offerings (ἐμπύρων) to ignite (οὐκ ἔλαμπεν), signifying divine rejection."^^xsd:string .

# ==========================
# Causal & Event Logic
# ==========================

:Causal_Pollution
    a owl:Thing ;
    :description "Polyneices' unburied body -> Carrion birds/dogs carry flesh to altars -> Altars polluted -> Gods reject prayers."^^xsd:string ;
    :relatedTo :Antigone_Character_Polyneices, :Theme_CivicPollution .

:Event_Peripeteia
    a owl:Thing ;
    :description "The moment Creon explicitly states 'My mind has changed' (Reversal of Fortune)."^^xsd:string .