@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

################################################################
# ENGLISH TRANSLATION VARIANTS (Lines 1033 - 1063)
################################################################

:TV_Line_1033_en a :TranslationVariant ;
    :text "Old man, like a whole team of archers taking aim"^^xsd:string ;
    :relatedTo :Line_1033 ;
    :containsRhetoricalDevice :Device_Simile_Archers .

:TV_Line_1034_en a :TranslationVariant ;
    :text "At a single man, I cannot escape the assault"^^xsd:string ;
    :relatedTo :Line_1034 .

:TV_Line_1035_en a :TranslationVariant ;
    :text "Of your oracular art: I’m bandied about"^^xsd:string ;
    :relatedTo :Line_1035 .

:TV_Line_1036_en a :TranslationVariant ;
    :text "By all these fortune-tellers, I’m bought and sold like cargo."^^xsd:string ;
    :relatedTo :Line_1036 ;
    :experiencesEmotion :Emotion_Paranoia .

:TV_Line_1037_en a :TranslationVariant ;
    :text "You’re making a good profit—earning your white gold"^^xsd:string ;
    :relatedTo :Line_1037 ;
    :hasTheme :Theme_Corruption .

:TV_Line_1038_en a :TranslationVariant ;
    :text "From Sardis, and, if you like, even gold from India—"^^xsd:string ;
    :relatedTo :Line_1038 .

:TV_Line_1039_en a :TranslationVariant ;
    :text "But you will not seal that man in a tomb,"^^xsd:string ;
    :relatedTo :Line_1039 .

:TV_Line_1040_en a :TranslationVariant ;
    :text "Not even if the eagles of heaven want to"^^xsd:string ;
    :relatedTo :Line_1040 ;
    :containsRhetoricalDevice :Device_Hyperbole_Eagles .

:TV_Line_1041_en a :TranslationVariant ;
    :text "Carry him off as food for Zeus’ throne—"^^xsd:string ;
    :relatedTo :Line_1041 ;
    :hasTheme :Theme_Hybris .

:TV_Line_1042_en a :TranslationVariant ;
    :text "Even if it meant wiping my hands of this pollution,"^^xsd:string ;
    :relatedTo :Line_1042 .

:TV_Line_1043_en a :TranslationVariant ;
    :text "I will never let that man be buried, for I know well that"^^xsd:string ;
    :relatedTo :Line_1043 .

:TV_Line_1044_en a :TranslationVariant ;
    :text "No mortal can pollute the gods."^^xsd:string ;
    :relatedTo :Line_1044 ;
    :advocatesFor :Principle_DivineInvulnerability .

:TV_Line_1045_en a :TranslationVariant ;
    :text "Men fall, elder Teiresias, even clever men..."^^xsd:string ;
    :relatedTo :Line_1045 .

:TV_Line_1046_en a :TranslationVariant ;
    :text "They fall far and in disgrace when they"^^xsd:string ;
    :relatedTo :Line_1046 .

:TV_Line_1047_en a :TranslationVariant ;
    :text "Lie, however beautifully, for a little extra gold."^^xsd:string ;
    :relatedTo :Line_1047 .

:TV_Line_1048_en a :TranslationVariant ;
    :text "Then does anyone know, does anyone consider..."^^xsd:string ;
    :relatedTo :Line_1048 .

:TV_Line_1049_en a :TranslationVariant ;
    :text "What old saying is this?"^^xsd:string ;
    :relatedTo :Line_1049 .

:TV_Line_1050_en a :TranslationVariant ;
    :text "...That man’s greatest gift is reason?"^^xsd:string ;
    :relatedTo :Line_1050 ;
    :hasTheme :Theme_WisdomVsFolly ;
    :advocatesFor :Principle_PrimacyOfReason .

:TV_Line_1051_en a :TranslationVariant ;
    :text "As surely as madness is our greatest curse.."^^xsd:string ;
    :relatedTo :Line_1051 .

:TV_Line_1052_en a :TranslationVariant ;
    :text "But you have clearly come down with that disease."^^xsd:string ;
    :relatedTo :Line_1052 ;
    :description "Teiresias diagnoses Creon with the disease of thoughtlessness/madness."^^xsd:string .

:TV_Line_1053_en a :TranslationVariant ;
    :text "I won’t trade insults with a prophet."^^xsd:string ;
    :relatedTo :Line_1053 .

:TV_Line_1054_en a :TranslationVariant ;
    :text "And yet you do, in saying that I prophesy falsely."^^xsd:string ;
    :relatedTo :Line_1054 .

:TV_Line_1055_en a :TranslationVariant ;
    :text "All prophets love money."^^xsd:string ;
    :relatedTo :Line_1055 .

:TV_Line_1056_en a :TranslationVariant ;
    :text "All tyrants love theft."^^xsd:string ;
    :relatedTo :Line_1056 ;
    :hasTheme :Theme_StateVsProphecy .

:TV_Line_1057_en a :TranslationVariant ;
    :text "Do you realize that you’re speaking to your king?"^^xsd:string ;
    :relatedTo :Line_1057 ;
    :hasMotivation :Motivation_AssertAuthority .

:TV_Line_1058_en a :TranslationVariant ;
    :text "I do. You only saved the city because of me."^^xsd:string ;
    :relatedTo :Line_1058 .

:TV_Line_1059_en a :TranslationVariant ;
    :text "You’re a wise prophet, and yet you love doing the wrong thing."^^xsd:string ;
    :relatedTo :Line_1059 .

:TV_Line_1060_en a :TranslationVariant ;
    :text "You will force me to utter the holy secret in my heart."^^xsd:string ;
    :relatedTo :Line_1060 ;
    :hasMotivation :Motivation_RevealTruth .

:TV_Line_1061_en a :TranslationVariant ;
    :text "Go on!"^^xsd:string ;
    :relatedTo :Line_1061 .

:TV_Line_1062_en a :TranslationVariant ;
    :text "Tell it, as long as you won’t be talking for profit."^^xsd:string ;
    :relatedTo :Line_1062 .

:TV_Line_1063_en a :TranslationVariant ;
    :text "Hear my words, or no one will profit; You should know you won’t be paid for my decisions."^^xsd:string ;
    :relatedTo :Line_1063 ;
    :hasConflict :Conflict_ProfitVsTruth .


################################################################
# MODERN GREEK TRANSLATION VARIANTS (Lines 1033 - 1063)
################################################################

:TV_Line_1033_Gr a :TranslationVariant ;
    :text "Φτάνει γέρο· κατάλαβα πολύ καλά. Πρώτα με κύκλωσαν ετούτοι εδώ και μου έριξαν τα βέλη τους βροχή"^^xsd:string ;
    :relatedTo :Line_1033 ;
    :containsRhetoricalDevice :Device_Simile_Archers .

:TV_Line_1034_Gr a :TranslationVariant ;
    :text "(Implicit in previous line's 'rain of arrows')"^^xsd:string ;
    :relatedTo :Line_1034 .

:TV_Line_1035_Gr a :TranslationVariant ;
    :text "και ύστερα ήρθε η ράτσα των μάντεων και με φόρτωσε"^^xsd:string ;
    :relatedTo :Line_1035 .

:TV_Line_1036_Gr a :TranslationVariant ;
    :text "και πάει να με πουλήσει."^^xsd:string ;
    :relatedTo :Line_1036 ;
    :experiencesEmotion :Emotion_Paranoia .

:TV_Line_1037_Gr a :TranslationVariant ;
    :text "Εμπόριο κανονικό. Πλουτίζετε εσείς, μαζεύετε ήλεκτρο απ’ τις Σάρδεις"^^xsd:string ;
    :relatedTo :Line_1037 ;
    :hasTheme :Theme_Corruption .

:TV_Line_1038_Gr a :TranslationVariant ;
    :text "και ινδικό χρυσάφι."^^xsd:string ;
    :relatedTo :Line_1038 .

:TV_Line_1039_Gr a :TranslationVariant ;
    :text "Τον Πολυνείκη πάντως δεν θα τον θάψετε, ακόμα"^^xsd:string ;
    :relatedTo :Line_1039 .

:TV_Line_1040_Gr a :TranslationVariant ;
    :text "κι αν κουβαλήσουν οι αετοί του Δία τα βρωμερά"^^xsd:string ;
    :relatedTo :Line_1040 ;
    :containsRhetoricalDevice :Device_Hyperbole_Eagles .

:TV_Line_1041_Gr a :TranslationVariant ;
    :text "κομμάτια του στον Όλυμπο, ακόμα κι αν τα καταβροχθίσουν"^^xsd:string ;
    :relatedTo :Line_1041 ;
    :hasTheme :Theme_Hybris .

:TV_Line_1042_Gr a :TranslationVariant ;
    :text "πάνω στον θρόνο του θεού."^^xsd:string ;
    :relatedTo :Line_1042 .

:TV_Line_1043_Gr a :TranslationVariant ;
    :text "Δεν το φοβάμαι το σίχαμα. Άταφος θα μείνει."^^xsd:string ;
    :relatedTo :Line_1043 .

:TV_Line_1044_Gr a :TranslationVariant ;
    :text "Οι άνθρωποι δεν γίνεται να μιάνουν τους θεούς."^^xsd:string ;
    :relatedTo :Line_1044 ;
    :advocatesFor :Principle_DivineInvulnerability .

:TV_Line_1045_Gr a :TranslationVariant ;
    :text "Μιαίνουν, όμως, την ίδια τους τη ράτσα, γέρο-Τειρεσία,"^^xsd:string ;
    :relatedTo :Line_1045 .

:TV_Line_1046_Gr a :TranslationVariant ;
    :text "όταν τυλίγουν το αίσχος με ωραία λόγια"^^xsd:string ;
    :relatedTo :Line_1046 .

:TV_Line_1047_Gr a :TranslationVariant ;
    :text "και το πουλάνε για καλό."^^xsd:string ;
    :relatedTo :Line_1047 .

:TV_Line_1048_Gr a :TranslationVariant ;
    :text "Δεν ξέρουν οι άνθρωποι. Δεν έμαθαν ποτέ. Δεν μπήκαν καν στον κόπο να σκεφτούν..."^^xsd:string ;
    :relatedTo :Line_1048 .

:TV_Line_1049_Gr a :TranslationVariant ;
    :text "Τι πράγμα; Τι τόσο σπουδαίο μας διαφεύγει;"^^xsd:string ;
    :relatedTo :Line_1049 .

:TV_Line_1050_Gr a :TranslationVariant ;
    :text "Πως δεν υπάρχει μεγαλύτερο αγαθό απ’ την ορθοφροσύνη."^^xsd:string ;
    :relatedTo :Line_1050 ;
    :hasTheme :Theme_WisdomVsFolly ;
    :advocatesFor :Principle_PrimacyOfReason .

:TV_Line_1051_Gr a :TranslationVariant ;
    :text "Εγώ ξέρω σίγουρα πως η αφροσύνη είναι το μεγαλύτερο κακό."^^xsd:string ;
    :relatedTo :Line_1051 .

:TV_Line_1052_Gr a :TranslationVariant ;
    :text "Ναι, γιατί έχεις πάρα πολλή."^^xsd:string ;
    :relatedTo :Line_1052 ;
    :description "Teiresias diagnoses Creon with excessive folly."^^xsd:string .

:TV_Line_1053_Gr a :TranslationVariant ;
    :text "Δεν θ’ απαντήσω. Δεν θέλω ν’ ανταλλάξω άσχημα λόγια μ’ έναν μάντη."^^xsd:string ;
    :relatedTo :Line_1053 .

:TV_Line_1054_Gr a :TranslationVariant ;
    :text "Και τι κάνεις όταν λες πως εμπορεύομαι χρησμούς;"^^xsd:string ;
    :relatedTo :Line_1054 .

:TV_Line_1055_Gr a :TranslationVariant ;
    :text "Είναι γνωστή η φιλαργυρία των μάντεων."^^xsd:string ;
    :relatedTo :Line_1055 .

:TV_Line_1056_Gr a :TranslationVariant ;
    :text "Κι η αισχροκέρδεια των τυράννων."^^xsd:string ;
    :relatedTo :Line_1056 ;
    :hasTheme :Theme_StateVsProphecy .

:TV_Line_1057_Gr a :TranslationVariant ;
    :text "Καταλαβαίνεις πως σ’ ακούνε οι ταγοί σου;"^^xsd:string ;
    :relatedTo :Line_1057 ;
    :hasMotivation :Motivation_AssertAuthority .

:TV_Line_1058_Gr a :TranslationVariant ;
    :text "Ασφαλώς· αφού χάρη στα λόγια μου έσωσες την πόλη."^^xsd:string ;
    :relatedTo :Line_1058 .

:TV_Line_1059_Gr a :TranslationVariant ;
    :text "Είσαι επιδέξιος μάντης. Με τη δικαιοσύνη δεν τα πας καλά."^^xsd:string ;
    :relatedTo :Line_1059 .

:TV_Line_1060_Gr a :TranslationVariant ;
    :text "Με προκαλείς να πω πράγματα που κράτησα μέσα μου μέχρι τώρα."^^xsd:string ;
    :relatedTo :Line_1060 ;
    :hasMotivation :Motivation_RevealTruth .

:TV_Line_1061_Gr a :TranslationVariant ;
    :text "Και δες τα λες!"^^xsd:string ;
    :relatedTo :Line_1061 .

:TV_Line_1062_Gr a :TranslationVariant ;
    :text "Φτάνει να μην είναι κι αυτά πληρωμένα."^^xsd:string ;
    :relatedTo :Line_1062 .

:TV_Line_1063_Gr a :TranslationVariant ;
    :text "Όχι ακόμα. Για να μην τα πληρώσεις εσύ ακριβά θα σου τα πω. / Πρόσεξε τι πας να μου πουλήσεις."^^xsd:string ;
    :relatedTo :Line_1063 ;
    :hasConflict :Conflict_ProfitVsTruth .


################################################################
# ANCIENT GREEK VARIANTS (Lines 1033 - 1063)
################################################################

:TV_Line_1033_grc a :TranslationVariant ;
    :text "ΚΡ. Ὦ πρέσβυ, πάντες ὥστε τοξόται σκοποῦ"^^xsd:string ;
    :relatedTo :Line_1033 ;
    :containsRhetoricalDevice :Device_Simile_Archers .

:TV_Line_1034_grc a :TranslationVariant ;
    :text "τοξεύετ ̓ ἀνδρὸς τοῦδε, κοὐδὲ μαντικῆς"^^xsd:string ;
    :relatedTo :Line_1034 .

:TV_Line_1035_grc a :TranslationVariant ;
    :text "ἄπρακτος ὑμῖν εἰμι, τῶν δ ̓ ὑπαὶ γένους"^^xsd:string ;
    :relatedTo :Line_1035 .

:TV_Line_1036_grc a :TranslationVariant ;
    :text "ἐξημπόλημαι κἀμπεφόρτισμαι πάλαι."^^xsd:string ;
    :relatedTo :Line_1036 ;
    :hasTheme :Theme_Corruption .

:TV_Line_1037_grc a :TranslationVariant ;
    :text "Κερδαίνετ ̓, ἐμπολᾶτε τἀπὸ Σάρδεων"^^xsd:string ;
    :relatedTo :Line_1037 .

:TV_Line_1038_grc a :TranslationVariant ;
    :text "ἤλεκτρον, εἰ βούλεσθε, καὶ τὸν Ἰνδικὸν"^^xsd:string ;
    :relatedTo :Line_1038 .

:TV_Line_1039_grc a :TranslationVariant ;
    :text "χρυσόν· τάφῳ δ ̓ ἐκεῖνον οὐχὶ κρύψετε,"^^xsd:string ;
    :relatedTo :Line_1039 .

:TV_Line_1040_grc a :TranslationVariant ;
    :text "οὐδ ̓ ἢν θέλωσ ̓ οἱ Ζηνὸς αἰετοὶ βορὰν"^^xsd:string ;
    :relatedTo :Line_1040 ;
    :containsRhetoricalDevice :Device_Hyperbole_Eagles .

:TV_Line_1041_grc a :TranslationVariant ;
    :text "φέρειν νιν ἁρπάζοντες ἐς Διὸς θρόνους,"^^xsd:string ;
    :relatedTo :Line_1041 ;
    :hasTheme :Theme_Hybris .

:TV_Line_1042_grc a :TranslationVariant ;
    :text "οὐδ ̓ ὣς μίασμα τοῦτο μὴ τρέσας ἐγὼ"^^xsd:string ;
    :relatedTo :Line_1042 .

:TV_Line_1043_grc a :TranslationVariant ;
    :text "θάπτειν παρήσω κεῖνον· εὖ γὰρ οἶδ ̓ ὅτι"^^xsd:string ;
    :relatedTo :Line_1043 .

:TV_Line_1044_grc a :TranslationVariant ;
    :text "θεοὺς μιαίνειν οὔτις ἀνθρώπων σθένει."^^xsd:string ;
    :relatedTo :Line_1044 ;
    :advocatesFor :Principle_DivineInvulnerability .

:TV_Line_1045_grc a :TranslationVariant ;
    :text "Πίπτουσι δ ̓, ὦ γεραιὲ Τειρεσία, βροτῶν"^^xsd:string ;
    :relatedTo :Line_1045 .

:TV_Line_1046_grc a :TranslationVariant ;
    :text "χοἰ πολλὰ δεινοὶ πτώματ ̓ αἴσχρ ̓, ὅταν λόγους"^^xsd:string ;
    :relatedTo :Line_1046 .

:TV_Line_1047_grc a :TranslationVariant ;
    :text "αἰσχροὺς καλῶς λέγωσι τοῦ κέρδους χάριν."^^xsd:string ;
    :relatedTo :Line_1047 .

:TV_Line_1048_grc a :TranslationVariant ;
    :text "ΤΕΙ. Φεῦ· ἆρ ̓ οἶδεν ἀνθρώπων τις, ἆρα φράζεται,"^^xsd:string ;
    :relatedTo :Line_1048 .

:TV_Line_1049_grc a :TranslationVariant ;
    :text "ΚΡ. Τί χρῆμα; ποῖον τοῦτο πάγκοινον λέγεις;"^^xsd:string ;
    :relatedTo :Line_1049 .

:TV_Line_1050_grc a :TranslationVariant ;
    :text "ΤΕΙ. Ὅσῳ κράτιστον κτημάτων εὐβουλία;"^^xsd:string ;
    :relatedTo :Line_1050 ;
    :hasTheme :Theme_WisdomVsFolly ;
    :advocatesFor :Principle_PrimacyOfReason .

:TV_Line_1051_grc a :TranslationVariant ;
    :text "ΚΡ. Ὅσῳπερ, οἶμαι, μὴ φρονεῖν πλείστη βλάβη."^^xsd:string ;
    :relatedTo :Line_1051 .

:TV_Line_1052_grc a :TranslationVariant ;
    :text "ΤΕΙ. Ταύτης σὺ μέντοι τῆς νόσου πλήρης ἔφυς."^^xsd:string ;
    :relatedTo :Line_1052 .

:TV_Line_1053_grc a :TranslationVariant ;
    :text "ΚΡ. Οὐ βούλομαι τὸν μάντιν ἀντειπεῖν κακῶς."^^xsd:string ;
    :relatedTo :Line_1053 .

:TV_Line_1054_grc a :TranslationVariant ;
    :text "ΤΕΙ. Καὶ μὴν λέγεις, ψευδῆ με θεσπίζειν λέγων."^^xsd:string ;
    :relatedTo :Line_1054 .

:TV_Line_1055_grc a :TranslationVariant ;
    :text "ΚΡ. Τὸ μαντικὸν γὰρ πᾶν φιλάργυρον γένος."^^xsd:string ;
    :relatedTo :Line_1055 ;
    :hasTheme :Theme_Corruption .

:TV_Line_1056_grc a :TranslationVariant ;
    :text "ΤΕΙ. Τὸ δέ γε τυράννων αἰσχροκέρδειαν φιλεῖ."^^xsd:string ;
    :relatedTo :Line_1056 ;
    :hasTheme :Theme_StateVsProphecy .

:TV_Line_1057_grc a :TranslationVariant ;
    :text "ΚΡ. Ἆρ ̓ οἶσθα ταγοὺς ὄντας ἃν λέγῃς λέγων;"^^xsd:string ;
    :relatedTo :Line_1057 ;
    :hasMotivation :Motivation_AssertAuthority .

:TV_Line_1058_grc a :TranslationVariant ;
    :text "ΤΕΙ. Οἶδ ̓· ἐξ ἐμοῦ γὰρ τήνδ ̓ ἔχεις σώσας πόλιν."^^xsd:string ;
    :relatedTo :Line_1058 .

:TV_Line_1059_grc a :TranslationVariant ;
    :text "ΚΡ. Σοφὸς σὺ μάντις, ἀλλὰ τἀδικεῖν φιλῶν."^^xsd:string ;
    :relatedTo :Line_1059 .

:TV_Line_1060_grc a :TranslationVariant ;
    :text "ΤΕΙ. Ὄρσεις με τἀκίνητα διὰ φρενῶν φράσαι."^^xsd:string ;
    :relatedTo :Line_1060 ;
    :hasMotivation :Motivation_RevealTruth .

:TV_Line_1061_grc a :TranslationVariant ;
    :text "ΚΡ. Κίνει, μόνον δὲ μὴ  ̓πὶ κέρδεσιν λέγων."^^xsd:string ;
    :relatedTo :Line_1061 .

:TV_Line_1062_grc a :TranslationVariant ;
    :text "ΤΕ. Οὕτω γὰρ ἤδη καὶ δοκῶ τὸ σὸν μέρος."^^xsd:string ;
    :relatedTo :Line_1062 .

:TV_Line_1063_grc a :TranslationVariant ;
    :text "ΚΡ. Ὡς μὴ  ̓μπολήσων ἴσθι τὴν ἐμὴν φρένα."^^xsd:string ;
    :relatedTo :Line_1063 ;
    :hasConflict :Conflict_ProfitVsTruth .