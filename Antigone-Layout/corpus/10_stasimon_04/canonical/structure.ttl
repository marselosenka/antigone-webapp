@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:stasimon04-structure a owl:Ontology .

:Line_944
  a owl:NamedIndividual, :Line ;
  :lineNumber 944 ;
  :canonicalReference "944"^^xsd:string ;
  :text "Ἔτλα καὶ Δανάας οὐράνιον φῶς"^^xsd:string ;
  :hasTheme :Theme_PietyAndSuffering .

:Line_945
  a owl:NamedIndividual, :Line ;
  :lineNumber 945 ;
  :canonicalReference "945"^^xsd:string ;
  :text "ἀλλάξαι δέμας ἐν χαλκοδέτοις αὐλαῖς·"^^xsd:string ;
  :hasTheme :Theme_PietyAndSuffering .

:Line_946
  a owl:NamedIndividual, :Line ;
  :lineNumber 946 ;
  :canonicalReference "946"^^xsd:string ;
  :text "κρυπτομένα δ’ ἐν τυμβήρει θαλάμῳ κατεζεύχθη·"^^xsd:string ;
  :hasTheme :Theme_PietyAndSuffering .

:Line_947
  a owl:NamedIndividual, :Line ;
  :lineNumber 947 ;
  :canonicalReference "947"^^xsd:string ;
  :text "καίτοι καὶ γενεᾷ τίμιος, ὦ παῖ, παῖ,"^^xsd:string ;
  :hasTheme :Theme_PietyAndSuffering .

:Line_950
  a owl:NamedIndividual, :Line ;
  :lineNumber 950 ;
  :canonicalReference "950"^^xsd:string ;
  :text "καὶ Ζηνὸς ταμιεύεσκε γονὰς χρυσορύτους."^^xsd:string ;
  :hasTheme :Theme_PietyAndSuffering .

:Line_951
  a owl:NamedIndividual, :Line ;
  :lineNumber 951 ;
  :canonicalReference "951"^^xsd:string ;
  :text "Ἀλλ’ ἁ μοιριδία τις δύνασις δεινά·"^^xsd:string ;
  :hasTheme :Theme_InevitabilityOfFate .

:Line_952
  a owl:NamedIndividual, :Line ;
  :lineNumber 952 ;
  :canonicalReference "952"^^xsd:string ;
  :text "οὔτ’ ἄν νιν ὄλβος οὔτ’ Ἄρης, οὐ πύργος, οὐχ ἁλίκτυποι"^^xsd:string ;
  :hasTheme :Theme_InevitabilityOfFate .

:Line_953
  a owl:NamedIndividual, :Line ;
  :lineNumber 953 ;
  :canonicalReference "953"^^xsd:string ;
  :text "κελαιναὶ νᾶες ἐκφύγοιεν."^^xsd:string ;
  :hasTheme :Theme_InevitabilityOfFate .

#:Line_954
#  a owl:NamedIndividual, :Line ;
#  :lineNumber 954 ;
#  :canonicalReference "954"^^xsd:string ;
#  :text "κελαιναὶ νᾶες ἐκφύγοιεν."^^xsd:string ;
#  :hasTheme :Theme_InevitabilityOfFate .

:Line_955
  a owl:NamedIndividual, :Line ;
  :lineNumber 955 ;
  :canonicalReference "955"^^xsd:string ;
  :text "Ζεύχθη δ’ ὀξύχολος παῖς ὁ Δρύαντος "^^xsd:string ;
  :hasTheme :Theme_DivinePowerOverHumanWill .

:Line_956
  a owl:NamedIndividual, :Line ;
  :lineNumber 956 ;
  :canonicalReference "956"^^xsd:string ;
  :text "Ἠδωνῶν βασιλεύς, κερτομίοις ὀργαῖς"^^xsd:string ;
  :hasTheme :Theme_DivinePowerOverHumanWill .

:Line_957
  a owl:NamedIndividual, :Line ;
  :lineNumber 957 ;
  :canonicalReference "957"^^xsd:string ;
  :text "ἐκ Διονύσου πετρώδει κατάφαρκτος ἐν δεσμῷ."^^xsd:string ;
  :hasTheme :Theme_DivinePowerOverHumanWill .

:Line_958
  a owl:NamedIndividual, :Line ;
  :lineNumber 958 ;
  :canonicalReference "958"^^xsd:string ;
  :text "Οὕτω τᾶς μανίας δεινὸν ἀποστάζει"^^xsd:string ;
  :hasTheme :Theme_DivinePowerOverHumanWill .

:Line_960
  a owl:NamedIndividual, :Line ;
  :lineNumber 960 ;
  :canonicalReference "960"^^xsd:string ;
  :text "ἀνθηρόν τε μένος. κεῖνος ἐπέγνω μανίαις"^^xsd:string ;
  :hasTheme :Theme_DivinePowerOverHumanWill .

:Line_961
  a owl:NamedIndividual, :Line ;
  :lineNumber 961 ;
  :canonicalReference "961"^^xsd:string ;
  :text "ψαύων τὸν θεὸν ἐν κερτομίοις γλώσσαις."^^xsd:string ;
  :hasTheme :Theme_DivinePowerOverHumanWill .

:Line_962
  a owl:NamedIndividual, :Line ;
  :lineNumber 962 ;
  :canonicalReference "962"^^xsd:string ;
  :text "παύεσκε μὲν γὰρ ἐνθέους γυναῖκας εὔιόν τε πῦρ,"^^xsd:string ;
  :hasTheme :Theme_DivinePowerOverHumanWill .

#:Line_963
#  a owl:NamedIndividual, :Line ;
#  :lineNumber 963 ;
#  :canonicalReference "963"^^xsd:string ;
#  :text "τομίοις γλώσσαις."^^xsd:string ;
#  :hasTheme :Theme_DivinePowerOverHumanWill .

#:Line_964
#  a owl:NamedIndividual, :Line ;
#  :lineNumber 964 ;
#  :canonicalReference "964"^^xsd:string ;
#  :text "Παύεσκε μὲν γὰρ ἐνθέους"^^xsd:string ;
#  :hasTheme :Theme_DivinePowerOverHumanWill .

:Line_965
  a owl:NamedIndividual, :Line ;
  :lineNumber 965 ;
  :canonicalReference "965"^^xsd:string ;
  :text "φιλαύλους τʼ ἠρέθιζε Μούσας."^^xsd:string ;
  :hasTheme :Theme_DivinePowerOverHumanWill .


:Line_966 a :Line ;
  :lineNumber 966 ;
  :canonicalReference "966" ;
  :text "Παρὰ δὲ κυανέαιν σπιλάδοιν διδύμας ἁλὸς"^^xsd:string .

:Line_967 a :Line ;
  :lineNumber 967 ;
  :canonicalReference "967" ;
  :text "ἀκταὶ Βοσπόριαι ἰδ ̓ ὁ Θρῃκῶν <ἠιὼν>"^^xsd:string ;
  :hasTheme :Theme_NobleSuffering .

# 968 and 969 do not exist in the verses
:Line_970 a :Line ;
  :lineNumber 970 ;
  :canonicalReference "970" ;
  :text "Σαλμυδησσός, ἵν ̓ ἀγχίπολις Ἄρης"^^xsd:string ;
  :referencesMyth :Antigone_Character_Ares .

:Line_971 a :Line ;
  :lineNumber 971 ;
  :canonicalReference "971" ;
  :text "δισσοῖσι Φινείδαις"^^xsd:string ;
  :referencesMyth :Antigone_Character_Phineids .

:Line_972 a :Line ;
  :lineNumber 972 ;
  :canonicalReference "972" ;
  :text "εἶδεν ἀρατὸν ἕλκος"^^xsd:string .

:Line_973 a :Line ;
  :lineNumber 973 ;
  :canonicalReference "973" ;
  :text "τυφλωθὲν ἐξ ἀγρίας δάμαρτος"^^xsd:string ;
  :relatedTo :Antigone_Character_PhineusWife ;
  :experiencesEmotion :Emotion_Savagery .

:Line_974 a :Line ;
  :lineNumber 974 ;
  :canonicalReference "974" ;
  :text "ἀλαὸν ἀλαστόροισιν ὀμμάτων κύκλοις"^^xsd:string .

:Line_975 a :Line ;
  :lineNumber 975 ;
  :canonicalReference "975" ;
  :text "ἀραχθέντων ὑφ ̓ αἱματηραῖς"^^xsd:string ;
  :hasSymbol :Symbol_Blood .

:Line_976 a :Line ;
  :lineNumber 976 ;
  :canonicalReference "976" ;
  :text "χείρεσσι καὶ κερκίδων ἀκμαῖσιν."^^xsd:string .

:Line_977 a :Line ;
  :lineNumber 977 ;
  :canonicalReference "977" ;
  :text "Κατὰ δὲ τακόμενοι μέλεοι μελέαν πάθαν"^^xsd:string ;
  :experiencesEmotion :Emotion_Misery .

:Line_980 a :Line ;
  :lineNumber 980 ;
  :canonicalReference "980" ;
  :text "κλαῖον, ματρὸς ἔχοντες ἀνύμφευτον γονάν·"^^xsd:string ;
  :experiencesEmotion :Emotion_Grief .

:Line_981 a :Line ;
  :lineNumber 981 ;
  :canonicalReference "981" ;
  :text "ἁ δὲ σπέρμα μὲν ἀρχαιογόνων"^^xsd:string .

:Line_982 a :Line ;
  :lineNumber 982 ;
  :canonicalReference "982" ;
  :text "ἄντασ ̓ Ἐρεχθεϊδᾶν,"^^xsd:string ;
  :referencesMyth :Antigone_Character_Cleopatra .

:Line_983 a :Line ;
  :lineNumber 983 ;
  :canonicalReference "983" ;
  :text "τηλεπόροις δ ̓ ἐν ἄντροις"^^xsd:string .

:Line_984 a :Line ;
  :lineNumber 984 ;
  :canonicalReference "984" ;
  :text "τράφη θυέλλῃσιν ἐν πατρῴαις"^^xsd:string .

:Line_985 a :Line ;
  :lineNumber 985 ;
  :canonicalReference "985" ;
  :text "Βορεὰς ἅμιππος ὀρθόποδος ὑπὲρ πάγου"^^xsd:string ;
  :referencesMyth :Antigone_Character_Boreas .

:Line_986 a :Line ;
  :lineNumber 986 ;
  :canonicalReference "986" ;
  :text "θεῶν παῖς· ἀλλὰ κἀπ ̓ ἐκείνᾳ"^^xsd:string .

:Line_987 a :Line ;
  :lineNumber 987 ;
  :canonicalReference "987" ;
  :text "Μοῖραι μακραίωνες ἔσχον, ὦ παῖ."^^xsd:string ;
  :hasTheme :Theme_FateInevitability ;
  :relatedTo :Antigone_Character_Fates .
