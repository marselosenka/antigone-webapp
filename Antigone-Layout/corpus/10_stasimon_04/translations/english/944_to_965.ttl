@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:stasimon_04-translations-944-965-english a owl:Ontology .
# English translation variants extracted from 944_to_965.ttl

:TV_Line_944_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Also did Danaë dare to trade away the sky’s light for the enclosure of bronze walls;"^^xsd:string ;
    :relatedTo :Line_944 .

:TV_Line_945_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Though she was hidden,"^^xsd:string ;
    :relatedTo :Line_945 .

:TV_Line_946_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Trapped as if in a grave."^^xsd:string ;
    :relatedTo :Line_946 .

:TV_Line_947_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Yet she was of noble lineage, oh child, darling, and kept safe"^^xsd:string ;
    :relatedTo :Line_947 .

:TV_Line_950_en a owl:NamedIndividual, :TranslationVariant ;
    :text "The gold-streamed seed of Zeus."^^xsd:string ;
    :relatedTo :Line_950 .

:TV_Line_951_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Destiny has a certain terrible power:"^^xsd:string ;
    :relatedTo :Line_951 .

:TV_Line_952_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Nothing—neither wealth, nor Ares, nor lofty heights, nor dark sea-tossed ships—"^^xsd:string ;
    :relatedTo :Line_952 .

:TV_Line_953_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Can ward off its grasp."^^xsd:string ;
    :relatedTo :Line_953 .

:TV_Line_955_en a owl:NamedIndividual, :TranslationVariant ;
    :text "The sharp-tempered Edonian king, son of Dryas,"^^xsd:string ;
    :relatedTo :Line_955 .

:TV_Line_956_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Was tempered and shut up"^^xsd:string ;
    :relatedTo :Line_956 .

:TV_Line_957_en a owl:NamedIndividual, :TranslationVariant ;
    :text "By Dionysus in craggy confinement."^^xsd:string ;
    :relatedTo :Line_957 .

:TV_Line_958_en a owl:NamedIndividual, :TranslationVariant ;
    :text "In such a way did the terror of his madness"^^xsd:string ;
    :relatedTo :Line_958 .

:TV_Line_960_en a owl:NamedIndividual, :TranslationVariant ;
    :text "And brilliant might recede. That man soon met that very same god"^^xsd:string ;
    :relatedTo :Line_960 .

:TV_Line_961_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Whom he once pestered in his mania with biting words."^^xsd:string ;
    :relatedTo :Line_961 .

:TV_Line_962_en a owl:NamedIndividual, :TranslationVariant ;
    :text "For he kept trying to halt the frenzied Bacchantes and the fire of Apollo,"^^xsd:string ;
    :relatedTo :Line_962 .

:TV_Line_965_en a owl:NamedIndividual, :TranslationVariant ;
    :text "Provoking the flute-loving Muses."^^xsd:string ;
    :relatedTo :Line_965 .
