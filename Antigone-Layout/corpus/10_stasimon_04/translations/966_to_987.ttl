@prefix : <http://example.org/antigone#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

################################################################
# ENGLISH
################################################################

# --- 966 ---

:TV_Line_966_en a :TranslationVariant ;
:text "Beside the dark-blue rocks of the sea,"^^xsd:string ;
:relatedTo :Line_966 .

# --- 967 ---

:TV_Line_967_en a :TranslationVariant ;
:text "The twin Bosporian coasts and the Thracian shore,"^^xsd:string ;
:relatedTo :Line_967 .

# 968 and 969 do not exist in the Greek base

# --- 970 ---

:TV_Line_970_en a :TranslationVariant ;
:text "Salmydessus, where neighboring Ares"^^xsd:string ;
:relatedTo :Line_970 ;
:referencesMyth :Antigone_Character_Ares .

# --- 971 ---

:TV_Line_971_en a :TranslationVariant ;
:text "Saw for the two sons of Phineus"^^xsd:string ;
:relatedTo :Line_971 ;
:referencesMyth :Antigone_Character_Phineids .

# --- 972 ---

:TV_Line_972_en a :TranslationVariant ;
:text "The accursed wound,"^^xsd:string ;
:relatedTo :Line_972 .

# --- 973 ---

:TV_Line_973_en a :TranslationVariant ;
:text "Blinded by a savage wife,"^^xsd:string ;
:relatedTo :Line_973 ;
:relatedTo :Antigone_Character_PhineusWife .

# --- 974 ---

:TV_Line_974_en a :TranslationVariant ;
:text "Their eyes struck in cruel circles,"^^xsd:string ;
:relatedTo :Line_974 .

# --- 975 ---

:TV_Line_975_en a :TranslationVariant ;
:text "Torn out by bloody"^^xsd:string ;
:relatedTo :Line_975 ;
:hasSymbol :Symbol_Blood .

# --- 976 ---

:TV_Line_976_en a :TranslationVariant ;
:text "Hands and the sharp points of shuttles."^^xsd:string ;
:relatedTo :Line_976 .

# --- 977 ---

:TV_Line_977_en a :TranslationVariant ;
:text "And they, wasting away, miserable in their misery,"^^xsd:string ;
:relatedTo :Line_977 ;
:experiencesEmotion :Emotion_Misery .

# 978 and 979 do not exist in the Greek base

# --- 980 ---

:TV_Line_980_en a :TranslationVariant ;
:text "Wept, having for mother a mother of unwed birth;"^^xsd:string ;
:relatedTo :Line_980 ;
:experiencesEmotion :Emotion_Grief .

# --- 981 ---

:TV_Line_981_en a :TranslationVariant ;
:text "And she was descended from the ancient race"^^xsd:string ;
:relatedTo :Line_981 .

# --- 982 ---

:TV_Line_982_en a :TranslationVariant ;
:text "Of the Erechtheids,"^^xsd:string ;
:relatedTo :Line_982 ;
:referencesMyth :Antigone_Character_Cleopatra .

# --- 983 ---

:TV_Line_983_en a :TranslationVariant ;
:text "And in far-off caves"^^xsd:string ;
:relatedTo :Line_983 .

# --- 984 ---

:TV_Line_984_en a :TranslationVariant ;
:text "She was reared amid her father’s storms,"^^xsd:string ;
:relatedTo :Line_984 .

# --- 985 ---

:TV_Line_985_en a :TranslationVariant ;
:text "A child of Boreas, swift as horses over the steep crags,"^^xsd:string ;
:relatedTo :Line_985 ;
:referencesMyth :Antigone_Character_Boreas .

# --- 986 ---

:TV_Line_986_en a :TranslationVariant ;
:text "A child of the gods; but even upon her"^^xsd:string ;
:relatedTo :Line_986 .

# --- 987 ---

:TV_Line_987_en a :TranslationVariant ;
:text "The long-lived Fates took hold, O child."^^xsd:string ;
:relatedTo :Line_987 ;
:hasTheme :Theme_FateInevitability ;
:relatedTo :Antigone_Character_Fates .