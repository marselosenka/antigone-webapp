@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

############################
# SCENE & SPEECH DEFINITIONS
############################

:Antigone_Scene_Exodus_Cont_4
    a owl:NamedIndividual, :Scene ;
    :sceneNumber "Exodus (Part 4)"^^xsd:string ;
    :hasSpeech :Speech_Exangelos_1277_1280, :Speech_Creon_1281, :Speech_Exangelos_1282_1283, 
                :Speech_Creon_1284_1292, :Speech_Chorus_1293, :Speech_Creon_1294_1300, 
                :Speech_Exangelos_1301_1305 ;
    :developsTheme :Theme_DoubleWoe, :Theme_ChildSlayer, :Theme_HadesHarbor .

:Speech_Exangelos_1277_1280 a owl:NamedIndividual, :Speech ; :speechBy :Exangelos_Character_Exangelos ; :containsLine :Line_1277, :Line_1278, :Line_1279, :Line_1280 .
:Speech_Creon_1281 a owl:NamedIndividual, :Speech ; :speechBy :Creon_Character_Creon ; :containsLine :Line_1281 .
:Speech_Exangelos_1282_1283 a owl:NamedIndividual, :Speech ; :speechBy :Exangelos_Character_Exangelos ; :containsLine :Line_1282, :Line_1283 ; :hasTheme :Theme_DoubleWoe .
:Speech_Creon_1284_1292 a owl:NamedIndividual, :Speech ; :speechBy :Creon_Character_Creon ; :containsLine :Line_1284, :Line_1285, :Line_1286, :Line_1287, :Line_1288, :Line_1289, :Line_1290, :Line_1291, :Line_1292 ; :hasTheme :Theme_HadesHarbor .
:Speech_Chorus_1293 a owl:NamedIndividual, :Speech ; :speechBy :Chorus_Character_Chorus ; :containsLine :Line_1293 .
:Speech_Creon_1294_1300 a owl:NamedIndividual, :Speech ; :speechBy :Creon_Character_Creon ; :containsLine :Line_1294, :Line_1295, :Line_1296, :Line_1297, :Line_1298, :Line_1299, :Line_1300 .
:Speech_Exangelos_1301_1305 a owl:NamedIndividual, :Speech ; :speechBy :Exangelos_Character_Exangelos ; :containsLine :Line_1301, :Line_1302, :Line_1303, :Line_1304, :Line_1305 ; :hasTheme :Theme_ChildSlayer .

############################
# CHARACTERS & ENTITIES
############################

:Exangelos_Character_Exangelos a owl:NamedIndividual, :Character ; :hasMotivation :ExangelosMotivation_ReportHouseholdRuin .
:Creon_Character_Creon a owl:NamedIndividual, :Character ; :experiencesEmotion :CreonEmotion_TotalDespair .
:Eurydice_Character_Eurydice a owl:NamedIndividual, :Character ; :makesMoralDecision :EurydiceDecision_Suicide_Curse ; :experiencesEmotion :EurydiceEmotion_Bitterness .
:Megareus_Character_Megareus a owl:NamedIndividual, :Character ; :status "Dead"^^xsd:string ; :rdfs:comment "First son of Eurydice and Creon, mentioned in her final moments." .

############################
# CANONICAL LINES (1277-1305)
############################
@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

################################################################
# CANONICAL LINES (1277-1305)
################################################################

:Line_1277 a :Line ; :lineNumber 1277 ; :canonicalReference "1277" ; :text "Ὦ δέσποθ ̓, ὡς ἔχων τε καὶ κεκτημένος,"^^xsd:string .
:Line_1278 a :Line ; :lineNumber 1278 ; :canonicalReference "1278" ; :text "τὰ μὲν πρὸ χειρῶν τάδε φέρειν, τὰ δ ̓ ἐν δόμοις"^^xsd:string .
:Line_1280 a :Line ; :lineNumber 1280 ; :canonicalReference "1280" ; :text "ἔοικας ἥκων καὶ τάχ ̓ ὄψεσθαι κακά."^^xsd:string .
:Line_1281 a :Line ; :lineNumber 1281 ; :canonicalReference "1281" ; :text "Τί δ; ἔστιν αὖ κάκιον ἐκ κακῶν ἔτι;"^^xsd:string .
:Line_1282 a :Line ; :lineNumber 1282 ; :canonicalReference "1282" ; :text "ΕΞ. Γυνὴ τέθνηκεν, τοῦδε παμμήτωρ νεκρού,"^^xsd:string .
:Line_1283 a :Line ; :lineNumber 1283 ; :canonicalReference "1283" ; :text "δύστηνος, ἄρτι νεοτόμοισι πλήγμασιν."^^xsd:string .
:Line_1284 a :Line ; :lineNumber 1284 ; :canonicalReference "1284" ; :text "ΚΡ. Ἰὼ, ἰὼ δυσκάθαρτος Ἅιδου λιμήν,"^^xsd:string ; :hasTheme :Theme_HadesHarbor .
:Line_1285 a :Line ; :lineNumber 1285 ; :canonicalReference "1285" ; :text "τί μ ̓ ἄρα τί μ ̓ ὀλέκεις;"^^xsd:string .
:Line_1286 a :Line ; :lineNumber 1286 ; :canonicalReference "1286" ; :text "Ὦ κακάγγελτά μοι"^^xsd:string .
:Line_1287 a :Line ; :lineNumber 1287 ; :canonicalReference "1287" ; :text "προπέμψας ἄχη, τίνα θροεῖς λόγον;"^^xsd:string .
:Line_1288 a :Line ; :lineNumber 1288 ; :canonicalReference "1288" ; :text "Αἰαῖ, ὀλωλότ ̓ ἄνδρ ̓ ἐπεξειργάσω."^^xsd:string .
:Line_1289 a :Line ; :lineNumber 1289 ; :canonicalReference "1289" ; :text "Τί φῄς, ὦ παῖ; τίνα λέγεις μοι νέον,"^^xsd:string .
:Line_1290 a :Line ; :lineNumber 1290 ; :canonicalReference "1290" ; :text "αἰαῖ, αἰαῖ,"^^xsd:string .
:Line_1291 a :Line ; :lineNumber 1291 ; :canonicalReference "1291" ; :text "σφάγιον ἐπ ̓ ὀλέθρῳ,"^^xsd:string .
:Line_1292 a :Line ; :lineNumber 1292 ; :canonicalReference "1292" ; :text "γυναικεῖον ἀμφικεῖσθαι μόρον;"^^xsd:string .
:Line_1293 a :Line ; :lineNumber 1293 ; :canonicalReference "1293" ; :text "ΧΟ. Ὁρᾶν πάρεστιν· οὐ γὰρ ἐν μυχοῖς ἔτι."^^xsd:string .
:Line_1294 a :Line ; :lineNumber 1294 ; :canonicalReference "1294" ; :text "ΚΡ. Οἴμοι,"^^xsd:string .
:Line_1295 a :Line ; :lineNumber 1295 ; :canonicalReference "1295" ; :text "κακὸν τόδ ̓ ἄλλο δεύτερον βλέπω τάλας"^^xsd:string .
:Line_1296 a :Line ; :lineNumber 1296 ; :canonicalReference "1296" ; :text "Τίς ἄρα, τίς με πότμος ἔτι περιμένει;"^^xsd:string .
:Line_1297 a :Line ; :lineNumber 1297 ; :canonicalReference "1297" ; :text "Ἔχω μὲν ἐν χείρεσσιν ἀρτίως τέκνον,"^^xsd:string .
:Line_1299 a :Line ; :lineNumber 1299 ; :canonicalReference "1299" ; :text "τάλας, τὸν δ ̓ ἔναντα προσβλέπω νεκρόν."^^xsd:string ; :hasTheme :Theme_DoubleWoe .
:Line_1300 a :Line ; :lineNumber 1300 ; :canonicalReference "1300" ; :text "Φεῦ φεῦ μᾶτερ ἀθλία, φεῦ τέκνον."^^xsd:string .
:Line_1301 a :Line ; :lineNumber 1301 ; :canonicalReference "1301" ; :text "Ἡ δ ̓ ὀξύπληκτος ἡμένη βωμία"^^xsd:string .
:Line_1302 a :Line ; :lineNumber 1302 ; :canonicalReference "1302" ; :text "λύει κελαινὰ βλέφαρα, κωκύσασα μὲν"^^xsd:string .
:Line_1303 a :Line ; :lineNumber 1303 ; :canonicalReference "1303" ; :text "τοῦ πρὶν θανόντος Μεγαρέως κενὸν λέχος,"^^xsd:string .
:Line_1304 a :Line ; :lineNumber 1304 ; :canonicalReference "1304" ; :text "αὖθις δὲ τοῦδε, λοίσθιον δὲ σοὶ κακὰς"^^xsd:string .
:Line_1305 a :Line ; :lineNumber 1305 ; :canonicalReference "1305" ; :text "πράξεις ἐφυμνήσασα τῷ παιδοκτόνῳ."^^xsd:string ; :hasTheme :Theme_ChildSlayer .

############################
# TRANSLATION VARIANTS (EN)
############################

:TV_Line_1282_en a :TranslationVariant ; :relatedTo :Line_1282 ; :text "Your wife is dead, the true mother of this corpse."^^xsd:string .
:TV_Line_1284_en a :TranslationVariant ; :relatedTo :Line_1284 ; :text "O harbor of Death, so hard to purify!"^^xsd:string .
:TV_Line_1296_en a :TranslationVariant ; :relatedTo :Line_1296 ; :text "What destiny, what destiny yet awaits me?"^^xsd:string .
:TV_Line_1305_en a :TranslationVariant ; :relatedTo :Line_1305 ; :text "Cursing you as the slayer of your children."^^xsd:string .

############################
# THEMES, EMOTIONS, CONFLICTS
############################

:Theme_DoubleWoe a owl:NamedIndividual, :Theme ; :description "The accumulation of tragic losses, where one death follows another in a relentless sequence."^^xsd:string .
:Theme_HadesHarbor a owl:NamedIndividual, :Theme ; :description "The metaphorical description of death/Hades as a 'harbor' that consumes everything and cannot be cleansed."^^xsd:string .
:Theme_ChildSlayer a owl:NamedIndividual, :Theme ; :description "The ultimate condemnation of Creon (paidoktonos) as the cause of his own children's deaths."^^xsd:string .

:CreonEmotion_TotalDespair a owl:NamedIndividual, :Emotion ; :description "The psychological collapse of Creon as he faces the reality that his actions have destroyed his entire family."^^xsd:string .
:EurydiceEmotion_Bitterness a owl:NamedIndividual, :Emotion ; :description "The vengeful grief of Eurydice, who uses her final breath to curse her husband."^^xsd:string .

:ExangelosMotivation_ReportHouseholdRuin a owl:NamedIndividual, :Motivation ; :description "The messenger's obligation to bring the internal news of the palace to the external scene of the tragedy."^^xsd:string .
:EurydiceDecision_Suicide_Curse a owl:NamedIndividual, :MoralDecision ; :description "Eurydice's choice to end her life at the altar, transforming her suicide into a ritual of cursing Creon."^^xsd:string .

:Conflict_EurydiceVsCreon_Curse a owl:NamedIndividual, :Conflict ;
    :conflictBetween :Eurydice_Character_Eurydice, :Creon_Character_Creon ;
    :description "The final domestic conflict where the wife acts as the ultimate judge and punisher of the husband's 'aboulia'."^^xsd:string .