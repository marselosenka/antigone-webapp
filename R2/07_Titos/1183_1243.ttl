@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

############################
# SCENE & SPEECH DEFINITIONS
############################

:Antigone_Scene_Exodus_Cont
    a owl:NamedIndividual, :Scene ;
    :sceneNumber "Exodus (Part 2)"^^xsd:string ;
    :hasSpeech :Speech_Eurydice_1183_1191, :Speech_Messenger_1192_1243 ;
    :developsTheme :Theme_Aboulia, :Theme_MarriageToDeath, :Theme_PiousBurial .

:Speech_Eurydice_1183_1191
    a owl:NamedIndividual, :Speech ;
    :speechBy :Eurydice_Character_Eurydice ;
    :experiencesEmotion :EurydiceEmotion_Shock ;
    :containsLine :Line_1183, :Line_1184, :Line_1185, :Line_1186, :Line_1187, 
                  :Line_1188, :Line_1189, :Line_1190, :Line_1191 .

:Speech_Messenger_1192_1243
    a owl:NamedIndividual, :Speech ;
    :speechBy :Messenger_Character_Messenger ;
    :hasMotivation :MessengerMotivation_UnerringTruth ;
    :containsLine :Line_1192, :Line_1193, :Line_1194, :Line_1195, :Line_1196, 
                  :Line_1197, :Line_1198, :Line_1199, :Line_1200, :Line_1201,
                  :Line_1202, :Line_1203, :Line_1204, :Line_1205, :Line_1206,
                  :Line_1207, :Line_1208, :Line_1209, :Line_1210, :Line_1211,
                  :Line_1212, :Line_1213, :Line_1214, :Line_1215, :Line_1216,
                  :Line_1217, :Line_1218, :Line_1219, :Line_1220, :Line_1221,
                  :Line_1222, :Line_1223, :Line_1224, :Line_1225, :Line_1226,
                  :Line_1227, :Line_1228, :Line_1229, :Line_1230, :Line_1231,
                  :Line_1232, :Line_1233, :Line_1234, :Line_1235, :Line_1236,
                  :Line_1237, :Line_1238, :Line_1239, :Line_1240, :Line_1241,
                  :Line_1242, :Line_1243 .

############################
# CHARACTERS & ENTITIES
############################

:Eurydice_Character_Eurydice
    a owl:NamedIndividual, :Character ;
    :status "Queen"^^xsd:string ;
    :experiencesEmotion :EurydiceEmotion_Shock, :EurydiceEmotion_Resilience ;
    :isChildOf :Creon_Character_Creon . # Wife of Creon

:Haemon_Character_Haemon
    a owl:NamedIndividual, :Character ;
    :experiencesEmotion :HaemonEmotion_Despair, :HaemonEmotion_Rage ;
    :makesMoralDecision :HaemonDecision_Suicide_Grief .

:Antigone_Character_Antigone
    a owl:NamedIndividual, :Character ;
    :status "Exile/Prisoner"^^xsd:string .

:Polynices_Character_Polynices
    a owl:NamedIndividual, :Character ;
    :status "Exile"^^xsd:string .

############################
# CANONICAL LINES (1183-1243)
############################

:Line_1183 a :Line ; :lineNumber 1183 ; :canonicalReference "1183" ; :text "Ὦ πάντες ἀστοί, τῶν λόγων ἐπῃσθόμην"^^xsd:string .
:Line_1184 a :Line ; :lineNumber 1184 ; :canonicalReference "1184" ; :text "πρὸς ἔξοδον στείχουσα, Παλλάδος θεᾶς"^^xsd:string .
:Line_1185 a :Line ; :lineNumber 1185 ; :canonicalReference "1185" ; :text "ὅπως ἱκοίμην εὐγμάτων προσήγορος."^^xsd:string .
:Line_1186 a :Line ; :lineNumber 1186 ; :canonicalReference "1186" ; :text "Καὶ τυγχάνω τε κλῇθρ ̓ ἀνασπαστοῦ πύλης"^^xsd:string .
:Line_1187 a :Line ; :lineNumber 1187 ; :canonicalReference "1187" ; :text "χαλῶσα, καί με φθόγγος οἰκείου κακοῦ"^^xsd:string .
:Line_1188 a :Line ; :lineNumber 1188 ; :canonicalReference "1188" ; :text "βάλλει δι ̓ ὤτων· ὑπτία δὲ κλίνομαι"^^xsd:string ; :hasTheme :Theme_DivineMiasma .
:Line_1189 a :Line ; :lineNumber 1189 ; :canonicalReference "1189" ; :text "δείσασα πρὸς δμωαῖσι κἀποπλήσσομαι."^^xsd:string .
:Line_1190 a :Line ; :lineNumber 1190 ; :canonicalReference "1190" ; :text "Ἀλλ ̓ ὅστις ἦν ὁ μῦθος αὖθις εἴπατε·"^^xsd:string .
:Line_1191 a :Line ; :lineNumber 1191 ; :canonicalReference "1191" ; :text "κακῶν γὰρ οὐκ ἄπειρος οὖσ ̓ ἀκούσομαι."^^xsd:string .
:Line_1192 a :Line ; :lineNumber 1192 ; :canonicalReference "1192" ; :text "ΑΓ. Ἐγώ, φίλη δέσποινα, καὶ παρὼν ἐρῶ,"^^xsd:string .
:Line_1193 a :Line ; :lineNumber 1193 ; :canonicalReference "1193" ; :text "κοὐδὲν παρήσω τῆς ἀληθείας ἔπος·"^^xsd:string .
:Line_1194 a :Line ; :lineNumber 1194 ; :canonicalReference "1194" ; :text "τί γάρ σε μαλθάσσοιμ ̓ ἂν ὧν ἐς ὕστερον"^^xsd:string .
:Line_1195 a :Line ; :lineNumber 1195 ; :canonicalReference "1195" ; :text "ψεῦσται φανούμεθ ̓; ὀρθὸν ἁλήθει ̓ ἀεί."^^xsd:string ; :hasTheme :Theme_UnerringTruth .
:Line_1196 a :Line ; :lineNumber 1196 ; :canonicalReference "1196" ; :text "Ἐγὼ δὲ σῷ ποδαγὸς ἑσπόμην πόσει"^^xsd:string .
:Line_1197 a :Line ; :lineNumber 1197 ; :canonicalReference "1197" ; :text "πεδίον ἐπ ̓ ἄκρον, ἔνθ ̓ ἔκειτο νηλεὲς"^^xsd:string .
:Line_1198 a :Line ; :lineNumber 1198 ; :canonicalReference "1198" ; :text "κυνοσπάρακτον σῶμα Πολυνείκους ἔτι·"^^xsd:string ; :hasTheme :Theme_PiousBurial .
:Line_1199 a :Line ; :lineNumber 1199 ; :canonicalReference "1199" ; :text "καὶ τὸν μέν, αἰτήσαντες ἐνοδίαν θεὸν"^^xsd:string .
:Line_1200 a :Line ; :lineNumber 1200 ; :canonicalReference "1200" ; :text "Πλούτωνά τ ̓ ὀργὰς εὐμενεῖς κατασχεθεῖν,"^^xsd:string .
:Line_1201 a :Line ; :lineNumber 1201 ; :canonicalReference "1201" ; :text "λούσαντες ἁγνὸν λουτρόν, ἐν νεοσπάσιν"^^xsd:string .
:Line_1202 a :Line ; :lineNumber 1202 ; :canonicalReference "1202" ; :text "θαλλοῖς ὃ δὴ λέλειπτο συγκατῄθομεν,"^^xsd:string .
:Line_1203 a :Line ; :lineNumber 1203 ; :canonicalReference "1203" ; :text "καὶ τύμβον ὀρθόκρανον οἰκείας χθονὸς"^^xsd:string .
:Line_1204 a :Line ; :lineNumber 1204 ; :canonicalReference "1204" ; :text "χώσαντες αὖθις πρὸς λιθόστρωτον κόρης"^^xsd:string .
:Line_1205 a :Line ; :lineNumber 1205 ; :canonicalReference "1205" ; :text "νυμφεῖον Ἅιδου κοῖλον εἰσεβαίνομεν."^^xsd:string ; :hasTheme :Theme_MarriageToDeath .
:Line_1206 a :Line ; :lineNumber 1206 ; :canonicalReference "1206" ; :text "Φωνῆς δ ̓ ἄπωθεν ὀρθίων κωκυμάτων"^^xsd:string .
:Line_1207 a :Line ; :lineNumber 1207 ; :canonicalReference "1207" ; :text "κλύει τις ἀκτέριστον ἀμφὶ παστάδα,"^^xsd:string .
:Line_1208 a :Line ; :lineNumber 1208 ; :canonicalReference "1208" ; :text "καὶ δεσπότῃ Κρέοντι σημαίνει μολών·"^^xsd:string .
:Line_1209 a :Line ; :lineNumber 1209 ; :canonicalReference "1209" ; :text "τῷ δ ̓ ἀθλίας ἄσημα περιβαίνει βοῆς"^^xsd:string .
:Line_1210 a :Line ; :lineNumber 1210 ; :canonicalReference "1210" ; :text "ἕρποντι μᾶλλον ἆσσον, οἰμώξας δ ̓ ἔπος"^^xsd:string .
:Line_1211 a :Line ; :lineNumber 1211 ; :canonicalReference "1211" ; :text "ἵησι δυσθρήνητον· Ὢ τάλας ἐγώ,"^^xsd:string .
:Line_1212 a :Line ; :lineNumber 1212 ; :canonicalReference "1212" ; :text "ἆρ ̓ εἰμὶ μάντις; ἆρα δυστυχεστάτην"^^xsd:string .
:Line_1213 a :Line ; :lineNumber 1213 ; :canonicalReference "1213" ; :text "κέλευθον ἕρπω τῶν παρελθουσῶν ὁδῶν;"^^xsd:string .
:Line_1214 a :Line ; :lineNumber 1214 ; :canonicalReference "1214" ; :text "παιδός με σαίνει φθόγγος. Ἀλλά, πρόσπολοι,"^^xsd:string .
:Line_1215 a :Line ; :lineNumber 1215 ; :canonicalReference "1215" ; :text "ἴτ ̓ ἆσσον ὠκεῖς, καὶ παραστάντες τάφῳ"^^xsd:string .
:Line_1216 a :Line ; :lineNumber 1216 ; :canonicalReference "1216" ; :text "ἀθρήσαθ ̓, ἁρμὸν χώματος λιθοσπαδῆ"^^xsd:string .
:Line_1217 a :Line ; :lineNumber 1217 ; :canonicalReference "1217" ; :text "δύντες πρὸς αὐτὸ στόμιον, εἰ τὸν Αἵμονος"^^xsd:string .
:Line_1218 a :Line ; :lineNumber 1218 ; :canonicalReference "1218" ; :text "φθόγγον συνίημ ̓, ἢ θεοῖσι κλέπτομαι."^^xsd:string .
:Line_1219 a :Line ; :lineNumber 1219 ; :canonicalReference "1219" ; :text "Τάδ ̓ ἐξ ἀθύμου δεσπότου κελευσμάτων"^^xsd:string .
:Line_1220 a :Line ; :lineNumber 1220 ; :canonicalReference "1220" ; :text "ἠθροῦμεν· ἐν δὲ λοισθίῳ τυμβεύματι"^^xsd:string .
:Line_1221 a :Line ; :lineNumber 1221 ; :canonicalReference "1221" ; :text "τὴν μὲν κρεμαστὴν αὐχένος κατείδομεν,"^^xsd:string .
:Line_1222 a :Line ; :lineNumber 1222 ; :canonicalReference "1222" ; :text "βρόχῳ μιτώδει σινδόνος καθημμένην,"^^xsd:string .
:Line_1223 a :Line ; :lineNumber 1223 ; :canonicalReference "1223" ; :text "τὸν δ ̓ ἀμφὶ μέσσῃ περιπετῆ προσκείμενον,"^^xsd:string .
:Line_1224 a :Line ; :lineNumber 1224 ; :canonicalReference "1224" ; :text "εὐνῆς ἀποιμώζοντα τῆς κάτω φθορὰν"^^xsd:string .
:Line_1225 a :Line ; :lineNumber 1225 ; :canonicalReference "1225" ; :text "καὶ πατρὸς ἔργα καὶ τὸ δύστηνον λέχος."^^xsd:string .
:Line_1226 a :Line ; :lineNumber 1226 ; :canonicalReference "1226" ; :text "Ὁ δ ̓ ὡς ὁρᾷ σφε, στυγνὸν οἰμώξας ἔσω"^^xsd:string .
:Line_1227 a :Line ; :lineNumber 1227 ; :canonicalReference "1227" ; :text "χωρεῖ πρὸς αὐτὸν κἀνακωκύσας καλεῖ·"^^xsd:string .
:Line_1228 a :Line ; :lineNumber 1228 ; :canonicalReference "1228" ; :text "Ὦ τλῆμον, οἷον ἔργον εἴργασαι· τίνα"^^xsd:string .
:Line_1229 a :Line ; :lineNumber 1229 ; :canonicalReference "1229" ; :text "νοῦν ἔσχες; ἐν τῷ συμφορᾶς διεφθάρης;"^^xsd:string .
:Line_1230 a :Line ; :lineNumber 1230 ; :canonicalReference "1230" ; :text "Ἔξελθε, τέκνον, ἱκέσιός σε λίσσομαι."^^xsd:string .
:Line_1231 a :Line ; :lineNumber 1231 ; :canonicalReference "1231" ; :text "Τὸν δ ̓ ἀγρίοις ὄσσοισι παπτήνας ὁ παῖς,"^^xsd:string ; :hasConflict :Conflict_HaemonVsCreon_Violence .
:Line_1232 a :Line ; :lineNumber 1232 ; :canonicalReference "1232" ; :text "πτύσας προσώπῳ κοὐδὲν ἀντειπών, ξίφους"^^xsd:string .
:Line_1233 a :Line ; :lineNumber 1233 ; :canonicalReference "1233" ; :text "ἕλκει διπλοῦς κνώδοντας, ἐκ δ ̓ ὁρμωμένου"^^xsd:string .
:Line_1234 a :Line ; :lineNumber 1234 ; :canonicalReference "1234" ; :text "πατρὸς φυγαῖσιν ἤμπλακ ̓· εἶθ ̓ ὁ δύσμορος"^^xsd:string .
:Line_1235 a :Line ; :lineNumber 1235 ; :canonicalReference "1235" ; :text "αὑτῷ χολωθείς, ὥσπερ εἶχ ̓, ἐπενταθεὶς"^^xsd:string .
:Line_1236 a :Line ; :lineNumber 1236 ; :canonicalReference "1236" ; :text "ἤρεισε πλευραῖς μέσσον ἔγχος, ἐς δ ̓ ὑγρὸν"^^xsd:string .
:Line_1237 a :Line ; :lineNumber 1237 ; :canonicalReference "1237" ; :text "ἀγκῶν ̓ ἔτ ̓ ἔμφρων παρθένῳ προσπτύσσεται·"^^xsd:string .
:Line_1238 a :Line ; :lineNumber 1238 ; :canonicalReference "1238" ; :text "καὶ φυσιῶν ὀξεῖαν ἐκβάλλει ῥοὴν"^^xsd:string .
:Line_1239 a :Line ; :lineNumber 1239 ; :canonicalReference "1239" ; :text "λευκῇ παρειᾷ φοινίου σταλάγματος."^^xsd:string .
:Line_1240 a :Line ; :lineNumber 1240 ; :canonicalReference "1240" ; :text "Κεῖται δὲ νεκρὸς περὶ νεκρῷ, τὰ νυμφικὰ"^^xsd:string ; :hasTheme :Theme_MarriageToDeath .
:Line_1241 a :Line ; :lineNumber 1241 ; :canonicalReference "1241" ; :text "τέλη λαχὼν δείλαιος εἰν Ἅιδου δόμοις,"^^xsd:string .
:Line_1242 a :Line ; :lineNumber 1242 ; :canonicalReference "1242" ; :text "δείξας ἐν ἀνθρώποισι τὴν ἀβουλίαν"^^xsd:string ; :hasTheme :Theme_Aboulia .
:Line_1243 a :Line ; :lineNumber 1243 ; :canonicalReference "1243" ; :text "ὅσῳ μέγιστον ἀνδρὶ πρόσκειται κακόν."^^xsd:string .

############################
# TRANSLATION VARIANTS (EN)
############################

:TV_Line_1195_en a :TranslationVariant ; :relatedTo :Line_1195 ; :text "Truth is always the right way."^^xsd:string .
:TV_Line_1205_en a :TranslationVariant ; :relatedTo :Line_1205 ; :text "We entered the hollow bridal chamber of Hades."^^xsd:string .
:TV_Line_1240_en a :TranslationVariant ; :relatedTo :Line_1240 ; :text "He lies, a corpse upon a corpse, having won his marriage rites in the halls of Death."^^xsd:string .
:TV_Line_1242_en a :TranslationVariant ; :relatedTo :Line_1242 ; :text "Showing that lack of counsel is the greatest evil for man."^^xsd:string .

############################
# THEMES, EMOTIONS, CONFLICTS
############################

:Theme_Aboulia a owl:NamedIndividual, :Theme ; :description "The 'lack of counsel' or poor judgment, identified as the greatest human evil."^^xsd:string .
:Theme_MarriageToDeath a owl:NamedIndividual, :Theme ; :description "The tragic union of Haemon and Antigone in the tomb (marriage in Hades)."^^xsd:string .
:Theme_PiousBurial a owl:NamedIndividual, :Theme ; :description "The belated religious duty performed for Polynices' body."^^xsd:string .
:Theme_UnerringTruth a owl:NamedIndividual, :Theme ; :description "The Messenger's commitment to absolute honesty regardless of the pain it causes."^^xsd:string .

:EurydiceEmotion_Shock a owl:NamedIndividual, :Emotion ; :description "Eurydice's physical collapse and fainting upon hearing the initial cry of woe."^^xsd:string .
:EurydiceEmotion_Resilience a owl:NamedIndividual, :Emotion ; :description "Her determination to hear the full story, being 'not unacquainted with evils'."^^xsd:string .
:HaemonEmotion_Rage a owl:NamedIndividual, :Emotion ; :description "The wild, savage glare Haemon directs at his father before the suicide."^^xsd:string .
:CreonEmotion_BelatedAgony a owl:NamedIndividual, :Emotion ; :description "Creon's realization and wretched cries as he approaches the tomb."^^xsd:string .

:MessengerMotivation_UnerringTruth a owl:NamedIndividual, :Motivation ; :description "The intent to speak clearly and fully, as truth is always best."^^xsd:string .
:HaemonDecision_Suicide_Grief a owl:NamedIndividual, :MoralDecision ; :description "Haemon's choice to join Antigone in death, leaning his side against his sword."^^xsd:string .

:Conflict_HaemonVsCreon_Violence a owl:NamedIndividual, :Conflict ; 
    :conflictBetween :Haemon_Character_Haemon, :Creon_Character_Creon ;
    :description "The physical and emotional confrontation at the tomb, ending in attempted patricide and suicide."^^xsd:string .

:Conflict_HumanWillVsDivineLaw a owl:NamedIndividual, :Conflict ;
    :conflictBetween :Creon_Character_Creon, :Law_DivineBurial ;
    :description "The conflict between Creon's late obedience and the resulting destruction."^^xsd:string .

:Law_DivineBurial a owl:NamedIndividual, :Law ; :description "The divine law requiring burial, finally honored by Creon at the field."^^xsd:string .