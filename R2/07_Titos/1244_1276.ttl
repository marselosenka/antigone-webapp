@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

############################
# SCENE & SPEECH DEFINITIONS
############################

:Antigone_Scene_Exodus_Cont_3
    a owl:NamedIndividual, :Scene ;
    :sceneNumber "Exodus (Part 3)"^^xsd:string ;
    :hasSpeech :Speech_Chorus_1244_1245, :Speech_Messenger_1246_1250, :Speech_Chorus_1251_1252, 
                :Speech_Messenger_1253_1256, :Speech_Chorus_1257_1260, :Speech_Creon_1261_1269, 
                :Speech_Chorus_1270, :Speech_Creon_1271_1276 ;
    :developsTheme :Theme_ExcessiveSilence, :Theme_LateJustice, :Theme_DivineRetribution .

:Speech_Chorus_1244_1245 a owl:NamedIndividual, :Speech ; :speechBy :Chorus_Character_Chorus ; :containsLine :Line_1244, :Line_1245 .
:Speech_Messenger_1246_1250 a owl:NamedIndividual, :Speech ; :speechBy :Messenger_Character_Messenger ; :containsLine :Line_1246, :Line_1247, :Line_1248, :Line_1249, :Line_1250 .
:Speech_Chorus_1251_1252 a owl:NamedIndividual, :Speech ; :speechBy :Chorus_Character_Chorus ; :containsLine :Line_1251, :Line_1252 ; :hasTheme :Theme_ExcessiveSilence .
:Speech_Messenger_1253_1256 a owl:NamedIndividual, :Speech ; :speechBy :Messenger_Character_Messenger ; :containsLine :Line_1253, :Line_1254, :Line_1255, :Line_1256 .
:Speech_Chorus_1257_1260 a owl:NamedIndividual, :Speech ; :speechBy :Chorus_Character_Chorus ; :containsLine :Line_1257, :Line_1258, :Line_1259, :Line_1260 .
:Speech_Creon_1261_1269 a owl:NamedIndividual, :Speech ; :speechBy :Creon_Character_Creon ; :containsLine :Line_1261, :Line_1262, :Line_1263, :Line_1264, :Line_1265, :Line_1266, :Line_1267, :Line_1268, :Line_1269 ; :hasTheme :Theme_SelfDestructiveCounsel .
:Speech_Chorus_1270 a owl:NamedIndividual, :Speech ; :speechBy :Chorus_Character_Chorus ; :containsLine :Line_1270 ; :hasTheme :Theme_LateJustice .
:Speech_Creon_1271_1276 a owl:NamedIndividual, :Speech ; :speechBy :Creon_Character_Creon ; :containsLine :Line_1271, :Line_1272, :Line_1273, :Line_1274, :Line_1275, :Line_1276 ; :hasTheme :Theme_DivineRetribution .

############################
# CHARACTERS & ENTITIES
############################

:Chorus_Character_Chorus a owl:NamedIndividual, :Character ; :experiencesEmotion :ChorusEmotion_Foreboding .
:Messenger_Character_Messenger a owl:NamedIndividual, :Character ; :hasMotivation :MessengerMotivation_InvestigateSilence ; :makesMoralDecision :MessengerDecision_CheckOnQueen .
:Creon_Character_Creon a owl:NamedIndividual, :Character ; :experiencesEmotion :CreonEmotion_Agony, :CreonEmotion_Anagnorisis .

############################
# CANONICAL LINES (1244-1276)
############################

:Line_1244 a :Line ; :lineNumber 1244 ; :text "ΧΟ. Τί τοῦτ ̓ ἂν εἰκάσειας; ἡ γυνὴ πάλιν"^^xsd:string .
:Line_1245 a :Line ; :lineNumber 1245 ; :text "φρούδη, πρὶν εἰπεῖν ἐσθλὸν ἢ κακὸν λόγον."^^xsd:string .
:Line_1246 a :Line ; :lineNumber 1246 ; :text "ΑΓ. Καὐτὸς τεθάμβηκ ̓· ἐλπίσιν δὲ βόσκομαι"^^xsd:string .
:Line_1247 a :Line ; :lineNumber 1247 ; :text "ἄχη τέκνου κλύουσαν ἐς πόλιν γόου"^^xsd:string .
:Line_1248 a :Line ; :lineNumber 1248 ; :text "οὐκ ἀξιώσειν, ἀλλ ̓ ὑπὸ στέγης ἔσω"^^xsd:string .
:Line_1249 a :Line ; :lineNumber 1249 ; :text "δμωαῖς προθήσειν πένθος οἰκεῖον στένειν."^^xsd:string .
:Line_1250 a :Line ; :lineNumber 1250 ; :text "Γνώμης γὰρ οὐκ ἄπειρος, ὥσθ ̓ ἁμαρτάνειν."^^xsd:string .
:Line_1251 a :Line ; :lineNumber 1251 ; :text "ΧΟ. Οὐκ οἶδ ̓· ἐμοὶ δ ̓ οὖν ἥ τ ̓ ἄγαν σιγὴ βαρὺ"^^xsd:string .
:Line_1252 a :Line ; :lineNumber 1252 ; :text "δοκεῖ προσεῖναι χἠ μάτην πολλὴ βοή."^^xsd:string .
:Line_1253 a :Line ; :lineNumber 1253 ; :text "ΑΓ. Ἀλλ ̓ εἰσόμεσθα μή τι καὶ κατάσχετον"^^xsd:string .
:Line_1254 a :Line ; :lineNumber 1254 ; :text "κρυφῇ καλύπτει καρδίᾳ θυμουμένῃ,"^^xsd:string .
:Line_1255 a :Line ; :lineNumber 1255 ; :text "δόμους παραστείχοντες· εὖ γὰρ οὖν λέγεις·"^^xsd:string .
:Line_1256 a :Line ; :lineNumber 1256 ; :text "καὶ τῆς ἄγαν γάρ ἐστί που σιγῆς βάρος."^^xsd:string .
:Line_1257 a :Line ; :lineNumber 1257 ; :text "ΧΟ. Καὶ μὴν ὅδ ̓ ἄναξ αὐτὸς ἐφήκει"^^xsd:string .
:Line_1258 a :Line ; :lineNumber 1258 ; :text "μνῆμ ̓ ἐπίσημον διὰ χειρὸς ἔχων,"^^xsd:string .
:Line_1259 a :Line ; :lineNumber 1259 ; :text "εἰ θέμις εἰπεῖν, οὐκ ἀλλοτρίαν"^^xsd:string .
:Line_1260 a :Line ; :lineNumber 1260 ; :text "ἄτην, ἀλλ ̓ αὐτὸς ἁμαρτών."^^xsd:string .
:Line_1261 a :Line ; :lineNumber 1261 ; :text "ΚΡ. Ἰὼ φρενῶν δυσφρόνων ἁμαρτήματα"^^xsd:string ; :hasTheme :Theme_Misjudgment .
:Line_1262 a :Line ; :lineNumber 1262 ; :text "στερεὰ θανατόεντ ̓,"^^xsd:string .
:Line_1263 a :Line ; :lineNumber 1263 ; :text "ὦ κτανόντας τε καὶ"^^xsd:string .
:Line_1264 a :Line ; :lineNumber 1264 ; :text "θανόντας βλέποντες ἐμφυλίους."^^xsd:string .
:Line_1265 a :Line ; :lineNumber 1265 ; :text "Ὤμοι ἐμῶν ἄνολβα βουλευμάτων."^^xsd:string .
:Line_1266 a :Line ; :lineNumber 1266 ; :text "Ἰὼ παῖ, νέος νέῳ ξὺν μόρῳ,"^^xsd:string .
:Line_1267 a :Line ; :lineNumber 1267 ; :text "αἰαῖ αἰαῖ,"^^xsd:string .
:Line_1268 a :Line ; :lineNumber 1268 ; :text "ἔθανες, ἀπελύθης,"^^xsd:string .
:Line_1269 a :Line ; :lineNumber 1269 ; :text "ἐμαῖς οὐδὲ σαῖσι δυσβουλίαις."^^xsd:string .
:Line_1270 a :Line ; :lineNumber 1270 ; :text "ΧΟ. Οἴμ ̓ ὡς ἔοικας ὀψὲ τὴν δίκην ἰδεῖν."^^xsd:string ; :hasTheme :Theme_LateJustice .
:Line_1271 a :Line ; :lineNumber 1271 ; :text "ΚΡ. Οἴμοι,"^^xsd:string .
:Line_1272 a :Line ; :lineNumber 1272 ; :text "ἔχω μαθὼν δείλαιος· ἐν δ ̓ ἐμῷ κάρᾳ"^^xsd:string .
:Line_1273 a :Line ; :lineNumber 1273 ; :text "θεὸς τότ ̓ ἄρα τότε μέγα βάρος μ ̓ ἔχων"^^xsd:string ; :hasTheme :Theme_DivineRetribution .
:Line_1274 a :Line ; :lineNumber 1274 ; :text "ἔπαισεν, ἐν δ ̓ ἔσεισεν ἀγρίαις ὁδοῖς,"^^xsd:string .
:Line_1275 a :Line ; :lineNumber 1275 ; :text "οἴμοι, λακπάτητον ἀντρέπων χαράν."^^xsd:string .
:Line_1276 a :Line ; :lineNumber 1276 ; :text "Φεῦ φεῦ, ἰὼ πόνοι βροτῶν δύσπονοι."^^xsd:string .

############################
# TRANSLATION VARIANTS (EN)
############################

:TV_Line_1251_en a :TranslationVariant ; :relatedTo :Line_1251 ; :text "I do not know; to me at least an excessive silence seems to bode as heavy as much vain shouting."^^xsd:string .
:TV_Line_1261_en a :TranslationVariant ; :relatedTo :Line_1261 ; :text "O the errors of a misguided mind, stubborn and death-bringing."^^xsd:string .
:TV_Line_1270_en a :TranslationVariant ; :relatedTo :Line_1270 ; :text "Alas, you seem to see justice only when it is too late."^^xsd:string .
:TV_Line_1273_en a :TranslationVariant ; :relatedTo :Line_1273 ; :text "A god then, yes then, struck me on my head with a great weight."^^xsd:string .

############################
# THEMES, EMOTIONS, CONFLICTS
############################

:Theme_ExcessiveSilence a owl:NamedIndividual, :Theme ; :description "The ominous nature of absolute silence in the face of tragedy."^^xsd:string .
:Theme_LateJustice a owl:NamedIndividual, :Theme ; :description "The tragic realization of truth only after the point of no return (Anagnorisis)."^^xsd:string .
:Theme_DivineRetribution a owl:NamedIndividual, :Theme ; :description "The idea of a god striking down the arrogant with a heavy hand."^^xsd:string .
:Theme_SelfDestructiveCounsel a owl:NamedIndividual, :Theme ; :description "The ruin caused by one's own poor decisions (dysbouliais)."^^xsd:string .
:Theme_Misjudgment a owl:NamedIndividual, :Theme ; :description "The fatal errors of the mind (hamartemata) that lead to blood-guilt."^^xsd:string .

:ChorusEmotion_Foreboding a owl:NamedIndividual, :Emotion ; :description "The Chorus's fear that Eurydice's silence hides a desperate resolution."^^xsd:string .
:CreonEmotion_Agony a owl:NamedIndividual, :Emotion ; :description "Creon's raw, vocalized pain upon holding his son's body."^^xsd:string .
:CreonEmotion_Anagnorisis a owl:NamedIndividual, :Emotion ; :description "The painful recognition of his own culpability in the deaths of his kin."^^xsd:string .

:MessengerMotivation_InvestigateSilence a owl:NamedIndividual, :Motivation ; :description "The Messenger's need to verify if the Queen is safe or hiding a secret grief."^^xsd:string .
:MessengerDecision_CheckOnQueen a owl:NamedIndividual, :MoralDecision ; :description "The choice to follow Eurydice into the house to prevent further tragedy."^^xsd:string .

:Conflict_CreonVsJustice a owl:NamedIndividual, :Conflict ;
    :conflictBetween :Creon_Character_Creon, :EthicalPrinciple_Justice ;
    :description "The internal and external conflict where Creon acknowledges that Justice has finally caught up with him."^^xsd:string .

:EthicalPrinciple_Justice a owl:NamedIndividual, :EthicalPrinciple ; :description "Dike (Justice), which Creon sees too late."^^xsd:string .