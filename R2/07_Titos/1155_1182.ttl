@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

################################################################
# SCENE & SPEECH DEFINITIONS (Lines 1155-1182)
################################################################

:Antigone_Scene_Exodus
    a owl:NamedIndividual, :Scene ;
    :sceneNumber "Exodus"^^xsd:string ;
    :hasSpeech :Speech_Messenger_1155_1171, :Speech_Chorus_1172, :Speech_Messenger_1173, :Speech_Chorus_1174, :Speech_Messenger_1175, :Speech_Chorus_1176, :Speech_Messenger_1177, :Speech_Chorus_1178, :Speech_Messenger_1179, :Speech_Chorus_1180_1182 ;
    :developsTheme :Theme_InstabilityOfFortune, :Theme_LivingDeath .

:Speech_Messenger_1155_1171
    a owl:NamedIndividual, :Speech ;
    :speechBy :Messenger_Character_Messenger ;
    :hasMotivation :MessengerMotivation_ReportTragedy ;
    :containsLine :Line_1155, :Line_1156, :Line_1157, :Line_1158, :Line_1159, 
                  :Line_1160, :Line_1161, :Line_1162, :Line_1163, :Line_1164, 
                  :Line_1165, :Line_1166, :Line_1167, :Line_1168, :Line_1169, 
                  :Line_1170, :Line_1171 .

################################################################
# CHARACTERS & ENTITIES
################################################################

:Messenger_Character_Messenger
    a owl:NamedIndividual, :Character ;
    :experiencesEmotion :MessengerEmotion_SomberReflection ;
    :hasMotivation :MessengerMotivation_ReportTragedy .

:Chorus_Character_Chorus
    a owl:NamedIndividual, :Character ;
    :experiencesEmotion :ChorusEmotion_Anxiety .

:Haemon_Character_Haemon
    a owl:NamedIndividual, :Character ;
    :experiencesEmotion :HaemonEmotion_AngerAtFather ;
    :makesMoralDecision :HaemonDecision_Suicide .

:Creon_Character_Creon
    a owl:NamedIndividual, :Character ;
    :status "Tyrannos"^^xsd:string .

:Eurydice_Character_Eurydice
    a owl:NamedIndividual, :Character ;
    :status "Queen"^^xsd:string .

################################################################
# CANONICAL LINES (Extraction 1155-1182)
################################################################

:Line_1155 a :Line ; :lineNumber 1155 ; :text "Κάδμου πάροικοι καὶ δόμων Ἀμφίονος,"^^xsd:string .
:Line_1156 a :Line ; :lineNumber 1156 ; :text "οὐκ ἔσθ ̓ ὁποῖον στάντ ̓ ἂν ἀνθρώπου βίον"^^xsd:string .
:Line_1157 a :Line ; :lineNumber 1157 ; :text "οὔτ ̓ αἰνέσαιμ ̓ ἂν οὔτε μεμψαίμην ποτέ·"^^xsd:string .
:Line_1158 a :Line ; :lineNumber 1158 ; :text "τύχη γὰρ ὀρθοῖ καὶ τύχη καταρρέπει"^^xsd:string ; :hasTheme :Theme_InstabilityOfFortune .
:Line_1159 a :Line ; :lineNumber 1159 ; :text "τὸν εὐτυχοῦντα τόν τε δυστυχοῦντ ̓ ἀεί·"^^xsd:string .
:Line_1160 a :Line ; :lineNumber 1160 ; :text "καὶ μάντις οὐδεὶς τῶν καθεστώτων βροτοῖς."^^xsd:string .
:Line_1161 a :Line ; :lineNumber 1161 ; :text "Κρέων γὰρ ἦν ζηλωτός, ὡς ἐμοί, ποτέ,"^^xsd:string .
:Line_1162 a :Line ; :lineNumber 1162 ; :text "σώσας μὲν ἐχθρῶν τήνδε Καδμείαν χθόνα,"^^xsd:string .
:Line_1163 a :Line ; :lineNumber 1163 ; :text "λαβών τε χώρας παντελῆ μοναρχίαν"^^xsd:string .
:Line_1164 a :Line ; :lineNumber 1164 ; :text "ηὔθυνε, θάλλων εὐγενεῖ τέκνων σπορᾷ·"^^xsd:string .
:Line_1165 a :Line ; :lineNumber 1165 ; :text "καὶ νῦν ἀφεῖται πάντα. Τὰς γὰρ ἡδονὰς"^^xsd:string .
:Line_1166 a :Line ; :lineNumber 1166 ; :text "ὅταν προδῶσιν ἄνδρες, οὐ τίθημ ̓ ἐγὼ"^^xsd:string .
:Line_1167 a :Line ; :lineNumber 1167 ; :text "ζῆν τοῦτον, ἀλλ ̓ ἔμψυχον ἡγοῦμαι νεκρόν."^^xsd:string ; :hasTheme :Theme_LivingDeath .
:Line_1168 a :Line ; :lineNumber 1168 ; :text "Πλούτει τε γὰρ κατ ̓ οἶκον, εἰ βούλει, μέγα,"^^xsd:string .
:Line_1169 a :Line ; :lineNumber 1169 ; :text "καὶ ζῆ τύραννον σχῆμ ̓ ἔχων, ἐὰν δ ̓ ἀπῇ"^^xsd:string .
:Line_1170 a :Line ; :lineNumber 1170 ; :text "τούτων τὸ χαίρειν, τἄλλ ̓ ἐγὼ καπνοῦ σκιᾶς"^^xsd:string .
:Line_1171 a :Line ; :lineNumber 1171 ; :text "οὐκ ἂν πριαίμην ἀνδρὶ πρὸς τὴν ἡδονήν."^^xsd:string .
:Line_1172 a :Line ; :lineNumber 1172 ; :text "Τί δ ̓ αὖ τόδ ̓ ἄχθος βασιλέων ἥκεις φέρων;"^^xsd:string .
:Line_1173 a :Line ; :lineNumber 1173 ; :text "Τεθνᾶσιν· οἱ δὲ ζῶντες αἴτιοι θανεῖν."^^xsd:string .
:Line_1174 a :Line ; :lineNumber 1174 ; :text "Καὶ τίς φονεύει; τίς δ ̓ ὁ κείμενος; λέγε."^^xsd:string .
:Line_1175 a :Line ; :lineNumber 1175 ; :text "Αἵμων ὄλωλεν· αὐτόχειρ δ ̓ αἱμάσσεται."^^xsd:string .
:Line_1176 a :Line ; :lineNumber 1176 ; :text "Πότερα πατρῴας ἢ πρὸς οἰκείας χερός;"^^xsd:string .
:Line_1177 a :Line ; :lineNumber 1177 ; :text "Αὐτὸς πρὸς αὑτοῦ, πατρὶ μηνίσας φόνου."^^xsd:string .
:Line_1178 a :Line ; :lineNumber 1178 ; :text "Ὦ μάντι, τοὔπος ὡς ἄρ ̓ ὀρθὸν ἤνυσας."^^xsd:string .
:Line_1179 a :Line ; :lineNumber 1179 ; :text "Ὡς ὧδ ̓ ἐχόντων τἄλλα βουλεύειν πάρα."^^xsd:string .
:Line_1180 a :Line ; :lineNumber 1180 ; :text "Καὶ μὴν ὁρῶ τάλαιναν Εὐρυδίκην ὁμοῦ"^^xsd:string .
:Line_1181 a :Line ; :lineNumber 1181 ; :text "δάμαρτα τὴν Κρέοντος· ἐκ δὲ δωμάτων"^^xsd:string .
:Line_1182 a :Line ; :lineNumber 1182 ; :text "ἤτοι κλύουσα παιδὸς ἢ τύχῃ περᾷ."^^xsd:string .

################################################################
# TRANSLATION VARIANTS (English)
################################################################

:TV_Line_1158_en a :TranslationVariant ; :relatedTo :Line_1158 ; :text "Fortune raises up and Fortune casts down the lucky and unlucky."^^xsd:string .
:TV_Line_1167_en a :TranslationVariant ; :relatedTo :Line_1167 ; :text "I do not consider such a man to live, but call him a breathing corpse."^^xsd:string .
:TV_Line_1175_en a :TranslationVariant ; :relatedTo :Line_1175 ; :text "Haemon has perished; he is bloodied by his own hand."^^xsd:string .
:TV_Line_1177_en a :TranslationVariant ; :relatedTo :Line_1177 ; :text "By his own hand, angry with his father for the murder."^^xsd:string .

################################################################
# SEMANTIC METADATA (Themes, Emotions, Conflicts)
################################################################

:Theme_InstabilityOfFortune a :Theme ; :description "The unpredictable nature of fate that can overturn prosperity in an instant."^^xsd:string .
:Theme_LivingDeath a :Theme ; :description "The state of existing without joy or meaning, described as being a 'breathing corpse'."^^xsd:string .

:MessengerEmotion_SomberReflection a :Emotion ; :description "The Messenger's detached, philosophical grief while observing the fall of Creon."^^xsd:string .
:ChorusEmotion_Anxiety a :Emotion ; :description "The dread of the Chorus upon seeing the Messenger arrive with bad news."^^xsd:string .
:HaemonEmotion_AngerAtFather a :Emotion ; :description "Haemon's fatal rage (menisas) against Creon's actions."^^xsd:string .

:MessengerMotivation_ReportTragedy a :Motivation ; :description "The Messenger's duty to inform the citizens of the royal house's destruction."^^xsd:string .
:HaemonDecision_Suicide a :MoralDecision ; :description "Haemon's choice to die by his own hand as a result of grief and anger."^^xsd:string .

:Conflict_HaemonVsCreon a :Conflict ; 
    :conflictBetween :Haemon_Character_Haemon, :Creon_Character_Creon ;
    :description "The ultimate break between son and father, ending in violence."^^xsd:string .