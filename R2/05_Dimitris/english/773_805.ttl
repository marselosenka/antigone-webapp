    :hasTheme :Theme_ErosOverpowersReasonAndLaw,
        :Theme_TearsAndPityAtBridalChamberOfDeath ;
    :speechBy :Chorus_Character_Chorus .

:Speech_Creon_773_780 a :Speech,
        owl:NamedIndividual ;
    :containsLine :Line_773,
        :Line_774,
        :Line_775,
        :Line_776,
        :Line_777,
        :Line_778,
        :Line_779,
        :Line_780 ;
    :hasTheme :Theme_CivicPurityAndMiasma,
        :Theme_DeathAndHadesReverence ;
    :speechBy :Creon_Character_Creon .

:Theme_CivicPurityAndMiasma a :Theme,
        owl:NamedIndividual ;
    :description "Civic anxiety about ritual pollution and the attempt to protect the polis from miasma."^^xsd:string .

:Theme_TearsAndPityAtBridalChamberOfDeath a :Theme,
        owl:NamedIndividual ;
    :description "Pathos: tears at Antigone's approach to the 'bridal chamber' of death."^^xsd:string .

:CreonDecision_EntombAntigoneAlive a :MoralDecision,
        owl:NamedIndividual ;
    :description "Creon decides to hide Antigone alive in a rocky underground chamber with minimal food."^^xsd:string ;
    :relatedTo :CreonMotivation_AvoidMiasmaForCity .

:CreonMotivation_AvoidMiasmaForCity a :Motivation,
        owl:NamedIndividual ;
    :description "To ensure the city escapes pollution by shifting responsibility to Hades and isolating the condemned."^^xsd:string .

