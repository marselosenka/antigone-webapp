@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Antigone_Character_Antigone a :Character,
        owl:NamedIndividual ;
    :relatedTo :CreonDecision_EntombAntigoneAlive .

:Antigone_Scene_ThirdStasimon_773_805 a :Scene,
        owl:NamedIndividual ;
    :developsTheme :Theme_DeathAndHadesReverence,
        :Theme_ErosOverpowersReasonAndLaw ;
    :hasConflict :Conflict_ErosVsJustice ;
    :hasSpeech :Speech_Chorus_781_805,
        :Speech_Creon_773_780 ;
    :sceneNumber "Stasimon 3"^^xsd:string .

:TV_Line_773_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_773 ;
    :text "I will lead her along a deserted path"^^xsd:string .

:TV_Line_774_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_774 ;
    :text "And then seal her in a rocky cavern there,"^^xsd:string .

:TV_Line_775_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_775 ;
    :text "Leaving her only as much food as is necessary"^^xsd:string .

:TV_Line_776_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_776 ;
    :text "To clear the city’s name of the charge of murder."^^xsd:string .

:TV_Line_777_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_777 ;
    :text "And at some point in that cave she will beg Hades"^^xsd:string .

:TV_Line_778_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_778 ;
    :text "Not to let her die (since he’s the only god she cares for),"^^xsd:string .

:TV_Line_779_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_779 ;
    :text "Or at any rate she will realize then that there’s"^^xsd:string .

:TV_Line_780_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_780 ;
    :text "Excessive pain in worshipping the god of death."^^xsd:string .

:TV_Line_781_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_781 ;
    :text "Eros, o Eros, unvanquished in battle!"^^xsd:string .

:TV_Line_782_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_782 ;
    :text "Who falls upon riches,"^^xsd:string .

:TV_Line_783_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_783 ;
    :text "Who sleeps every night"^^xsd:string .

:TV_Line_784_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_784 ;
    :text "On a young maiden’s tender cheeks,"^^xsd:string .

:TV_Line_785_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_785 ;
    :text "Traversing both the depths and"^^xsd:string .

:TV_Line_786_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_786 ;
    :text "The most rural of abodes:"^^xsd:string .

:TV_Line_787_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_787 ;
    :text "From you indeed neither the deathless gods"^^xsd:string .

:TV_Line_788_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_788 ;
    :text "Nor any man who lives but one day"^^xsd:string .

:TV_Line_789_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_789 ;
    :text "Can ever hope to escape;"^^xsd:string .

:TV_Line_790_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_790 ;
    :text "Your victim is always driven mad."^^xsd:string .

:TV_Line_791_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_791 ;
    :text "You lead the minds of the just"^^xsd:string .

:TV_Line_792_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_792 ;
    :text "Astray towards disgraceful insult;"^^xsd:string .

:TV_Line_793_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_793 ;
    :text "The one to have ignited this strife of mankind is you;"^^xsd:string .

:TV_Line_794_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_794 ;
    :text "Yet desire wins out, shining"^^xsd:string .

:TV_Line_795_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_795 ;
    :text "From the brow of a brilliant bride,"^^xsd:string .

:TV_Line_796_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_796 ;
    :text "Desire sitting in the office"^^xsd:string .

:TV_Line_797_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_797 ;
    :text "Of the great divine law."^^xsd:string .

:TV_Line_798_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_798 ;
    :text "For, while this battle is waged, a god jests from afar—Aphrodite!"^^xsd:string .

:TV_Line_799_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_799 ;
    :text "Yet, now, seeing these things, I am forced to transgress justice,"^^xsd:string .

:TV_Line_800_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_800 ;
    :text "No longer strong enough to restrain"^^xsd:string .

:TV_Line_801_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_801 ;
    :text "The river of tears when I see Antigone"^^xsd:string .

:TV_Line_802_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_802 ;
    :text "Proceeding to her final place of rest."^^xsd:string .

:TV_Line_803_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_803 ;
    :text "Proceeding to her final place of rest."^^xsd:string .

:TV_Line_804_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_804 ;
    :text "Proceeding to her final place of rest."^^xsd:string .

:TV_Line_805_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_805 ;
    :text "Proceeding to her final place of rest."^^xsd:string .

:ChorusEmotion_AweAtErosPower a :Emotion,
        owl:NamedIndividual ;
    :description "Awe at Eros as an invincible power that drives all to madness."^^xsd:string .

:ChorusEmotion_TearsAndPityForAntigone a :Emotion,
        owl:NamedIndividual ;
    :description "Tears and pity at the sight of Antigone going to the all-shared bridal chamber (death)."^^xsd:string .

:Chorus_Character_Chorus a :Character,
        owl:NamedIndividual ;
    :experiencesEmotion :ChorusEmotion_AweAtErosPower,
        :ChorusEmotion_TearsAndPityForAntigone .

:Conflict_ErosVsJustice a :Conflict,
        owl:NamedIndividual ;
    :conflictBetween :EthicalPrinciple_ErosDesire,
        :EthicalPrinciple_Justice ;
    :description "Eros overthrows just minds, turning the just toward injustice and stirring kin-strife."^^xsd:string .

:Creon_Character_Creon a :Character,
        owl:NamedIndividual ;
    :advocatesFor :EthicalPrinciple_AvoidMiasma,
        :EthicalPrinciple_CivicPurity ;
    :hasMotivation :CreonMotivation_AvoidMiasmaForCity ;
    :makesMoralDecision :CreonDecision_EntombAntigoneAlive .

:EthicalPrinciple_AvoidMiasma a :EthicalPrinciple,
        owl:NamedIndividual ;
    :description "Avoidance of ritual pollution (μίασμα) as a public danger."^^xsd:string .

:EthicalPrinciple_CivicPurity a :EthicalPrinciple,
        owl:NamedIndividual ;
    :description "Protection of the polis from pollution; prioritizing civic well-being."^^xsd:string .

:EthicalPrinciple_ErosDesire a :EthicalPrinciple,
        owl:NamedIndividual ;
    :description "Eros/desire as a compelling force that bends minds and actions."^^xsd:string .

:EthicalPrinciple_Justice a :EthicalPrinciple,
        owl:NamedIndividual ;
    :description "Commitment to what is just (δίκαια) in judgment and action."^^xsd:string .

