:Antigone_Scene_Stasimon4_ExodosTransition a :Scene,
        owl:NamedIndividual ;
    :developsTheme :Theme_DivineVsMortalCondition,
        :Theme_FamilyCurseOfLabdacids,
        :Theme_LivingDeathAndExile ;
    :hasConflict :Conflict_AntigoneVsChorusOnDivineComparison ;
    :hasSpeech :Speech_Antigone_823_853,
        :Speech_Antigone_856_871,
        :Speech_Chorus_854_855 ;
    :sceneNumber "Kommos/lyric exchange (Antigone with Chorus), lines 823-871"^^xsd:string ;
    :setting "Before the palace at Thebes; Antigone led toward her living tomb (implied by text)."^^xsd:string .

:TV_Line_823_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_823 ;
    :text "I have heard how our Phrygian guest, Niobe, the daughter of Tantalus, died a miserable death."^^xsd:string .

:TV_Line_824_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_824 ;
    :text "I have heard how our Phrygian guest, Niobe, the daughter of Tantalus, died a miserable death."^^xsd:string .

:TV_Line_825_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_825 ;
    :text "I have heard how our Phrygian guest, Niobe, the daughter of Tantalus, died a miserable death near lofty Mount Sipylus."^^xsd:string .

:TV_Line_826_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_826 ;
    :text "The growth of rock, like clinging ivy, subdued her."^^xsd:string .

:TV_Line_827_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_827 ;
    :text "Now—as the story goes—she melts away."^^xsd:string .

:TV_Line_828_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_828 ;
    :text "Now—as the story goes—she melts away."^^xsd:string .

:TV_Line_829_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_829 ;
    :text "Rain and snow never leave her."^^xsd:string .

:TV_Line_830_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_830 ;
    :text "But with tears streaming down her face, she dampens the ridges of the mountain."^^xsd:string .

:TV_Line_831_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_831 ;
    :text "I am most like her, as the god leads me to my sleep."^^xsd:string .

:TV_Line_832_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_832 ;
    :text "Yet she was not only god-born but also a goddess herself, while we are but mortals, born from mortals."^^xsd:string .

:TV_Line_833_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_833 ;
    :text "Yet she was not only god-born but also a goddess herself, while we are but mortals, born from mortals."^^xsd:string .

:TV_Line_834_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_834 ;
    :text "Still, it is great for one in the throes of death to hear that she has obtained the luck of a god in life and in death."^^xsd:string .

:TV_Line_835_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_835 ;
    :text "Still, it is great for one in the throes of death to hear that she has obtained the luck of a god in life and in death."^^xsd:string .

:TV_Line_836_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_836 ;
    :text "Still, it is great for one in the throes of death to hear that she has obtained the luck of a god in life and in death."^^xsd:string .

:TV_Line_837_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_837 ;
    :text "Oh, now you’re mocking me!"^^xsd:string .

:TV_Line_838_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_838 ;
    :text "Why, by my father’s gods, do you insult me to my face, and not wait until I’ve gone, my city and you, her wealthiest citizens?"^^xsd:string .

:TV_Line_839_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_839 ;
    :text "Why, by my father’s gods, do you insult me to my face, and not wait until I’ve gone, my city and you, her wealthiest citizens?"^^xsd:string .

:TV_Line_840_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_840 ;
    :text "Why, by my father’s gods, do you insult me to my face, and not wait until I’ve gone, my city and you, her wealthiest citizens?"^^xsd:string .

:TV_Line_841_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_841 ;
    :text "Why, by my father’s gods, do you insult me to my face, and not wait until I’ve gone, my city and you, her wealthiest citizens?"^^xsd:string .

:TV_Line_842_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_842 ;
    :text "Why, by my father’s gods, do you insult me to my face, and not wait until I’ve gone, my city and you, her wealthiest citizens?"^^xsd:string .

:TV_Line_843_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_843 ;
    :text "Ah! Springs of Dirce and grove of Thebes of many chariots, you at least I can count on to witness how I go, unwept by my loved ones, to my rock-heap prison, to my unknown tomb."^^xsd:string .

:TV_Line_844_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_844 ;
    :text "Ah! Springs of Dirce and grove of Thebes of many chariots, you at least I can count on to witness how I go, unwept by my loved ones, to my rock-heap prison, to my unknown tomb."^^xsd:string .

:TV_Line_845_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_845 ;
    :text "Ah! Springs of Dirce and grove of Thebes of many chariots, you at least I can count on to witness how I go, unwept by my loved ones, to my rock-heap prison, to my unknown tomb."^^xsd:string .

:TV_Line_846_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_846 ;
    :text "Ah! Springs of Dirce and grove of Thebes of many chariots, you at least I can count on to witness how I go, unwept by my loved ones, to my rock-heap prison, to my unknown tomb."^^xsd:string .

:TV_Line_847_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_847 ;
    :text "Ah! Unhappy one! I neither live among mortals nor shades, neither with the living nor the dead."^^xsd:string .

:TV_Line_848_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_848 ;
    :text "Ah! Unhappy one! I neither live among mortals nor shades, neither with the living nor the dead."^^xsd:string .

:TV_Line_849_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_849 ;
    :text "Ah! Unhappy one! I neither live among mortals nor shades, neither with the living nor the dead."^^xsd:string .

:TV_Line_850_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_850 ;
    :text "You rushed through the depths of recklessness for the high throne of Dike, but you have fallen, oh child, fallen very far."^^xsd:string .

:TV_Line_851_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_851 ;
    :text "You rushed through the depths of recklessness for the high throne of Dike, but you have fallen, oh child, fallen very far."^^xsd:string .

:TV_Line_852_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_852 ;
    :text "You rushed through the depths of recklessness for the high throne of Dike, but you have fallen, oh child, fallen very far."^^xsd:string .

:TV_Line_853_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_853 ;
    :text "Now you will pay for your father’s crimes."^^xsd:string .

:TV_Line_854_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_854 ;
    :text "You have touched upon my most painful memory, the thrice-told doom of my father and our whole destiny, that of the famed Labdacids."^^xsd:string .

:TV_Line_855_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_855 ;
    :text "You have touched upon my most painful memory, the thrice-told doom of my father and our whole destiny, that of the famed Labdacids."^^xsd:string .

:TV_Line_856_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_856 ;
    :text "You have touched upon my most painful memory, the thrice-told doom of my father and our whole destiny, that of the famed Labdacids."^^xsd:string .

:TV_Line_857_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_857 ;
    :text "You have touched upon my most painful memory, the thrice-told doom of my father and our whole destiny, that of the famed Labdacids."^^xsd:string .

:TV_Line_858_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_858 ;
    :text "You have touched upon my most painful memory, the thrice-told doom of my father and our whole destiny, that of the famed Labdacids."^^xsd:string .

:TV_Line_859_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_859 ;
    :text "You have touched upon my most painful memory, the thrice-told doom of my father and our whole destiny, that of the famed Labdacids."^^xsd:string .

:TV_Line_860_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_860 ;
    :text "Oh, our mother’s disaster of a marriage and my father’s incestuous intercourse with his ill-fated mother!"^^xsd:string .

:TV_Line_861_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_861 ;
    :text "Oh, our mother’s disaster of a marriage and my father’s incestuous intercourse with his ill-fated mother!"^^xsd:string .

:TV_Line_862_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_862 ;
    :text "From such people I, the miserable one, was born!"^^xsd:string .

:TV_Line_863_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_863 ;
    :text "I go to them to live, accursed, unmarried."^^xsd:string .

:TV_Line_864_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_864 ;
    :text "I go to them to live, accursed, unmarried."^^xsd:string .

:TV_Line_865_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_865 ;
    :text "Ah, my brother who secured an ill-fated marriage, in your death you have slain me alive."^^xsd:string .

:TV_Line_866_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_866 ;
    :text "Ah, my brother who secured an ill-fated marriage, in your death you have slain me alive."^^xsd:string .

:TV_Line_867_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_867 ;
    :text "Ah, my brother who secured an ill-fated marriage, in your death you have slain me alive."^^xsd:string .

:AntigoneEmotion_HumiliationAtMockery a :Emotion,
        owl:NamedIndividual ;
    :description "Antigone feels mocked and dishonoured ('γελῶμαι', 'ὑβρίζεις') while still visible and not yet gone."^^xsd:string .

:AntigoneEmotion_LamentationAndDespair a :Emotion,
        owl:NamedIndividual ;
    :description "Lament for her fate as neither among the living nor the dead; grief over family curse and isolation."^^xsd:string .

:AntigoneMotivation_AppealToCityAsWitness a :Motivation,
        owl:NamedIndividual ;
    :description "She calls on Thebes (Dirce's springs, the grove) and its citizens as witnesses to her unwept, friendless march to the tomb."^^xsd:string .

:AntigoneMotivation_InterpretFateAsDivineLullingToRest a :Motivation,
        owl:NamedIndividual ;
    :description "She interprets her situation through the paradigm of Niobe and says a daimon 'lulls' her into a similar rest—seeking meaning in divine causation."^^xsd:string .

:ChorusEmotion_AustereAdmonition a :Emotion,
        owl:NamedIndividual ;
    :description "Sober, admonitory stance: stresses mortal limits and frames Antigone's suffering as consequence of daring against Justice."^^xsd:string .

:Conflict_AntigoneVsChorusOnDivineComparison a :Conflict,
        owl:NamedIndividual ;
    :conflictBetween :Antigone_Character_Antigone,
        :Chorus_Character_Chorus,
        :EthicalPrinciple_MortalHumilityBeforeGods ;
    :description "Antigone's self-comparison to Niobe and appeal to divine framing clashes with the Chorus' insistence on mortal humility and separation from the divine."^^xsd:string .

:EthicalPrinciple_RespectForAncestralGodsAndCity a :EthicalPrinciple,
        owl:NamedIndividual ;
    :description "Appeal to ancestral gods and the civic community as moral witnesses; insistence on being judged within sacred/civic frameworks."^^xsd:string .

:Event_AntigoneLedToLivingTomb a :MoralDecision,
        owl:NamedIndividual ;
    :description "Antigone is taken toward the 'τυμβόχωστον ἕργμα'—a tomb-like enclosure while alive."^^xsd:string ;
    :relatedTo :Theme_LivingDeathAndExile .

