:Antigone_Scene_Unknown_929_965 a :Scene,
        owl:NamedIndividual ;
    :developsTheme :Theme_DivinePowerOverHumanWill,
        :Theme_InevitabilityOfFate,
        :Theme_PietyAndSuffering ;
    :hasConflict :Conflict_AntigonePietyVsCreonAuthority ;
    :hasSpeech :Speech_Antigone_933_934,
        :Speech_Antigone_936_943,
        :Speech_Chorus_929_930,
        :Speech_Chorus_944_965,
        :Speech_Creon_931_932,
        :Speech_Creon_935_935 ;
    :sceneNumber "929-965"^^xsd:string .

:ChorusFateEvent_MoiridiaPower a owl:NamedIndividual,
        owl:Thing ;
    :description "The Chorus asserts that a certain allotted power (μοιριδία δύνασις) is terrible and inescapable."^^xsd:string ;
    :relatedTo :Theme_InevitabilityOfFate .

:TV_Line_929_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_929 ;
    :text "The same brutal gusts of wind"^^xsd:string .

:TV_Line_930_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_930 ;
    :text "Still grip her soul."^^xsd:string .

:TV_Line_931_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_931 ;
    :text "I’ll give her guards reason"^^xsd:string .

:TV_Line_932_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_932 ;
    :text "To weep for their sluggishness."^^xsd:string .

:TV_Line_933_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_933 ;
    :text "Oh no! These words"^^xsd:string .

:TV_Line_934_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_934 ;
    :text "Are nearly death."^^xsd:string .

:TV_Line_935_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_935 ;
    :text "I cannot encourage you to hope for a different outcome."^^xsd:string .

:TV_Line_936_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_936 ;
    :text "O city of my father, o land of Thebes,"^^xsd:string .

:TV_Line_937_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_937 ;
    :text "Land of the ancient gods,"^^xsd:string .

:TV_Line_938_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_938 ;
    :text "I am led away now without delay."^^xsd:string .

:TV_Line_939_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_939 ;
    :text "Behold, princes of Thebes,"^^xsd:string .

:TV_Line_940_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_940 ;
    :text "The very last of the royal line!"^^xsd:string .

:TV_Line_941_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_941 ;
    :text "See what things I suffer, and at whose hands,"^^xsd:string .

:TV_Line_942_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_942 ;
    :text "All because I revered reverence!"^^xsd:string .

:TV_Line_943_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_943 ;
    :text "Also did Danaë dare to trade away the sky’s"^^xsd:string .

:TV_Line_944_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_944 ;
    :text "Light for the enclosure of bronze walls;"^^xsd:string .

:TV_Line_945_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_945 ;
    :text "Though she was hidden,"^^xsd:string .

:TV_Line_946_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_946 ;
    :text "Trapped as if in a grave."^^xsd:string .

:TV_Line_947_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_947 ;
    :text "Yet she was of noble lineage, oh child, darling, and kept safe"^^xsd:string .

:TV_Line_948_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_948 ;
    :text "The gold-streamed seed of Zeus."^^xsd:string .

:TV_Line_950_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_950 ;
    :text "Destiny has a certain terrible power:"^^xsd:string .

:TV_Line_952_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_952 ;
    :text "Nothing—neither wealth, nor Ares,"^^xsd:string .

:TV_Line_953_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_953 ;
    :text "Nor lofty heights, nor dark sea-tossed ships—"^^xsd:string .

:TV_Line_954_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_954 ;
    :text "Can ward off its grasp."^^xsd:string .

:TV_Line_955_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_955 ;
    :text "The sharp-tempered Edonian king, son of Dryas,"^^xsd:string .

:TV_Line_957_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_957 ;
    :text "By Dionysus in craggy confinement."^^xsd:string .

:TV_Line_958_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_958 ;
    :text "Was tempered and shut up."^^xsd:string .

:TV_Line_959_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_959 ;
    :text "In such a way did the terror of his madness"^^xsd:string .

:TV_Line_960_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_960 ;
    :text "And brilliant might recede."^^xsd:string .

:TV_Line_961_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_961 ;
    :text "That man soon met that very same god"^^xsd:string .

:TV_Line_962_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_962 ;
    :text "Whom he once pestered"^^xsd:string .

:TV_Line_963_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_963 ;
    :text "In his mania with biting words."^^xsd:string .

:TV_Line_964_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_964 ;
    :text "For he kept trying to halt"^^xsd:string .

:TV_Line_965_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_965 ;
    :text "The frenzied Bacchantes and the fire of Apollo, provoking the flute-loving Muses."^^xsd:string .

:AntigoneDecision_AcceptBeingLed a :MoralDecision,
        owl:NamedIndividual ;
    :description "Antigone acknowledges she is being led away and will no longer delay, accepting the immediate course toward death."^^xsd:string ;
    :relatedTo :AntigoneMotivation_AffirmPietyBeforeDeath .

:AntigoneEmotion_LamentAndDread a :Emotion,
        owl:NamedIndividual ;
    :description "Antigone laments (οἴμοι) and recognizes the nearness of death as she is led away."^^xsd:string .

:ChorusEmotion_ConcernAtPersistentGrief a :Emotion,
        owl:NamedIndividual ;
    :description "The Chorus notes the same gusts of the soul still persist, implying ongoing agitation and grief."^^xsd:string .

:Conflict_AntigonePietyVsCreonAuthority a :Conflict,
        owl:NamedIndividual ;
    :conflictBetween :Antigone_Character_Antigone,
        :Creon_Character_Creon,
        :EthicalPrinciple_CivicAuthority,
        :EthicalPrinciple_Piety ;
    :description "Opposition between Antigone's claim to piety (εὐσέβεια) and Creon's insistence on civic authority and the confirmed sentence."^^xsd:string .

:CreonDecision_ConfirmSentence a :MoralDecision,
        owl:NamedIndividual ;
    :description "Creon refuses to offer reassurance and insists the outcome will be confirmed as decided."^^xsd:string .

:CreonEmotion_UnyieldingResolve a :Emotion,
        owl:NamedIndividual ;
    :description "Creon shows firmness and lack of consolation; he will not be persuaded otherwise."^^xsd:string .

:CreonMotivation_PunishDelayAndProceed a :Motivation,
        owl:NamedIndividual ;
    :description "Creon intends that those leading Antigone away will have lamentation as a consequence of their slowness; he presses the process forward."^^xsd:string .

:EthicalPrinciple_SubmissionToFate a :EthicalPrinciple,
        owl:NamedIndividual ;
    :description "Recognition that allotted destiny (μοῖρα) is inescapable and must be endured."^^xsd:string .

