:AntigoneEmotion_LamentAndIsolation a :Emotion,
        owl:NamedIndividual ;
    :description "Antigone laments being led away 'ἄκλαυτος, ἄφιλος, ἀνυμέναιος' and deprived of the light; she notes no friend mourns her fate."^^xsd:string .

:AntigoneMotivation_HonorPolyneicesWithBurialRites a :Motivation,
        owl:NamedIndividual ;
    :description "To honor Polyneices by washing, adorning, and giving tomb-offerings; she claims this is why she now suffers."^^xsd:string .

:Creon_Character_Creon a :Character,
        owl:NamedIndividual ;
    :hasMotivation :CreonMotivation_EnforcePunishmentByEntombment ;
    :makesMoralDecision :CreonDecision_EntombAntigoneAlive .

:EthicalPrinciple_PietyTowardDeadAndFamily a :EthicalPrinciple,
        owl:NamedIndividual ;
    :description "Eusebeia expressed as duty to the dead and to kin: burial, offerings, and honoring family even against civic judgment."^^xsd:string .

