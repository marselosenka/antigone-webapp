@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Antigone_Scene_872_928 a :Scene,
        owl:NamedIndividual ;
    :developsTheme :Theme_FamilyLoyalty,
        :Theme_IsolationAndDeath,
        :Theme_PietyAndPunishment ;
    :hasConflict :Conflict_AntigonePietyVsCreonDecree ;
    :hasSpeech :Speech_Antigone_876_882,
        :Speech_Antigone_891_928,
        :Speech_Chorus_872_875,
        :Speech_Creon_883_890 ;
    :sceneNumber "872-928"^^xsd:string .

:TV_Line_872_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_872 ;
    :text "Your prayers may be reverent,"^^xsd:string .

:TV_Line_873_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_873 ;
    :text "But they are in no way tolerable to those in power."^^xsd:string .

:TV_Line_875_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_875 ;
    :text "The rage you wished for has ruined you."^^xsd:string .

:TV_Line_876_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_876 ;
    :text "Unwept, unloved, unwed,"^^xsd:string .

:TV_Line_877_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_877 ;
    :text "I am led in misery"^^xsd:string .

:TV_Line_878_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_878 ;
    :text "Down this final path."^^xsd:string .

:TV_Line_879_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_879 ;
    :text "No more can I, unhappy girl,"^^xsd:string .

:TV_Line_880_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_880 ;
    :text "Behold the sacred eye of the flaming sun."^^xsd:string .

:TV_Line_881_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_881 ;
    :text "No friend moans in grief"^^xsd:string .

:TV_Line_882_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_882 ;
    :text "And no tears are wept for my fate."^^xsd:string .

:TV_Line_883_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_883 ;
    :text "Who would end their dying song"^^xsd:string .

:TV_Line_884_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_884 ;
    :text "If they knew the final note would be their last?"^^xsd:string .

:TV_Line_885_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_885 ;
    :text "Bring her as fast as you can, and leave her"^^xsd:string .

:TV_Line_886_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_886 ;
    :text "Alone, sealed in that shadowy tomb—as I’ve ordered you to."^^xsd:string .

:TV_Line_887_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_887 ;
    :text "She’ll either die right then and there,"^^xsd:string .

:TV_Line_888_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_888 ;
    :text "Or she’ll live entombed in that room—the decision is hers."^^xsd:string .

:TV_Line_889_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_889 ;
    :text "Our hands are clean as far as this girl is concerned."^^xsd:string .

:TV_Line_890_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_890 ;
    :text "Her place on this earth is gone."^^xsd:string .

:TV_Line_891_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_891 ;
    :text "O tomb, o bridal chamber, o deep-dug"^^xsd:string .

:TV_Line_892_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_892 ;
    :text "Everlasting home, the place I go"^^xsd:string .

:TV_Line_893_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_893 ;
    :text "To join my own, a greatest number of whom"^^xsd:string .

:TV_Line_894_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_894 ;
    :text "Persephone has welcomed among the dead;"^^xsd:string .

:TV_Line_895_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_895 ;
    :text "I am the last of them and I will descend most shamefully"^^xsd:string .

:TV_Line_896_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_896 ;
    :text "Before my time on earth can be properly spent."^^xsd:string .

:TV_Line_897_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_897 ;
    :text "But when I go, I cherish the thought"^^xsd:string .

:TV_Line_898_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_898 ;
    :text "That I will go dear to my father, and dear to you,"^^xsd:string .

:TV_Line_899_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_899 ;
    :text "Mother, and dear to you, my brother."^^xsd:string .

:TV_Line_900_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_900 ;
    :text "Since when each of you died I washed you"^^xsd:string .

:TV_Line_901_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_901 ;
    :text "With my own hands, and adorned you, and poured out"^^xsd:string .

:TV_Line_902_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_902 ;
    :text "Funeral libations—and now, Polyneices,"^^xsd:string .

:TV_Line_903_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_903 ;
    :text "This is my reward for burying you!"^^xsd:string .

:TV_Line_904_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_904 ;
    :text "And yet, in the eyes of the wise, I honored you well."^^xsd:string .

:TV_Line_905_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_905 ;
    :text "If I were a mother of children,"^^xsd:string .

:TV_Line_906_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_906 ;
    :text "Or if my husband rotted away dead,"^^xsd:string .

:TV_Line_907_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_907 ;
    :text "I would never have taken on this burden without public support."^^xsd:string .

:TV_Line_908_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_908 ;
    :text "But what law am I saying all this for?"^^xsd:string .

:TV_Line_909_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_909 ;
    :text "If my husband had died, I could’ve found another,"^^xsd:string .

:TV_Line_910_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_910 ;
    :text "And if I had lost my first child, another man could’ve fathered my second,"^^xsd:string .

:TV_Line_911_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_911 ;
    :text "But with my mother and my father both sealed away in Hades,"^^xsd:string .

:TV_Line_912_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_912 ;
    :text "I can never have a new brother."^^xsd:string .

:TV_Line_913_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_913 ;
    :text "For such a law I honored you above all others,"^^xsd:string .

:TV_Line_914_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_914 ;
    :text "But to Creon I seemed to act wrongfully"^^xsd:string .

:TV_Line_915_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_915 ;
    :text "And to be terribly reckless, dear brother!"^^xsd:string .

:TV_Line_916_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_916 ;
    :text "And now he leads me thus by the hands,"^^xsd:string .

:TV_Line_917_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_917 ;
    :text "Without a marriage bed, without a bridal song, receiving no share"^^xsd:string .

:TV_Line_918_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_918 ;
    :text "In marriage or the nurture of children,"^^xsd:string .

:TV_Line_919_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_919 ;
    :text "But in this way, deserted by loved ones, ill-fated,"^^xsd:string .

:TV_Line_920_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_920 ;
    :text "I come living to the graves of the dead."^^xsd:string .

:TV_Line_921_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_921 ;
    :text "What holy law did I violate?"^^xsd:string .

:TV_Line_922_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_922 ;
    :text "Why must I, unhappy girl, still look to the gods?"^^xsd:string .

:TV_Line_923_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_923 ;
    :text "Who should I call my ally, when pious behavior"^^xsd:string .

:TV_Line_924_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_924 ;
    :text "Has incurred me the charge of impiety."^^xsd:string .

:TV_Line_925_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_925 ;
    :text "But if these things please the gods,"^^xsd:string .

:TV_Line_927_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_927 ;
    :text "After my suffering I will come to know what I have done wrong."^^xsd:string .

:TV_Line_928_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_928 ;
    :text "But if my judges are found guilty, may they suffer no more greatly than I have suffered at their unjust hands."^^xsd:string .

:AntigoneDecision_PrioritizeBrotherOverPotentialHusbandOrChildren a :MoralDecision,
        owl:NamedIndividual ;
    :description "She declares she would not have taken such toil for a dead husband or for children, since those could be replaced, but not a brother once parents are in Hades."^^xsd:string ;
    :relatedTo :AntigoneMotivation_HonorPolyneicesWithBurialRites .

:AntigoneEmotion_HopeForFamilyAcceptanceInDeath a :Emotion,
        owl:NamedIndividual ;
    :description "She nourishes hope that she will come dear to her father, mother, and brother in Hades because she performed burial rites for them."^^xsd:string .

:AntigoneEmotion_IndignationAtInjustice a :Emotion,
        owl:NamedIndividual ;
    :description "She questions what divine justice she has transgressed and protests that she has gained 'δυσσέβειαν' by acting piously."^^xsd:string .

:ChorusEmotion_ReproachAtSelfWilledAnger a :Emotion,
        owl:NamedIndividual ;
    :description "The Chorus attributes Antigone's ruin to 'αὐτόγνωτος ... ὀργά' while acknowledging piety."^^xsd:string .

:Chorus_Character_Chorus a :Character,
        owl:NamedIndividual ;
    :experiencesEmotion :ChorusEmotion_ReproachAtSelfWilledAnger .

:Conflict_AntigonePietyVsCreonDecree a :Conflict,
        owl:NamedIndividual ;
    :conflictBetween :Antigone_Character_Antigone,
        :Creon_Character_Creon,
        :EthicalPrinciple_PietyTowardDeadAndFamily,
        :Law_CreonDecreeAgainstPolyneicesBurial ;
    :description "Opposition between Antigone's pious familial duty and Creon's civic decree/punishment."^^xsd:string .

:CreonDecision_EntombAntigoneAlive a :MoralDecision,
        owl:NamedIndividual ;
    :description "He orders Antigone to be taken quickly and enclosed in a covered tomb, left solitary to die or live entombed."^^xsd:string ;
    :relatedTo :AntigoneEmotion_LamentAndIsolation .

:CreonMotivation_EnforcePunishmentByEntombment a :Motivation,
        owl:NamedIndividual ;
    :description "To carry out the ordered punishment: shut Antigone in a roofed tomb, leave her alone, and remove the city's direct responsibility for her death."^^xsd:string .

:Law_CreonDecreeAgainstPolyneicesBurial a :Law,
        owl:NamedIndividual ;
    :description "Creon's civic prohibition/punitive stance regarding Polyneices' burial, implied by Antigone's claim that Creon judged her acts as wrongdoing."^^xsd:string .

