:Theme_StatePowerAndControl a :Theme,
        owl:NamedIndividual ;
    :description "Civic authority asserts control through punishment and procedural distancing ('we are pure' yet she will be deprived of upper-world dwelling)."^^xsd:string .

:Antigone_Character_Antigone a :Character,
        owl:NamedIndividual ;
    :advocatesFor :EthicalPrinciple_PietyTowardDeadAndFamily ;
    :experiencesEmotion :AntigoneEmotion_HopeForFamilyAcceptanceInDeath,
        :AntigoneEmotion_IndignationAtInjustice,
        :AntigoneEmotion_LamentAndIsolation ;
    :hasMotivation :AntigoneMotivation_HonorPolyneicesWithBurialRites ;
    :makesMoralDecision :AntigoneDecision_PrioritizeBrotherOverPotentialHusbandOrChildren .

:Theme_FamilyLoyalty a :Theme,
        owl:NamedIndividual ;
    :description "Kinship loyalty motivates action; Antigone prioritizes brother over replaceable marital/parental ties."^^xsd:string .

:Theme_IsolationAndDeath a :Theme,
        owl:NamedIndividual ;
    :description "Isolation, loss of marriage/children, and living entombment as a passage to death."^^xsd:string .

:Theme_PietyAndPunishment a :Theme,
        owl:NamedIndividual ;
    :description "Piety (εὐσέβεια) is affirmed yet entangled with punishment and accusations of impiety."^^xsd:string .

