@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Antigone_Scene_Stasimon4 a :Scene,
        owl:NamedIndividual ;
    :developsTheme :Theme_DeathAsMarriage,
        :Theme_IsolationAndFameInDeath ;
    :hasConflict :Conflict_LifeVsDeathTransition ;
    :hasSpeech :Speech_Antigone_806_815,
        :Speech_Chorus_816_822 ;
    :sceneNumber "Stasimon 4"^^xsd:string .

:TV_Line_806_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_806 ;
    :text "Look at me, o citizens"^^xsd:string .

:TV_Line_807_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_807 ;
    :text "Of my fatherland, as I set out"^^xsd:string .

:TV_Line_808_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_808 ;
    :text "On my last journey, as I gaze upon"^^xsd:string .

:TV_Line_809_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_809 ;
    :text "My last sunlight,"^^xsd:string .

:TV_Line_810_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_810 ;
    :text "But Hades, who puts all to sleep, leads me, still living,"^^xsd:string .

:TV_Line_811_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_811 ;
    :text "To Acheron’s shore, without the bridal song"^^xsd:string .

:TV_Line_812_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_812 ;
    :text "Which I was due."^^xsd:string .

:TV_Line_813_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_813 ;
    :text "No song has been"^^xsd:string .

:TV_Line_814_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_814 ;
    :text "Sung for me at my marriage,"^^xsd:string .

:TV_Line_815_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_815 ;
    :text "But instead I shall wed Acheron."^^xsd:string .

:TV_Line_816_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_816 ;
    :text "And so in renown and with praise"^^xsd:string .

:TV_Line_817_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_817 ;
    :text "You journey to the corpse-filled depths,"^^xsd:string .

:TV_Line_818_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_818 ;
    :text "Neither lashed by flesh-wasting plague"^^xsd:string .

:TV_Line_819_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_819 ;
    :text "Nor chancing upon death by sword;"^^xsd:string .

:TV_Line_820_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_820 ;
    :text "Rather, living alone and self-determined,"^^xsd:string .

:TV_Line_821_en a :TranslationVariant,
        owl:NamedIndividual ;
    :relatedTo :Line_821 ;
    :text "You attain for yourself the Death of mortals."^^xsd:string .

:AntigoneDecision_AcceptDeathAsAcheronBride a :MoralDecision,
        owl:NamedIndividual ;
    :description "Ἀντὶ γάμου ἐν νυμφείοις, Ἀχέροντι νυμφεύσεσθαι: ἀποδέχεται τὴν κάθοδον ὡς 'γάμον' πρὸς τὸν κάτω κόσμον."^^xsd:string ;
    :relatedTo :Theme_DeathAsMarriage .

:AntigoneEmotion_LamentAndDespair a :Emotion,
        owl:NamedIndividual ;
    :description "Θρῆνος καὶ ἀπόγνωσις: ὁρᾶται βαδίζουσα τὴν νεάταν ὁδόν, ἀπολείπουσα τὸ φέγγος ἡλίου, ἄνευ ὑμεναίων."^^xsd:string .

:AntigoneMotivation_AddressCitizensAsWitnesses a :Motivation,
        owl:NamedIndividual ;
    :description "Βούλεται τοὺς πολίτας μάρτυρας ποιήσασθαι τῆς ἐσχάτης πορείας καὶ τῆς ἀδικίας/μοίρας τῆς ἄγουσας."^^xsd:string .

:Antigone_Character_Antigone a :Character,
        owl:NamedIndividual ;
    :experiencesEmotion :AntigoneEmotion_LamentAndDespair ;
    :hasMotivation :AntigoneMotivation_AddressCitizensAsWitnesses ;
    :makesMoralDecision :AntigoneDecision_AcceptDeathAsAcheronBride ;
    :relatedTo :Theme_DeathAsMarriage .

:ChorusEmotion_AweAndPity a :Emotion,
        owl:NamedIndividual ;
    :description "Θαῦμα καὶ οἶκτος: κλεινὴ καὶ ἔπαινον ἔχουσα, αὐτόνομος ζῶσα μόνη καταβαίνει πρὸς Ἅιδην."^^xsd:string .

:Chorus_Character_Chorus a :Character,
        owl:NamedIndividual ;
    :experiencesEmotion :ChorusEmotion_AweAndPity ;
    :relatedTo :Theme_IsolationAndFameInDeath .

:EthicalPrinciple_Life a :EthicalPrinciple,
        owl:NamedIndividual ;
    :description "Ἀξία τοῦ ζῆν καὶ τοῦ ὁρᾶν τὸ φέγγος ἡλίου."^^xsd:string .

:FateConcept_DeathInevitability a :FateConcept,
        owl:NamedIndividual ;
    :description "Ἀναπόδραστος κάθοδος πρὸς Ἅιδην· ὁ θάνατος ὡς ἀνάγκη."^^xsd:string ;
    :determinesOutcomeOf :Conflict_LifeVsDeathTransition .

:Line_822 a :Line,
        owl:NamedIndividual ;
    :canonicalReference "822"^^xsd:string ;
    :lineNumber 822 .

:Speech_Antigone_806_815 a :ChoralSong,
        :Speech,
        owl:NamedIndividual ;
    :containsLine :Line_806,
        :Line_807,
        :Line_808,
        :Line_809,
        :Line_810,
        :Line_811,
        :Line_812,
        :Line_813,
        :Line_814,
        :Line_815 ;
    :hasTheme :Theme_DeathAsMarriage,
        :Theme_LamentForLostMarriage ;
    :speechBy :Antigone_Character_Antigone ;
    :text "Ὁρᾶτ’ ἔμ’, ὦ γᾶς πατρίας πολῖται, τὰν νεάταν ὁδὸν στείχουσαν, νέατον δὲ φέγγος λεύσσουσαν ἀελίου, κοὔποτ’ αὖθις, ἀλλά μ’ ὁ παγκοίτας Ἅιδας ζῶσαν ἄγει τὰν Ἀχέροντος ἀκτάν, οὔθ’ ὑμεναίων ἔγκληρον, οὔτ’ ἐπὶ νυμφείοις πώ μέ τις ὕμνος ὕμνησεν, ἀλλ’ Ἀχέροντι νυμφεύσω."^^xsd:string .

:Speech_Chorus_816_822 a :ChoralSong,
        :Speech,
        owl:NamedIndividual ;
    :containsLine :Line_816,
        :Line_817,
        :Line_818,
        :Line_819,
        :Line_820,
        :Line_821,
        :Line_822 ;
    :hasTheme :Theme_IsolationAndFameInDeath ;
    :speechBy :Chorus_Character_Chorus ;
    :text "Οὐκοῦν κλεινὴ καὶ ἔπαινον ἔχουσ’ ἐς τόδ’ ἀπέρχῃ κεῦθος νεκύων, οὔτε φθινάσιν πληγεῖσα νόσοις οὔτε ξιφέων ἐπίχειρα λαχοῦσ’, ἀλλ’ αὐτόνομος ζῶσα μόνη δὴ θνητῶν Ἀίδην καταβήσῃ."^^xsd:string .

:Conflict_LifeVsDeathTransition a :Conflict,
        owl:NamedIndividual ;
    :conflictBetween :EthicalPrinciple_Life,
        :FateConcept_DeathInevitability ;
    :description "Ἀντίθεσις μεταξὺ τοῦ φέγγους ἡλίου (βίος) καὶ τοῦ παγκοίτου Ἅιδου/Ἀχέροντος (θάνατος), ὡς ἀναγκαστικὴ μετάβασις."^^xsd:string .

