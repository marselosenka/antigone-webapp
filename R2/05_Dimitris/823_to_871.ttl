  a owl:NamedIndividual, :Speech ;
  :speechBy :Antigone_Character_Antigone ;
  :containsLine :Line_823, :Line_824, :Line_825, :Line_826, :Line_827, :Line_828, :Line_829, :Line_830, :Line_831, :Line_832, :Line_833, :Line_834, :Line_835, :Line_836, :Line_837, :Line_838, :Line_839, :Line_840, :Line_841, :Line_842, :Line_843, :Line_844, :Line_845, :Line_846, :Line_847, :Line_848, :Line_849, :Line_850, :Line_851, :Line_852, :Line_853 ;
  :hasTheme :Theme_LivingDeathAndExile .

