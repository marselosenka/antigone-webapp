  :containsLine :Line_883, :Line_884, :Line_885, :Line_886, :Line_887, :Line_888, :Line_889, :Line_890 ;
  :hasTheme :Theme_StatePowerAndControl .

:Speech_Antigone_891_928
  a owl:NamedIndividual, :Speech ;
  :speechBy :Antigone_Character_Antigone ;
  :containsLine :Line_891, :Line_892, :Line_893, :Line_894, :Line_895, :Line_896, :Line_897, :Line_898, :Line_899, :Line_900, :Line_901, :Line_902, :Line_903, :Line_904, :Line_905, :Line_906, :Line_907, :Line_908, :Line_909, :Line_910, :Line_911, :Line_912, :Line_913, :Line_914, :Line_915, :Line_916, :Line_917, :Line_918, :Line_919, :Line_920, :Line_921, :Line_922, :Line_923, :Line_924, :Line_925, :Line_926, :Line_927, :Line_928 ;
  :hasTheme :Theme_FamilyLoyalty ;
  :hasTheme :Theme_PietyAndPunishment ;
  :hasTheme :Theme_IsolationAndDeath .

:Antigone_Character_Antigone
  a owl:NamedIndividual, :Character ;
  :experiencesEmotion :AntigoneEmotion_LamentAndIsolation ;
  :experiencesEmotion :AntigoneEmotion_HopeForFamilyAcceptanceInDeath ;
  :experiencesEmotion :AntigoneEmotion_IndignationAtInjustice ;
  :hasMotivation :AntigoneMotivation_HonorPolyneicesWithBurialRites ;
  :makesMoralDecision :AntigoneDecision_PrioritizeBrotherOverPotentialHusbandOrChildren ;
  :advocatesFor :EthicalPrinciple_PietyTowardDeadAndFamily .

:Creon_Character_Creon
  a owl:NamedIndividual, :Character ;
  :hasMotivation :CreonMotivation_EnforcePunishmentByEntombment ;
  :makesMoralDecision :CreonDecision_EntombAntigoneAlive .

:Chorus_Character_Chorus
  a owl:NamedIndividual, :Character ;
  :experiencesEmotion :ChorusEmotion_ReproachAtSelfWilledAnger .

:AntigoneEmotion_LamentAndIsolation
  a owl:NamedIndividual, :Emotion ;
  :description "Antigone laments being led away 'ἄκλαυτος, ἄφιλος, ἀνυμέναιος' and deprived of the light; she notes no friend mourns her fate."^^xsd:string .

:AntigoneEmotion_HopeForFamilyAcceptanceInDeath
  a owl:NamedIndividual, :Emotion ;
  :description "She nourishes hope that she will come dear to her father, mother, and brother in Hades because she performed burial rites for them."^^xsd:string .

:AntigoneEmotion_IndignationAtInjustice
  a owl:NamedIndividual, :Emotion ;
  :description "She questions what divine justice she has transgressed and protests that she has gained 'δυσσέβειαν' by acting piously."^^xsd:string .

:ChorusEmotion_ReproachAtSelfWilledAnger
  a owl:NamedIndividual, :Emotion ;
  :description "The Chorus attributes Antigone's ruin to 'αὐτόγνωτος ... ὀργά' while acknowledging piety."^^xsd:string .

:AntigoneMotivation_HonorPolyneicesWithBurialRites
  a owl:NamedIndividual, :Motivation ;
  :description "To honor Polyneices by washing, adorning, and giving tomb-offerings; she claims this is why she now suffers."^^xsd:string .

:CreonMotivation_EnforcePunishmentByEntombment
  a owl:NamedIndividual, :Motivation ;
  :description "To carry out the ordered punishment: shut Antigone in a roofed tomb, leave her alone, and remove the city's direct responsibility for her death."^^xsd:string .

:AntigoneDecision_PrioritizeBrotherOverPotentialHusbandOrChildren
  a owl:NamedIndividual, :MoralDecision ;
  :description "She declares she would not have taken such toil for a dead husband or for children, since those could be replaced, but not a brother once parents are in Hades."^^xsd:string .

:CreonDecision_EntombAntigoneAlive
  a owl:NamedIndividual, :MoralDecision ;
  :description "He orders Antigone to be taken quickly and enclosed in a covered tomb, left solitary to die or live entombed."^^xsd:string .

:EthicalPrinciple_PietyTowardDeadAndFamily
  a owl:NamedIndividual, :EthicalPrinciple ;
  :description "Eusebeia expressed as duty to the dead and to kin: burial, offerings, and honoring family even against civic judgment."^^xsd:string .

:Law_CreonDecreeAgainstPolyneicesBurial
  a owl:NamedIndividual, :Law ;
  :description "Creon's civic prohibition/punitive stance regarding Polyneices' burial, implied by Antigone's claim that Creon judged her acts as wrongdoing."^^xsd:string .

:Conflict_AntigonePietyVsCreonDecree
  a owl:NamedIndividual, :Conflict ;
  :description "Opposition between Antigone's pious familial duty and Creon's civic decree/punishment."^^xsd:string ;
  :conflictBetween :Antigone_Character_Antigone ;
  :conflictBetween :Creon_Character_Creon ;
  :conflictBetween :EthicalPrinciple_PietyTowardDeadAndFamily ;
  :conflictBetween :Law_CreonDecreeAgainstPolyneicesBurial .

:Theme_PietyAndPunishment
  a owl:NamedIndividual, :Theme ;
  :description "Piety (εὐσέβεια) is affirmed yet entangled with punishment and accusations of impiety."^^xsd:string .

:Theme_IsolationAndDeath
  a owl:NamedIndividual, :Theme ;
  :description "Isolation, loss of marriage/children, and living entombment as a passage to death."^^xsd:string .

:Theme_FamilyLoyalty
  a owl:NamedIndividual, :Theme ;
  :description "Kinship loyalty motivates action; Antigone prioritizes brother over replaceable marital/parental ties."^^xsd:string .

:Theme_StatePowerAndControl
  a owl:NamedIndividual, :Theme ;
  :description "Civic authority asserts control through punishment and procedural distancing ('we are pure' yet she will be deprived of upper-world dwelling)."^^xsd:string .

:AntigoneDecision_PrioritizeBrotherOverPotentialHusbandOrChildren
  :relatedTo :AntigoneMotivation_HonorPolyneicesWithBurialRites .

:CreonDecision_EntombAntigoneAlive
  :relatedTo :AntigoneEmotion_LamentAndIsolation .

:Line_872
  a owl:NamedIndividual, :Line ;
  :lineNumber 872 ;
  :canonicalReference "872"^^xsd:string ;
  :text "Σέβειν μὲν εὐσέβειά τις,"^^xsd:string ;
  :hasTheme :Theme_PietyAndPunishment .

:Line_873
  a owl:NamedIndividual, :Line ;
  :lineNumber 873 ;
  :canonicalReference "873"^^xsd:string ;
  :text "κράτος δ᾽, ὅτῳ κράτος μέλει,"^^xsd:string .

:Line_874
  a owl:NamedIndividual, :Line ;
  :lineNumber 874 ;
  :canonicalReference "874"^^xsd:string ;
  :text "παραβατὸν οὐδαμᾷ πέλει,"^^xsd:string .

:Line_875
  a owl:NamedIndividual, :Line ;
  :lineNumber 875 ;
  :canonicalReference "875"^^xsd:string ;
  :text "σὲ δ᾽ αὐτόγνωτος ὤλεσ᾽ ὀργά."^^xsd:string .

:Line_876
  a owl:NamedIndividual, :Line ;
  :lineNumber 876 ;
  :canonicalReference "876"^^xsd:string ;
  :text "Ἄκλαυτος, ἄφιλος, ἀνυμέναιος ἐπωδός"^^xsd:string ;
  :hasTheme :Theme_IsolationAndDeath .

:Line_877
  a owl:NamedIndividual, :Line ;
  :lineNumber 877 ;
  :canonicalReference "877"^^xsd:string ;
  :text "ταλαίφρων ἄγομαι"^^xsd:string .

:Line_878
  a owl:NamedIndividual, :Line ;
  :lineNumber 878 ;
  :canonicalReference "878"^^xsd:string ;
  :text "τάν ἑτοίμαν ὁδόν·"^^xsd:string .

:Line_879
  a owl:NamedIndividual, :Line ;
  :lineNumber 879 ;
  :canonicalReference "879"^^xsd:string ;
  :text "οὐκέτι μοι τόδε λαμπάδος ἱερὸν"^^xsd:string .

:Line_880
  a owl:NamedIndividual, :Line ;
  :lineNumber 880 ;
  :canonicalReference "880"^^xsd:string ;
  :text "ὄμμα θέμις ὁρᾶν ταλαίνᾳ·"^^xsd:string .

:Line_881
  a owl:NamedIndividual, :Line ;
  :lineNumber 881 ;
  :canonicalReference "881"^^xsd:string ;
  :text "τὸν δ᾽ ἐμὸν πότμον ἀδάκρυτον"^^xsd:string .

:Line_882
  a owl:NamedIndividual, :Line ;
  :lineNumber 882 ;
  :canonicalReference "882"^^xsd:string ;
  :text "οὐδεὶς φίλων στενάζει."^^xsd:string .

:Line_883
  a owl:NamedIndividual, :Line ;
  :lineNumber 883 ;
  :canonicalReference "883"^^xsd:string ;
  :text "Ἆρ᾽ ἴστ᾽ ἀοιδὰς καὶ γόους πρὸ τοῦ θανεῖν"^^xsd:string ;
  :hasTheme :Theme_StatePowerAndControl .

:Line_884
  a owl:NamedIndividual, :Line ;
  :lineNumber 884 ;
  :canonicalReference "884"^^xsd:string ;
  :text "ὡς οὐδ᾽ ἂν εἷς παύσαιτ᾽ ἄν, εἰ χρείη, λέγων;"^^xsd:string .

:Line_885
  a owl:NamedIndividual, :Line ;
  :lineNumber 885 ;
  :canonicalReference "885"^^xsd:string ;
  :text "Οὐκ ἄξεθ᾽ ὡς τάχιστα, καὶ κατηρεφεῖ"^^xsd:string .

:Line_886
  a owl:NamedIndividual, :Line ;
  :lineNumber 886 ;
  :canonicalReference "886"^^xsd:string ;
  :text "τύμβῳ περιπτύξαντες, ὡς εἴρηκ᾽ ἐγώ,"^^xsd:string .

:Line_887
  a owl:NamedIndividual, :Line ;
  :lineNumber 887 ;
  :canonicalReference "887"^^xsd:string ;
  :text "ἄφετε μόνην ἔρημον, εἴτε χρῇ θανεῖν,"^^xsd:string .

:Line_888
  a owl:NamedIndividual, :Line ;
  :lineNumber 888 ;
  :canonicalReference "888"^^xsd:string ;
  :text "εἴτ᾽ ἐν τοιαύτῃ ζῶσα τυμβεύειν στέγῃ."^^xsd:string .

:Line_889
  a owl:NamedIndividual, :Line ;
  :lineNumber 889 ;
  :canonicalReference "889"^^xsd:string ;
  :text "Ἡμεῖς γὰρ ἁγνοὶ τοὐπὶ τήνδε τὴν κόρην·"^^xsd:string .

:Line_890
  a owl:NamedIndividual, :Line ;
  :lineNumber 890 ;
  :canonicalReference "890"^^xsd:string ;
  :text "μετοικίας δ᾽ οὖν τῆς ἄνω στερήσεται."^^xsd:string .

:Line_891
  a owl:NamedIndividual, :Line ;
  :lineNumber 891 ;
  :canonicalReference "891"^^xsd:string ;
  :text "Ὦ τύμβος, ὦ νυμφεῖον, ὦ κατασκαφὴς"^^xsd:string ;
  :hasTheme :Theme_IsolationAndDeath .

:Line_892
  a owl:NamedIndividual, :Line ;
  :lineNumber 892 ;
  :canonicalReference "892"^^xsd:string ;
  :text "οἴκησις αἰείφρουρος, οἷ πορεύομαι"^^xsd:string .

:Line_893
  a owl:NamedIndividual, :Line ;
  :lineNumber 893 ;
  :canonicalReference "893"^^xsd:string ;
  :text "πρὸς τοὺς ἐμαυτῆς, ὧν ἀριθμὸν ἐν νεκροῖς"^^xsd:string .

:Line_894
  a owl:NamedIndividual, :Line ;
  :lineNumber 894 ;
  :canonicalReference "894"^^xsd:string ;
  :text "πλεῖστον δέδεκται Φερσέφασσ᾽ ὀλωλότων·"^^xsd:string .

:Line_895
  a owl:NamedIndividual, :Line ;
  :lineNumber 895 ;
  :canonicalReference "895"^^xsd:string ;
  :text "ὧν λοισθία ἐγὼ καὶ κάκιστα δὴ μακρῷ"^^xsd:string .

:Line_896
  a owl:NamedIndividual, :Line ;
  :lineNumber 896 ;
  :canonicalReference "896"^^xsd:string ;
  :text "κάτειμι, πρίν μοι μοῖραν ἐξήκειν βίου."^^xsd:string .

:Line_897
  a owl:NamedIndividual, :Line ;
  :lineNumber 897 ;
  :canonicalReference "897"^^xsd:string ;
  :text "Ἐλθοῦσα μέντοι κάρτ᾽ ἐν ἐλπίσιν τρέφω"^^xsd:string .

:Line_898
  a owl:NamedIndividual, :Line ;
  :lineNumber 898 ;
  :canonicalReference "898"^^xsd:string ;
  :text "φίλη μὲν ἥξειν πατρί, προσφιλὴς δὲ σοί,"^^xsd:string .

:Line_899
  a owl:NamedIndividual, :Line ;
  :lineNumber 899 ;
  :canonicalReference "899"^^xsd:string ;
  :text "μῆτερ, φίλη δὲ σοί, κασίγνητον κάρα·"^^xsd:string ;
  :hasTheme :Theme_FamilyLoyalty .

:Line_900
  a owl:NamedIndividual, :Line ;
  :lineNumber 900 ;
  :canonicalReference "900"^^xsd:string ;
  :text "ἐπεὶ θανόντας αὐτόχειρ ὑμᾶς ἐγὼ"^^xsd:string .

:Line_901
  a owl:NamedIndividual, :Line ;
  :lineNumber 901 ;
  :canonicalReference "901"^^xsd:string ;
  :text "ἔλουσα κἀκόσμησα κἀπιτυμβίους"^^xsd:string .

:Line_902
  a owl:NamedIndividual, :Line ;
  :lineNumber 902 ;
  :canonicalReference "902"^^xsd:string ;
  :text "χοὰς ἔδωκα· νῦν δέ, Πολύνεικες, τὸ σὸν"^^xsd:string .

:Line_903
  a owl:NamedIndividual, :Line ;
  :lineNumber 903 ;
  :canonicalReference "903"^^xsd:string ;
  :text "δέμας περιστέλλουσα τοιάδ᾽ ἄρνυμαι."^^xsd:string .

:Line_904
  a owl:NamedIndividual, :Line ;
  :lineNumber 904 ;
  :canonicalReference "904"^^xsd:string ;
  :text "Καίτοι σ᾽ ἐγὼ ἐτίμησα τοῖς φρονοῦσιν εὖ."^^xsd:string .

:Line_905
  a owl:NamedIndividual, :Line ;
  :lineNumber 905 ;
  :canonicalReference "905"^^xsd:string ;
  :text "Οὐ γάρ ποτ᾽ οὔτ᾽ ἂν εἰ τέκνων μήτηρ ἔφυν,"^^xsd:string .

:Line_906
  a owl:NamedIndividual, :Line ;
  :lineNumber 906 ;
  :canonicalReference "906"^^xsd:string ;
  :text "οὔτ᾽ εἰ πόσις μοι κατθανὼν ἐτήκετο,"^^xsd:string .

:Line_907
  a owl:NamedIndividual, :Line ;
  :lineNumber 907 ;
  :canonicalReference "907"^^xsd:string ;
  :text "βίᾳ πολιτῶν τόνδ᾽ ἂν ᾐρόμην πόνον."^^xsd:string .

:Line_908
  a owl:NamedIndividual, :Line ;
  :lineNumber 908 ;
  :canonicalReference "908"^^xsd:string ;
  :text "Τίνος νόμου δὴ ταῦτα πρὸς χάριν λέγω;"^^xsd:string .

:Line_909
  a owl:NamedIndividual, :Line ;
  :lineNumber 909 ;
  :canonicalReference "909"^^xsd:string ;
  :text "πόσις μὲν ἄν μοι κατθανόντος ἄλλος ἦν,"^^xsd:string .

:Line_910
  a owl:NamedIndividual, :Line ;
  :lineNumber 910 ;
  :canonicalReference "910"^^xsd:string ;
  :text "καὶ παῖς ἀπ᾽ ἄλλου φωτός, εἰ τοῦδ᾽ ἤμπλακον·"^^xsd:string .

:Line_911
  a owl:NamedIndividual, :Line ;
  :lineNumber 911 ;
  :canonicalReference "911"^^xsd:string ;
  :text "μητρὸς δ᾽ ἐν Ἅιδου καὶ πατρὸς κεκευθότοιν"^^xsd:string .

:Line_912
  a owl:NamedIndividual, :Line ;
  :lineNumber 912 ;
  :canonicalReference "912"^^xsd:string ;
  :text "οὐκ ἔστ᾽ ἀδελφὸς ὅστις ἂν βλάστοι ποτέ."^^xsd:string .

:Line_913
  a owl:NamedIndividual, :Line ;
  :lineNumber 913 ;
  :canonicalReference "913"^^xsd:string ;
  :text "Τοιῷδε μέντοι σ᾽ ἐκπροτιμήσασ᾽ ἐγὼ"^^xsd:string .

:Line_914
  a owl:NamedIndividual, :Line ;
  :lineNumber 914 ;
  :canonicalReference "914"^^xsd:string ;
  :text "νόμῳ, Κρέοντι ταῦτ᾽ ἔδοξ᾽ ἁμαρτάνειν"^^xsd:string .

:Line_915
  a owl:NamedIndividual, :Line ;
  :lineNumber 915 ;
  :canonicalReference "915"^^xsd:string ;
  :text "καὶ δεινὰ τολμᾶν, ὦ κασίγνητον κάρα."^^xsd:string .

:Line_916
  a owl:NamedIndividual, :Line ;
  :lineNumber 916 ;
  :canonicalReference "916"^^xsd:string ;
  :text "Καὶ νῦν ἄγει με διὰ χερῶν οὕτω λαβὼν"^^xsd:string .

:Line_917
  a owl:NamedIndividual, :Line ;
  :lineNumber 917 ;
  :canonicalReference "917"^^xsd:string ;
  :text "ἄλεκτρον, ἀνυμέναιον, οὔτε του γάμου"^^xsd:string ;
  :hasTheme :Theme_IsolationAndDeath .

:Line_918
  a owl:NamedIndividual, :Line ;
  :lineNumber 918 ;
  :canonicalReference "918"^^xsd:string ;
  :text "μέρος λαχοῦσαν οὔτε παιδείου τροφῆς,"^^xsd:string .

:Line_919
  a owl:NamedIndividual, :Line ;
  :lineNumber 919 ;
  :canonicalReference "919"^^xsd:string ;
  :text "ἀλλ᾽ ὧδ᾽ ἔρημος πρὸς φίλων ἡ δύσμορος"^^xsd:string .

:Line_920
  a owl:NamedIndividual, :Line ;
  :lineNumber 920 ;
  :canonicalReference "920"^^xsd:string ;
  :text "ζῶσ᾽ ἐς θανόντων ἔρχομαι κατασκαφάς·"^^xsd:string .

:Line_921
  a owl:NamedIndividual, :Line ;
  :lineNumber 921 ;
  :canonicalReference "921"^^xsd:string ;
  :text "ποίαν παρεξελθοῦσα δαιμόνων δίκην;"^^xsd:string ;
  :hasTheme :Theme_PietyAndPunishment .

:Line_922
  a owl:NamedIndividual, :Line ;
  :lineNumber 922 ;
  :canonicalReference "922"^^xsd:string ;
  :text "Τί χρή με τὴν δύστηνον ἐς θεοὺς ἔτι"^^xsd:string .

:Line_923
  a owl:NamedIndividual, :Line ;
  :lineNumber 923 ;
  :canonicalReference "923"^^xsd:string ;
  :text "βλέπειν; τίν᾽ αὐδᾶν ξυμμάχων; ἐπεί γε δὴ"^^xsd:string .

:Line_924
  a owl:NamedIndividual, :Line ;
  :lineNumber 924 ;
  :canonicalReference "924"^^xsd:string ;
  :text "τὴν δυσσέβειαν εὐσεβοῦσ᾽ ἐκτησάμην."^^xsd:string .

:Line_925
  a owl:NamedIndividual, :Line ;
  :lineNumber 925 ;
  :canonicalReference "925"^^xsd:string ;
  :text "Ἀλλ᾽ εἰ μὲν οὖν τάδ᾽ ἐστὶν ἐν θεοῖς καλά,"^^xsd:string .

:Line_926
  a owl:NamedIndividual, :Line ;
  :lineNumber 926 ;
  :canonicalReference "926"^^xsd:string ;
  :text "παθόντες ἂν ξυγγνοῖμεν ἡμαρτηκότες·"^^xsd:string .

:Line_927
  a owl:NamedIndividual, :Line ;
  :lineNumber 927 ;
  :canonicalReference "927"^^xsd:string ;
  :text "εἰ δ᾽ οἵδ᾽ ἁμαρτάνουσι, μὴ πλείω κακὰ"^^xsd:string .

:Line_928
  a owl:NamedIndividual, :Line ;
  :lineNumber 928 ;
  :canonicalReference "928"^^xsd:string ;
  :text "πάθοιεν ἢ καὶ δρῶσιν ἐκδίκως ἐμέ."^^xsd:string .

# REPORT: Produced canonical :Line_872–:Line_928 (inclusive) and linked them into four speeches within :Antigone_Scene_872_928. No explicit scene label (episode/stasimon) was present in the source text; used numeric range as :sceneNumber. No verse-splitting conflicts detected beyond standard wrapping.