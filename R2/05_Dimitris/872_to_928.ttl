  a owl:NamedIndividual, :Scene ;
  :sceneNumber "872-928"^^xsd:string ;
  :hasSpeech :Speech_Chorus_872_875 ;
  :hasSpeech :Speech_Antigone_876_882 ;
  :hasSpeech :Speech_Creon_883_890 ;
  :hasSpeech :Speech_Antigone_891_928 ;
  :hasConflict :Conflict_AntigonePietyVsCreonDecree ;
  :developsTheme :Theme_PietyAndPunishment ;
  :developsTheme :Theme_IsolationAndDeath ;
  :developsTheme :Theme_FamilyLoyalty .

