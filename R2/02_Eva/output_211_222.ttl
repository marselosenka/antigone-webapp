  :hasTheme :Theme_AuthorityOfLaw, :Theme_StateLoyalty .

:Speech_Creon_215
  :hasTheme :Theme_StrictEnforcement .

:Speech_Creon_217
  :hasTheme :Theme_Surveillance .

:Speech_Creon_219
  :hasTheme :Theme_StrictEnforcement .

:Speech_Chorus_220
  :hasTheme :Theme_DeathAsDeterrent .

:Speech_Creon_221_222
  :hasTheme :Theme_GreedAndRuin .