################################################################

# SCENE AND SPEECH STRUCTURE

################################################################

:Antigone_Scene_Stasimon5
a :Scene ;
:sceneNumber "Stasimon 5"^^xsd:string ;
:hasSpeech :Speech_Chorus_Stasimon5 ;
:developsTheme :Theme_DivineIntervention, :Theme_CivicPollution, :Theme_DionysianWorship ;
:hasHistoricalContext :Context_ThebanPlague .

:Speech_Chorus_Stasimon5
a :Speech ;
:speechBy :Antigone_Character_Chorus ;
:containsLine :Line_1115, :Line_1120, :Line_1125, :Line_1130, :Line_1135, :Line_1140, :Line_1145, :Line_1150 ;
:hasConvention :Convention_ChoralOde .

:Antigone_Character_Chorus
a :Character ;
:role "Chorus of Theban Elders"^^xsd:string ;
:hasMotivation :Motivation_CleanseThebes ;
:experiencesEmotion :Emotion_ReligiousFervor, :Emotion_DesperateHope ;
:referencesMyth :Myth_Semele, :Myth_DragonsTeeth, :Myth_Nysa .

:Antigone_Character_Dionysus
a :Character ;
:role "Deity (Invoked)"^^xsd:string ;
:description "The god Bacchus, protector of Thebes, invoked to heal the city."^^xsd:string .

################################################################

# THEMES, MOTIVATIONS, EMOTIONS, MYTHS

################################################################

:Theme_DivineIntervention
a :Theme ;
:description "The reliance on gods to cure civic ailments that human agency cannot fix."^^xsd:string .

:Theme_CivicPollution
a :Theme ;
:description "The concept of the city being infected by a moral or physical miasma (noxious disease)."^^xsd:string .

:Theme_DionysianWorship
a :Theme ;
:description "Ritualistic elements associated with Bacchus: dancing, fire, night, and frenzy."^^xsd:string .

:Motivation_CleanseThebes
a :Motivation ;
:description "The urgent desire to purify the city of its current plague or curse."^^xsd:string .

:Emotion_ReligiousFervor
a :Emotion ;
:description "Intense, frenzied devotion and praise directed at the deity."^^xsd:string .

:Emotion_DesperateHope
a :Emotion ;
:description "Anxiety mixed with the hope that the god will arrive in time to save the city."^^xsd:string .

:Myth_Semele
a :MythologicalBackground ;
:description "Reference to Bacchus's mother, the Theban princess Semele (Cadmus' wife is implied context of lineage)."^^xsd:string .

:Myth_DragonsTeeth
a :MythologicalBackground ;
:description "The founding myth of Thebes involving the sowing of dragon's teeth."^^xsd:string .

:Myth_Nysa
a :MythologicalBackground ;
:description "The mountain associated with the raising of Dionysus."^^xsd:string .

:Convention_ChoralOde
a :AthenianTragedyConvention ;
:description "Lyric song performed by the Chorus, invoking gods and commenting on the action."^^xsd:string .

:Context_ThebanPlague
a :HistoricalContext ;
:description "The metaphorical or literal sickness affecting Thebes, mirroring the corruption of the royal house."^^xsd:string .

