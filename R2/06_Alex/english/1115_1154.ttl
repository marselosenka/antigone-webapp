# --- 1115 ---

:Line_1115 a :Line ; :lineNumber 1115 ; :canonicalReference "1115" .
:TV_Line_1115_en a :TranslationVariant ;
:text "Oh many-named one, glory of Cadmus’ wife"^^xsd:string ;
:relatedTo :Line_1115 ;
:hasIntertextualReference :Myth_Semele .

# --- 1116 ---

:Line_1116 a :Line ; :lineNumber 1116 ; :canonicalReference "1116" .
:TV_Line_1116_en a :TranslationVariant ;
:text "And offspring of thundering Zeus,"^^xsd:string ;
:relatedTo :Line_1116 .

# --- 1117 ---

:Line_1117 a :Line ; :lineNumber 1117 ; :canonicalReference "1117" .
:TV_Line_1117_en a :TranslationVariant ;
:text "Who protects famous Italy"^^xsd:string ;
:relatedTo :Line_1117 .

# --- 1118 ---

:Line_1118 a :Line ; :lineNumber 1118 ; :canonicalReference "1118" .
:TV_Line_1118_en a :TranslationVariant ;
:text "And rules over all,"^^xsd:string ;
:relatedTo :Line_1118 .

# --- 1119 ---

:Line_1119 a :Line ; :lineNumber 1119 ; :canonicalReference "1119" .
:TV_Line_1119_en a :TranslationVariant ;
:text "Who cleaves the valley of Eleusis—"^^xsd:string ;
:relatedTo :Line_1119 .

# --- 1120 ---

:Line_1120 a :Line ; :lineNumber 1120 ; :canonicalReference "1120" .
:TV_Line_1120_en a :TranslationVariant ;
:text "Bacchus! Dweller of the mother city Thebes"^^xsd:string ;
:relatedTo :Line_1120 ;
:referencesMyth :Antigone_Character_Dionysus .

# --- 1121 ---

:Line_1121 a :Line ; :lineNumber 1121 ; :canonicalReference "1121" .
:TV_Line_1121_en a :TranslationVariant ;
:text "By the flowing rivers of Ismenus"^^xsd:string ;
:relatedTo :Line_1121 .

# --- 1122 ---

:Line_1122 a :Line ; :lineNumber 1122 ; :canonicalReference "1122" .
:TV_Line_1122_en a :TranslationVariant ;
:text "And the planting of the"^^xsd:string ;
:relatedTo :Line_1122 .

# --- 1123 ---

:Line_1123 a :Line ; :lineNumber 1123 ; :canonicalReference "1123" .
:TV_Line_1123_en a :TranslationVariant ;
:text "Wild dragon’s teeth."^^xsd:string ;
:relatedTo :Line_1123 ;
:hasIntertextualReference :Myth_DragonsTeeth .

# --- 1125 ---

:Line_1125 a :Line ; :lineNumber 1125 ; :canonicalReference "1125" .
:TV_Line_1125_en a :TranslationVariant ;
:text "Flashing smoke has seen you"^^xsd:string ;
:relatedTo :Line_1125 .

# --- 1126 ---

:Line_1126 a :Line ; :lineNumber 1126 ; :canonicalReference "1126" .
:TV_Line_1126_en a :TranslationVariant ;
:text "Beyond the cliffs of the double ridge,"^^xsd:string ;
:relatedTo :Line_1126 .

# --- 1127 ---

:Line_1127 a :Line ; :lineNumber 1127 ; :canonicalReference "1127" .
:TV_Line_1127_en a :TranslationVariant ;
:text "Where the Corycian nymphs"^^xsd:string ;
:relatedTo :Line_1127 .

# --- 1128 ---

:Line_1128 a :Line ; :lineNumber 1128 ; :canonicalReference "1128" .
:TV_Line_1128_en a :TranslationVariant ;
:text "Proceed all frenzied about;"^^xsd:string ;
:relatedTo :Line_1128 ;
:hasTheme :Theme_DionysianWorship .

# --- 1129 ---

:Line_1129 a :Line ; :lineNumber 1129 ; :canonicalReference "1129" .
:TV_Line_1129_en a :TranslationVariant ;
:text "See you as well"^^xsd:string ;
:relatedTo :Line_1129 .

# --- 1130 ---

:Line_1130 a :Line ; :lineNumber 1130 ; :canonicalReference "1130" .
:TV_Line_1130_en a :TranslationVariant ;
:text "Did the Castalian streams."^^xsd:string ;
:relatedTo :Line_1130 .

# --- 1131 ---

:Line_1131 a :Line ; :lineNumber 1131 ; :canonicalReference "1131" .
:TV_Line_1131_en a :TranslationVariant ;
:text "And it is you whom the ivied heights"^^xsd:string ;
:relatedTo :Line_1131 .

# --- 1132 ---

:Line_1132 a :Line ; :lineNumber 1132 ; :canonicalReference "1132" .
:TV_Line_1132_en a :TranslationVariant ;
:text "Of the mountains of Nysa and the shore"^^xsd:string ;
:relatedTo :Line_1132 ;
:hasIntertextualReference :Myth_Nysa .

# --- 1133 ---

:Line_1133 a :Line ; :lineNumber 1133 ; :canonicalReference "1133" .
:TV_Line_1133_en a :TranslationVariant ;
:text "Green with vines send, as you strive"^^xsd:string ;
:relatedTo :Line_1133 .

# --- 1134 ---

:Line_1134 a :Line ; :lineNumber 1134 ; :canonicalReference "1134" .
:TV_Line_1134_en a :TranslationVariant ;
:text "To look upon the streets of Thebes,"^^xsd:string ;
:relatedTo :Line_1134 .

# --- 1135 ---

:Line_1135 a :Line ; :lineNumber 1135 ; :canonicalReference "1135" .
:TV_Line_1135_en a :TranslationVariant ;
:text "The immortal words crying themselves out."^^xsd:string ;
:relatedTo :Line_1135 .

# --- 1137 ---

:Line_1137 a :Line ; :lineNumber 1137 ; :canonicalReference "1137" .
:TV_Line_1137_en a :TranslationVariant ;
:text "Of all cities you honor Thebes the most,"^^xsd:string ;
:relatedTo :Line_1137 .

# --- 1138 ---

:Line_1138 a :Line ; :lineNumber 1138 ; :canonicalReference "1138" .
:TV_Line_1138_en a :TranslationVariant ;
:text "Along with your petrified mother:"^^xsd:string ;
:relatedTo :Line_1138 ;
:hasIntertextualReference :Myth_Semele .

# --- 1140 ---

:Line_1140 a :Line ; :lineNumber 1140 ; :canonicalReference "1140" .
:TV_Line_1140_en a :TranslationVariant ;
:text "Now indeed, when the whole city is"^^xsd:string ;
:relatedTo :Line_1140 ;
:hasTheme :Theme_CivicPollution .

# --- 1141 ---

:Line_1141 a :Line ; :lineNumber 1141 ; :canonicalReference "1141" .
:TV_Line_1141_en a :TranslationVariant ;
:text "Infected head to toe"^^xsd:string ;
:relatedTo :Line_1141 .

# --- 1142 ---

:Line_1142 a :Line ; :lineNumber 1142 ; :canonicalReference "1142" .
:TV_Line_1142_en a :TranslationVariant ;
:text "By some noxious disease,"^^xsd:string ;
:relatedTo :Line_1142 .

# --- 1143 ---

:Line_1143 a :Line ; :lineNumber 1143 ; :canonicalReference "1143" .
:TV_Line_1143_en a :TranslationVariant ;
:text "You hurry to pass over"^^xsd:string ;
:relatedTo :Line_1143 ;
:hasTheme :Theme_DivineIntervention .

# --- 1144 ---

:Line_1144 a :Line ; :lineNumber 1144 ; :canonicalReference "1144" .
:TV_Line_1144_en a :TranslationVariant ;
:text "With your cleansing foot"^^xsd:string ;
:relatedTo :Line_1144 .

# --- 1145 ---

:Line_1145 a :Line ; :lineNumber 1145 ; :canonicalReference "1145" .
:TV_Line_1145_en a :TranslationVariant ;
:text "Mount Parnassus and the sighing straits."^^xsd:string ;
:relatedTo :Line_1145 .

# --- 1146 ---

:Line_1146 a :Line ; :lineNumber 1146 ; :canonicalReference "1146" .
:TV_Line_1146_en a :TranslationVariant ;
:text "Oh come you chorus-leader, ushering the stars"^^xsd:string ;
:relatedTo :Line_1146 .

# --- 1147 ---

:Line_1147 a :Line ; :lineNumber 1147 ; :canonicalReference "1147" .
:TV_Line_1147_en a :TranslationVariant ;
:text "Which breathe fire, you who supervise the"^^xsd:string ;
:relatedTo :Line_1147 .

# --- 1148 ---

:Line_1148 a :Line ; :lineNumber 1148 ; :canonicalReference "1148" .
:TV_Line_1148_en a :TranslationVariant ;
:text "Incantations of the night, child born of Zeus,"^^xsd:string ;
:relatedTo :Line_1148 .

# --- 1149 ---

:Line_1149 a :Line ; :lineNumber 1149 ; :canonicalReference "1149" .
:TV_Line_1149_en a :TranslationVariant ;
:text "Oh show yourself our Lord"^^xsd:string ;
:relatedTo :Line_1149 .

# --- 1150 ---

:Line_1150 a :Line ; :lineNumber 1150 ; :canonicalReference "1150" .
:TV_Line_1150_en a :TranslationVariant ;
:text "With your trusty Thyiads,"^^xsd:string ;
:relatedTo :Line_1150 .

# --- 1151 ---

:Line_1151 a :Line ; :lineNumber 1151 ; :canonicalReference "1151" .
:TV_Line_1151_en a :TranslationVariant ;
:text "Who rage ‘till sunrise"^^xsd:string ;
:relatedTo :Line_1151 ;
:hasTheme :Theme_DionysianWorship .

# --- 1152 ---

:Line_1152 a :Line ; :lineNumber 1152 ; :canonicalReference "1152" .
:TV_Line_1152_en a :TranslationVariant ;
:text "And salute you in dance"^^xsd:string ;
:relatedTo :Line_1152 .

# --- 1153 ---

:Line_1153 a :Line ; :lineNumber 1153 ; :canonicalReference "1153" .
:TV_Line_1153_en a :TranslationVariant ;
:text "As their master -"^^xsd:string ;
:relatedTo :Line_1153 .

# --- 1154 ---

:Line_1154 a :Line ; :lineNumber 1154 ; :canonicalReference "1154" .
:TV_Line_1154_en a :TranslationVariant ;
