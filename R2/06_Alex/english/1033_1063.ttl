@prefix owl: [http://www.w3.org/2002/07/owl#](http://www.w3.org/2002/07/owl#) .
@prefix rdfs: [http://www.w3.org/2000/01/rdf-schema#](http://www.w3.org/2000/01/rdf-schema#) .
@prefix xsd: [http://www.w3.org/2001/XMLSchema#](http://www.w3.org/2001/XMLSchema#) .

################################################################

# SCENE AND SPEECH STRUCTURE

################################################################

:Antigone_Scene_Episode5_Cont
a :Scene ;
:sceneNumber "Episode 5 (Continued)"^^xsd:string ;
:hasSpeech :Speech_Creon_Ep5_Defense, :Speech_Stichomythia_Ep5 ;
:developsTheme :Theme_Hybris, :Theme_Corruption, :Theme_WisdomVsFolly, :Theme_StateVsProphecy ;
:hasConflict :Conflict_KingVsSeer, :Conflict_ProfitVsTruth .

:Speech_Creon_Ep5_Defense
a :Speech ;
:speechBy :Antigone_Character_Creon ;
:containsLine :Line_1033, :Line_1034, :Line_1035, :Line_1036, :Line_1037, :Line_1038, :Line_1039, :Line_1040, :Line_1041, :Line_1042, :Line_1043, :Line_1044, :Line_1045, :Line_1046, :Line_1047 ;
:hasMotivation :Motivation_DismissProphecy ;
:experiencesEmotion :Emotion_Paranoia, :Emotion_DefensiveAnger ;
:containsRhetoricalDevice :Device_Simile_Archers, :Device_Hyperbole_Eagles .

:Speech_Stichomythia_Ep5
a :Speech ;
:description "Rapid dialogue (stichomythia) between Creon and Teiresias."^^xsd:string ;
:speechBy :Antigone_Character_Creon, :Antigone_Character_Teiresias ;
:containsLine :Line_1048, :Line_1049, :Line_1050, :Line_1051, :Line_1052, :Line_1053, :Line_1054, :Line_1055, :Line_1056, :Line_1057, :Line_1058, :Line_1059, :Line_1060, :Line_1061, :Line_1062, :Line_1063 .

################################################################

# CHARACTERS & PSYCHOLOGY

################################################################

:Antigone_Character_Creon
a :Character ;
:experiencesEmotion :Emotion_Paranoia ;
:advocatesFor :Principle_DivineInvulnerability ;
:hasMotivation :Motivation_AssertAuthority ;
:tragicFlaw "Stubbornness/Hybris"^^xsd:string .

:Antigone_Character_Teiresias
a :Character ;
:experiencesEmotion :Emotion_Indignation ;
:advocatesFor :Principle_PrimacyOfReason ;
:hasMotivation :Motivation_RevealTruth .

################################################################

# THEMES, CONFLICTS, PRINCIPLES

################################################################

:Theme_Hybris
a :Theme ;
:description "Creon's extreme arrogance in claiming his will supersedes ritual pollution, even daring Zeus's eagles."^^xsd:string .

:Theme_Corruption
a :Theme ;
:description "The recurring accusation that prophecy is merely a mechanism for profit and bribery."^^xsd:string .

:Theme_WisdomVsFolly
a :Theme ;
:description "The debate over whether 'reason' (euboulia) is the greatest good and 'thoughtlessness' the greatest disease."^^xsd:string .

:Theme_StateVsProphecy
a :Theme ;
:description "The clash between secular royal authority and divine/mantic authority."^^xsd:string .

:Conflict_KingVsSeer
a :Conflict ;
:description "Direct confrontation between Creon's political power and Teiresias's spiritual insight."^^xsd:string ;
:conflictBetween :Antigone_Character_Creon, :Antigone_Character_Teiresias .

:Conflict_ProfitVsTruth
a :Conflict ;
:description "Creon frames the conflict as monetary (profit) while Teiresias frames it as truth-telling."^^xsd:string .

:Motivation_DismissProphecy
a :Motivation ;
:description "Creon intends to invalidate the seer's warnings by attributing them to greed."^^xsd:string .

:Motivation_AssertAuthority
a :Motivation ;
:description "Creon reminds Teiresias of his status as King to demand submission."^^xsd:string .

:Motivation_RevealTruth
a :Motivation ;
:description "Teiresias is provoked to reveal the 'holy secret' (the specific punishment awaiting Creon)."^^xsd:string .

:Emotion_Paranoia
a :Emotion ;
:description "Creon feels besieged, comparing himself to a target for archers and believing he is being 'sold'."^^xsd:string .

:Emotion_DefensiveAnger
a :Emotion ;
:description "Creon's anger rises as he is challenged, leading to insults."^^xsd:string .

:Emotion_Indignation
a :Emotion ;
:description "Teiresias's offense at being called a liar and a profiteer."^^xsd:string .

:Principle_DivineInvulnerability
a :EthicalPrinciple ;
:description "Creon's theological (mis)conception that human actions (leaving a corpse) cannot pollute the gods."^^xsd:string .

:Principle_PrimacyOfReason
a :PhilosophicalConcept ;
:description "The assertion that sound judgment (reason) is the most valuable possession a human can have."^^xsd:string .

:Device_Simile_Archers
a :MetaphorSimile ;
:description "Comparison of the prophet's accusations to a team of archers shooting at a target."^^xsd:string .

:Device_Hyperbole_Eagles
a :RhetoricalDevice ;
:description "Exaggeration that even if eagles carried the corpse to Zeus's throne, Creon would not yield."^^xsd:string .

################################################################

# CANONICAL LINES & TRANSLATION VARIANTS

################################################################

# --- 1033 ---

:Line_1033 a :Line ; :lineNumber 1033 ; :canonicalReference "1033" .
:TV_Line_1033_en a :TranslationVariant ;
:text "Old man, like a whole team of archers taking aim"^^xsd:string ;
:relatedTo :Line_1033 ;
:containsRhetoricalDevice :Device_Simile_Archers .

# --- 1034 ---

:Line_1034 a :Line ; :lineNumber 1034 ; :canonicalReference "1034" .
:TV_Line_1034_en a :TranslationVariant ;
:text "At a single man, I cannot escape the assault"^^xsd:string ;
:relatedTo :Line_1034 .

# --- 1035 ---

:Line_1035 a :Line ; :lineNumber 1035 ; :canonicalReference "1035" .
:TV_Line_1035_en a :TranslationVariant ;
:text "Of your oracular art: I’m bandied about"^^xsd:string ;
:relatedTo :Line_1035 .

# --- 1036 ---

:Line_1036 a :Line ; :lineNumber 1036 ; :canonicalReference "1036" .
:TV_Line_1036_en a :TranslationVariant ;
:text "By all these fortune-tellers, I’m bought and sold like cargo."^^xsd:string ;
:relatedTo :Line_1036 ;
:experiencesEmotion :Emotion_Paranoia .

# --- 1037 ---

:Line_1037 a :Line ; :lineNumber 1037 ; :canonicalReference "1037" .
:TV_Line_1037_en a :TranslationVariant ;
:text "You’re making a good profit—earning your white gold"^^xsd:string ;
:relatedTo :Line_1037 ;
:hasTheme :Theme_Corruption .

# --- 1038 ---

:Line_1038 a :Line ; :lineNumber 1038 ; :canonicalReference "1038" .
:TV_Line_1038_en a :TranslationVariant ;
:text "From Sardis, and, if you like, even gold from India—"^^xsd:string ;
:relatedTo :Line_1038 .

# --- 1039 ---

:Line_1039 a :Line ; :lineNumber 1039 ; :canonicalReference "1039" .
:TV_Line_1039_en a :TranslationVariant ;
:text "But you will not seal that man in a tomb,"^^xsd:string ;
:relatedTo :Line_1039 .

# --- 1040 ---

:Line_1040 a :Line ; :lineNumber 1040 ; :canonicalReference "1040" .
:TV_Line_1040_en a :TranslationVariant ;
:text "Not even if the eagles of heaven want to"^^xsd:string ;
:relatedTo :Line_1040 ;
:containsRhetoricalDevice :Device_Hyperbole_Eagles .

# --- 1041 ---

:Line_1041 a :Line ; :lineNumber 1041 ; :canonicalReference "1041" .
:TV_Line_1041_en a :TranslationVariant ;
:text "Carry him off as food for Zeus’ throne—"^^xsd:string ;
:relatedTo :Line_1041 ;
:hasTheme :Theme_Hybris .

# --- 1042 ---

:Line_1042 a :Line ; :lineNumber 1042 ; :canonicalReference "1042" .
:TV_Line_1042_en a :TranslationVariant ;
:text "Even if it meant wiping my hands of this pollution,"^^xsd:string ;
:relatedTo :Line_1042 .

# --- 1043 ---

:Line_1043 a :Line ; :lineNumber 1043 ; :canonicalReference "1043" .
:TV_Line_1043_en a :TranslationVariant ;
:text "I will never let that man be buried, for I know well that"^^xsd:string ;
:relatedTo :Line_1043 .

# --- 1044 ---

:Line_1044 a :Line ; :lineNumber 1044 ; :canonicalReference "1044" .
:TV_Line_1044_en a :TranslationVariant ;
:text "No mortal can pollute the gods."^^xsd:string ;
:relatedTo :Line_1044 ;
:advocatesFor :Principle_DivineInvulnerability .

# --- 1045 ---

:Line_1045 a :Line ; :lineNumber 1045 ; :canonicalReference "1045" .
:TV_Line_1045_en a :TranslationVariant ;
:text "Men fall, elder Teiresias, even clever men..."^^xsd:string ;
:relatedTo :Line_1045 .

# --- 1046 ---

:Line_1046 a :Line ; :lineNumber 1046 ; :canonicalReference "1046" .
:TV_Line_1046_en a :TranslationVariant ;
:text "They fall far and in disgrace when they"^^xsd:string ;
:relatedTo :Line_1046 .

# --- 1047 ---

:Line_1047 a :Line ; :lineNumber 1047 ; :canonicalReference "1047" .
:TV_Line_1047_en a :TranslationVariant ;
:text "Lie, however beautifully, for a little extra gold."^^xsd:string ;
:relatedTo :Line_1047 .

# --- 1048 ---

:Line_1048 a :Line ; :lineNumber 1048 ; :canonicalReference "1048" .
:TV_Line_1048_en a :TranslationVariant ;
:text "Then does anyone know, does anyone consider..."^^xsd:string ;
:relatedTo :Line_1048 .

# --- 1049 ---

:Line_1049 a :Line ; :lineNumber 1049 ; :canonicalReference "1049" .
:TV_Line_1049_en a :TranslationVariant ;
:text "What old saying is this?"^^xsd:string ;
:relatedTo :Line_1049 .

# --- 1050 ---

:Line_1050 a :Line ; :lineNumber 1050 ; :canonicalReference "1050" .
:TV_Line_1050_en a :TranslationVariant ;
:text "...That man’s greatest gift is reason?"^^xsd:string ;
:relatedTo :Line_1050 ;
:hasTheme :Theme_WisdomVsFolly ;
:advocatesFor :Principle_PrimacyOfReason .

# --- 1051 ---

:Line_1051 a :Line ; :lineNumber 1051 ; :canonicalReference "1051" .
:TV_Line_1051_en a :TranslationVariant ;
:text "As surely as madness is our greatest curse.."^^xsd:string ;
:relatedTo :Line_1051 .

# --- 1052 ---

:Line_1052 a :Line ; :lineNumber 1052 ; :canonicalReference "1052" .
:TV_Line_1052_en a :TranslationVariant ;
:text "But you have clearly come down with that disease."^^xsd:string ;
:relatedTo :Line_1052 ;
:description "Teiresias diagnoses Creon with the disease of thoughtlessness/madness."^^xsd:string .

# --- 1053 ---

:Line_1053 a :Line ; :lineNumber 1053 ; :canonicalReference "1053" .
:TV_Line_1053_en a :TranslationVariant ;
:text "I won’t trade insults with a prophet."^^xsd:string ;
:relatedTo :Line_1053 .

# --- 1054 ---

:Line_1054 a :Line ; :lineNumber 1054 ; :canonicalReference "1054" .
:TV_Line_1054_en a :TranslationVariant ;
:text "And yet you do, in saying that I prophesy falsely."^^xsd:string ;
:relatedTo :Line_1054 .

# --- 1055 ---

:Line_1055 a :Line ; :lineNumber 1055 ; :canonicalReference "1055" .
:TV_Line_1055_en a :TranslationVariant ;
:text "All prophets love money."^^xsd:string ;
:relatedTo :Line_1055 .

# --- 1056 ---

:Line_1056 a :Line ; :lineNumber 1056 ; :canonicalReference "1056" .
:TV_Line_1056_en a :TranslationVariant ;
:text "All tyrants love theft."^^xsd:string ;
:relatedTo :Line_1056 ;
:hasTheme :Theme_StateVsProphecy .

# --- 1057 ---

:Line_1057 a :Line ; :lineNumber 1057 ; :canonicalReference "1057" .
:TV_Line_1057_en a :TranslationVariant ;
:text "Do you realize that you’re speaking to your king?"^^xsd:string ;
:relatedTo :Line_1057 ;
:hasMotivation :Motivation_AssertAuthority .

# --- 1058 ---

:Line_1058 a :Line ; :lineNumber 1058 ; :canonicalReference "1058" .
:TV_Line_1058_en a :TranslationVariant ;
:text "I do. You only saved the city because of me."^^xsd:string ;
:relatedTo :Line_1058 .

# --- 1059 ---

:Line_1059 a :Line ; :lineNumber 1059 ; :canonicalReference "1059" .
:TV_Line_1059_en a :TranslationVariant ;
:text "You’re a wise prophet, and yet you love doing the wrong thing."^^xsd:string ;
:relatedTo :Line_1059 .

# --- 1060 ---

:Line_1060 a :Line ; :lineNumber 1060 ; :canonicalReference "1060" .
:TV_Line_1060_en a :TranslationVariant ;
:text "You will force me to utter the holy secret in my heart."^^xsd:string ;
:relatedTo :Line_1060 ;
:hasMotivation :Motivation_RevealTruth .

# --- 1061 ---

:Line_1061 a :Line ; :lineNumber 1061 ; :canonicalReference "1061" .
:TV_Line_1061_en a :TranslationVariant ;
:text "Go on!"^^xsd:string ;
:relatedTo :Line_1061 .

# --- 1062 ---

:Line_1062 a :Line ; :lineNumber 1062 ; :canonicalReference "1062" .
:TV_Line_1062_en a :TranslationVariant ;
:text "Tell it, as long as you won’t be talking for profit."^^xsd:string ;
:relatedTo :Line_1062 .

# --- 1063 ---

:Line_1063 a :Line ; :lineNumber 1063 ; :canonicalReference "1063" .
:TV_Line_1063_en a :TranslationVariant ;
:text "Hear my words, or no one will profit; You should know you won’t be paid for my decisions."^^xsd:string ;
:relatedTo :Line_1063 ;
:hasConflict :Conflict_ProfitVsTruth .