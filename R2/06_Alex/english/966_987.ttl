# --- 976 ---

:Line_976 a :Line ; :lineNumber 976 ; :canonicalReference "976" .
:TV_Line_976_en a :TranslationVariant ;
:text "By the edge of her shuttle"^^xsd:string ;
:relatedTo :Line_976 .

# --- 977 ---

:Line_977 a :Line ; :lineNumber 977 ; :canonicalReference "977" .
:TV_Line_977_en a :TranslationVariant ;
:text "In her bloody hands."^^xsd:string ;
:relatedTo :Line_977 .

# --- 978 ---

:Line_978 a :Line ; :lineNumber 978 ; :canonicalReference "978" .
:TV_Line_978_en a :TranslationVariant ;
:text "Melting away miserably they lamented their"^^xsd:string ;
:relatedTo :Line_978 ;
:experiencesEmotion :Emotion_Despair .

# --- 979 ---

:Line_979 a :Line ; :lineNumber 979 ; :canonicalReference "979" .
:TV_Line_979_en a :TranslationVariant ;
:text "Unfortunate plight, their unmarried mother, too."^^xsd:string ;
:relatedTo :Line_979 ;
:referencesMyth :Antigone_Character_Cleopatra .

# --- 980 ---

:Line_980 a :Line ; :lineNumber 980 ; :canonicalReference "980" .
:TV_Line_980_en a :TranslationVariant ;
:text "But she traced herself all the way back to the"^^xsd:string ;
:relatedTo :Line_980 .

# --- 981 ---

:Line_981 a :Line ; :lineNumber 981 ; :canonicalReference "981" .
:TV_Line_981_en a :TranslationVariant ;
:text "Ancient house of the Erechtheus,"^^xsd:string ;
:relatedTo :Line_981 ;
:hasTheme :Theme_NobleSuffering .

# --- 982 ---

:Line_982 a :Line ; :lineNumber 982 ; :canonicalReference "982" .
:TV_Line_982_en a :TranslationVariant ;
:text "And she was raised in far-off caves"^^xsd:string ;
:relatedTo :Line_982 .

# --- 983 ---

:Line_983 a :Line ; :lineNumber 983 ; :canonicalReference "983" .
:TV_Line_983_en a :TranslationVariant ;
:text "Amidst paternal whirlwinds, a child"^^xsd:string ;
:relatedTo :Line_983 .

# --- 984 ---

:Line_984 a :Line ; :lineNumber 984 ; :canonicalReference "984" .
:TV_Line_984_en a :TranslationVariant ;
:text "Of Boreas, a swift-footed child who could dart"^^xsd:string ;
:relatedTo :Line_984 .

# --- 985 ---

:Line_985 a :Line ; :lineNumber 985 ; :canonicalReference "985" .
:TV_Line_985_en a :TranslationVariant ;
:text "Beyond the horizon at a horse’s pace, a child"^^xsd:string ;
:relatedTo :Line_985 .

# --- 986 ---

:Line_986 a :Line ; :lineNumber 986 ; :canonicalReference "986" .
:TV_Line_986_en a :TranslationVariant ;
:text "Born from the gods."^^xsd:string ;
