# --- 971 ---

:Line_971 a :Line ; :lineNumber 971 ; :canonicalReference "971" .
:TV_Line_971_en a :TranslationVariant ;
:text "A cursed, blinding wound"^^xsd:string ;
:relatedTo :Line_971 .

# --- 972 ---

:Line_972 a :Line ; :lineNumber 972 ; :canonicalReference "972" .
:TV_Line_972_en a :TranslationVariant ;
:text "From a savage wife,"^^xsd:string ;
:relatedTo :Line_972 ;
