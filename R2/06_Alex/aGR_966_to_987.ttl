@prefix rdfs: [http://www.w3.org/2000/01/rdf-schema#](http://www.w3.org/2000/01/rdf-schema#) .
@prefix xsd: [http://www.w3.org/2001/XMLSchema#](http://www.w3.org/2001/XMLSchema#) .

################################################################
# SCENE AND SPEECH STRUCTURE
################################################################

:Antigone_Scene_Stasimon4
a :Scene ;
:sceneNumber "Stasimon 4"^^xsd:string ;
:hasSpeech :Speech_Chorus_Stasimon4 ;
:hasHistoricalContext :Context_MythologicalPrecedents .

:Speech_Chorus_Stasimon4
a :Speech ;
:speechBy :Antigone_Character_Chorus ;
:containsLine :Line_966, :Line_967, :Line_968, :Line_969, :Line_970, :Line_971, :Line_972, :Line_973, :Line_974, :Line_975, :Line_976, :Line_977, :Line_978, :Line_979, :Line_980, :Line_981, :Line_982, :Line_983, :Line_984, :Line_985, :Line_986, :Line_987 ;
:referencesMyth :Myth_PhineusSons, :Myth_CleopatraBoread .

################################################################
# CONCEPTS
################################################################

:Emotion_Savagery
a :Emotion ;
:description "The savage nature (ἀγρίας) of the stepmother."^^xsd:string .

:Emotion_Misery
a :Emotion ;
:description "Wasting away in misery (τακόμενοι μέλεοι)."^^xsd:string .

:Emotion_Grief
a :Emotion ;
:description "Weeping (κλαῖον)."^^xsd:string .

:Symbol_Blood
a :Symbol ;
:description "Bloody hands (αἱματηραῖς χείρεσσι)."^^xsd:string .

################################################################
# CHARACTERS & MYTHS (GREEK TEXT CONTEXT)
################################################################

:Antigone_Character_Ares
a :Character ;
:role "Deity"^^xsd:string ;
:description "God of War (Ἄρης), watching near Salmydessus."^^xsd:string .

:Antigone_Character_Phineids
a :Character ;
:description "The sons of Phineus (Φινείδαις)."^^xsd:string .

:Antigone_Character_PhineusWife
a :Character ;
:description "The savage wife (ἀγρίας δάμαρτος) who blinded the sons."^^xsd:string .

:Antigone_Character_Cleopatra
a :Character ;
:description "Daughter of Boreas, of the Erechtheid line."^^xsd:string ;
:relatedTo :Antigone_Character_Boreas .

:Antigone_Character_Boreas
a :Character ;
:description "The North Wind (Βορεὰς)."^^xsd:string .

:Antigone_Character_Fates
a :Character ;
:role "Deities"^^xsd:string ;
:description "The long-lived Fates (Μοῖραι μακραίωνες)."^^xsd:string .

:Myth_PhineusSons
a :MythologicalBackground ;
:description "The blinding of Phineus's sons in Thrace."^^xsd:string .

:Myth_CleopatraBoread
a :MythologicalBackground ;
:description "The fate of Cleopatra, divine child of Boreas."^^xsd:string .

:Place_Salmydessus
a :Place ;
:description "Thracian city (Σαλμυδησσός)."^^xsd:string .

################################################################
# CANONICAL LINES (ANCIENT GREEK)
################################################################

:Line_966 a :Line ;
:lineNumber 966 ;
:canonicalReference "966" ;
:text "Παρὰ δὲ κυανέαιν σπιλάδοιν διδύμας ἁλὸς"^^xsd:string .

:Line_967 a :Line ;
:lineNumber 967 ;
:canonicalReference "967" ;
:text "ἀκταὶ Βοσπόριαι ἰδ ̓ ὁ Θρῃκῶν <ἠιὼν>"^^xsd:string ;
:hasTheme :Theme_NobleSuffering .

:Line_968 a :Line ;
:lineNumber 968 ;
:canonicalReference "968" ;
:text "(context of Salmydessus)"^^xsd:string ;
:relatedTo :Place_Salmydessus .

:Line_969 a :Line ;
:lineNumber 969 ;
:canonicalReference "969" ;
:text "(context of Ares)"^^xsd:string .

:Line_970 a :Line ;
:lineNumber 970 ;
:canonicalReference "970" ;
:text "Σαλμυδησσός, ἵν ̓ ἀγχίπολις Ἄρης"^^xsd:string ;
:referencesMyth :Antigone_Character_Ares .

:Line_971 a :Line ;
:lineNumber 971 ;
:canonicalReference "971" ;
:text "δισσοῖσι Φινείδαις"^^xsd:string ;
:referencesMyth :Antigone_Character_Phineids .

:Line_972 a :Line ;
:lineNumber 972 ;
:canonicalReference "972" ;
:text "εἶδεν ἀρατὸν ἕλκος"^^xsd:string .

:Line_973 a :Line ;
:lineNumber 973 ;
:canonicalReference "973" ;
:text "τυφλωθὲν ἐξ ἀγρίας δάμαρτος"^^xsd:string ;
:relatedTo :Antigone_Character_PhineusWife ;
:experiencesEmotion :Emotion_Savagery .

:Line_974 a :Line ;
:lineNumber 974 ;
:canonicalReference "974" ;
:text "ἀλαὸν ἀλαστόροισιν ὀμμάτων κύκλοις"^^xsd:string .

:Line_975 a :Line ;
:lineNumber 975 ;
:canonicalReference "975" ;
:text "ἀραχθέντων ὑφ ̓ αἱματηραῖς"^^xsd:string ;
:hasSymbol :Symbol_Blood .

:Line_976 a :Line ;
:lineNumber 976 ;
:canonicalReference "976" ;
:text "χείρεσσι καὶ κερκίδων ἀκμαῖσιν."^^xsd:string .

:Line_977 a :Line ;
:lineNumber 977 ;
:canonicalReference "977" ;
:text "Κατὰ δὲ τακόμενοι μέλεοι μελέαν πάθαν"^^xsd:string ;
:experiencesEmotion :Emotion_Misery .

:Line_978 a :Line ;
:lineNumber 978 ;
:canonicalReference "978" ;
:text "κλαῖον, ματρὸς ἔχοντες ἀνύμφευτον γονάν·"^^xsd:string ;
:experiencesEmotion :Emotion_Grief .

:Line_979 a :Line ;
:lineNumber 979 ;
:canonicalReference "979" ;
:text "ἁ δὲ σπέρμα μὲν ἀρχαιογόνων"^^xsd:string .

:Line_980 a :Line ;
:lineNumber 980 ;
:canonicalReference "980" ;
:text "ἄντασ ̓ Ἐρεχθεϊδᾶν,"^^xsd:string ;
:referencesMyth :Antigone_Character_Cleopatra .

:Line_981 a :Line ;
:lineNumber 981 ;
:canonicalReference "981" ;
:text "τηλεπόροις δ ̓ ἐν ἄντροις"^^xsd:string .

:Line_982 a :Line ;
:lineNumber 982 ;
:canonicalReference "982" ;
:text "τράφη θυέλλῃσιν ἐν πατρῴαις"^^xsd:string .

:Line_983 a :Line ;
:lineNumber 983 ;
:canonicalReference "983" ;
:text "Βορεὰς ἅμιππος ὀρθόποδος ὑπὲρ πάγου"^^xsd:string ;
:referencesMyth :Antigone_Character_Boreas .

:Line_984 a :Line ;
:lineNumber 984 ;
:canonicalReference "984" ;
:text "θεῶν παῖς· ἀλλὰ κἀπ ̓ ἐκείνᾳ"^^xsd:string .

:Line_985 a :Line ;
:lineNumber 985 ;
:canonicalReference "985" ;
:text "Μοῖραι μακραίωνες ἔσχον, ὦ παῖ."^^xsd:string ;
:hasTheme :Theme_FateInevitability ;
:relatedTo :Antigone_Character_Fates .

:Line_986 a :Line ;
:lineNumber 986 ;
:canonicalReference "986" ;
:text "(Text flow continues in previous lines)"^^xsd:string .

:Line_987 a :Line ;
:lineNumber 987 ;
:canonicalReference "987" ;
:text "(Conclusion of strophe)"^^xsd:string .
