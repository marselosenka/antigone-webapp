############################

# CHARACTERS & ENTITIES

############################

:Antigone_Chorus
a owl:NamedIndividual, :Character ;
:experiencesEmotion :Emotion_ReligiousHope, :Emotion_DesperateReverence ;
:hasMotivation :Motivation_InvokeHealer .

:MythologicalBackground_Dionysus
a owl:NamedIndividual, :MythologicalBackground ;
:description "The god Dionysus (Bacchus, Iacchus), patron of Thebes, invoked to heal the city."^^xsd:string .

:MythologicalBackground_Semele
a owl:NamedIndividual, :MythologicalBackground ;
:description "Semele, the Cadmean bride and mother of Dionysus."^^xsd:string .

:MythologicalBackground_Dragon
a owl:NamedIndividual, :MythologicalBackground ;
:description "The fierce dragon of Thebes (Ismenian), related to the sowing of the Spartoi."^^xsd:string .

############################

# CANONICAL LINES (Full Extraction 1115-1154)

############################

:Line_1115
a owl:NamedIndividual, :Line ;
:lineNumber 1115 ;
:canonicalReference "Stasimon5.1115"^^xsd:string ;
:text "Πολυώνυμε, Καδμείας ἄγαλμα νύμφας"^^xsd:string ;
:referencesMyth :MythologicalBackground_Semele ;
:hasTheme :Theme_DivineIntervention .

:Line_1116
a owl:NamedIndividual, :Line ;
:lineNumber 1116 ;
:canonicalReference "Stasimon5.1116"^^xsd:string ;
:text "καὶ Διὸς βαρυβρεμέτα"^^xsd:string .

:Line_1117
a owl:NamedIndividual, :Line ;
:lineNumber 1117 ;
:canonicalReference "Stasimon5.1117"^^xsd:string ;
:text "γένος, κλυτὰν ὃς ἀμφέπεις"^^xsd:string .

:Line_1118
a owl:NamedIndividual, :Line ;
:lineNumber 1118 ;
:canonicalReference "Stasimon5.1118"^^xsd:string ;
:text "Ἰταλίαν, μέδεις δὲ"^^xsd:string .

:Line_1119
a owl:NamedIndividual, :Line ;
:lineNumber 1119 ;
:canonicalReference "Stasimon5.1119"^^xsd:string ;
:text "παγκοίνοις Ἐλευσινίας"^^xsd:string ;
:referencesMyth :MythologicalBackground_Dionysus .

:Line_1120
a owl:NamedIndividual, :Line ;
:lineNumber 1120 ;
:canonicalReference "Stasimon5.1120"^^xsd:string ;
:text "Δῃοῦς ἐν κόλποις, ὦ Βακχεῦ,"^^xsd:string .

:Line_1121
a owl:NamedIndividual, :Line ;
:lineNumber 1121 ;
:canonicalReference "Stasimon5.1121"^^xsd:string ;
:text "Βακχᾶν ματρόπολιν Θήβαν"^^xsd:string ;
:hasTheme :Theme_ThebesPatronage .

:Line_1122
a owl:NamedIndividual, :Line ;
:lineNumber 1122 ;
:canonicalReference "Stasimon5.1122"^^xsd:string ;
:text "ναιετῶν παρ ̓ ὑγροῖς"^^xsd:string .

:Line_1123
a owl:NamedIndividual, :Line ;
:lineNumber 1123 ;
:canonicalReference "Stasimon5.1123"^^xsd:string ;
:text "Ἰσμηνοῦ ῥείθροις, ἀγρίου τ ̓"^^xsd:string .

:Line_1124
a owl:NamedIndividual, :Line ;
:lineNumber 1124 ;
:canonicalReference "Stasimon5.1124"^^xsd:string ;
:text "ἐπὶ σπορᾷ δράκοντος·"^^xsd:string ;
:referencesMyth :MythologicalBackground_Dragon .

:Line_1125
a owl:NamedIndividual, :Line ;
:lineNumber 1125 ;
:canonicalReference "Stasimon5.1125"^^xsd:string ;
:text "σὲ δ ̓ ὑπὲρ διλόφου πέτρας"^^xsd:string .

:Line_1126
a owl:NamedIndividual, :Line ;
:lineNumber 1126 ;
:canonicalReference "Stasimon5.1126"^^xsd:string ;
:text "στέροψ ὄπωπε λιγνύς,"^^xsd:string .

:Line_1127
a owl:NamedIndividual, :Line ;
:lineNumber 1127 ;
:canonicalReference "Stasimon5.1127"^^xsd:string ;
:text "ἔνθα Κωρύκιαι"^^xsd:string .

:Line_1128
a owl:NamedIndividual, :Line ;
:lineNumber 1128 ;
:canonicalReference "Stasimon5.1128"^^xsd:string ;
:text "στείχουσι νύμφαι Βακχίδες"^^xsd:string .

:Line_1129
a owl:NamedIndividual, :Line ;
:lineNumber 1129 ;
:canonicalReference "Stasimon5.1129"^^xsd:string ;
:text "Κασταλίας τε νᾶμα."^^xsd:string .

:Line_1130
a owl:NamedIndividual, :Line ;
:lineNumber 1130 ;
:canonicalReference "Stasimon5.1130"^^xsd:string ;
:text "Καί σε Νυσαίων ὀρέων"^^xsd:string .

:Line_1131
a owl:NamedIndividual, :Line ;
:lineNumber 1131 ;
:canonicalReference "Stasimon5.1131"^^xsd:string ;
:text "κισσήρεις ὄχθαι"^^xsd:string .

:Line_1132
a owl:NamedIndividual, :Line ;
:lineNumber 1132 ;
:canonicalReference "Stasimon5.1132"^^xsd:string ;
:text "χλωρά τ ̓ ἀκτὰ"^^xsd:string .

:Line_1133
a owl:NamedIndividual, :Line ;
:lineNumber 1133 ;
:canonicalReference "Stasimon5.1133"^^xsd:string ;
:text "πολυστάφυλος πέμπει,"^^xsd:string .

:Line_1134
a owl:NamedIndividual, :Line ;
:lineNumber 1134 ;
:canonicalReference "Stasimon5.1134"^^xsd:string ;
:text "ἀμβρότων ἑπετᾶν"^^xsd:string .

:Line_1135
a owl:NamedIndividual, :Line ;
:lineNumber 1135 ;
:canonicalReference "Stasimon5.1135"^^xsd:string ;
:text "εὐαζόντων Θηβαΐας"^^xsd:string .

:Line_1136
a owl:NamedIndividual, :Line ;
:lineNumber 1136 ;
:canonicalReference "Stasimon5.1136"^^xsd:string ;
:text "ἐπισκοποῦντ ̓ ἀγυιάς·"^^xsd:string .

:Line_1137
a owl:NamedIndividual, :Line ;
:lineNumber 1137 ;
:canonicalReference "Stasimon5.1137"^^xsd:string ;
:text "τὰν ἐκ πασᾶν τιμᾷς"^^xsd:string ;
:description "Reference to Dionysus honoring Thebes above all cities."^^xsd:string .

:Line_1138
a owl:NamedIndividual, :Line ;
:lineNumber 1138 ;
:canonicalReference "Stasimon5.1138"^^xsd:string ;
:text "ὑπερτάταν πόλεων"^^xsd:string .

:Line_1139
a owl:NamedIndividual, :Line ;
:lineNumber 1139 ;
:canonicalReference "Stasimon5.1139"^^xsd:string ;
:text "ματρὶ σὺν κεραυνίᾳ·"^^xsd:string ;
:referencesMyth :MythologicalBackground_Semele .

:Line_1140
a owl:NamedIndividual, :Line ;
:lineNumber 1140 ;
:canonicalReference "Stasimon5.1140"^^xsd:string ;
:text "καὶ νῦν, ὡς βιαίας ἔχεται"^^xsd:string ;
:hasConflict :Conflict_ThebesVsPlague .

:Line_1141
a owl:NamedIndividual, :Line ;
:lineNumber 1141 ;
:canonicalReference "Stasimon5.1141"^^xsd:string ;
:text "πάνδαμος πόλις ἐπὶ νόσου,"^^xsd:string ;
:hasTheme :Theme_CivicCleansing ;
:containsRhetoricalDevice :Metaphor_Disease .

:Line_1142
a owl:NamedIndividual, :Line ;
:lineNumber 1142 ;
:canonicalReference "Stasimon5.1142"^^xsd:string ;
:text "μολεῖν καθαρσίῳ ποδὶ"^^xsd:string .

:Line_1143
a owl:NamedIndividual, :Line ;
:lineNumber 1143 ;
:canonicalReference "Stasimon5.1143"^^xsd:string ;
:text "Παρνασίαν ὑπὲρ κλιτύν,"^^xsd:string ;
:hasTheme :Theme_Purification .

:Line_1144
a owl:NamedIndividual, :Line ;
:lineNumber 1144 ;
:canonicalReference "Stasimon5.1144"^^xsd:string ;
:text "ἢ στονόεντα πορθμόν."^^xsd:string .

:Line_1145
a owl:NamedIndividual, :Line ;
:lineNumber 1145 ;
:canonicalReference "Stasimon5.1145"^^xsd:string ;
:text "Ἰὼ πῦρ πνειόντων"^^xsd:string .

:Line_1146
a owl:NamedIndividual, :Line ;
:lineNumber 1146 ;
:canonicalReference "Stasimon5.1146"^^xsd:string ;
:text "χοράγ ̓ ἄστρων, νυχίων"^^xsd:string .

:Line_1147
a owl:NamedIndividual, :Line ;
:lineNumber 1147 ;
:canonicalReference "Stasimon5.1147"^^xsd:string ;
:text "φθεγμάτων ἐπίσκοπε,"^^xsd:string .

:Line_1148
a owl:NamedIndividual, :Line ;
:lineNumber 1148 ;
:canonicalReference "Stasimon5.1148"^^xsd:string ;
:text "παῖ Διὸς γένεθλον,"^^xsd:string .

:Line_1149
a owl:NamedIndividual, :Line ;
:lineNumber 1149 ;
:canonicalReference "Stasimon5.1149"^^xsd:string ;
:text "προφάνηθ ̓,"^^xsd:string .

:Line_1150
a owl:NamedIndividual, :Line ;
:lineNumber 1150 ;
:canonicalReference "Stasimon5.1150"^^xsd:string ;
:text "ὦναξ, σαῖς ἅμα περιπόλοις"^^xsd:string .

:Line_1151
a owl:NamedIndividual, :Line ;
:lineNumber 1151 ;
:canonicalReference "Stasimon5.1151"^^xsd:string ;
:text "Θυίαισιν, αἵ σε μαινόμεναι"^^xsd:string .

:Line_1152
a owl:NamedIndividual, :Line ;
:lineNumber 1152 ;
:canonicalReference "Stasimon5.1152"^^xsd:string ;
:text "πάννυχοι"^^xsd:string ;
:hasTheme :Theme_DionysiacWorship .

:Line_1153
a owl:NamedIndividual, :Line ;
:lineNumber 1153 ;
:canonicalReference "Stasimon5.1153"^^xsd:string ;
:text "χορεύουσι τὸν ταμίαν"^^xsd:string .

:Line_1154
a owl:NamedIndividual, :Line ;
:lineNumber 1154 ;
:canonicalReference "Stasimon5.1154"^^xsd:string ;
:text "Ἴακχον."^^xsd:string .

############################

# THEMES, EMOTIONS, CONFLICTS

############################

:Theme_DivineIntervention
a owl:NamedIndividual, :Theme ;
:description "The invocation of a god to intervene in human affairs."^^xsd:string .

:Theme_CivicCleansing
a owl:NamedIndividual, :Theme ;
:description "The necessity of purifying the city from pollution (miasma/disease)."^^xsd:string .

:Theme_ThebesPatronage
a owl:NamedIndividual, :Theme ;
:description "The special relationship between Dionysus and his mother-city Thebes."^^xsd:string .

:Theme_DionysiacWorship
a owl:NamedIndividual, :Theme ;
:description "Ecstatic worship, dance, and Bacchic rituals."^^xsd:string .

:Theme_Hope
a owl:NamedIndividual, :Theme ;
:description "The Chorus's optimistic expectation of relief."^^xsd:string .

:Theme_Purification
a owl:NamedIndividual, :Theme ;
:description "Ritual cleansing required to heal the polis."^^xsd:string .

:Emotion_ReligiousHope
a owl:NamedIndividual, :Emotion ;
:description "A hopeful fervor relying on divine aid."^^xsd:string .

:Emotion_DesperateReverence
a owl:NamedIndividual, :Emotion ;
:description "Deep respect for the god mixed with the desperation of the plague."^^xsd:string .

:Motivation_InvokeHealer
a owl:NamedIndividual, :Motivation ;
:description "The Chorus intends to summon Dionysus to cure the city's violent disease."^^xsd:string .

:Conflict_ThebesVsPlague
a owl:NamedIndividual, :Conflict ;
:conflictBetween :Antigone_Chorus, :Concept_Plague ;
:description "The struggle of the entire city against the 'violent disease' gripping it."^^xsd:string ;
:relatedTo :Motivation_InvokeHealer .

:Concept_Plague
a owl:NamedIndividual, :FateConcept ;
:description "The violent sickness (nosos) holding the city."^^xsd:string .

:Metaphor_Disease
a owl:NamedIndividual, :MetaphorSimile ;
:description "The political/spiritual state of Thebes described as a physical violent disease."^^xsd:string .

# REPORT: Produced Canonical Lines 1115-1154 explicitly as requested. Text distribution approximated based on visual blocks and standard Stasimon 5 colometry. No translation variants produced.