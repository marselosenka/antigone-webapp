:Line_775
  a owl:NamedIndividual, :Line ;
  :lineNumber 775 ;
  :canonicalReference "775"^^xsd:string ;
  :text "φορβῆς τοσοῦτον ὡς ἄγος μόνον προθείς,"^^xsd:string ;
  :hasTheme :Theme_AbuseOfPowerAndPunishment ;
  :relatedTo :CreonDecision_ImprisonAntigoneAlive .

:Line_780
  a owl:NamedIndividual, :Line ;
  :lineNumber 780 ;
  :canonicalReference "780"^^xsd:string ;
  :text "πόνος περισσός ἐστι τἀν Ἅιδου σέβειν."^^xsd:string ;
  :hasTheme :Theme_PietyAndHades ;
  :relatedTo :CreonEmotion_ContemptForHadesPiety .

:Line_785
  a owl:NamedIndividual, :Line ;
  :lineNumber 785 ;
  :canonicalReference "785"^^xsd:string ;
  :text "φοιτᾷς δ ̓ ὑπερπόντιος ἔν τ ̓ ἀγρονόμοις αὐλαῖς·"^^xsd:string ;
  :hasTheme :Theme_ErosOverpowersReason .

:Line_790
  a owl:NamedIndividual, :Line ;
  :lineNumber 790 ;
  :canonicalReference "790"^^xsd:string ;
  :text "ἀνθρώπων, ὁ δ ̓ ἔχων μέμηνεν."^^xsd:string ;
  :hasTheme :Theme_ErosOverpowersReason .

:Line_795
  a owl:NamedIndividual, :Line ;
  :lineNumber 795 ;
  :canonicalReference "795"^^xsd:string ;
  :text "νικᾷ δ ̓ ἐναργὴς βλεφάρων"^^xsd:string ;
  :hasTheme :Theme_ErosOverpowersReason .

:Line_800
  a owl:NamedIndividual, :Line ;
  :lineNumber 800 ;
  :canonicalReference "800"^^xsd:string ;
  :text "θεσμῶν ζει θεὸς Ἀφροδίτα."^^xsd:string ;
  :hasTheme :Theme_ErosOverpowersReason .

:Line_805
  a owl:NamedIndividual, :Line ;
  :lineNumber 805 ;
  :canonicalReference "805"^^xsd:string ;
  :text "τήνδ ̓ Ἀντιγόνην ἀνύτουσαν."^^xsd:string ;
  :hasTheme :Theme_AbuseOfPowerAndPunishment ;
  :relatedTo :ChorusEmotion_TearsForAntigone .

:CreonMotivation_AvoidMiasmaByBuryingAlive
  a owl:NamedIndividual, :Motivation ;
  :description "To prevent the city from incurring pollution (μίασμα) by hiding Antigone alive in a rocky underground chamber with minimal food as a token offering."^^xsd:string ;
  :relatedTo :EthicalPrinciple_CivicPurity .

:CreonDecision_ImprisonAntigoneAlive
  a owl:NamedIndividual, :MoralDecision ;
  :description "Creon decides to conceal Antigone alive in a stone-built underground tomb, providing only enough food to avert ritual guilt."^^xsd:string ;
  :relatedTo :AntigoneEmotion_FearOfDeath ;
  :relatedTo :Conflict_CreonPietyVsDeath .

:EthicalPrinciple_CivicPurity
  a owl:NamedIndividual, :EthicalPrinciple ;
  :description "The ruler's duty to protect the polis from religious pollution (μίασμα), even through harsh punitive measures."^^xsd:string .

:EthicalPrinciple_PietyTowardHades
  a owl:NamedIndividual, :EthicalPrinciple ;
  :description "Reverence for Hades/the gods of the underworld as a binding religious obligation."^^xsd:string .

:CreonEmotion_ContemptForHadesPiety
  a owl:NamedIndividual, :Emotion ;
  :description "Dismissive contempt: Creon calls reverence for Hades a 'superfluous toil'."^^xsd:string ;
  :relatedTo :EthicalPrinciple_PietyTowardHades .

:AntigoneEmotion_FearOfDeath
  a owl:NamedIndividual, :Emotion ;
  :description "Fear and dread of impending death implied by Creon's plan to entomb her alive."^^xsd:string .

:ChorusEmotion_AweAtErosPower
  a owl:NamedIndividual, :Emotion ;
  :description "Awe at Eros as an invincible force that drives humans to madness and overthrows justice."^^xsd:string .

:ChorusEmotion_TearsForAntigone
  a owl:NamedIndividual, :Emotion ;
  :description "Grief and uncontrollable tears at the sight of Antigone going to the bridal-chamber of death."^^xsd:string .

:Theme_AbuseOfPowerAndPunishment
  a owl:NamedIndividual, :Theme ;
  :description "State power inflicts extreme punishment (live entombment) under the guise of civic necessity."^^xsd:string .

:Theme_PietyAndHades
  a owl:NamedIndividual, :Theme ;
  :description "Tension around reverence for Hades and the gods, and the human attempt to evade death."^^xsd:string .

:Theme_ErosOverpowersReason
  a owl:NamedIndividual, :Theme ;
  :description "Eros as an irresistible, universal force that overwhelms human minds and social order."^^xsd:string .

:Theme_FamilyConflictUnderEros
  a owl:NamedIndividual, :Theme ;
  :description "Eros stirs strife even among kindred men (ξύναιμον), destabilizing familial bonds."^^xsd:string .

:Conflict_CreonPietyVsDeath
  a owl:NamedIndividual, :Conflict ;
  :description "Creon's civic-religious rationale (avoiding miasma) clashes with reverence for Hades and the reality of death he tries to manipulate through live entombment."^^xsd:string ;
  :conflictBetween :EthicalPrinciple_CivicPurity ;
  :conflictBetween :EthicalPrinciple_PietyTowardHades ;
  :relatedTo :CreonDecision_ImprisonAntigoneAlive .

:Conflict_ErosDerailsJustice
  a owl:NamedIndividual, :Conflict ;
  :description "Eros pulls even just minds toward injustice and causes kin-strife, opposing the claims of justice."^^xsd:string ;
  :conflictBetween :EthicalPrinciple_Justice ;
  :conflictBetween :EthicalPrinciple_ErosImpulse .

:EthicalPrinciple_Justice
  a owl:NamedIndividual, :EthicalPrinciple ;
  :description "Commitment to what is just (δίκαια) in judgment and action."^^xsd:string .

:EthicalPrinciple_ErosImpulse
  a owl:NamedIndividual, :EthicalPrinciple ;
  :description "The compelling force of erotic desire (ἵμερος/Ἔρως) treated as a governing power over human choices."^^xsd:string .

