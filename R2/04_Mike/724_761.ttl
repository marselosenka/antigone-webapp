@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Chorus a :Character .
:Creon a :Character .
:Haemon a :Character .
:Antigone a :Character .

# --- Semantic Entities (Greek) ---

:Motivation_HelpFather a :Motivation ;
    :description "Η πρόθεση του Αίμονα να προστατεύσει τον πατέρα του από τα λάθη του (σοῦ γὰρ οὖν προκήδομαι)."^^xsd:string .
:Haemon :hasMotivation :Motivation_HelpFather .

:Motivation_DefendAuthority a :Motivation ;
    :description "Η πρόθεση του Κρέοντα να υπερασπιστεί την απόλυτη εξουσία του και να μην επιτρέψει να διδαχθεί από έναν νεότερο."^^xsd:string .
:Creon :hasMotivation :Motivation_DefendAuthority .

:MoralDecision_ExecuteAntigoneBeforeHaemon a :MoralDecision ;
    :description "Η εκδικητική απόφαση του Κρέοντα να φέρει την Αντιγόνη και να τη θανατώσει αμέσως, μπροστά στα μάτια του νυμφίου της."^^xsd:string .
:Creon :makesMoralDecision :MoralDecision_ExecuteAntigoneBeforeHaemon .

:EthicalPrinciple_MutualLearning a :EthicalPrinciple ;
    :description "Η αρχή ότι οι άνθρωποι πρέπει να μαθαίνουν ο ένας από τον άλλον όταν τα λόγια είναι σωστά και καίρια."^^xsd:string .
:Chorus :advocatesFor :EthicalPrinciple_MutualLearning .

:EthicalPrinciple_JudgeByActions a :EthicalPrinciple ;
    :description "Η αρχή ότι η ορθότητα και η αξία πρέπει να κρίνονται από τα έργα και όχι από την ηλικία."^^xsd:string .
:Haemon :advocatesFor :EthicalPrinciple_JudgeByActions .

:EthicalPrinciple_CollectiveRule a :EthicalPrinciple ;
    :description "Η πολιτική αρχή ότι μια πόλη δεν αποτελεί ιδιοκτησία ενός μόνο άνδρα (Πόλις γὰρ οὐκ ἔσθ' ἥτις ἀνδρός ἐσθ' ἑνός)."^^xsd:string .
:Haemon :advocatesFor :EthicalPrinciple_CollectiveRule .

:EthicalPrinciple_DivineReverence a :EthicalPrinciple ;
    :description "Η ηθική επιταγή ότι η ανθρώπινη εξουσία δεν πρέπει να καταπατά τις τιμές των θεών (τιμάς γε τὰς θεῶν πατῶν)."^^xsd:string .
:Haemon :advocatesFor :EthicalPrinciple_DivineReverence .

:EthicalPrinciple_TyrannicalOwnership a :EthicalPrinciple ;
    :description "Η αυταρχική πεποίθηση ότι η πόλη ανήκει νομίμως σε αυτόν που την κυβερνά."^^xsd:string .
:Creon :advocatesFor :EthicalPrinciple_TyrannicalOwnership .

:Emotion_InsultedPride a :Emotion ;
    :description "Η οργή και ο πληγωμένος εγωισμός του Κρέοντα στην ιδέα ότι θα διδαχθεί και θα κριθεί από έναν νέο."^^xsd:string .
:Creon :experiencesEmotion :Emotion_InsultedPride .

:Emotion_Outrage a :Emotion ;
    :description "Η εκρηκτική οργή του Κρέοντα για τις επικρίσεις του Αίμονα."^^xsd:string .
:Creon :experiencesEmotion :Emotion_Outrage .

:Emotion_Frustration a :Emotion ;
    :description "Η αγανάκτηση του Αίμονα για την αλαζονεία, τον παραλογισμό και την άρνηση του πατέρα του να ακούσει."^^xsd:string .
:Haemon :experiencesEmotion :Emotion_Frustration .

:Conflict_AgeVsWisdom a :Conflict ;
    :description "Η σύγκρουση μεταξύ της ηλικίας ως απόλυτο τεκμήριο σοφίας και της αξιολόγησης βάσει των πράξεων (τἄργα)."^^xsd:string ;
    :conflictBetween :Creon, :Haemon .

:Conflict_AutocracyVsCollectiveCity a :Conflict ;
    :description "Η σύγκρουση μεταξύ της τυραννικής ιδιοκτησίας της πόλης (Κρέων) και της πόλης ως συλλογικό σώμα (Αίμων)."^^xsd:string ;
    :conflictBetween :Creon, :Haemon .

:Conflict_HumanAuthorityVsDivineLaw a :Conflict ;
    :description "Η σύγκρουση μεταξύ του σεβασμού στην αποκλειστική ανθρώπινη εξουσία και του σεβασμού στους θεϊκούς νόμους."^^xsd:string ;
    :conflictBetween :Creon, :Theme_DivineLaw .

:Event_AntigonesDeath a owl:Thing ;
    :description "Ο επικείμενος θάνατος της Αντιγόνης."^^xsd:string .

:Event_AnotherDeath a owl:Thing ;
    :description "Ο θάνατος ενός άλλου προσώπου, μια άμεση απειλή για την αυτοκτονία του Αίμονα."^^xsd:string .
:Event_AntigonesDeath :relatedTo :Event_AnotherDeath .

:Cause_AbsoluteTyranny a owl:Thing ;
    :description "Η διακυβέρνηση όπου ο ηγέτης θεωρεί την πόλη δική του και αγνοεί τους πολίτες."^^xsd:string .

:Effect_Wasteland a owl:Thing ;
    :description "Το αποτέλεσμα να κυβερνά κανείς τέλεια, αλλά μόνος του σε μια έρημη γη (ερήμης γῆς)."^^xsd:string .
:Cause_AbsoluteTyranny :relatedTo :Effect_Wasteland .

:Cause_ListeningToWomen a owl:Thing ;
    :description "Η υπεράσπιση των πράξεων μιας γυναίκας, που θεωρείται υποδούλωση (γυναικὸς ὢν δούλευμα)."^^xsd:string .

:Effect_CloudedJudgement a owl:Thing ;
    :description "Η αντιμετώπιση του ανθρώπου ως μιαρού και κατώτερου."^^xsd:string .
:Cause_ListeningToWomen :relatedTo :Effect_CloudedJudgement .

:Theme_Tyranny a :Theme ;
    :description "Η καταστροφική φύση της αυταρχικής εξουσίας, όπου ο μονάρχης ταυτίζει τον εαυτό του με την πόλη."^^xsd:string .

:Theme_AgeVsYouth a :Theme ;
    :description "Η ηλικιακή ένταση μεταξύ της εδραιωμένης, παραδοσιακής εξουσίας των γερόντων και της λογικής των νέων."^^xsd:string .

:Theme_Misogyny a :Theme ;
    :description "Ο μισογυνισμός ως εργαλείο της πατριαρχικής εξουσίας για την υποτίμηση της αντίθετης άποψης."^^xsd:string .

:Theme_DivineLaw a :Theme ;
    :description "Η υπεροχή και τα δικαιώματα των χθόνιων θεών, τα οποία κανένας θνητός άρχοντας δεν μπορεί να καταπατά."^^xsd:string .

# --- Line-by-Line Extraction with Translation Variants ---

:Line_724 a owl:NamedIndividual, :Line ; :lineNumber 724 ; :canonicalReference "724"^^xsd:string .
:TV_Line_724_grc a :TranslationVariant ;
    :text "ΧΟ. Ἄναξ, σέ τ ̓ εἰκός, εἴ τι καίριον λέγει,"^^xsd:string ;
    :relatedTo :Line_724 ;
    :advocatesFor :EthicalPrinciple_MutualLearning .

:Line_725 a owl:NamedIndividual, :Line ; :lineNumber 725 ; :canonicalReference "725"^^xsd:string .
:TV_Line_725_grc a :TranslationVariant ;
    :text "μαθεῖν, σέ τ ̓ αὖ τοῦδ ̓· εὖ γὰρ εἴρηται διπλῇ."^^xsd:string ;
    :relatedTo :Line_725 .

:Line_726 a owl:NamedIndividual, :Line ; :lineNumber 726 ; :canonicalReference "726"^^xsd:string .
:TV_Line_726_grc a :TranslationVariant ;
    :text "ΚΡ. Οἱ τηλικοίδε καὶ διδαξόμεσθα δὴ"^^xsd:string ;
    :relatedTo :Line_726 ;
    :experiencesEmotion :Emotion_InsultedPride ;
    :hasTheme :Theme_AgeVsYouth .

:Line_727 a owl:NamedIndividual, :Line ; :lineNumber 727 ; :canonicalReference "727"^^xsd:string .
:TV_Line_727_grc a :TranslationVariant ;
    :text "φρονεῖν ὑπ ̓ ἀνδρὸς τηλικοῦδε τὴν φύσιν;"^^xsd:string ;
    :relatedTo :Line_727 ;
    :hasMotivation :Motivation_DefendAuthority .

:Line_728 a owl:NamedIndividual, :Line ; :lineNumber 728 ; :canonicalReference "728"^^xsd:string .
:TV_Line_728_grc a :TranslationVariant ;
    :text "ΑΙ. Μηδὲν τὸ μὴ δίκαιον· εἰ δ ̓ ἐγὼ νέος,"^^xsd:string ;
    :relatedTo :Line_728 .

:Line_729 a owl:NamedIndividual, :Line ; :lineNumber 729 ; :canonicalReference "729"^^xsd:string .
:TV_Line_729_grc a :TranslationVariant ;
    :text "οὐ τὸν χρόνον χρὴ μᾶλλον ἢ τἄργα σκοπεῖν."^^xsd:string ;
    :relatedTo :Line_729 ;
    :advocatesFor :EthicalPrinciple_JudgeByActions ;
    :hasConflict :Conflict_AgeVsWisdom .

:Line_730 a owl:NamedIndividual, :Line ; :lineNumber 730 ; :canonicalReference "730"^^xsd:string .
:TV_Line_730_grc a :TranslationVariant ;
    :text "ΚΡ. Ἔργον γάρ ἐστι τοὺς ἀκοσμοῦντας σέβειν;"^^xsd:string ;
    :relatedTo :Line_730 .

:Line_731 a owl:NamedIndividual, :Line ; :lineNumber 731 ; :canonicalReference "731"^^xsd:string .
:TV_Line_731_grc a :TranslationVariant ;
    :text "ΑΙ. Οὐδ ̓ ἂν κελεύσαιμ ̓ εὐσεβεῖν ἐς τοὺς κακούς."^^xsd:string ;
    :relatedTo :Line_731 .

:Line_732 a owl:NamedIndividual, :Line ; :lineNumber 732 ; :canonicalReference "732"^^xsd:string .
:TV_Line_732_grc a :TranslationVariant ;
    :text "ΚΡ. Οὐχ ἥδε γὰρ τοιᾷδ ̓ ἐπείληπται νόσῳ;"^^xsd:string ;
    :relatedTo :Line_732 .

:Line_733 a owl:NamedIndividual, :Line ; :lineNumber 733 ; :canonicalReference "733"^^xsd:string .
:TV_Line_733_grc a :TranslationVariant ;
    :text "ΑΙ. Οὔ φησι Θήβης τῆσδ ̓ ὁμόπτολις λεώς."^^xsd:string ;
    :relatedTo :Line_733 .

:Line_734 a owl:NamedIndividual, :Line ; :lineNumber 734 ; :canonicalReference "734"^^xsd:string .
:TV_Line_734_grc a :TranslationVariant ;
    :text "ΚΡ. Πόλις γὰρ ἡμῖν ἁμὲ χρὴ τάσσειν ἐρεῖ;"^^xsd:string ;
    :relatedTo :Line_734 .

:Line_735 a owl:NamedIndividual, :Line ; :lineNumber 735 ; :canonicalReference "735"^^xsd:string .
:TV_Line_735_grc a :TranslationVariant ;
    :text "ΑΙ. Ὁρᾷς τόδ ̓ ὡς εἴρηκας ὡς ἄγαν νέος;"^^xsd:string ;
    :relatedTo :Line_735 .

:Line_736 a owl:NamedIndividual, :Line ; :lineNumber 736 ; :canonicalReference "736"^^xsd:string .
:TV_Line_736_grc a :TranslationVariant ;
    :text "ΚΡ. Ἄλλῳ γὰρ ἢ  ̓μοὶ χρή με τῆσδ ̓ ἄρχειν χθονός;"^^xsd:string ;
    :relatedTo :Line_736 .

:Line_737 a owl:NamedIndividual, :Line ; :lineNumber 737 ; :canonicalReference "737"^^xsd:string .
:TV_Line_737_grc a :TranslationVariant ;
    :text "ΑΙ. Πόλις γὰρ οὐκ ἔσθ ̓ ἥτις ἀνδρός ἐσθ ̓ ἑνός."^^xsd:string ;
    :relatedTo :Line_737 ;
    :advocatesFor :EthicalPrinciple_CollectiveRule ;
    :hasConflict :Conflict_AutocracyVsCollectiveCity .

:Line_738 a owl:NamedIndividual, :Line ; :lineNumber 738 ; :canonicalReference "738"^^xsd:string .
:TV_Line_738_grc a :TranslationVariant ;
    :text "ΚΡ. Οὐ τοῦ κρατοῦντος ἡ πόλις νομίζεται;"^^xsd:string ;
    :relatedTo :Line_738 ;
    :advocatesFor :EthicalPrinciple_TyrannicalOwnership ;
    :hasTheme :Theme_Tyranny .

:Line_739 a owl:NamedIndividual, :Line ; :lineNumber 739 ; :canonicalReference "739"^^xsd:string .
:TV_Line_739_grc a :TranslationVariant ;
    :text "ΑΙ. Καλῶς ἐρήμης γ ̓ ἂν σὺ γῆς ἄρχοις μόνος."^^xsd:string ;
    :relatedTo :Line_739 ;
    :relatedTo :Effect_Wasteland .

:Line_740 a owl:NamedIndividual, :Line ; :lineNumber 740 ; :canonicalReference "740"^^xsd:string .
:TV_Line_740_grc a :TranslationVariant ;
    :text "ΚΡ. Ὅδ ̓, ὡς ἔοικε, τῇ γυναικὶ συμμαχεῖ."^^xsd:string ;
    :relatedTo :Line_740 ;
    :relatedTo :Cause_ListeningToWomen .

:Line_741 a owl:NamedIndividual, :Line ; :lineNumber 741 ; :canonicalReference "741"^^xsd:string .
:TV_Line_741_grc a :TranslationVariant ;
    :text "ΑΙ. Εἴπερ γυνὴ σύ· σοῦ γὰρ οὖν προκήδομαι."^^xsd:string ;
    :relatedTo :Line_741 ;
    :hasMotivation :Motivation_HelpFather .

:Line_742 a owl:NamedIndividual, :Line ; :lineNumber 742 ; :canonicalReference "742"^^xsd:string .
:TV_Line_742_grc a :TranslationVariant ;
    :text "ΚΡ. Ὦ παγκάκιστε, διὰ δίκης ἰὼν πατρί;"^^xsd:string ;
    :relatedTo :Line_742 .

:Line_743 a owl:NamedIndividual, :Line ; :lineNumber 743 ; :canonicalReference "743"^^xsd:string .
:TV_Line_743_grc a :TranslationVariant ;
    :text "ΑΙ. Οὐ γὰρ δίκαιά σ ̓ ἐξαμαρτάνονθ ̓ ὁρῶ."^^xsd:string ;
    :relatedTo :Line_743 .

:Line_744 a owl:NamedIndividual, :Line ; :lineNumber 744 ; :canonicalReference "744"^^xsd:string .
:TV_Line_744_grc a :TranslationVariant ;
    :text "ΚΡ. Ἁμαρτάνω γὰρ τὰς ἐμὰς ἀρχὰς σέβων;"^^xsd:string ;
    :relatedTo :Line_744 ;
    :hasConflict :Conflict_HumanAuthorityVsDivineLaw .

:Line_745 a owl:NamedIndividual, :Line ; :lineNumber 745 ; :canonicalReference "745"^^xsd:string .
:TV_Line_745_grc a :TranslationVariant ;
    :text "ΑΙ. Οὐ γὰρ σέβεις, τιμάς γε τὰς θεῶν πατῶν."^^xsd:string ;
    :relatedTo :Line_745 ;
    :advocatesFor :EthicalPrinciple_DivineReverence ;
    :hasTheme :Theme_DivineLaw .

:Line_746 a owl:NamedIndividual, :Line ; :lineNumber 746 ; :canonicalReference "746"^^xsd:string .
:TV_Line_746_grc a :TranslationVariant ;
    :text "ΚΡ. Ὦ μιαρὸν ἦθος καὶ γυναικὸς ὕστερον."^^xsd:string ;
    :relatedTo :Line_746 ;
    :relatedTo :Effect_CloudedJudgement ;
    :hasTheme :Theme_Misogyny .

:Line_747 a owl:NamedIndividual, :Line ; :lineNumber 747 ; :canonicalReference "747"^^xsd:string .
:TV_Line_747_grc a :TranslationVariant ;
    :text "ΑΙ. Οὔ τἂν ἕλοις ἥσσω γε τῶν αἰσχρῶν ἐμέ."^^xsd:string ;
    :relatedTo :Line_747 .

:Line_748 a owl:NamedIndividual, :Line ; :lineNumber 748 ; :canonicalReference "748"^^xsd:string .
:TV_Line_748_grc a :TranslationVariant ;
    :text "ΚΡ. Ὁ γοῦν λόγος σοι πᾶς ὑπὲρ κείνης ὅδε."^^xsd:string ;
    :relatedTo :Line_748 .

:Line_749 a owl:NamedIndividual, :Line ; :lineNumber 749 ; :canonicalReference "749"^^xsd:string .
:TV_Line_749_grc a :TranslationVariant ;
    :text "ΑΙ. Καὶ σοῦ γε κἀμοῦ, καὶ θεῶν τῶν νερτέρων."^^xsd:string ;
    :relatedTo :Line_749 .

:Line_750 a owl:NamedIndividual, :Line ; :lineNumber 750 ; :canonicalReference "750"^^xsd:string .
:TV_Line_750_grc a :TranslationVariant ;
    :text "ΚΡ. Ταύτην ποτ ̓ οὐκ ἔσθ ̓ ὡς ἔτι ζῶσαν γαμεῖς."^^xsd:string ;
    :relatedTo :Line_750 ;
    :relatedTo :Event_AntigonesDeath .

:Line_751 a owl:NamedIndividual, :Line ; :lineNumber 751 ; :canonicalReference "751"^^xsd:string .
:TV_Line_751_grc a :TranslationVariant ;
    :text "ΑΙ. Ἥδ ̓ οὖν θανεῖται καὶ θανοῦσ ̓ ὀλεῖ τινα."^^xsd:string ;
    :relatedTo :Line_751 ;
    :relatedTo :Event_AnotherDeath .

:Line_752 a owl:NamedIndividual, :Line ; :lineNumber 752 ; :canonicalReference "752"^^xsd:string .
:TV_Line_752_grc a :TranslationVariant ;
    :text "ΚΡ. Ἦ κἀπαπειλῶν ὧδ ̓ ἐπεξέρχῃ θρασύς;"^^xsd:string ;
    :relatedTo :Line_752 .

:Line_753 a owl:NamedIndividual, :Line ; :lineNumber 753 ; :canonicalReference "753"^^xsd:string .
:TV_Line_753_grc a :TranslationVariant ;
    :text "ΑΙ. Τίς δ ̓ ἔστ ̓ ἀπειλὴ πρὸς κενὰς γνώμας λέγειν;"^^xsd:string ;
    :relatedTo :Line_753 ;
    :experiencesEmotion :Emotion_Frustration .

:Line_754 a owl:NamedIndividual, :Line ; :lineNumber 754 ; :canonicalReference "754"^^xsd:string .
:TV_Line_754_grc a :TranslationVariant ;
    :text "ΚΡ. Κλαίων φρενώσεις, ὢν φρενῶν αὐτὸς κενός."^^xsd:string ;
    :relatedTo :Line_754 .

:Line_755 a owl:NamedIndividual, :Line ; :lineNumber 755 ; :canonicalReference "755"^^xsd:string .
:TV_Line_755_grc a :TranslationVariant ;
    :text "ΑΙ. Εἰ μὴ πατὴρ ἦσθ ̓, εἶπον ἄν σ ̓ οὐκ εὖ φρονεῖν."^^xsd:string ;
    :relatedTo :Line_755 .

:Line_756 a owl:NamedIndividual, :Line ; :lineNumber 756 ; :canonicalReference "756"^^xsd:string .
:TV_Line_756_grc a :TranslationVariant ;
    :text "ΚΡ. Γυναικὸς ὢν δούλευμα, μὴ κώτιλλέ με."^^xsd:string ;
    :relatedTo :Line_756 ;
    :hasTheme :Theme_Misogyny .

:Line_757 a owl:NamedIndividual, :Line ; :lineNumber 757 ; :canonicalReference "757"^^xsd:string .
:TV_Line_757_grc a :TranslationVariant ;
    :text "ΑΙ. Βούλει λέγειν τι καὶ λέγων μηδὲν κλύειν;"^^xsd:string ;
    :relatedTo :Line_757 .

:Line_758 a owl:NamedIndividual, :Line ; :lineNumber 758 ; :canonicalReference "758"^^xsd:string .
:TV_Line_758_grc a :TranslationVariant ;
    :text "ΚΡ. Ἄληθες; ἀλλ ̓ οὐ τόνδ ̓ Ὄλυμπον, ἴσθ ̓ ὅτι,"^^xsd:string ;
    :relatedTo :Line_758 ;
    :experiencesEmotion :Emotion_Outrage .

:Line_759 a owl:NamedIndividual, :Line ; :lineNumber 759 ; :canonicalReference "759"^^xsd:string .
:TV_Line_759_grc a :TranslationVariant ;
    :text "χαίρων ἐπὶ ψόγοισι δεννάσεις ἐμέ."^^xsd:string ;
    :relatedTo :Line_759 .

:Line_760 a owl:NamedIndividual, :Line ; :lineNumber 760 ; :canonicalReference "760"^^xsd:string .
:TV_Line_760_grc a :TranslationVariant ;
    :text "Ἄγαγε τὸ μῖσος, ὡς κατ ̓ ὄμματ ̓ αὐτίκα"^^xsd:string ;
    :relatedTo :Line_760 ;
    :makesMoralDecision :MoralDecision_ExecuteAntigoneBeforeHaemon .

:Line_761 a owl:NamedIndividual, :Line ; :lineNumber 761 ; :canonicalReference "761"^^xsd:string .
:TV_Line_761_grc a :TranslationVariant ;
    :text "παρόντι θνῄσκῃ πλησία τῷ νυμφίῳ."^^xsd:string ;
    :relatedTo :Line_761 .
