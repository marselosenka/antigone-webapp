@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Haemon a :Character .
:Creon a :Character .
:Antigone a :Character .
:Zeus a :Character .

# --- Semantic Entities (Greek) ---

:Motivation_FollowFathersGuidance a :Motivation ;
    :description "Η πρόθεση του Αίμονα να ακολουθήσει την ορθή κρίση του πατέρα του, βάζοντάς την πάνω από κάθε γάμο (οὐδεὶς ἀξιώσεται γάμος μείζων φέρεσθαι)."^^xsd:string .
:Haemon :hasMotivation :Motivation_FollowFathersGuidance .

:Motivation_DemandObedience a :Motivation ;
    :description "Η απαίτηση του Κρέοντα για απόλυτη υπακοή των παιδιών, ώστε να τιμούν τους φίλους και να πολεμούν τους εχθρούς (γνώμης πατρῴας πάντ' ὄπισθεν ἑστάναι)."^^xsd:string .
:Creon :hasMotivation :Motivation_DemandObedience .

:Motivation_MaintainPatriarchalDominance a :Motivation ;
    :description "Η απόλυτη άρνηση του Κρέοντα να ηττηθεί ή να υποταχθεί σε γυναίκα, προτιμώντας να πέσει από ανδρικό χέρι."^^xsd:string .
:Creon :hasMotivation :Motivation_MaintainPatriarchalDominance .

:MoralDecision_ExecuteAntigone a :MoralDecision ;
    :description "Η αμετάκλητη απόφαση του Κρέοντα να θανατώσει (κτενῶ) την Αντιγόνη για την ανοιχτή της απείθεια απέναντι στην πόλη."^^xsd:string .
:Creon :makesMoralDecision :MoralDecision_ExecuteAntigone .

:EthicalPrinciple_FilialPiety a :EthicalPrinciple ;
    :description "Η αρχή της υιικής ευσέβειας και της πλήρους υποταγής ενός γιου στη θέληση του πατέρα του."^^xsd:string .
:Haemon :advocatesFor :EthicalPrinciple_FilialPiety .
:Creon :advocatesFor :EthicalPrinciple_FilialPiety .

:EthicalPrinciple_AbsoluteCivicObedience a :EthicalPrinciple ;
    :description "Η πεποίθηση ότι οι πολίτες πρέπει να υπακούν τυφλά στον εκλεγμένο ηγέτη σε όλα τα ζητήματα, είτε μικρά και δίκαια, είτε τα αντίθετά τους (καὶ σμικρὰ καὶ δίκαια καὶ τἀναντία)."^^xsd:string .
:Creon :advocatesFor :EthicalPrinciple_AbsoluteCivicObedience .

:EthicalPrinciple_HouseholdGovernance a :EthicalPrinciple ;
    :description "Ο κανόνας ότι όποιος διοικεί σωστά τον οίκο του, αποδεικνύεται δίκαιος και στη διοίκηση της πόλης."^^xsd:string .
:Creon :advocatesFor :EthicalPrinciple_HouseholdGovernance .

:Emotion_FearOfMockery a :Emotion ;
    :description "Ο φόβος του Κρέοντα μήπως γίνει περίγελος στους εχθρούς του (πολὺν δὲ τοῖσιν ἐχθροῖσιν γέλων) ανατρέφοντας ανυπάκουα τέκνα."^^xsd:string .
:Creon :experiencesEmotion :Emotion_FearOfMockery .

:Emotion_Contempt a :Emotion ;
    :description "Η βαθιά περιφρόνηση του Κρέοντα προς την Αντιγόνη, την οποία θεωρεί 'ψυχρό αγκάλιασμα' (ψυχρὸν παραγκάλισμα) και εχθρό."^^xsd:string .
:Creon :experiencesEmotion :Emotion_Contempt .

:Conflict_StateAuthorityVsIndividualDefiance a :Conflict ;
    :description "Η σύγκρουση μεταξύ της απόλυτης εξουσίας του ηγέτη και του ατόμου που παραβιάζει τους νόμους ή προσπαθεί να επιβάλει τη θέλησή του στην εξουσία."^^xsd:string .
:Conflict_MaleAuthorityVsFemaleDefiance a :Conflict ;
    :description "Η έμφυλη σύγκρουση και ο φόβος του άνδρα ηγέτη να φανεί κατώτερος και πιο αδύναμος από μια γυναίκα."^^xsd:string .

:Cause_DisobedientChildren a owl:Thing ;
    :description "Η ανατροφή ανώφελων και ανυπάκουων παιδιών."^^xsd:string .
:Effect_EnemyMockery a owl:Thing ;
    :description "Η πρόκληση κόπων για τον ίδιο τον πατέρα και άφθονου γέλιου για τους εχθρούς."^^xsd:string .
:Cause_DisobedientChildren :relatedTo :Effect_EnemyMockery .

:Cause_LustForWoman a owl:Thing ;
    :description "Η απώλεια του λογικού εξαιτίας της ηδονής για μια γυναίκα."^^xsd:string .
:Effect_ColdMarriage a owl:Thing ;
    :description "Η κατάληξη σε ένα ψυχρό αγκάλιασμα με μια κακή σύζυγο μέσα στο σπίτι."^^xsd:string .
:Cause_LustForWoman :relatedTo :Effect_ColdMarriage .

:Cause_TolerateFamilyDisobedience a owl:Thing ;
    :description "Η ανοχή της απειθαρχίας στους ανθρώπους του ίδιου του συγγενικού κύκλου."^^xsd:string .
:Effect_GeneralAnarchy a owl:Thing ;
    :description "Η πεποίθηση ότι αν οι συγγενείς είναι άτακτοι, τότε και οι εκτός γένους θα γίνουν ανεξέλεγκτοι."^^xsd:string .
:Cause_TolerateFamilyDisobedience :relatedTo :Effect_GeneralAnarchy .

:Cause_Disobedience a owl:Thing ;
    :description "Η αναρχία, ως το μεγαλύτερο από όλα τα κακά (Ἀναρχίας δὲ μεῖζον οὐκ ἔστιν κακόν)."^^xsd:string .
:Effect_SocialCollapse a owl:Thing ;
    :description "Η καταστροφή των πόλεων, η ερήμωση των οίκων και η διάσπαση του στρατού."^^xsd:string .
:Cause_Disobedience :relatedTo :Effect_SocialCollapse .

:Cause_CivicObedience a owl:Thing ;
    :description "Η πειθαρχία (ἡ πειθαρχία) και η υπακοή στην εξουσία."^^xsd:string .
:Effect_PreservationOfLife a owl:Thing ;
    :description "Η διάσωση των ζωών όσων ακολουθούν την τάξη (σῴζει τὰ πολλὰ σώμαθ')."^^xsd:string .
:Cause_CivicObedience :relatedTo :Effect_PreservationOfLife .

:Theme_AbsoluteAuthority a :Theme ;
    :description "Η επιβολή της απόλυτης εξουσίας, η οποία απαιτεί υποταγή σε κάθε εντολή, είτε αυτή είναι δίκαιη είτε άδικη."^^xsd:string .
:Theme_CivicOrderVsAnarchy a :Theme ;
    :description "Η αντίθεση ανάμεσα στην πειθαρχία που σώζει την πόλη και την αναρχία που φέρνει τον απόλυτο όλεθρο."^^xsd:string .
:Theme_Patriarchy a :Theme ;
    :description "Ο πατριαρχικός κώδικας τιμής που θεωρεί ανεπίτρεπτη την υποταγή ενός άνδρα στις επιθυμίες ή την εξουσία μιας γυναίκας."^^xsd:string .
:Theme_FilialPiety a :Theme ;
    :description "Η συστημική προσδοκία της πλήρους αφοσίωσης του γιου στα προστάγματα και τις έχθρες του πατέρα του."^^xsd:string .


# --- Line-by-Line Extraction with Translation Variants ---

:Line_635 a owl:NamedIndividual, :Line ; :lineNumber 635 ; :canonicalReference "635"^^xsd:string .
:TV_Line_635_grc a :TranslationVariant ;
    :text "Πάτερ, σός εἰμι· καὶ σύ μοι γνώμας ἔχων"^^xsd:string ;
    :relatedTo :Line_635 ;
    :hasMotivation :Motivation_FollowFathersGuidance ;
    :advocatesFor :EthicalPrinciple_FilialPiety .

:Line_636 a owl:NamedIndividual, :Line ; :lineNumber 636 ; :canonicalReference "636"^^xsd:string .
:TV_Line_636_grc a :TranslationVariant ;
    :text "χρηστὰς ἀπορθοῖς, αἷς ἔγωγ ̓ ἐφέψομαι."^^xsd:string ;
    :relatedTo :Line_636 .

:Line_637 a owl:NamedIndividual, :Line ; :lineNumber 637 ; :canonicalReference "637"^^xsd:string .
:TV_Line_637_grc a :TranslationVariant ;
    :text "Ἐμοὶ γὰρ οὐδεὶς ἀξιώσεται γάμος"^^xsd:string ;
    :relatedTo :Line_637 .

:Line_638 a owl:NamedIndividual, :Line ; :lineNumber 638 ; :canonicalReference "638"^^xsd:string .
:TV_Line_638_grc a :TranslationVariant ;
    :text "μείζων φέρεσθαι σοῦ καλῶς ἡγουμένου."^^xsd:string ;
    :relatedTo :Line_638 .

:Line_639 a owl:NamedIndividual, :Line ; :lineNumber 639 ; :canonicalReference "639"^^xsd:string .
:TV_Line_639_grc a :TranslationVariant ;
    :text "ΚΡ. Οὕτω γάρ, ὦ παῖ, χρὴ διὰ στέρνων ἔχειν,"^^xsd:string ;
    :relatedTo :Line_639 .

:Line_640 a owl:NamedIndividual, :Line ; :lineNumber 640 ; :canonicalReference "640"^^xsd:string .
:TV_Line_640_grc a :TranslationVariant ;
    :text "γνώμης πατρῴας πάντ ̓ ὄπισθεν ἑστάναι."^^xsd:string ;
    :relatedTo :Line_640 ;
    :hasMotivation :Motivation_DemandObedience ;
    :hasTheme :Theme_FilialPiety .

:Line_641 a owl:NamedIndividual, :Line ; :lineNumber 641 ; :canonicalReference "641"^^xsd:string .
:TV_Line_641_grc a :TranslationVariant ;
    :text "Τούτου γὰρ οὕνεκ ̓ ἄνδρες εὔχονται γονὰς"^^xsd:string ;
    :relatedTo :Line_641 .

:Line_642 a owl:NamedIndividual, :Line ; :lineNumber 642 ; :canonicalReference "642"^^xsd:string .
:TV_Line_642_grc a :TranslationVariant ;
    :text "κατηκόους φύσαντες ἐν δόμοις ἔχειν,"^^xsd:string ;
    :relatedTo :Line_642 .

:Line_643 a owl:NamedIndividual, :Line ; :lineNumber 643 ; :canonicalReference "643"^^xsd:string .
:TV_Line_643_grc a :TranslationVariant ;
    :text "ὡς καὶ τὸν ἐχθρὸν ἀνταμύνωνται κακοῖς"^^xsd:string ;
    :relatedTo :Line_643 .

:Line_644 a owl:NamedIndividual, :Line ; :lineNumber 644 ; :canonicalReference "644"^^xsd:string .
:TV_Line_644_grc a :TranslationVariant ;
    :text "καὶ τὸν φίλον τιμῶσιν ἐξ ἴσου πατρί."^^xsd:string ;
    :relatedTo :Line_644 .

:Line_645 a owl:NamedIndividual, :Line ; :lineNumber 645 ; :canonicalReference "645"^^xsd:string .
:TV_Line_645_grc a :TranslationVariant ;
    :text "Ὅστις δ ̓ ἀνωφέλητα φιτύει τέκνα,"^^xsd:string ;
    :relatedTo :Line_645 ;
    :relatedTo :Cause_DisobedientChildren .

:Line_646 a owl:NamedIndividual, :Line ; :lineNumber 646 ; :canonicalReference "646"^^xsd:string .
:TV_Line_646_grc a :TranslationVariant ;
    :text "τί τόνδ ̓ ἂν εἴποις ἄλλο πλὴν αὑτῷ πόνους"^^xsd:string ;
    :relatedTo :Line_646 .

:Line_647 a owl:NamedIndividual, :Line ; :lineNumber 647 ; :canonicalReference "647"^^xsd:string .
:TV_Line_647_grc a :TranslationVariant ;
    :text "φῦσαι, πολὺν δὲ τοῖσιν ἐχθροῖσιν γέλων;"^^xsd:string ;
    :relatedTo :Line_647 ;
    :relatedTo :Effect_EnemyMockery .

:Line_648 a owl:NamedIndividual, :Line ; :lineNumber 648 ; :canonicalReference "648"^^xsd:string .
:TV_Line_648_grc a :TranslationVariant ;
    :text "Μή νύν ποτ ̓, ὦ παῖ, τὰς φρένας γ ̓ ὑφ ̓ ἡδονῆς"^^xsd:string ;
    :relatedTo :Line_648 ;
    :experiencesEmotion :Emotion_FearOfMockery .

:Line_649 a owl:NamedIndividual, :Line ; :lineNumber 649 ; :canonicalReference "649"^^xsd:string .
:TV_Line_649_grc a :TranslationVariant ;
    :text "γυναικὸς οὕνεκ ̓ ἐκβάλῃς, εἰδὼς ὅτι"^^xsd:string ;
    :relatedTo :Line_649 ;
    :relatedTo :Cause_LustForWoman .

:Line_650 a owl:NamedIndividual, :Line ; :lineNumber 650 ; :canonicalReference "650"^^xsd:string .
:TV_Line_650_grc a :TranslationVariant ;
    :text "ψυχρὸν παραγκάλισμα τοῦτο γίγνεται,"^^xsd:string ;
    :relatedTo :Line_650 .

:Line_651 a owl:NamedIndividual, :Line ; :lineNumber 651 ; :canonicalReference "651"^^xsd:string .
:TV_Line_651_grc a :TranslationVariant ;
    :text "γυνὴ κακὴ ξύνευνος ἐν δόμοις. Τί γὰρ"^^xsd:string ;
    :relatedTo :Line_651 ;
    :relatedTo :Effect_ColdMarriage .

:Line_652 a owl:NamedIndividual, :Line ; :lineNumber 652 ; :canonicalReference "652"^^xsd:string .
:TV_Line_652_grc a :TranslationVariant ;
    :text "γένοιτ ̓ ἂν ἕλκος μεῖζον ἢ φίλος κακός;"^^xsd:string ;
    :relatedTo :Line_652 .

:Line_653 a owl:NamedIndividual, :Line ; :lineNumber 653 ; :canonicalReference "653"^^xsd:string .
:TV_Line_653_grc a :TranslationVariant ;
    :text "Ἀλλὰ πτύσας ὡσεί τε δυσμενῆ μέθες"^^xsd:string ;
    :relatedTo :Line_653 ;
    :experiencesEmotion :Emotion_Contempt .

:Line_654 a owl:NamedIndividual, :Line ; :lineNumber 654 ; :canonicalReference "654"^^xsd:string .
:TV_Line_654_grc a :TranslationVariant ;
    :text "τὴν παῖδ ̓ ἐν Ἅιδου τήνδε νυμφεύειν τινί."^^xsd:string ;
    :relatedTo :Line_654 .

:Line_655 a owl:NamedIndividual, :Line ; :lineNumber 655 ; :canonicalReference "655"^^xsd:string .
:TV_Line_655_grc a :TranslationVariant ;
    :text "Ἐπεὶ γὰρ αὐτὴν εἷλον ἐμφανῶς ἐγὼ"^^xsd:string ;
    :relatedTo :Line_655 ;
    :hasConflict :Conflict_StateAuthorityVsIndividualDefiance .

:Line_656 a owl:NamedIndividual, :Line ; :lineNumber 656 ; :canonicalReference "656"^^xsd:string .
:TV_Line_656_grc a :TranslationVariant ;
    :text "πόλεως ἀπιστήσασαν ἐκ πάσης μόνην,"^^xsd:string ;
    :relatedTo :Line_656 .

:Line_657 a owl:NamedIndividual, :Line ; :lineNumber 657 ; :canonicalReference "657"^^xsd:string .
:TV_Line_657_grc a :TranslationVariant ;
    :text "ψευδῆ γ ̓ ἐμαυτὸν οὐ καταστήσω πόλει,"^^xsd:string ;
    :relatedTo :Line_657 .

:Line_658 a owl:NamedIndividual, :Line ; :lineNumber 658 ; :canonicalReference "658"^^xsd:string .
:TV_Line_658_grc a :TranslationVariant ;
    :text "ἀλλὰ κτενῶ. Πρὸς ταῦτ ̓ ἐφυμνείτω Δία"^^xsd:string ;
    :relatedTo :Line_658 ;
    :makesMoralDecision :MoralDecision_ExecuteAntigone .

:Line_659 a owl:NamedIndividual, :Line ; :lineNumber 659 ; :canonicalReference "659"^^xsd:string .
:TV_Line_659_grc a :TranslationVariant ;
    :text "ξύναιμον· εἰ γὰρ δὴ τά γ ̓ ἐγγενῆ φύσει"^^xsd:string ;
    :relatedTo :Line_659 ;
    :relatedTo :Cause_TolerateFamilyDisobedience .

:Line_660 a owl:NamedIndividual, :Line ; :lineNumber 660 ; :canonicalReference "660"^^xsd:string .
:TV_Line_660_grc a :TranslationVariant ;
    :text "ἄκοσμα θρέψω, κάρτα τοὺς ἔξω γένους."^^xsd:string ;
    :relatedTo :Line_660 ;
    :relatedTo :Effect_GeneralAnarchy .

:Line_661 a owl:NamedIndividual, :Line ; :lineNumber 661 ; :canonicalReference "661"^^xsd:string .
:TV_Line_661_grc a :TranslationVariant ;
    :text "Ἐν τοῖς γὰρ οἰκείοισιν ὅστις ἔστ ̓ ἀνὴρ"^^xsd:string ;
    :relatedTo :Line_661 .

:Line_662 a owl:NamedIndividual, :Line ; :lineNumber 662 ; :canonicalReference "662"^^xsd:string .
:TV_Line_662_grc a :TranslationVariant ;
    :text "χρηστός, φανεῖται κἀν πόλει δίκαιος ὤν."^^xsd:string ;
    :relatedTo :Line_662 ;
    :advocatesFor :EthicalPrinciple_HouseholdGovernance .

:Line_663 a owl:NamedIndividual, :Line ; :lineNumber 663 ; :canonicalReference "663"^^xsd:string .
:TV_Line_663_grc a :TranslationVariant ;
    :text "Ὅστις δ ̓ ὑπερβὰς ἢ νόμους βιάζεται"^^xsd:string ;
    :relatedTo :Line_663 .

:Line_664 a owl:NamedIndividual, :Line ; :lineNumber 664 ; :canonicalReference "664"^^xsd:string .
:TV_Line_664_grc a :TranslationVariant ;
    :text "ἢ τοὐπιτάσσειν τοῖς κρατύνουσιν νοεῖ,"^^xsd:string ;
    :relatedTo :Line_664 .

:Line_665 a owl:NamedIndividual, :Line ; :lineNumber 665 ; :canonicalReference "665"^^xsd:string .
:TV_Line_665_grc a :TranslationVariant ;
    :text "οὐκ ἔστ ̓ ἐπαίνου τοῦτον ἐξ ἐμοῦ τυχεῖν."^^xsd:string ;
    :relatedTo :Line_665 .

:Line_666 a owl:NamedIndividual, :Line ; :lineNumber 666 ; :canonicalReference "666"^^xsd:string .
:TV_Line_666_grc a :TranslationVariant ;
    :text "Ἀλλ ̓ ὃν πόλις στήσειε, τοῦδε χρὴ κλύειν"^^xsd:string ;
    :relatedTo :Line_666 ;
    :advocatesFor :EthicalPrinciple_AbsoluteCivicObedience ;
    :hasTheme :Theme_AbsoluteAuthority .

:Line_667 a owl:NamedIndividual, :Line ; :lineNumber 667 ; :canonicalReference "667"^^xsd:string .
:TV_Line_667_grc a :TranslationVariant ;
    :text "καὶ σμικρὰ καὶ δίκαια καὶ τἀναντία."^^xsd:string ;
    :relatedTo :Line_667 .

:Line_668 a owl:NamedIndividual, :Line ; :lineNumber 668 ; :canonicalReference "668"^^xsd:string .
:TV_Line_668_grc a :TranslationVariant ;
    :text "Καὶ τοῦτον ἂν τὸν ἄνδρα θαρσοίην ἐγὼ"^^xsd:string ;
    :relatedTo :Line_668 .

:Line_669 a owl:NamedIndividual, :Line ; :lineNumber 669 ; :canonicalReference "669"^^xsd:string .
:TV_Line_669_grc a :TranslationVariant ;
    :text "καλῶς μὲν ἄρχειν, εὖ δ ̓ ἂν ἄρχεσθαι θέλειν,"^^xsd:string ;
    :relatedTo :Line_669 .

:Line_670 a owl:NamedIndividual, :Line ; :lineNumber 670 ; :canonicalReference "670"^^xsd:string .
:TV_Line_670_grc a :TranslationVariant ;
    :text "δορός τ ̓ ἂν ἐν χειμῶνι προστεταγμένον"^^xsd:string ;
    :relatedTo :Line_670 .

:Line_671 a owl:NamedIndividual, :Line ; :lineNumber 671 ; :canonicalReference "671"^^xsd:string .
:TV_Line_671_grc a :TranslationVariant ;
    :text "μένειν δίκαιον κἀγαθὸν παραστάτην."^^xsd:string ;
    :relatedTo :Line_671 .

:Line_672 a owl:NamedIndividual, :Line ; :lineNumber 672 ; :canonicalReference "672"^^xsd:string .
:TV_Line_672_grc a :TranslationVariant ;
    :text "Ἀναρχίας δὲ μεῖζον οὐκ ἔστιν κακόν·"^^xsd:string ;
    :relatedTo :Line_672 ;
    :relatedTo :Cause_Disobedience .

:Line_673 a owl:NamedIndividual, :Line ; :lineNumber 673 ; :canonicalReference "673"^^xsd:string .
:TV_Line_673_grc a :TranslationVariant ;
    :text "αὕτη πόλεις ὄλλυσιν, ἥδ ̓ ἀναστάτους"^^xsd:string ;
    :relatedTo :Line_673 ;
    :relatedTo :Effect_SocialCollapse .

:Line_674 a owl:NamedIndividual, :Line ; :lineNumber 674 ; :canonicalReference "674"^^xsd:string .
:TV_Line_674_grc a :TranslationVariant ;
    :text "οἴκους τίθησιν, ἥδε συμμάχου δορὸς"^^xsd:string ;
    :relatedTo :Line_674 .

:Line_675 a owl:NamedIndividual, :Line ; :lineNumber 675 ; :canonicalReference "675"^^xsd:string .
:TV_Line_675_grc a :TranslationVariant ;
    :text "τροπὰς καταρρήγνυσι· τῶν δ ̓ ὀρθουμένων"^^xsd:string ;
    :relatedTo :Line_675 .

:Line_676 a owl:NamedIndividual, :Line ; :lineNumber 676 ; :canonicalReference "676"^^xsd:string .
:TV_Line_676_grc a :TranslationVariant ;
    :text "σῴζει τὰ πολλὰ σώμαθ ̓ ἡ πειθαρχία."^^xsd:string ;
    :relatedTo :Line_676 ;
    :relatedTo :Cause_CivicObedience ;
    :relatedTo :Effect_PreservationOfLife ;
    :hasTheme :Theme_CivicOrderVsAnarchy .

:Line_677 a owl:NamedIndividual, :Line ; :lineNumber 677 ; :canonicalReference "677"^^xsd:string .
:TV_Line_677_grc a :TranslationVariant ;
    :text "Οὕτως ἀμυντέ ̓ ἐστὶ τοῖς κοσμουμένοις,"^^xsd:string ;
    :relatedTo :Line_677 .

:Line_678 a owl:NamedIndividual, :Line ; :lineNumber 678 ; :canonicalReference "678"^^xsd:string .
:TV_Line_678_grc a :TranslationVariant ;
    :text "κοὔτοι γυναικὸς οὐδαμῶς ἡσσητέα·"^^xsd:string ;
    :relatedTo :Line_678 ;
    :hasMotivation :Motivation_MaintainPatriarchalDominance .

:Line_679 a owl:NamedIndividual, :Line ; :lineNumber 679 ; :canonicalReference "679"^^xsd:string .
:TV_Line_679_grc a :TranslationVariant ;
    :text "κρεῖσσον γάρ, εἴπερ δεῖ, πρὸς ἀνδρὸς ἐκπεσεῖν,"^^xsd:string ;
    :relatedTo :Line_679 .

:Line_680 a owl:NamedIndividual, :Line ; :lineNumber 680 ; :canonicalReference "680"^^xsd:string .
:TV_Line_680_grc a :TranslationVariant ;
    :text "κοὐκ ἂν γυναικῶν ἥσσονες καλοίμεθ ̓ ἄν."^^xsd:string ;
    :relatedTo :Line_680 ;
    :hasTheme :Theme_Patriarchy ;
    :hasConflict :Conflict_MaleAuthorityVsFemaleDefiance .
