@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Chorus a :Character .
:Haemon a :Character .
:Antigone a :Character .
:Creon a :Character .

# --- Semantic Entities ---

:Motivation_MournBride a :Motivation ;
    :description "Haemon's supposed intention to mourn the fate of his bride Antigone and grieve his lost marriage."^^xsd:string .
:Haemon :hasMotivation :Motivation_MournBride .

:Motivation_AssessSonLoyalty a :Motivation ;
    :description "Creon's intention to determine if his son remains a faithful ally after hearing of his bride's condemnation."^^xsd:string .
:Creon :hasMotivation :Motivation_AssessSonLoyalty .

:EthicalPrinciple_FilialLoyalty a :EthicalPrinciple ;
    :description "The principle that a son should act as an unconditional ally to his father through all circumstances."^^xsd:string .
:Creon :advocatesFor :EthicalPrinciple_FilialLoyalty .

:Emotion_Grief a :Emotion ;
    :description "The sorrow and mourning over the fate of a bride and being cheated out of a marriage bed."^^xsd:string .
:Haemon :experiencesEmotion :Emotion_Grief .

:Emotion_Raving a :Emotion ;
    :description "The intense anger or irrational raving over the loss of a bride-to-be."^^xsd:string .
:Haemon :experiencesEmotion :Emotion_Raving .

:Conflict_EvilAppearingAsGood a :Conflict ;
    :description "The cognitive and moral contradiction where evil is perceived as good by a mind being led to ruin."^^xsd:string ;
    :conflictBetween :Theme_FalseHope, :Event_InevitableRuin .

:Conflict_LoyaltyVsLove a :Conflict ;
    :description "The tension between Haemon's romantic bond with Antigone and his filial duty to Creon."^^xsd:string ;
    :conflictBetween :Antigone, :Creon .

:Cause_DivineDeception a owl:Thing ;
    :description "The gods leading a mortal's mind to ruin."^^xsd:string .

:Effect_MoralBlindness a owl:Thing ;
    :description "Evil appearing as good to the deceived mortal."^^xsd:string .

:Effect_InevitableRuin a owl:Thing ;
    :description "The mortal falling into ruin shortly after losing moral clarity."^^xsd:string .
:Cause_DivineDeception :relatedTo :Effect_MoralBlindness .
:Effect_MoralBlindness :relatedTo :Effect_InevitableRuin .

:Cause_FalseHope a owl:Thing ;
    :description "Hope acting as a trick of thoughtless lust."^^xsd:string .

:Effect_UnexpectedPain a owl:Thing ;
    :description "A victim unknowingly crying out from a foot blazing with fire."^^xsd:string .
:Cause_FalseHope :relatedTo :Effect_UnexpectedPain .

:Event_FinalVote a owl:Thing ;
    :description "The casting of the final vote condemning Antigone."^^xsd:string .
:Event_FinalVote :relatedTo :Emotion_Grief .
:Event_FinalVote :relatedTo :Emotion_Raving .

:Theme_FalseHope a :Theme ;
    :description "Hope as a wandering illusion that acts as a trick of lust and leads unknowingly to pain."^^xsd:string .

:Theme_DivineMadness a :Theme ;
    :description "The gods distorting human perception to make evil seem good before bringing swift ruin."^^xsd:string .

:Theme_FilialDuty a :Theme ;
    :description "The expectation of unconditional allegiance from a son to his father."^^xsd:string .

# --- Line-by-Line Extraction ---

:Line_616 a owl:NamedIndividual, :Line ;
    :lineNumber 616 ;
    :canonicalReference "616"^^xsd:string ;
    :text "Behold that much-wandering hope,"^^xsd:string ;
    :hasTheme :Theme_FalseHope .

:Line_617 a owl:NamedIndividual, :Line ;
    :lineNumber 617 ;
    :canonicalReference "617"^^xsd:string ;
    :text "To many a benefit as much as"^^xsd:string .

:Line_618 a owl:NamedIndividual, :Line ;
    :lineNumber 618 ;
    :canonicalReference "618"^^xsd:string ;
    :text "To others a trick of thoughtless lust."^^xsd:string ;
    :relatedTo :Cause_FalseHope .

:Line_619 a owl:NamedIndividual, :Line ;
    :lineNumber 619 ;
    :canonicalReference "619"^^xsd:string ;
    :text "Its victim is unknowing, before crying out"^^xsd:string .

:Line_620 a owl:NamedIndividual, :Line ;
    :lineNumber 620 ;
    :canonicalReference "620"^^xsd:string ;
    :text "From a foot blazing with fire."^^xsd:string ;
    :relatedTo :Effect_UnexpectedPain .

:Line_621 a owl:NamedIndividual, :Line ;
    :lineNumber 621 ;
    :canonicalReference "621"^^xsd:string ;
    :text "With wisdom was the famous saying once revealed:"^^xsd:string ;
    :hasTheme :Theme_DivineMadness .

:Line_622 a owl:NamedIndividual, :Line ;
    :lineNumber 622 ;
    :canonicalReference "622"^^xsd:string ;
    :text "Evil can sometimes seem good to the one"^^xsd:string ;
    :relatedTo :Effect_MoralBlindness ;
    :hasConflict :Conflict_EvilAppearingAsGood .

:Line_623 a owl:NamedIndividual, :Line ;
    :lineNumber 623 ;
    :canonicalReference "623"^^xsd:string ;
    :text "Whose mind the gods are leading to ruin."^^xsd:string ;
    :relatedTo :Cause_DivineDeception .

:Line_624 a owl:NamedIndividual, :Line ;
    :lineNumber 624 ;
    :canonicalReference "624"^^xsd:string ;
    :text "Yet free from ruin he goes about"^^xsd:string .

:Line_625 a owl:NamedIndividual, :Line ;
    :lineNumber 625 ;
    :canonicalReference "625"^^xsd:string ;
    :text "For the shortest time."^^xsd:string ;
    :relatedTo :Effect_InevitableRuin .

:Line_626 a owl:NamedIndividual, :Line ;
    :lineNumber 626 ;
    :canonicalReference "626"^^xsd:string ;
    :text "Behold! It’s Haemon, the youngest"^^xsd:string .

:Line_627 a owl:NamedIndividual, :Line ;
    :lineNumber 627 ;
    :canonicalReference "627"^^xsd:string ;
    :text "Of your children: does he come to mourn"^^xsd:string .

:Line_628 a owl:NamedIndividual, :Line ;
    :lineNumber 628 ;
    :canonicalReference "628"^^xsd:string ;
    :text "The fate of his bride Antigone,"^^xsd:string ;
    :hasMotivation :Motivation_MournBride .

:Line_629 a owl:NamedIndividual, :Line ;
    :lineNumber 629 ;
    :canonicalReference "629"^^xsd:string ;
    :text "To grieve that he was"^^xsd:string .

:Line_630 a owl:NamedIndividual, :Line ;
    :lineNumber 630 ;
    :canonicalReference "630"^^xsd:string ;
    :text "Cheated out of his marriage bed?"^^xsd:string ;
    :experiencesEmotion :Emotion_Grief .

:Line_631 a owl:NamedIndividual, :Line ;
    :lineNumber 631 ;
    :canonicalReference "631"^^xsd:string ;
    :text "We’ll soon see more clearly than prophets."^^xsd:string .

:Line_632 a owl:NamedIndividual, :Line ;
    :lineNumber 632 ;
    :canonicalReference "632"^^xsd:string ;
    :text "O child, can it be that you come to your father, raving"^^xsd:string ;
    :experiencesEmotion :Emotion_Raving .

:Line_633 a owl:NamedIndividual, :Line ;
    :lineNumber 633 ;
    :canonicalReference "633"^^xsd:string ;
    :text "About your bride-to-be? Did you not hear that the last vote has been cast?"^^xsd:string ;
    :relatedTo :Event_FinalVote .

:Line_634 a owl:NamedIndividual, :Line ;
    :lineNumber 634 ;
    :canonicalReference "634"^^xsd:string ;
    :text "Or am I ever yours, your ally through thick and thin?"^^xsd:string ;
    :hasMotivation :Motivation_AssessSonLoyalty ;
    :advocatesFor :EthicalPrinciple_FilialLoyalty ;
    :hasTheme :Theme_FilialDuty ;
    :hasConflict :Conflict_LoyaltyVsLove .
