@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Chorus a :Character .
:Haemon a :Character .
:Creon a :Character .
:CommonMan a :Character .
:City a :Character .
:Antigone a :Character .

# --- Semantic Entities ---

:Motivation_InformAndProtectFather a :Motivation ;
    :description "Haemon's intention to look out for his father by secretly listening to and reporting the city's true opinions."^^xsd:string .
:Haemon :hasMotivation :Motivation_InformAndProtectFather .

:Motivation_PersuadeToYield a :Motivation ;
    :description "Haemon's objective to convince Creon to let his wrath subside and be open to the opinions of others."^^xsd:string .
:Haemon :hasMotivation :Motivation_PersuadeToYield .

:EthicalPrinciple_SupremacyOfReason a :EthicalPrinciple ;
    :description "The principle that reason is the supreme trait endowed to mankind by the gods."^^xsd:string .
:Haemon :advocatesFor :EthicalPrinciple_SupremacyOfReason .

:EthicalPrinciple_ValueOfFlexibility a :EthicalPrinciple ;
    :description "The moral stance that a wise man must be willing to learn, yield to good advice, and avoid absolute rigidity."^^xsd:string .
:Haemon :advocatesFor :EthicalPrinciple_ValueOfFlexibility .

:EthicalPrinciple_HonorForPiousDeeds a :EthicalPrinciple ;
    :description "The belief that burying a fallen brother to prevent desecration is a good deed deserving of honor, not death."^^xsd:string .
:City :advocatesFor :EthicalPrinciple_HonorForPiousDeeds .

:Emotion_FearOfTyrant a :Emotion ;
    :description "The fear experienced by the common man due to Creon's frightful eye, preventing open disagreement."^^xsd:string .
:CommonMan :experiencesEmotion :Emotion_FearOfTyrant .

:Emotion_PublicMourning a :Emotion ;
    :description "The sorrow and mourning of the city for Antigone's unjust condemnation."^^xsd:string .
:City :experiencesEmotion :Emotion_PublicMourning .

:Emotion_Wrath a :Emotion ;
    :description "Creon's intense anger and wrath, which Haemon begs him to relinquish."^^xsd:string .
:Creon :experiencesEmotion :Emotion_Wrath .

:Conflict_TyrantVsPublicOpinion a :Conflict ;
    :description "The contradiction between Creon's harsh decree and the city's secret belief that Antigone acted honorably."^^xsd:string ;
    :conflictBetween :Creon, :City .

:Conflict_RigidityVsFlexibility a :Conflict ;
    :description "The clash between holding a single uncompromising view and the willingness to learn and adapt."^^xsd:string ;
    :conflictBetween :Theme_Stubbornness, :Theme_Flexibility .

:Cause_FrightfulEye a owl:Thing ;
    :description "Creon's intimidating presence and frightful eye."^^xsd:string .

:Effect_SuppressedSpeech a owl:Thing ;
    :description "The common man withholding displeasing truths and speaking only in dim whispers."^^xsd:string .
:Cause_FrightfulEye :relatedTo :Effect_SuppressedSpeech .

:Cause_PiousBurial a owl:Thing ;
    :description "Antigone protecting her brother from flesh-eating dogs and birds."^^xsd:string .

:Effect_DeservingHonor a owl:Thing ;
    :description "The city's conclusion that Antigone deserves a share of gilded honor."^^xsd:string .
:Cause_PiousBurial :relatedTo :Effect_DeservingHonor .

:Cause_RigidStubbornness a owl:Thing ;
    :description "A tree refusing to yield to a swollen stream, or a captain tying his sail too tight."^^xsd:string .

:Effect_Destruction a owl:Thing ;
    :description "Being washed away roots and all, or snapping the mast in half."^^xsd:string .
:Cause_RigidStubbornness :relatedTo :Effect_Destruction .

:Cause_YieldingToForce a owl:Thing ;
    :description "A tree yielding its smaller branches to the fresh snowmelt."^^xsd:string .

:Effect_Survival a owl:Thing ;
    :description "The tree saving itself from destruction."^^xsd:string .
:Cause_YieldingToForce :relatedTo :Effect_Survival .

:Theme_DivineGiftOfReason a :Theme ;
    :description "The concept that the gods endow mankind with reason as their supreme trait."^^xsd:string .

:Theme_Flexibility a :Theme ;
    :description "The wisdom of adaptability, yielding, and continuous learning, contrasted with destructive rigidity."^^xsd:string .

:Theme_Stubbornness a :Theme ;
    :description "The arrogance of single-mindedness and believing one has no equal, which leads to ruin."^^xsd:string .

:Theme_PublicOpinionVsTyranny a :Theme ;
    :description "The hidden murmurings of the citizens who recognize justice but are silenced by a ruler's intimidation."^^xsd:string .

# --- Line-by-Line Extraction ---

:Line_681 a owl:NamedIndividual, :Line ;
    :lineNumber 681 ;
    :canonicalReference "681"^^xsd:string ;
    :text "Unless old age is playing tricks on us,"^^xsd:string .

:Line_682 a owl:NamedIndividual, :Line ;
    :lineNumber 682 ;
    :canonicalReference "682"^^xsd:string ;
    :text "You seem to be speaking wisely."^^xsd:string .

:Line_683 a owl:NamedIndividual, :Line ;
    :lineNumber 683 ;
    :canonicalReference "683"^^xsd:string ;
    :text "Father, the gods endow mankind with reason,"^^xsd:string ;
    :hasTheme :Theme_DivineGiftOfReason ;
    :advocatesFor :EthicalPrinciple_SupremacyOfReason .

:Line_684 a owl:NamedIndividual, :Line ;
    :lineNumber 684 ;
    :canonicalReference "684"^^xsd:string ;
    :text "Supreme among all the traits man can hope to possess."^^xsd:string .

:Line_685 a owl:NamedIndividual, :Line ;
    :lineNumber 685 ;
    :canonicalReference "685"^^xsd:string ;
    :text "I couldn’t say, nor would I want to say, that"^^xsd:string .

:Line_686 a owl:NamedIndividual, :Line ;
    :lineNumber 686 ;
    :canonicalReference "686"^^xsd:string ;
    :text "You are handling this situation incorrectly..."^^xsd:string .

:Line_687 a owl:NamedIndividual, :Line ;
    :lineNumber 687 ;
    :canonicalReference "687"^^xsd:string ;
    :text "But there may be something profitable in a difference"^^xsd:string .

:Line_688 a owl:NamedIndividual, :Line ;
    :lineNumber 688 ;
    :canonicalReference "688"^^xsd:string ;
    :text "Of opinions. Now, as your son, I am obliged to look out for you"^^xsd:string ;
    :hasMotivation :Motivation_InformAndProtectFather .

:Line_689 a owl:NamedIndividual, :Line ;
    :lineNumber 689 ;
    :canonicalReference "689"^^xsd:string ;
    :text "Every time a person speaks or acts or points his finger at you."^^xsd:string .

:Line_690 a owl:NamedIndividual, :Line ;
    :lineNumber 690 ;
    :canonicalReference "690"^^xsd:string ;
    :text "For your eye is frightful to the common man when he must"^^xsd:string ;
    :relatedTo :Cause_FrightfulEye ;
    :experiencesEmotion :Emotion_FearOfTyrant .

:Line_691 a owl:NamedIndividual, :Line ;
    :lineNumber 691 ;
    :canonicalReference "691"^^xsd:string ;
    :text "Tell you things which he knows you won’t be pleased to hear."^^xsd:string ;
    :relatedTo :Effect_SuppressedSpeech .

:Line_692 a owl:NamedIndividual, :Line ;
    :lineNumber 692 ;
    :canonicalReference "692"^^xsd:string ;
    :text "But I listen under cover of darkness, and I hear"^^xsd:string .

:Line_693 a owl:NamedIndividual, :Line ;
    :lineNumber 693 ;
    :canonicalReference "693"^^xsd:string ;
    :text "How the city mourns for this young girl,"^^xsd:string ;
    :experiencesEmotion :Emotion_PublicMourning .

:Line_694 a owl:NamedIndividual, :Line ;
    :lineNumber 694 ;
    :canonicalReference "694"^^xsd:string ;
    :text "Saying that of all women she deserves least of all"^^xsd:string .

:Line_695 a owl:NamedIndividual, :Line ;
    :lineNumber 695 ;
    :canonicalReference "695"^^xsd:string ;
    :text "To die so disgracefully for her good deeds,"^^xsd:string .

:Line_696 a owl:NamedIndividual, :Line ;
    :lineNumber 696 ;
    :canonicalReference "696"^^xsd:string ;
    :text "All because she wouldn’t allow her own brother,"^^xsd:string ;
    :relatedTo :Cause_PiousBurial .

:Line_697 a owl:NamedIndividual, :Line ;
    :lineNumber 697 ;
    :canonicalReference "697"^^xsd:string ;
    :text "Lying unburied in the gore where he fell, to be torn"^^xsd:string .

:Line_698 a owl:NamedIndividual, :Line ;
    :lineNumber 698 ;
    :canonicalReference "698"^^xsd:string ;
    :text "To pieces by flesh-eating dogs and birds of prey."^^xsd:string .

:Line_699 a owl:NamedIndividual, :Line ;
    :lineNumber 699 ;
    :canonicalReference "699"^^xsd:string ;
    :text "Doesn’t she deserve to get a share of the gilded honor?"^^xsd:string ;
    :relatedTo :Effect_DeservingHonor ;
    :advocatesFor :EthicalPrinciple_HonorForPiousDeeds .

:Line_700 a owl:NamedIndividual, :Line ;
    :lineNumber 700 ;
    :canonicalReference "700"^^xsd:string ;
    :text "Dim whispers to this point circulate in the otherwise silent city."^^xsd:string ;
    :hasTheme :Theme_PublicOpinionVsTyranny ;
    :hasConflict :Conflict_TyrantVsPublicOpinion .

:Line_701 a owl:NamedIndividual, :Line ;
    :lineNumber 701 ;
    :canonicalReference "701"^^xsd:string ;
    :text "I can think of no treasure more precious,"^^xsd:string .

:Line_702 a owl:NamedIndividual, :Line ;
    :lineNumber 702 ;
    :canonicalReference "702"^^xsd:string ;
    :text "Father, than your success."^^xsd:string .

:Line_703 a owl:NamedIndividual, :Line ;
    :lineNumber 703 ;
    :canonicalReference "703"^^xsd:string ;
    :text "What greater honor can there be for a child than the fame"^^xsd:string .

:Line_704 a owl:NamedIndividual, :Line ;
    :lineNumber 704 ;
    :canonicalReference "704"^^xsd:string ;
    :text "Of a prospering father, or for a father than the fame of his child?"^^xsd:string .

:Line_705 a owl:NamedIndividual, :Line ;
    :lineNumber 705 ;
    :canonicalReference "705"^^xsd:string ;
    :text "Now don’t reserve just one way of thinking for yourself,"^^xsd:string ;
    :hasTheme :Theme_Stubbornness .

:Line_706 a owl:NamedIndividual, :Line ;
    :lineNumber 706 ;
    :canonicalReference "706"^^xsd:string ;
    :text "Saying that this is correct, and nothing else."^^xsd:string .

:Line_707 a owl:NamedIndividual, :Line ;
    :lineNumber 707 ;
    :canonicalReference "707"^^xsd:string ;
    :text "For the one who imagines he thinks without equal,"^^xsd:string .

:Line_708 a owl:NamedIndividual, :Line ;
    :lineNumber 708 ;
    :canonicalReference "708"^^xsd:string ;
    :text "Or has a tongue or a soul like no other,"^^xsd:string .

:Line_709 a owl:NamedIndividual, :Line ;
    :lineNumber 709 ;
    :canonicalReference "709"^^xsd:string ;
    :text "Shows only how empty his head really is."^^xsd:string .

:Line_710 a owl:NamedIndividual, :Line ;
    :lineNumber 710 ;
    :canonicalReference "710"^^xsd:string ;
    :text "But even if a man is wise, there’s no shame in him"^^xsd:string ;
    :advocatesFor :EthicalPrinciple_ValueOfFlexibility .

:Line_711 a owl:NamedIndividual, :Line ;
    :lineNumber 711 ;
    :canonicalReference "711"^^xsd:string ;
    :text "Straying from the path and picking things up as he goes."^^xsd:string .

:Line_712 a owl:NamedIndividual, :Line ;
    :lineNumber 712 ;
    :canonicalReference "712"^^xsd:string ;
    :text "Look how one tree on the riverbank yields its smaller branches"^^xsd:string ;
    :relatedTo :Cause_YieldingToForce .

:Line_713 a owl:NamedIndividual, :Line ;
    :lineNumber 713 ;
    :canonicalReference "713"^^xsd:string ;
    :text "To the stream that’s gorged with fresh snowmelt, and saves itself,"^^xsd:string ;
    :relatedTo :Effect_Survival .

:Line_714 a owl:NamedIndividual, :Line ;
    :lineNumber 714 ;
    :canonicalReference "714"^^xsd:string ;
    :text "While another that’s just too rigid is washed away,"^^xsd:string ;
    :relatedTo :Cause_RigidStubbornness .

:Line_715 a owl:NamedIndividual, :Line ;
    :lineNumber 715 ;
    :canonicalReference "715"^^xsd:string ;
    :text "Roots and all. Likewise the captain who’s tied his ship’s sail"^^xsd:string .

:Line_716 a owl:NamedIndividual, :Line ;
    :lineNumber 716 ;
    :canonicalReference "716"^^xsd:string ;
    :text "So tight that it cannot yield to the wind will have to sail"^^xsd:string .

:Line_717 a owl:NamedIndividual, :Line ;
    :lineNumber 717 ;
    :canonicalReference "717"^^xsd:string ;
    :text "The rest of the way with oars once he’s snapped his mast in half."^^xsd:string ;
    :relatedTo :Effect_Destruction .

:Line_718 a owl:NamedIndividual, :Line ;
    :lineNumber 718 ;
    :canonicalReference "718"^^xsd:string ;
    :text "So yield and let your wrath subside."^^xsd:string ;
    :hasMotivation :Motivation_PersuadeToYield .

:Line_719 a owl:NamedIndividual, :Line ;
    :lineNumber 719 ;
    :canonicalReference "719"^^xsd:string ;
    :text "If I’m allowed to have an opinion (though I’m just a young man),"^^xsd:string .

:Line_720 a owl:NamedIndividual, :Line ;
    :lineNumber 720 ;
    :canonicalReference "720"^^xsd:string ;
    :text "I think it would be best by far if every man"^^xsd:string .

:Line_721 a owl:NamedIndividual, :Line ;
    :lineNumber 721 ;
    :canonicalReference "721"^^xsd:string ;
    :text "Were born full of wisdom and knowledge."^^xsd:string .

:Line_722 a owl:NamedIndividual, :Line ;
    :lineNumber 722 ;
    :canonicalReference "722"^^xsd:string ;
    :text "But if this is impossible, and it normally doesn’t happen this way,"^^xsd:string .

:Line_723 a owl:NamedIndividual, :Line ;
    :lineNumber 723 ;
    :canonicalReference "723"^^xsd:string ;
    :text "It is still good to learn from a thought well spoken."^^xsd:string ;
    :hasTheme :Theme_Flexibility ;
    :hasConflict :Conflict_RigidityVsFlexibility .
