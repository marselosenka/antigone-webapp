@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Haemon a :Character .
:Creon a :Character .
:Chorus a :Character .
:Ismene a :Character .

# --- Semantic Entities ---

:Motivation_AbandonFather a :Motivation ;
    :description "Haemon's intention to permanently sever ties with his father so Creon will never look upon his face again."^^xsd:string .
:Haemon :hasMotivation :Motivation_AbandonFather .

:MoralDecision_LeaveCreon a :MoralDecision ;
    :description "Haemon's decisive action to storm out and refuse to witness Antigone's death beside him."^^xsd:string .
:Haemon :makesMoralDecision :MoralDecision_LeaveCreon .

:MoralDecision_SpareIsmene a :MoralDecision ;
    :description "Creon's decision to spare the sister who kept her hands clean from the crime."^^xsd:string .
:Creon :makesMoralDecision :MoralDecision_SpareIsmene .

:Motivation_EnsureExecution a :Motivation ;
    :description "Creon's unwavering intention to ensure Antigone cannot be freed from her fate despite Haemon's threats."^^xsd:string .
:Creon :hasMotivation :Motivation_EnsureExecution .

:EthicalPrinciple_SpareTheInnocent a :EthicalPrinciple ;
    :description "The principle that one who kept her hands clean of a crime should not be punished alongside the guilty."^^xsd:string .
:Creon :advocatesFor :EthicalPrinciple_SpareTheInnocent .

:Emotion_Anger a :Emotion ;
    :description "Haemon's intense anger that drives him to storm out of the presence of his father."^^xsd:string .
:Haemon :experiencesEmotion :Emotion_Anger .

:Emotion_Resentment a :Emotion ;
    :description "The resentment that grows in a youthful mind when it is confronted with deep emotional pain."^^xsd:string .
:Haemon :experiencesEmotion :Emotion_Resentment .

:Emotion_Pain a :Emotion ;
    :description "The profound emotional agony felt by Haemon over the impending death of his bride and the rupture with his father."^^xsd:string .
:Haemon :experiencesEmotion :Emotion_Pain .

:Emotion_Ranting a :Emotion ;
    :description "Creon's irrational ranting and raving, as perceived and condemned by Haemon."^^xsd:string .
:Creon :experiencesEmotion :Emotion_Ranting .

:Conflict_FatherVsSon a :Conflict ;
    :description "The final rupture and contradiction between Haemon's loyalty to his bride and Creon's tyrannical demands."^^xsd:string ;
    :conflictBetween :Haemon, :Creon .

:Event_YouthfulPain a owl:Thing ;
    :description "A young mind experiencing severe emotional pain."^^xsd:string .

:Event_Resentment a owl:Thing ;
    :description "The mind growing resentful and turning to anger."^^xsd:string .
:Event_YouthfulPain :relatedTo :Event_Resentment .

:Event_StormingOut a owl:Thing ;
    :description "Haemon storming out in anger."^^xsd:string .
:Emotion_Anger :relatedTo :Event_StormingOut .

:Cause_KeptHandsClean a owl:Thing ;
    :description "Ismene keeping her hands clean of the burial act."^^xsd:string .

:Effect_SparedFromDeath a owl:Thing ;
    :description "Ismene being spared from the execution originally meant for both sisters."^^xsd:string .
:Cause_KeptHandsClean :relatedTo :Effect_SparedFromDeath .

:Theme_YouthfulRashness a :Theme ;
    :description "The passionate, resentful, and impulsive nature of youth when confronted with trauma and pain."^^xsd:string .

:Theme_TyrantIsolation a :Theme ;
    :description "The isolation of the tyrant, left to rant and rave only to compliant friends after driving away his own son."^^xsd:string .

:Theme_GuiltAndInnocence a :Theme ;
    :description "The demarcation between guilt and innocence, represented by the physical metaphor of keeping one's hands clean."^^xsd:string .

# --- Line-by-Line Extraction ---

:Line_762 a owl:NamedIndividual, :Line ;
    :lineNumber 762 ;
    :canonicalReference "762"^^xsd:string ;
    :text "No, don’t hold your breath on that—"^^xsd:string .

:Line_763 a owl:NamedIndividual, :Line ;
    :lineNumber 763 ;
    :canonicalReference "763"^^xsd:string ;
    :text "She will not die beside me, and you will never"^^xsd:string ;
    :makesMoralDecision :MoralDecision_LeaveCreon .

:Line_764 a owl:NamedIndividual, :Line ;
    :lineNumber 764 ;
    :canonicalReference "764"^^xsd:string ;
    :text "Look upon this face again with your two eyes,"^^xsd:string ;
    :hasMotivation :Motivation_AbandonFather ;
    :hasConflict :Conflict_FatherVsSon .

:Line_765 a owl:NamedIndividual, :Line ;
    :lineNumber 765 ;
    :canonicalReference "765"^^xsd:string ;
    :text "As you rant and rave to whatever friends will let you."^^xsd:string ;
    :experiencesEmotion :Emotion_Ranting ;
    :hasTheme :Theme_TyrantIsolation .

:Line_766 a owl:NamedIndividual, :Line ;
    :lineNumber 766 ;
    :canonicalReference "766"^^xsd:string ;
    :text "The boy, your majesty, stormed out in anger."^^xsd:string ;
    :experiencesEmotion :Emotion_Anger ;
    :relatedTo :Event_StormingOut .

:Line_767 a owl:NamedIndividual, :Line ;
    :lineNumber 767 ;
    :canonicalReference "767"^^xsd:string ;
    :text "At his age the mind grows resentful when it feels pain."^^xsd:string ;
    :experiencesEmotion :Emotion_Resentment ;
    :experiencesEmotion :Emotion_Pain ;
    :relatedTo :Event_YouthfulPain ;
    :relatedTo :Event_Resentment ;
    :hasTheme :Theme_YouthfulRashness .

:Line_768 a owl:NamedIndividual, :Line ;
    :lineNumber 768 ;
    :canonicalReference "768"^^xsd:string ;
    :text "Let him go, let him concoct some superhuman plan:"^^xsd:string .

:Line_769 a owl:NamedIndividual, :Line ;
    :lineNumber 769 ;
    :canonicalReference "769"^^xsd:string ;
    :text "He will not free these two girls from their fate."^^xsd:string ;
    :hasMotivation :Motivation_EnsureExecution .

:Line_770 a owl:NamedIndividual, :Line ;
    :lineNumber 770 ;
    :canonicalReference "770"^^xsd:string ;
    :text "Do you intend to kill them both?"^^xsd:string .

:Line_771 a owl:NamedIndividual, :Line ;
    :lineNumber 771 ;
    :canonicalReference "771"^^xsd:string ;
    :text "You have a point. Not the one who kept her hands clean."^^xsd:string ;
    :makesMoralDecision :MoralDecision_SpareIsmene ;
    :advocatesFor :EthicalPrinciple_SpareTheInnocent ;
    :relatedTo :Cause_KeptHandsClean ;
    :relatedTo :Effect_SparedFromDeath ;
    :hasTheme :Theme_GuiltAndInnocence .

:Line_772 a owl:NamedIndividual, :Line ;
    :lineNumber 772 ;
    :canonicalReference "772"^^xsd:string ;
    :text "And how do you plan to kill the other?"^^xsd:string .
