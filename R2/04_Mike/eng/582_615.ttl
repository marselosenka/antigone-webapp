@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Chorus a :Character .
:Zeus a :Character .
:Mankind a :Character .

# --- Semantic Entities ---

:Motivation_MaintainAbsolutePower a :Motivation ;
    :description "Zeus's intention to sustain his unwearying and eternal power over mankind."^^xsd:string .
:Zeus :hasMotivation :Motivation_MaintainAbsolutePower .

:EthicalPrinciple_GreatnessBringsRuin a :EthicalPrinciple ;
    :description "The enduring moral law that nothing grand comes to a mortal's life without ruin."^^xsd:string .
:Chorus :advocatesFor :EthicalPrinciple_GreatnessBringsRuin .

:Emotion_AweAndReverence a :Emotion ;
    :description "The awe and fear experienced when recognizing the inescapable and absolute power of Zeus."^^xsd:string .
:Chorus :experiencesEmotion :Emotion_AweAndReverence .

:Emotion_Despair a :Emotion ;
    :description "Despair over the unending, ancient miseries falling upon the House of Labdacus."^^xsd:string .
:Chorus :experiencesEmotion :Emotion_Despair .

:Conflict_DivineOmnipotenceVsHumanAspiration a :Conflict ;
    :description "The conflict between the eternal power of the gods and the tragic limits of mortal lives."^^xsd:string ;
    :conflictBetween :Zeus, :Mankind .

:Event_DivineIntervention a owl:Thing ;
    :description "A god throwing down a generation with no release and shaking their abode."^^xsd:string .

:Event_GenerationalRuin a owl:Thing ;
    :description "The ancient miseries of the house of Labdacus compounding upon the miseries of the dead."^^xsd:string .
:Event_DivineIntervention :relatedTo :Event_GenerationalRuin .

:Event_TransgressionOfPower a owl:Thing ;
    :description "A mortal committing a transgression against the eternal power of Zeus."^^xsd:string .

:Event_InevitableRuin a owl:Thing ;
    :description "The ruin that inextricably follows human greatness or transgression."^^xsd:string .
:Event_TransgressionOfPower :relatedTo :Event_InevitableRuin .

:Cause_FollyAndFrenzy a owl:Thing ;
    :description "The bloody dust, folly, and frenzy of thought."^^xsd:string .

:Effect_DestructionOfOedipusHouse a owl:Thing ;
    :description "Cutting down the final ray of light shining over the roots of the house of Oedipus."^^xsd:string .
:Cause_FollyAndFrenzy :relatedTo :Effect_DestructionOfOedipusHouse .

:Theme_GenerationalCurse a :Theme ;
    :description "The inescapable curse passing from the dead to the living in the House of Labdacus."^^xsd:string .

:Theme_DivineOmnipotence a :Theme ;
    :description "The unyielding, eternal power of the gods, untouched by sleep or time."^^xsd:string .

:Theme_HumanFrailty a :Theme ;
    :description "The tragic fragility of the human condition, where greatness inevitably invites destruction."^^xsd:string .

# --- Line-by-Line Extraction ---

:Line_582 a owl:NamedIndividual, :Line ;
    :lineNumber 582 ;
    :canonicalReference "582"^^xsd:string ;
    :text "Blessed is the life of he"^^xsd:string ;
    :hasTheme :Theme_HumanFrailty .

:Line_583 a owl:NamedIndividual, :Line ;
    :lineNumber 583 ;
    :canonicalReference "583"^^xsd:string ;
    :text "Who has never tasted evil."^^xsd:string .

:Line_584 a owl:NamedIndividual, :Line ;
    :lineNumber 584 ;
    :canonicalReference "584"^^xsd:string ;
    :text "For those whose abode is shaken by the gods,"^^xsd:string ;
    :relatedTo :Event_DivineIntervention .

:Line_585 a owl:NamedIndividual, :Line ;
    :lineNumber 585 ;
    :canonicalReference "585"^^xsd:string ;
    :text "No ruin is absent as it proceeds"^^xsd:string .

:Line_586 a owl:NamedIndividual, :Line ;
    :lineNumber 586 ;
    :canonicalReference "586"^^xsd:string ;
    :text "Through the multitude of peoples,"^^xsd:string .

:Line_587 a owl:NamedIndividual, :Line ;
    :lineNumber 587 ;
    :canonicalReference "587"^^xsd:string ;
    :text "Just as, when a swelling urged by"^^xsd:string .

:Line_588 a owl:NamedIndividual, :Line ;
    :lineNumber 588 ;
    :canonicalReference "588"^^xsd:string ;
    :text "Stormy Thracian sea-winds"^^xsd:string .

:Line_589 a owl:NamedIndividual, :Line ;
    :lineNumber 589 ;
    :canonicalReference "589"^^xsd:string ;
    :text "Surges over the gloomy deep,"^^xsd:string .

:Line_590 a owl:NamedIndividual, :Line ;
    :lineNumber 590 ;
    :canonicalReference "590"^^xsd:string ;
    :text "It churns up the dark sand"^^xsd:string .

:Line_591 a owl:NamedIndividual, :Line ;
    :lineNumber 591 ;
    :canonicalReference "591"^^xsd:string ;
    :text "From the seafloor,"^^xsd:string .

:Line_592 a owl:NamedIndividual, :Line ;
    :lineNumber 592 ;
    :canonicalReference "592"^^xsd:string ;
    :text "And the wave-beaten coast"^^xsd:string .

:Line_593 a owl:NamedIndividual, :Line ;
    :lineNumber 593 ;
    :canonicalReference "593"^^xsd:string ;
    :text "Roars and groans."^^xsd:string .

:Line_594 a owl:NamedIndividual, :Line ;
    :lineNumber 594 ;
    :canonicalReference "594"^^xsd:string ;
    :text "The ancient miseries of the"^^xsd:string ;
    :hasTheme :Theme_GenerationalCurse ;
    :experiencesEmotion :Emotion_Despair .

:Line_595 a owl:NamedIndividual, :Line ;
    :lineNumber 595 ;
    :canonicalReference "595"^^xsd:string ;
    :text "House of Labdacus, I see, fall"^^xsd:string ;
    :relatedTo :Event_GenerationalRuin .

:Line_596 a owl:NamedIndividual, :Line ;
    :lineNumber 596 ;
    :canonicalReference "596"^^xsd:string ;
    :text "On top of the miseries of the dead."^^xsd:string .

:Line_597 a owl:NamedIndividual, :Line ;
    :lineNumber 597 ;
    :canonicalReference "597"^^xsd:string ;
    :text "One generation cannot set a people"^^xsd:string .

:Line_598 a owl:NamedIndividual, :Line ;
    :lineNumber 598 ;
    :canonicalReference "598"^^xsd:string ;
    :text "Free, since some god will throw them down"^^xsd:string .

:Line_599 a owl:NamedIndividual, :Line ;
    :lineNumber 599 ;
    :canonicalReference "599"^^xsd:string ;
    :text "With no release. For the bloody dust"^^xsd:string .

:Line_600 a owl:NamedIndividual, :Line ;
    :lineNumber 600 ;
    :canonicalReference "600"^^xsd:string ;
    :text "Of the gods of hell, and folly, and frenzy of thought"^^xsd:string ;
    :relatedTo :Cause_FollyAndFrenzy .

:Line_601 a owl:NamedIndividual, :Line ;
    :lineNumber 601 ;
    :canonicalReference "601"^^xsd:string ;
    :text "Now cut down that ray of light"^^xsd:string ;
    :relatedTo :Effect_DestructionOfOedipusHouse .

:Line_602 a owl:NamedIndividual, :Line ;
    :lineNumber 602 ;
    :canonicalReference "602"^^xsd:string ;
    :text "Which had shone itself over the furthest roots"^^xsd:string .

:Line_603 a owl:NamedIndividual, :Line ;
    :lineNumber 603 ;
    :canonicalReference "603"^^xsd:string ;
    :text "Of the house of Oedipus."^^xsd:string .

:Line_604 a owl:NamedIndividual, :Line ;
    :lineNumber 604 ;
    :canonicalReference "604"^^xsd:string ;
    :text "Who of mankind can sustain,"^^xsd:string ;
    :hasConflict :Conflict_DivineOmnipotenceVsHumanAspiration .

:Line_605 a owl:NamedIndividual, :Line ;
    :lineNumber 605 ;
    :canonicalReference "605"^^xsd:string ;
    :text "O Zeus, a transgression of your power?"^^xsd:string ;
    :relatedTo :Event_TransgressionOfPower .

:Line_606 a owl:NamedIndividual, :Line ;
    :lineNumber 606 ;
    :canonicalReference "606"^^xsd:string ;
    :text "No one can take it away - neither sleep,"^^xsd:string ;
    :hasTheme :Theme_DivineOmnipotence .

:Line_607 a owl:NamedIndividual, :Line ;
    :lineNumber 607 ;
    :canonicalReference "607"^^xsd:string ;
    :text "Which ensnares everything, nor even"^^xsd:string .

:Line_608 a owl:NamedIndividual, :Line ;
    :lineNumber 608 ;
    :canonicalReference "608"^^xsd:string ;
    :text "Unwearying months of divine labor."^^xsd:string .

:Line_609 a owl:NamedIndividual, :Line ;
    :lineNumber 609 ;
    :canonicalReference "609"^^xsd:string ;
    :text "As lord for never-ending time"^^xsd:string ;
    :experiencesEmotion :Emotion_AweAndReverence .

:Line_610 a owl:NamedIndividual, :Line ;
    :lineNumber 610 ;
    :canonicalReference "610"^^xsd:string ;
    :text "You hold fast Olympus’s sparkled, marbled glory."^^xsd:string .

:Line_611 a owl:NamedIndividual, :Line ;
    :lineNumber 611 ;
    :canonicalReference "611"^^xsd:string ;
    :text "Both then and now"^^xsd:string .

:Line_612 a owl:NamedIndividual, :Line ;
    :lineNumber 612 ;
    :canonicalReference "612"^^xsd:string ;
    :text "Does this law hold strong:"^^xsd:string .

:Line_613 a owl:NamedIndividual, :Line ;
    :lineNumber 613 ;
    :canonicalReference "613"^^xsd:string ;
    :text "Nothing grand comes"^^xsd:string .

:Line_614 a owl:NamedIndividual, :Line ;
    :lineNumber 614 ;
    :canonicalReference "614"^^xsd:string ;
    :text "To a mortal’s life"^^xsd:string .

:Line_615 a owl:NamedIndividual, :Line ;
    :lineNumber 615 ;
    :canonicalReference "615"^^xsd:string ;
    :text "Without ruin."^^xsd:string ;
    :advocatesFor :EthicalPrinciple_GreatnessBringsRuin ;
    :relatedTo :Event_InevitableRuin .