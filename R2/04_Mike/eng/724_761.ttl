@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Chorus a :Character .
:Creon a :Character .
:Haemon a :Character .
:Antigone a :Character .

# --- Semantic Entities ---

:Motivation_HelpFather a :Motivation ;
    :description "Haemon's intention to help his father avoid making a mistake and angering the gods."^^xsd:string .
:Haemon :hasMotivation :Motivation_HelpFather .

:Motivation_DefendAuthority a :Motivation ;
    :description "Creon's intention to fiercely protect his absolute authority and refuse any teaching or correction from a younger man."^^xsd:string .
:Creon :hasMotivation :Motivation_DefendAuthority .

:MoralDecision_ExecuteAntigoneBeforeHaemon a :MoralDecision ;
    :description "Creon's vindictive decision to bring Antigone out to die immediately in front of her bridegroom as punishment for Haemon's insults."^^xsd:string .
:Creon :makesMoralDecision :MoralDecision_ExecuteAntigoneBeforeHaemon .

:EthicalPrinciple_MutualLearning a :EthicalPrinciple ;
    :description "The principle that individuals should learn from one another if they speak suitably, regardless of age."^^xsd:string .
:Chorus :advocatesFor :EthicalPrinciple_MutualLearning .

:EthicalPrinciple_JudgeByActions a :EthicalPrinciple ;
    :description "The principle that a person's wisdom and value should be judged by their actions, not merely by their age."^^xsd:string .
:Haemon :advocatesFor :EthicalPrinciple_JudgeByActions .

:EthicalPrinciple_CollectiveRule a :EthicalPrinciple ;
    :description "The political principle that a city does not belong to only one man, but to its people."^^xsd:string .
:Haemon :advocatesFor :EthicalPrinciple_CollectiveRule .

:EthicalPrinciple_DivineReverence a :EthicalPrinciple ;
    :description "The moral imperative that human authority must not walk all over the domains and laws of the gods."^^xsd:string .
:Haemon :advocatesFor :EthicalPrinciple_DivineReverence .

:EthicalPrinciple_TyrannicalOwnership a :EthicalPrinciple ;
    :description "The belief that the city is ruled, dictated, and effectively owned by the man in charge."^^xsd:string .
:Creon :advocatesFor :EthicalPrinciple_TyrannicalOwnership .

:Emotion_InsultedPride a :Emotion ;
    :description "Creon's indignation and wounded pride at the prospect of being taught by a younger man or having his authority questioned."^^xsd:string .
:Creon :experiencesEmotion :Emotion_InsultedPride .

:Emotion_Outrage a :Emotion ;
    :description "Creon's explosive anger at Haemon's perceived insults, culminating in his command for an immediate execution."^^xsd:string .
:Creon :experiencesEmotion :Emotion_Outrage .

:Emotion_Frustration a :Emotion ;
    :description "Haemon's exasperation at his father's refusal to listen and his foolish plans."^^xsd:string .
:Haemon :experiencesEmotion :Emotion_Frustration .

:Conflict_AgeVsWisdom a :Conflict ;
    :description "The contradiction between Creon's reliance on age as proof of wisdom and Haemon's insistence on being judged by actions."^^xsd:string ;
    :conflictBetween :Creon, :Haemon .

:Conflict_AutocracyVsCollectiveCity a :Conflict ;
    :description "The clash between Creon's dictatorial view that the ruler owns the city and Haemon's view that a city belongs to all."^^xsd:string ;
    :conflictBetween :Creon, :Haemon .

:Conflict_HumanAuthorityVsDivineLaw a :Conflict ;
    :description "The conflict between Creon worshiping his own human authority and respecting the fundamental laws of the gods."^^xsd:string ;
    :conflictBetween :Creon, :Theme_DivineLaw .

:Event_AntigonesDeath a owl:Thing ;
    :description "The impending death of Antigone."^^xsd:string .

:Event_AnotherDeath a owl:Thing ;
    :description "The consequent death of another person, representing Haemon's veiled suicide threat."^^xsd:string .
:Event_AntigonesDeath :relatedTo :Event_AnotherDeath .

:Cause_AbsoluteTyranny a owl:Thing ;
    :description "Ruling a city as if it belongs to only one man and ignoring the citizens."^^xsd:string .

:Effect_Wasteland a owl:Thing ;
    :description "The city effectively becoming an empty wasteland without its people's voice."^^xsd:string .
:Cause_AbsoluteTyranny :relatedTo :Effect_Wasteland .

:Cause_ListeningToWomen a owl:Thing ;
    :description "Taking sides with or being influenced by a woman, which Creon perceives as a weakness."^^xsd:string .

:Effect_CloudedJudgement a owl:Thing ;
    :description "The assumption that one's judgement has been clouded by emotions or slavery to a woman."^^xsd:string .
:Cause_ListeningToWomen :relatedTo :Effect_CloudedJudgement .

:Theme_Tyranny a :Theme ;
    :description "The destructive nature of absolute dictatorial rule and the dangerous belief that a city is the ruler's property."^^xsd:string .

:Theme_AgeVsYouth a :Theme ;
    :description "The generational tension between the traditional, rigid authority of elders and the adaptive wisdom of youth."^^xsd:string .

:Theme_Misogyny a :Theme ;
    :description "The deep-seated prejudice against women, used by Creon to invalidate Haemon's logical arguments."^^xsd:string .

:Theme_DivineLaw a :Theme ;
    :description "The absolute supremacy of the gods' laws over human arrogance and self-worship."^^xsd:string .

# --- Line-by-Line Extraction ---

:Line_724 a owl:NamedIndividual, :Line ;
    :lineNumber 724 ;
    :canonicalReference "724"^^xsd:string ;
    :text "Your majesty, if he speaks suitably, it is right that you learn from him,"^^xsd:string ;
    :advocatesFor :EthicalPrinciple_MutualLearning .

:Line_725 a owl:NamedIndividual, :Line ;
    :lineNumber 725 ;
    :canonicalReference "725"^^xsd:string ;
    :text "And you from him, Haemon: for both sides have spoken well."^^xsd:string .

:Line_726 a owl:NamedIndividual, :Line ;
    :lineNumber 726 ;
    :canonicalReference "726"^^xsd:string ;
    :text "Are we so rattled with age that"^^xsd:string ;
    :experiencesEmotion :Emotion_InsultedPride ;
    :hasTheme :Theme_AgeVsYouth .

:Line_727 a owl:NamedIndividual, :Line ;
    :lineNumber 727 ;
    :canonicalReference "727"^^xsd:string ;
    :text "Young men must do the teaching now?"^^xsd:string ;
    :hasMotivation :Motivation_DefendAuthority .

:Line_728 a owl:NamedIndividual, :Line ;
    :lineNumber 728 ;
    :canonicalReference "728"^^xsd:string ;
    :text "That’s not right at all: even if I am young,"^^xsd:string .

:Line_729 a owl:NamedIndividual, :Line ;
    :lineNumber 729 ;
    :canonicalReference "729"^^xsd:string ;
    :text "It’s best to judge by my actions, not just by my age."^^xsd:string ;
    :advocatesFor :EthicalPrinciple_JudgeByActions ;
    :hasConflict :Conflict_AgeVsWisdom .

:Line_730 a owl:NamedIndividual, :Line ;
    :lineNumber 730 ;
    :canonicalReference "730"^^xsd:string ;
    :text "And is there any use in honoring rebels?"^^xsd:string .

:Line_731 a owl:NamedIndividual, :Line ;
    :lineNumber 731 ;
    :canonicalReference "731"^^xsd:string ;
    :text "I wouldn’t even tell someone else to honor rebels."^^xsd:string .

:Line_732 a owl:NamedIndividual, :Line ;
    :lineNumber 732 ;
    :canonicalReference "732"^^xsd:string ;
    :text "And has she not come down with that very affliction?"^^xsd:string .

:Line_733 a owl:NamedIndividual, :Line ;
    :lineNumber 733 ;
    :canonicalReference "733"^^xsd:string ;
    :text "All of Thebes disagrees with you."^^xsd:string .

:Line_734 a owl:NamedIndividual, :Line ;
    :lineNumber 734 ;
    :canonicalReference "734"^^xsd:string ;
    :text "Will the city now be telling me how to rule?"^^xsd:string .

:Line_735 a owl:NamedIndividual, :Line ;
    :lineNumber 735 ;
    :canonicalReference "735"^^xsd:string ;
    :text "Can’t you see how childishly you’ve spoken?"^^xsd:string .

:Line_736 a owl:NamedIndividual, :Line ;
    :lineNumber 736 ;
    :canonicalReference "736"^^xsd:string ;
    :text "Must I rule this land by someone else’s opinions?"^^xsd:string .

:Line_737 a owl:NamedIndividual, :Line ;
    :lineNumber 737 ;
    :canonicalReference "737"^^xsd:string ;
    :text "It’s not a city if it only belongs to one man."^^xsd:string ;
    :advocatesFor :EthicalPrinciple_CollectiveRule ;
    :hasConflict :Conflict_AutocracyVsCollectiveCity .

:Line_738 a owl:NamedIndividual, :Line ;
    :lineNumber 738 ;
    :canonicalReference "738"^^xsd:string ;
    :text "Is the city not ruled by the man in charge?"^^xsd:string ;
    :advocatesFor :EthicalPrinciple_TyrannicalOwnership ;
    :hasTheme :Theme_Tyranny .

:Line_739 a owl:NamedIndividual, :Line ;
    :lineNumber 739 ;
    :canonicalReference "739"^^xsd:string ;
    :text "And I’m sure you’d rule very nicely in a wasteland."^^xsd:string ;
    :relatedTo :Effect_Wasteland .

:Line_740 a owl:NamedIndividual, :Line ;
    :lineNumber 740 ;
    :canonicalReference "740"^^xsd:string ;
    :text "It seems this one’s taken sides with the woman."^^xsd:string ;
    :relatedTo :Cause_ListeningToWomen .

:Line_741 a owl:NamedIndividual, :Line ;
    :lineNumber 741 ;
    :canonicalReference "741"^^xsd:string ;
    :text "Yeah, if you’re a woman. I’m actually trying to help you."^^xsd:string ;
    :hasMotivation :Motivation_HelpFather .

:Line_742 a owl:NamedIndividual, :Line ;
    :lineNumber 742 ;
    :canonicalReference "742"^^xsd:string ;
    :text "You ungrateful child, putting your own father on trial!"^^xsd:string .

:Line_743 a owl:NamedIndividual, :Line ;
    :lineNumber 743 ;
    :canonicalReference "743"^^xsd:string ;
    :text "Only because I can see that you’re making a mistake."^^xsd:string .

:Line_744 a owl:NamedIndividual, :Line ;
    :lineNumber 744 ;
    :canonicalReference "744"^^xsd:string ;
    :text "Is it a mistake to respect my own authority?"^^xsd:string ;
    :hasConflict :Conflict_HumanAuthorityVsDivineLaw .

:Line_745 a owl:NamedIndividual, :Line ;
    :lineNumber 745 ;
    :canonicalReference "745"^^xsd:string ;
    :text "No, but you can’t worship yourself while you walk all over the gods."^^xsd:string ;
    :advocatesFor :EthicalPrinciple_DivineReverence ;
    :hasTheme :Theme_DivineLaw .

:Line_746 a owl:NamedIndividual, :Line ;
    :lineNumber 746 ;
    :canonicalReference "746"^^xsd:string ;
    :text "You polluted creature, whipped by a woman!"^^xsd:string ;
    :relatedTo :Effect_CloudedJudgement ;
    :hasTheme :Theme_Misogyny .

:Line_747 a owl:NamedIndividual, :Line ;
    :lineNumber 747 ;
    :canonicalReference "747"^^xsd:string ;
    :text "You would never find emotions clouding my judgement."^^xsd:string .

:Line_748 a owl:NamedIndividual, :Line ;
    :lineNumber 748 ;
    :canonicalReference "748"^^xsd:string ;
    :text "Yet every word you say is in her defense."^^xsd:string .

:Line_749 a owl:NamedIndividual, :Line ;
    :lineNumber 749 ;
    :canonicalReference "749"^^xsd:string ;
    :text "And yours, and mine, and the gods’ below."^^xsd:string .

:Line_750 a owl:NamedIndividual, :Line ;
    :lineNumber 750 ;
    :canonicalReference "750"^^xsd:string ;
    :text "You will never marry this girl while she’s alive."^^xsd:string ;
    :relatedTo :Event_AntigonesDeath .

:Line_751 a owl:NamedIndividual, :Line ;
    :lineNumber 751 ;
    :canonicalReference "751"^^xsd:string ;
    :text "Then she will die, and in death kill another."^^xsd:string ;
    :relatedTo :Event_AnotherDeath .

:Line_752 a owl:NamedIndividual, :Line ;
    :lineNumber 752 ;
    :canonicalReference "752"^^xsd:string ;
    :text "You would really dare to make so bold a threat?"^^xsd:string .

:Line_753 a owl:NamedIndividual, :Line ;
    :lineNumber 753 ;
    :canonicalReference "753"^^xsd:string ;
    :text "What threat is there in discussing your foolish plans?"^^xsd:string ;
    :experiencesEmotion :Emotion_Frustration .

:Line_754 a owl:NamedIndividual, :Line ;
    :lineNumber 754 ;
    :canonicalReference "754"^^xsd:string ;
    :text "You whine while you talk, since you lack wisdom."^^xsd:string .

:Line_755 a owl:NamedIndividual, :Line ;
    :lineNumber 755 ;
    :canonicalReference "755"^^xsd:string ;
    :text "If you weren’t my father, I’d say you were out of your mind."^^xsd:string .

:Line_756 a owl:NamedIndividual, :Line ;
    :lineNumber 756 ;
    :canonicalReference "756"^^xsd:string ;
    :text "Oh don’t flatter me—you’re a slave to that woman!"^^xsd:string ;
    :hasTheme :Theme_Misogyny .

:Line_757 a owl:NamedIndividual, :Line ;
    :lineNumber 757 ;
    :canonicalReference "757"^^xsd:string ;
    :text "So you want to do all of the talking and none of the listening?"^^xsd:string .

:Line_758 a owl:NamedIndividual, :Line ;
    :lineNumber 758 ;
    :canonicalReference "758"^^xsd:string ;
    :text "Oh really? It’s clear, by Olympus,"^^xsd:string ;
    :experiencesEmotion :Emotion_Outrage .

:Line_759 a owl:NamedIndividual, :Line ;
    :lineNumber 759 ;
    :canonicalReference "759"^^xsd:string ;
    :text "You’re happy to abuse me with these insults."^^xsd:string .

:Line_760 a owl:NamedIndividual, :Line ;
    :lineNumber 760 ;
    :canonicalReference "760"^^xsd:string ;
    :text "Bring that wretched creature before his eyes at once,"^^xsd:string ;
    :makesMoralDecision :MoralDecision_ExecuteAntigoneBeforeHaemon .

:Line_761 a owl:NamedIndividual, :Line ;
    :lineNumber 761 ;
    :canonicalReference "761"^^xsd:string ;
    :text "So she can die while her bridegroom stands idly by."^^xsd:string .
