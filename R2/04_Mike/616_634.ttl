@prefix : <http://example.org/antigone#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:Chorus a :Character .
:Haemon a :Character .
:Antigone a :Character .
:Creon a :Character .

# --- Semantic Entities (Greek) ---

:Motivation_MournBride a :Motivation ;
    :description "Η υποτιθέμενη πρόθεση του Αίμονα να θρηνήσει τη μοίρα της νύφης του Αντιγόνης και να πενθήσει για τον χαμένο του γάμο."^^xsd:string .
:Haemon :hasMotivation :Motivation_MournBride .

:Motivation_AssessSonLoyalty a :Motivation ;
    :description "Η πρόθεση του Κρέοντα να διαπιστώσει αν ο γιος του παραμένει πιστός σύμμαχος (φίλος) αφού άκουσε για την καταδίκη της νύφης του."^^xsd:string .
:Creon :hasMotivation :Motivation_AssessSonLoyalty .

:EthicalPrinciple_FilialLoyalty a :EthicalPrinciple ;
    :description "Η αρχή ότι ένας γιος πρέπει να παραμένει άνευ όρων σύμμαχος στον πατέρα του σε κάθε περίσταση (πανταχῇ δρῶντες φίλοι)."^^xsd:string .
:Creon :advocatesFor :EthicalPrinciple_FilialLoyalty .

:Emotion_Grief a :Emotion ;
    :description "Η θλίψη (ἀχνύμενος) και το πένθος για τη μοίρα μιας νύφης και η υπερβολική οδύνη για την απώλεια του συζυγικού κρεβατιού (ἀπάτας λεχέων ὑπεραλγῶν)."^^xsd:string .
:Haemon :experiencesEmotion :Emotion_Grief .

:Emotion_Raving a :Emotion ;
    :description "Ο παράφορος θυμός και η μανία (λυσσαίνων) για την απώλεια της μελλοντικής νύφης."^^xsd:string .
:Haemon :experiencesEmotion :Emotion_Raving .

:Conflict_EvilAppearingAsGood a :Conflict ;
    :description "Η γνωστική και ηθική αντίφαση όπου το κακό φαίνεται ως καλό (τὸ κακὸν δοκεῖν ποτ' ἐσθλὸν) σε ένα μυαλό που οδηγείται στην καταστροφή."^^xsd:string ;
    :conflictBetween :Theme_FalseHope, :Event_InevitableRuin .

:Conflict_LoyaltyVsLove a :Conflict ;
    :description "Η ένταση ανάμεσα στον ρομαντικό δεσμό του Αίμονα με την Αντιγόνη και τη συγγενική του υποχρέωση προς τον Κρέοντα."^^xsd:string ;
    :conflictBetween :Antigone, :Creon .

:Cause_DivineDeception a owl:Thing ;
    :description "Οι θεοί που οδηγούν το μυαλό ενός θνητού στην καταστροφή (ὅτῳ φρένας θεὸς ἄγει πρὸς ἄταν)."^^xsd:string .

:Effect_MoralBlindness a owl:Thing ;
    :description "Το κακό που φαίνεται ως καλό στον εξαπατημένο θνητό."^^xsd:string .

:Effect_InevitableRuin a owl:Thing ;
    :description "Ο θνητός που παραμένει ελεύθερος από την καταστροφή για ελάχιστο μόνο χρόνο."^^xsd:string .
:Cause_DivineDeception :relatedTo :Effect_MoralBlindness .
:Effect_MoralBlindness :relatedTo :Effect_InevitableRuin .

:Cause_FalseHope a owl:Thing ;
    :description "Η περιπλανώμενη ελπίδα που λειτουργεί ως απάτη επιπόλαιων επιθυμιών (ἀπάτα κουφονόων ἐρώτων)."^^xsd:string .

:Effect_UnexpectedPain a owl:Thing ;
    :description "Το ανύποπτο θύμα που καίει το πόδι του σε καυτή φωτιά (πυρὶ θερμῷ πόδα τις προσαύσῃ)."^^xsd:string .
:Cause_FalseHope :relatedTo :Effect_UnexpectedPain .

:Event_FinalVote a owl:Thing ;
    :description "Η ρίψη της τελικής ψήφου (τελείαν ψῆφον) που καταδικάζει την Αντιγόνη."^^xsd:string .
:Event_FinalVote :relatedTo :Emotion_Grief .
:Event_FinalVote :relatedTo :Emotion_Raving .

:Theme_FalseHope a :Theme ;
    :description "Η ελπίδα ως πλάνη που ξεγελά τις επιπόλαιες επιθυμίες και οδηγεί ανεπίγνωστα στον πόνο."^^xsd:string .

:Theme_DivineMadness a :Theme ;
    :description "Η διαστρέβλωση της ανθρώπινης αντίληψης από τους θεούς, ώστε να φαίνεται το κακό ως καλό πριν από την καταστροφή."^^xsd:string .

:Theme_FilialDuty a :Theme ;
    :description "Η προσδοκία της απόλυτης πίστης και συμμαχίας ενός γιου προς τον πατέρα του."^^xsd:string .

# --- Line-by-Line Extraction with Translation Variants ---

:Line_616 a owl:NamedIndividual, :Line ; :lineNumber 616 ; :canonicalReference "616"^^xsd:string .
:TV_Line_616_grc a :TranslationVariant ;
    :text "Ἁ γὰρ δὴ πολύπλαγκτος ἐλπίς πολλοῖς μὲν ὄνασις ἀνδρῶν,"^^xsd:string ;
    :relatedTo :Line_616 ;
    :hasTheme :Theme_FalseHope .

:Line_617 a owl:NamedIndividual, :Line ; :lineNumber 617 ; :canonicalReference "617"^^xsd:string .
:TV_Line_617_grc a :TranslationVariant ;
    :text "πολλοῖς δ ̓ ἀπάτα κουφονόων ἐρώτων·"^^xsd:string ;
    :relatedTo :Line_617 .

:Line_618 a owl:NamedIndividual, :Line ; :lineNumber 618 ; :canonicalReference "618"^^xsd:string .
:TV_Line_618_grc a :TranslationVariant ;
    :text "εἰδότι δ ̓ οὐδὲν ἕρπει,"^^xsd:string ;
    :relatedTo :Line_618 ;
    :relatedTo :Cause_FalseHope .

:Line_619 a owl:NamedIndividual, :Line ; :lineNumber 619 ; :canonicalReference "619"^^xsd:string .
:TV_Line_619_grc a :TranslationVariant ;
    :text "πρὶν πυρὶ θερμῷ πόδα τις προσαύσῃ."^^xsd:string ;
    :relatedTo :Line_619 .

:Line_620 a owl:NamedIndividual, :Line ; :lineNumber 620 ; :canonicalReference "620"^^xsd:string .
:TV_Line_620_grc a :TranslationVariant ;
    :text "Σοφίᾳ γὰρ ἔκ του"^^xsd:string ;
    :relatedTo :Line_620 ;
    :relatedTo :Effect_UnexpectedPain .

:Line_621 a owl:NamedIndividual, :Line ; :lineNumber 621 ; :canonicalReference "621"^^xsd:string .
:TV_Line_621_grc a :TranslationVariant ;
    :text "κλεινὸν ἔπος πέφανται·"^^xsd:string ;
    :relatedTo :Line_621 ;
    :hasTheme :Theme_DivineMadness .

:Line_622 a owl:NamedIndividual, :Line ; :lineNumber 622 ; :canonicalReference "622"^^xsd:string .
:TV_Line_622_grc a :TranslationVariant ;
    :text "τὸ κακὸν δοκεῖν ποτ ̓ ἐσθλὸν"^^xsd:string ;
    :relatedTo :Line_622 ;
    :relatedTo :Effect_MoralBlindness ;
    :hasConflict :Conflict_EvilAppearingAsGood .

:Line_623 a owl:NamedIndividual, :Line ; :lineNumber 623 ; :canonicalReference "623"^^xsd:string .
:TV_Line_623_grc a :TranslationVariant ;
    :text "τῷδ ̓ ἔμμεν, ὅτῳ φρένας"^^xsd:string ;
    :relatedTo :Line_623 ;
    :relatedTo :Cause_DivineDeception .

:Line_624 a owl:NamedIndividual, :Line ; :lineNumber 624 ; :canonicalReference "624"^^xsd:string .
:TV_Line_624_grc a :TranslationVariant ;
    :text "θεὸς ἄγει πρὸς ἄταν·"^^xsd:string ;
    :relatedTo :Line_624 .

:Line_625 a owl:NamedIndividual, :Line ; :lineNumber 625 ; :canonicalReference "625"^^xsd:string .
:TV_Line_625_grc a :TranslationVariant ;
    :text "πράσσει δ ̓ ὀλίγιστον χρόνον ἐκτὸς ἄτας."^^xsd:string ;
    :relatedTo :Line_625 ;
    :relatedTo :Effect_InevitableRuin .

:Line_626 a owl:NamedIndividual, :Line ; :lineNumber 626 ; :canonicalReference "626"^^xsd:string .
:TV_Line_626_grc a :TranslationVariant ;
    :text "Ὅδε μὴν Αἵμων, παίδων τῶν σῶν"^^xsd:string ;
    :relatedTo :Line_626 .

:Line_627 a owl:NamedIndividual, :Line ; :lineNumber 627 ; :canonicalReference "627"^^xsd:string .
:TV_Line_627_grc a :TranslationVariant ;
    :text "νέατον γέννημ ̓· ἆρ ̓ ἀχνύμενος"^^xsd:string ;
    :relatedTo :Line_627 .

:Line_628 a owl:NamedIndividual, :Line ; :lineNumber 628 ; :canonicalReference "628"^^xsd:string .
:TV_Line_628_grc a :TranslationVariant ;
    :text "[τῆς μελλογάμου νύμφης]"^^xsd:string ;
    :relatedTo :Line_628 ;
    :hasMotivation :Motivation_MournBride .

:Line_629 a owl:NamedIndividual, :Line ; :lineNumber 629 ; :canonicalReference "629"^^xsd:string .
:TV_Line_629_grc a :TranslationVariant ;
    :text "τάλιδος ἥκει μόρον Ἀντιγόνης,"^^xsd:string ;
    :relatedTo :Line_629 .

:Line_630 a owl:NamedIndividual, :Line ; :lineNumber 630 ; :canonicalReference "630"^^xsd:string .
:TV_Line_630_grc a :TranslationVariant ;
    :text "ἀπάτας λεχέων ὑπεραλγῶν;"^^xsd:string ;
    :relatedTo :Line_630 ;
    :experiencesEmotion :Emotion_Grief .

:Line_631 a owl:NamedIndividual, :Line ; :lineNumber 631 ; :canonicalReference "631"^^xsd:string .
:TV_Line_631_grc a :TranslationVariant ;
    :text "ΚΡ. Τάχ ̓ εἰσόμεσθα μάντεων ὑπέρτερον."^^xsd:string ;
    :relatedTo :Line_631 .

:Line_632 a owl:NamedIndividual, :Line ; :lineNumber 632 ; :canonicalReference "632"^^xsd:string .
:TV_Line_632_grc a :TranslationVariant ;
    :text "Ὦ παῖ, τελείαν ψῆφον ἆρα μὴ κλύων"^^xsd:string ;
    :relatedTo :Line_632 ;
    :experiencesEmotion :Emotion_Raving .

:Line_633 a owl:NamedIndividual, :Line ; :lineNumber 633 ; :canonicalReference "633"^^xsd:string .
:TV_Line_633_grc a :TranslationVariant ;
    :text "τῆς μελλονύμφου πατρὶ λυσσαίνων πάρει;"^^xsd:string ;
    :relatedTo :Line_633 ;
    :relatedTo :Event_FinalVote .

:Line_634 a owl:NamedIndividual, :Line ; :lineNumber 634 ; :canonicalReference "634"^^xsd:string .
:TV_Line_634_grc a :TranslationVariant ;
    :text "ἢ σοὶ μὲν ἡμεῖς πανταχῇ δρῶντες φίλοι;"^^xsd:string ;
    :relatedTo :Line_634 ;
    :hasMotivation :Motivation_AssessSonLoyalty ;
    :advocatesFor :EthicalPrinciple_FilialLoyalty ;
    :hasTheme :Theme_FilialDuty ;
    :hasConflict :Conflict_LoyaltyVsLove .
