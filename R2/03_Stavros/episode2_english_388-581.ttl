############################
# CHARACTERS & ENTITIES
############################

:Antigone_Character_Guard
  a owl:NamedIndividual, :Character ;
  :experiencesEmotion :Emotion_Fear, :Emotion_Relief, :Emotion_Guilt, :Emotion_Enthusiasm ;
  :hasMotivation :Motivation_SelfPreservation, :Motivation_Exonerate ;
  :tragicFlaw "Selfishness"^^xsd:string ;
  :moralAlignment "Self-preserving"^^xsd:string .

:Antigone_Character_Creon
  a owl:NamedIndividual, :Character ;
  :experiencesEmotion :Emotion_Anger, :Emotion_Indignation, :Emotion_Satisfaction ;
  :hasMotivation :Motivation_MaintainAuthority, :Motivation_EnforceLaw, :Motivation_PunishTransgression, :Motivation_ProtectThrone, :Motivation_TestCourage ;
  :advocatesFor :EthicalPrinciple_CivicLaw ;
  :violatesLaw :Law_DivineBurialRite ;
  :tragicFlaw "Stubbornness, inflexibility, authoritarianism"^^xsd:string ;
  :moralAlignment "Tyrannical, absolute"^^xsd:string ;
  :status "Tyrant of Thebes, uncle of Antigone"^^xsd:string .

:Antigone_Character_Antigone
  a owl:NamedIndividual, :Character ;
  :experiencesEmotion :Emotion_Defiance, :Emotion_Resolve, :Emotion_Acceptance, :Emotion_Contempt ;
  :hasMotivation :Motivation_HonorBrother, :Motivation_ObeyDivineLaw ;
  :advocatesFor :EthicalPrinciple_DivineLaw, :EthicalPrinciple_FamilyDuty ;
  :makesMoralDecision :MoralDecision_BuryPolyneices ;
  :isSiblingOf :Antigone_Character_Ismene ;
  :tragicFlaw "Stubbornness, inflexibility, hubris toward authority"^^xsd:string ;
  :moralAlignment "Pious, god-fearing, logical, perceptive, harsh, moral, independent, free, self-sufficient, grief-stricken, loving, reactive, strong, dynamic, decisive, irreverent to Creon's office, emotional, angry"^^xsd:string ;
  :status "Princess, niece of Creon, daughter of Oedipus"^^xsd:string .

:Antigone_Character_Ismene
  a owl:NamedIndividual, :Character ;
  :experiencesEmotion :Emotion_Despair, :Emotion_Love, :Emotion_Guilt, :Emotion_Hurt, :Emotion_Regret ;
  :hasMotivation :Motivation_ShareFate, :Motivation_ProtectSister, :Motivation_LightenBurden, :Motivation_ShareNobleAct, :Motivation_HonorBrother ;
  :isSiblingOf :Antigone_Character_Antigone ;
  :tragicFlaw "Weakness, timidity, compromise"^^xsd:string ;
  :moralAlignment "Completely compromising, flexible, realistic, timid, cowardly, servile, law-abiding, adapted to human authority, weak character, fears Creon"^^xsd:string ;
  :status "Princess, niece of Creon, daughter of Oedipus, sister of Antigone"^^xsd:string .

:Antigone_Chorus
  a owl:NamedIndividual, :Character ;
  :experiencesEmotion :Emotion_Compassion, :Emotion_Observation .


