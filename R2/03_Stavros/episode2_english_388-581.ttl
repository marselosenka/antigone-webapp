  :description "The Guard's relief at having caught the perpetrator and avoiding punishment."^^xsd:string .

:Emotion_Anger
  a owl:NamedIndividual, :Emotion ;
  :description "Creon's rage at Antigone's defiance and challenge to his authority."^^xsd:string .

:Emotion_Indignation
  a owl:NamedIndividual, :Emotion ;
  :description "Creon's righteous anger at what he perceives as disobedience and hubris."^^xsd:string .

:Emotion_Defiance
  a owl:NamedIndividual, :Emotion ;
  :description "Antigone's bold resistance to Creon's decree."^^xsd:string .

:Emotion_Resolve
  a owl:NamedIndividual, :Emotion ;
  :description "Antigone's unwavering determination to honor her brother despite consequences."^^xsd:string .

:Emotion_Acceptance
  a owl:NamedIndividual, :Emotion ;
  :description "Antigone's peaceful acceptance of her death sentence."^^xsd:string .

:Emotion_Despair
  a owl:NamedIndividual, :Emotion ;
  :description "Ismene's hopelessness and desire to share Antigone's fate."^^xsd:string .

:Emotion_Love
  a owl:NamedIndividual, :Emotion ;
  :description "Ismene's love for her sister and desire to protect her."^^xsd:string .

:Emotion_Guilt
  a owl:NamedIndividual, :Emotion ;
  :description "Ismene's guilt for not having helped Antigone initially."^^xsd:string .

:Emotion_Compassion
  a owl:NamedIndividual, :Emotion ;
  :description "The Chorus's pity and understanding for the sisters' plight."^^xsd:string .

:Emotion_Observation
  a owl:NamedIndividual, :Emotion ;
  :description "The Chorus's detached observation and commentary on the events."^^xsd:string .

:Emotion_Enthusiasm
  a owl:NamedIndividual, :Emotion ;
  :description "The Guard's eager presentation of Antigone, fulfilling the tyrant's order."^^xsd:string .

:Emotion_Satisfaction
  a owl:NamedIndividual, :Emotion ;
  :description "Creon's contentment at having captured the perpetrator."^^xsd:string .

:Emotion_Hurt
  a owl:NamedIndividual, :Emotion ;
  :description "Ismene's pain from Antigone's harsh words."^^xsd:string .

:Emotion_Regret
  a owl:NamedIndividual, :Emotion ;
  :description "Ismene's remorse for not having helped Antigone initially and desire to justify her earlier choice."^^xsd:string .

:Emotion_Contempt
  a owl:NamedIndividual, :Emotion ;
  :description "Antigone's disdainful feeling toward those who act out of fear or self-interest."^^xsd:string .

:Conflict_AntigoneVsCreon
  a owl:NamedIndividual, :Conflict ;
  :conflictBetween :Antigone_Character_Antigone, :Antigone_Character_Creon ;
  :description "The central conflict between Antigone's duty to divine law and Creon's assertion of human authority."^^xsd:string ;
  :relatedTo :Conflict_DivineVsHumanLaw .

:Conflict_DivineVsHumanLaw
  a owl:NamedIndividual, :Conflict ;
  :conflictBetween :EthicalPrinciple_DivineLaw, :EthicalPrinciple_CivicLaw ;
  :description "The fundamental opposition between unwritten divine laws and human decrees."^^xsd:string .

:Conflict_AntigoneVsIsmene
  a owl:NamedIndividual, :Conflict ;
  :conflictBetween :Antigone_Character_Antigone, :Antigone_Character_Ismene ;
  :description "The tension between Antigone's active defiance and Ismene's initial passivity, later resolved by Ismene's desire to share the fate."^^xsd:string .

:Motivation_SelfPreservation
  a owl:NamedIndividual, :Motivation ;
  :description "The Guard's need to protect himself from Creon's wrath by finding the perpetrator."^^xsd:string .

:Motivation_MaintainAuthority
  a owl:NamedIndividual, :Motivation ;
  :description "Creon's drive to assert and maintain his power as ruler."^^xsd:string .

:Motivation_EnforceLaw
  a owl:NamedIndividual, :Motivation ;
  :description "Creon's commitment to enforcing his decree to maintain order."^^xsd:string .

:Motivation_HonorBrother
  a owl:NamedIndividual, :Motivation ;
  :description "Antigone's determination to give her brother Polyneices proper burial rites."^^xsd:string .

:Motivation_ObeyDivineLaw
  a owl:NamedIndividual, :Motivation ;
  :description "Antigone's commitment to following the unwritten laws of the gods."^^xsd:string .

:Motivation_ShareFate
  a owl:NamedIndividual, :Motivation ;
  :description "Ismene's desire to die alongside her sister rather than live without her."^^xsd:string .

:Motivation_ProtectSister
  a owl:NamedIndividual, :Motivation ;
  :description "Ismene's wish to protect Antigone by claiming shared responsibility."^^xsd:string .

:Motivation_Exonerate
  a owl:NamedIndividual, :Motivation ;
  :description "The Guard's desire to clear himself of blame and avoid punishment."^^xsd:string .

:Motivation_PunishTransgression
  a owl:NamedIndividual, :Motivation ;
  :description "Creon's drive to punish Antigone for her boldness in breaking the law."^^xsd:string .

:Motivation_ProtectThrone
  a owl:NamedIndividual, :Motivation ;
  :description "Creon's need to protect his position and authority from perceived threats."^^xsd:string .

:Motivation_LightenBurden
  a owl:NamedIndividual, :Motivation ;
  :description "Ismene's wish to share Antigone's burden of accusation."^^xsd:string .

:Motivation_ShareNobleAct
  a owl:NamedIndividual, :Motivation ;
  :description "Ismene's desire to partake in her sister's noble deed of burial."^^xsd:string .

:Motivation_TestCourage
  a owl:NamedIndividual, :Motivation ;
  :description "Creon's belief that fear of death will cause the sisters to seek salvation."^^xsd:string .

:EthicalPrinciple_DivineLaw
  a owl:NamedIndividual, :EthicalPrinciple ;
  :description "The eternal, unwritten laws established by the gods that take precedence over human law."^^xsd:string .

:EthicalPrinciple_CivicLaw
  a owl:NamedIndividual, :EthicalPrinciple ;
  :description "The laws and decrees of the state, established by human rulers."^^xsd:string .

:EthicalPrinciple_FamilyDuty
  a owl:NamedIndividual, :EthicalPrinciple ;
  :description "The moral obligation to honor and care for family members, especially in death."^^xsd:string .

:Law_DivineBurialRite
  a owl:NamedIndividual, :Law ;
  :description "The divine law requiring proper burial of the dead, regardless of their status in life."^^xsd:string .

:MoralDecision_BuryPolyneices
  a owl:NamedIndividual, :MoralDecision ;
  :description "Antigone's choice to bury her brother despite Creon's decree, prioritizing divine law over human law."^^xsd:string .

############################
# MYTHOLOGICAL BACKGROUND
############################

:MythologicalBackground_Zeus
  a owl:NamedIndividual, :MythologicalBackground ;
  :description "Zeus, the king of the gods, who establishes divine laws that mortals cannot override."^^xsd:string .

:MythologicalBackground_Dike
  a owl:NamedIndividual, :MythologicalBackground ;
  :description "Dike (Justice), the goddess who dwells with the gods below and ensures divine justice."^^xsd:string .

:MythologicalBackground_UnderworldGods
  a owl:NamedIndividual, :MythologicalBackground ;
  :description "The gods of the underworld (Hades, Persephone, and others) who govern the dead and require proper burial rites."^^xsd:string .

:MythologicalBackground_Hades
  a owl:NamedIndividual, :MythologicalBackground ;
  :description "Hades, the god of the underworld, who demands equal treatment for all the dead regardless of their status in life."^^xsd:string .

:MythologicalBackground_ZeusHerkeios
  a owl:NamedIndividual, :MythologicalBackground ;
  :description "Zeus Herkeios (Zeus of the Hearth), protector of family bonds and household relationships."^^xsd:string .

:MythologicalBackground_Oedipus
  a owl:NamedIndividual, :MythologicalBackground ;
  :description "Oedipus, the father of Antigone and Ismene, whose tragic fate and character traits are inherited by his children."^^xsd:string .

:MythologicalBackground_DivineStorm
  a owl:NamedIndividual, :MythologicalBackground ;
  :description "The divine tempest that appeared as a gift from the gods, hiding Antigone during the burial and allowing her to complete the rites."^^xsd:string .

:MythologicalBackground_Hermes
  a owl:NamedIndividual, :MythologicalBackground ;
  :description "Hermes, god of luck and discoveries, to whom the 'thourmaion' (lucky find) was traditionally attributed."^^xsd:string .

:MythologicalBackground_Nemesis
  a owl:NamedIndividual, :MythologicalBackground ;
  :description "Nemesis, daughter of Zeus and Themis, who with the Erinyes oversees moral order and punishes those who violate it."^^xsd:string .

:MythologicalBackground_Cadmus
  a owl:NamedIndividual, :MythologicalBackground ;
  :description "Cadmus, the mythological founder of Thebes, from whom the Thebans are called Cadmeans (Κάδμειοι)."^^xsd:string .

############################
# RHETORICAL DEVICES
############################

:Metaphor_UnwrittenLaws
  a owl:NamedIndividual, :MetaphorSimile ;
  :description "The metaphor of unwritten, eternal divine laws that exist beyond human decrees."^^xsd:string .

:Metaphor_Iron
  a owl:NamedIndividual, :MetaphorSimile ;
  :description "Creon's metaphor comparing rigid, unyielding character to iron that breaks when hardened and struck."^^xsd:string .

:Metaphor_Horse
  a owl:NamedIndividual, :MetaphorSimile ;
  :description "Creon's metaphor comparing the need to control strong-willed individuals to taming spirited horses with a small bit."^^xsd:string .

:Simile_Bird
  a owl:NamedIndividual, :MetaphorSimile ;
  :description "The Guard's simile comparing Antigone's cries of grief to a bird's sharp call when it finds its nest empty."^^xsd:string .

:Irony_GenderReversal
  a owl:NamedIndividual, :Irony ;
  :description "Creon's ironic statement that he is not a man while Antigone is, highlighting the reversal of traditional gender roles."^^xsd:string .

:Metaphor_Curse
  a owl:NamedIndividual, :MetaphorSimile ;
  :description "The powerful curses that Antigone utters against those who desecrated the body, believed to have magical force."^^xsd:string .

:Oxymoron_BittersweetJoy
  a owl:NamedIndividual, :RhetoricalDevice ;
  :description "The Guard's simultaneous feeling of joy and pain ('ἡδέως κἀλγεινῶς') at catching Antigone."^^xsd:string .

:Symbol_Trispondoi
  a owl:NamedIndividual, :Symbol ;
  :description "The three libations (honey, milk, wine) offered to the dead, representing proper burial rites."^^xsd:string .

:Metaphor_Serpent
  a owl:NamedIndividual, :MetaphorSimile ;
  :description "Creon's comparison of Ismene to a serpent hidden in the house, representing treachery and danger."^^xsd:string .

:Irony_QuestionCreon
  a owl:NamedIndividual, :Irony ;
  :description "Antigone's ironic suggestion that Ismene ask Creon, whom she fears or loves too much, highlighting Ismene's character."^^xsd:string .

:Irony_Mockery
  a owl:NamedIndividual, :Irony ;
  :description "Antigone's mockery of Ismene, using the word 'γελῶ' (laugh/mock/contempt) to express derision or falsehood."^^xsd:string .

:Metaphor_Field
  a owl:NamedIndividual, :MetaphorSimile ;
  :description "Creon's metaphor comparing available women to fields ready for sowing seed, expressing interchangeability."^^xsd:string .

############################
# ENGLISH TRANSLATION VARIANTS
# EPISODE 2 (Lines 388-581)
############################

# --- 388 ---

:TV_Line_388_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_388 ;
  :text "Let mortal men swear not against any thing,"^^xsd:string .

# --- 389 ---

:TV_Line_389_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_389 ;
  :text "For their minds are of a fickle mettle:"^^xsd:string .

# --- 390 ---

:TV_Line_390_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_390 ;
  :text "Yea, I swore unto God I would never"^^xsd:string .

# --- 391 ---

:TV_Line_391_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_391 ;
  :text "Return hither unto you and the threatening words"^^xsd:string .

# --- 392 ---

:TV_Line_392_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_392 ;
  :text "You bandy upon me, but—"^^xsd:string .

# --- 393 ---

:TV_Line_393_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_393 ;
  :text "As a pleasant surprise is pleasing unto all—"^^xsd:string .

# --- 394 ---

:TV_Line_394_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_394 ;
  :text "Behold! I am here, though I spoke otherwise,"^^xsd:string .

# --- 395 ---

:TV_Line_395_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_395 ;
  :text "With this maiden here, who was seen honoring the dead."^^xsd:string .

# --- 396 ---

:TV_Line_396_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_396 ;
  :text "This time, no lots needs were cast,"^^xsd:string .

# --- 397 ---

:TV_Line_397_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_397 ;
  :text "For this hath befallen me alone. Now, dread liege,"^^xsd:string .

# --- 398 ---

:TV_Line_398_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_398 ;
  :text "Take you her, examine her, "^^xsd:string .

# --- 399 ---

:TV_Line_399_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_399 ;
  :text "question her, as it pleaseth you, only"^^xsd:string .

# --- 400 ---

:TV_Line_400_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_400 ;
  :text "I am weary of the ado about this place."^^xsd:string .

# --- 401 ---

:TV_Line_401_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_401 ;
  :text "Can you explain how and where you found this woman?"^^xsd:string .

# --- 402 ---

:TV_Line_402_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_402 ;
  :text "She was burying the corpse—the rest you know."^^xsd:string .

# --- 403 ---

:TV_Line_403_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_403 ;
  :text "Do you understand what you are saying? Is this the truth?"^^xsd:string .

# --- 404 ---

:TV_Line_404_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_404 ;
  :text "Yes! I hath seen her burying the corpse"^^xsd:string .

# --- 405 ---

:TV_Line_405_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_405 ;
  :text "You had enjoined be not interred, there is no more, hear you?"^^xsd:string .

# --- 406 ---

:TV_Line_406_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_406 ;
  :text "How did you find her? How did you make your arrest?"^^xsd:string .

# --- 407 ---

:TV_Line_407_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_407 ;
  :text "It occured in this way: when arrived we to the place—"^^xsd:string .

# --- 408 ---

:TV_Line_408_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_408 ;
  :text "with your threats o’erhanging our heads—"^^xsd:string .

# --- 409 ---

:TV_Line_409_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_409 ;
  :text "We swept away all the dust that was upon the corpse,"^^xsd:string .

# --- 410 ---

:TV_Line_410_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_410 ;
  :text "Nudified the oddly bedewed flesh,"^^xsd:string .

# --- 411 ---

:TV_Line_411_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_411 ;
  :text "And sat we down by the hill against the wind,"^^xsd:string .

# --- 412 ---

:TV_Line_412_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_412 ;
  :text "Thus ensuring no odor did strike us."^^xsd:string .

# --- 413 ---

:TV_Line_413_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_413 ;
  :text "Every man did keep his watch, and did make each other keep theirs"^^xsd:string .

# --- 414 ---

:TV_Line_414_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_414 ;
  :text "With threats, lest any should prove a shirker."^^xsd:string .

# --- 415 ---

:TV_Line_415_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_415 ;
  :text "Time passed, then high noon arose"^^xsd:string .

# --- 416 ---

:TV_Line_416_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_416 ;
  :text "With the sun directly o’erhead"^^xsd:string .

# --- 417 ---

:TV_Line_417_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_417 ;
  :text "And the land was hot and roasting."^^xsd:string .

# --- 418 ---

:TV_Line_418_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_418 ;
  :text "Then arose a sudden a twisting wind,"^^xsd:string .

# --- 419 ---

:TV_Line_419_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_419 ;
  :text "Evil in the heavens, engendering a storm of dust,"^^xsd:string .

# --- 420 ---

:TV_Line_420_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_420 ;
  :text "Filling the plain, marking up the forest whole,"^^xsd:string .

# --- 421 ---

:TV_Line_421_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_421 ;
  :text "And choking up the air. We closed our eyes"^^xsd:string .

# --- 422 ---

:TV_Line_422_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_422 ;
  :text "And took we God’s wrath. It seems an eternity did pass,"^^xsd:string .

# --- 423 ---

:TV_Line_423_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_423 ;
  :text "But then we saw this maiden shrieking"^^xsd:string .

# --- 424 ---

:TV_Line_424_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_424 ;
  :text "Like a mother bird who findeth"^^xsd:string .

# --- 425 ---

:TV_Line_425_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_425 ;
  :text "her chicks gone from the nest."^^xsd:string .

# --- 426 ---

:TV_Line_426_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_426 ;
  :text "She did see the corpse denuded,"^^xsd:string .

# --- 427 ---

:TV_Line_427_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_427 ;
  :text "Began to wail in earnest,"^^xsd:string .

# --- 428 ---

:TV_Line_428_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_428 ;
  :text "And curst she whoever had done this."^^xsd:string .

# --- 429 ---

:TV_Line_429_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_429 ;
  :text "Straightway she took dust into her hands,"^^xsd:string .

# --- 430 ---

:TV_Line_430_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_430 ;
  :text "Raised up the water pitcher,"^^xsd:string .

# --- 431 ---

:TV_Line_431_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_431 ;
  :text "And did anoint the dead."^^xsd:string .

# --- 432 ---

:TV_Line_432_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_432 ;
  :text "Seeing this we did her arrest straightaway,"^^xsd:string .

# --- 433 ---

:TV_Line_433_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_433 ;
  :text "But she was unafraid."^^xsd:string .

# --- 434 ---

:TV_Line_434_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_434 ;
  :text "We did make inquiry unto her about"^^xsd:string .

# --- 435 ---

:TV_Line_435_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_435 ;
  :text "What she had did and she denied not a thing."^^xsd:string .

# --- 436 ---

:TV_Line_436_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_436 ;
  :text "It pleases me well, but also does me sorrow:"^^xsd:string .

# --- 437 ---

:TV_Line_437_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_437 ;
  :text "For, ‘tis good to ‘scape the gallows,"^^xsd:string .

# --- 438 ---

:TV_Line_438_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_438 ;
  :text "But to cast another therein agrieves."^^xsd:string .

# --- 439 ---

:TV_Line_439_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_439 ;
  :text "But, what is of import is"^^xsd:string .

# --- 440 ---

:TV_Line_440_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_440 ;
  :text "that I am saved: the rest troubleth not."^^xsd:string .

# --- 441 ---

:TV_Line_441_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_441 ;
  :text "You... you with your head hung down to the earth,"^^xsd:string .

# --- 442 ---

:TV_Line_442_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_442 ;
  :text "do you admit to this or do you deny it?"^^xsd:string .

# --- 443 ---

:TV_Line_443_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_443 ;
  :text "I say that I did it and I do not deny it."^^xsd:string .

# --- 444 ---

:TV_Line_444_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_444 ;
  :text "You’re free to go wherever you wish, guard,"^^xsd:string .

# --- 445 ---

:TV_Line_445_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_445 ;
  :text "Now that your name’s been cleared."^^xsd:string .

# --- 446 ---

:TV_Line_446_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_446 ;
  :text "Now girl, speak to the point:"^^xsd:string .

# --- 447 ---

:TV_Line_447_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_447 ;
  :text "Were you aware of my decree?"^^xsd:string .

# --- 448 ---

:TV_Line_448_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_448 ;
  :text "I knew it. Why wouldn’t I have known it? It was well-known to all."^^xsd:string .

# --- 449 ---

:TV_Line_449_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_449 ;
  :text "And yet you dared to disobey this law?"^^xsd:string .

# --- 450 ---

:TV_Line_450_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_450 ;
  :text "Yes, for Zeus did not make this decree,"^^xsd:string .

# --- 451 ---

:TV_Line_451_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_451 ;
  :text "And Dike, goddess of justice,"^^xsd:string .

# --- 452 ---

:TV_Line_452_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_452 ;
  :text "Did not ordain such a law for mortal men."^^xsd:string .

# --- 453 ---

:TV_Line_453_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_453 ;
  :text "I didn’t think your decrees"^^xsd:string .

# --- 454 ---

:TV_Line_454_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_454 ;
  :text "Were strong enough to outweigh"^^xsd:string .

# --- 455 ---

:TV_Line_455_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_455 ;
  :text "The firm and unwritten laws of the gods."^^xsd:string .

# --- 456 ---

:TV_Line_456_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_456 ;
  :text "For they live not today or yesterday, but for all time,"^^xsd:string .

# --- 457 ---

:TV_Line_457_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_457 ;
  :text "And no one knows how long ago they were revealed."^^xsd:string .

# --- 458 ---

:TV_Line_458_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_458 ;
  :text "I was not about to pay the gods’ price"^^xsd:string .

# --- 459 ---

:TV_Line_459_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_459 ;
  :text "For fear of one man’s arrogance."^^xsd:string .

# --- 460 ---

:TV_Line_460_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_460 ;
  :text "I knew very well that I would die one day. How could I not?"^^xsd:string .

# --- 461 ---

:TV_Line_461_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_461 ;
  :text "Even if you had not made your decree, it would still be so."^^xsd:string .

# --- 462 ---

:TV_Line_462_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_462 ;
  :text "But if I die before my time, I count it as a gain."^^xsd:string .

# --- 463 ---

:TV_Line_463_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_463 ;
  :text "When someone lives among as many evils as I do,"^^xsd:string .

# --- 464 ---

:TV_Line_464_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_464 ;
  :text "How could they not live better in death?"^^xsd:string .

# --- 465 ---

:TV_Line_465_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_465 ;
  :text "It won’t be painful at all for me to meet"^^xsd:string .

# --- 466 ---

:TV_Line_466_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_466 ;
  :text "This fate, but if I had allowed"^^xsd:string .

# --- 467 ---

:TV_Line_467_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_467 ;
  :text "The son of my own mother to die and remain unburied,"^^xsd:string .

# --- 468 ---

:TV_Line_468_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_468 ;
  :text "That would have tortured me, but this—this is nothing."^^xsd:string .

# --- 469 ---

:TV_Line_469_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_469 ;
  :text "Am I the fool?"^^xsd:string .

# --- 470 ---

:TV_Line_470_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_470 ;
  :text "Or is it the fool that accuses me of folly."^^xsd:string .

# --- 471 ---

:TV_Line_471_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_471 ;
  :text "It’s clear she’s the fierce child of a fierce father."^^xsd:string .

# --- 472 ---

:TV_Line_472_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_472 ;
  :text "She never learned how to be flexible."^^xsd:string .

# --- 473 ---

:TV_Line_473_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_473 ;
  :text "See how over-brittle minds are the first"^^xsd:string .

# --- 474 ---

:TV_Line_474_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_474 ;
  :text "To crack, and how the mightiest iron,"^^xsd:string .

# --- 475 ---

:TV_Line_475_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_475 ;
  :text "tempered by fire,"^^xsd:string .

# --- 476 ---

:TV_Line_476_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_476 ;
  :text "Can still splinter and crumble Into a million pieces."^^xsd:string .

# --- 477 ---

:TV_Line_477_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_477 ;
  :text "I know, too, how a great, Passionate horse can be broken with just a tiny bit:"^^xsd:string .

# --- 478 ---

:TV_Line_478_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_478 ;
  :text "You can’t be proud of what you say"^^xsd:string .

# --- 479 ---

:TV_Line_479_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_479 ;
  :text "If you’re just a slave to your audience."^^xsd:string .

# --- 480 ---

:TV_Line_480_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_480 ;
  :text "This girl knew full well how to commit a crime,"^^xsd:string .

# --- 481 ---

:TV_Line_481_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_481 ;
  :text "And she has transgressed the law that I established:"^^xsd:string .

# --- 482 ---

:TV_Line_482_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_482 ;
  :text "But she’s committed a second outrage"^^xsd:string .

# --- 483 ---

:TV_Line_483_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_483 ;
  :text "By being proud of what she’s done and laughing with self-congratulation."^^xsd:string .

# --- 484 ---

:TV_Line_484_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_484 ;
  :text "Now either I’m no man, or she’s become one,"^^xsd:string .

# --- 485 ---

:TV_Line_485_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_485 ;
  :text "If she’s to win such a victory without any retribution."^^xsd:string .

# --- 486 ---

:TV_Line_486_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_486 ;
  :text "I don’t care that she’s my sister’s child—"^^xsd:string .

# --- 487 ---

:TV_Line_487_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_487 ;
  :text "And even if she were closer to me than my own wife or son,"^^xsd:string .

# --- 488 ---

:TV_Line_488_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_488 ;
  :text "She and her sister"^^xsd:string .

# --- 489 ---

:TV_Line_489_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_489 ;
  :text "will never avoid this horrible fate—"^^xsd:string .

# --- 490 ---

:TV_Line_490_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_490 ;
  :text "I think her sister holds an equal share Of the blame for plotting this burial."^^xsd:string .

# --- 491 ---

:TV_Line_491_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_491 ;
  :text "Go! Summon her! For I see her now,"^^xsd:string .

# --- 492 ---

:TV_Line_492_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_492 ;
  :text "Raving about in there like she’s lost her mind."^^xsd:string .

# --- 493 ---

:TV_Line_493_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_493 ;
  :text "When someone’s concocting a villainous scheme,"^^xsd:string .

# --- 494 ---

:TV_Line_494_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_494 ;
  :text "Their mind will often betray"^^xsd:string .

# --- 495 ---

:TV_Line_495_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_495 ;
  :text "Their guilt before the act is done."^^xsd:string .

# --- 496 ---

:TV_Line_496_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_496 ;
  :text "I hate it, too, when a criminal Who’s been caught tries to glorify their crime."^^xsd:string .

# --- 497 ---

:TV_Line_497_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_497 ;
  :text "What more do you want than my death?"^^xsd:string .

# --- 498 ---

:TV_Line_498_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_498 ;
  :text "Nothing: once I have that, I’ll have everything."^^xsd:string .

# --- 499 ---

:TV_Line_499_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_499 ;
  :text "Why then do you delay?"^^xsd:string .

# --- 500 ---

:TV_Line_500_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_500 ;
  :text "Nothing you say pleases me—"^^xsd:string .

# --- 501 ---

:TV_Line_501_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_501 ;
  :text "And I hope it never does—And nothing I do pleases you."^^xsd:string .

# --- 502 ---

:TV_Line_502_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_502 ;
  :text "What greater glory could I have gained"^^xsd:string .

# --- 503 ---

:TV_Line_503_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_503 ;
  :text "Than placing my own brother In his grave."^^xsd:string .

# --- 504 ---

:TV_Line_504_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_504 ;
  :text "You could tell that everyone here Is happy to hear this,"^^xsd:string .

# --- 505 ---

:TV_Line_505_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_505 ;
  :text "if fear did not shut their mouths."^^xsd:string .

# --- 506 ---

:TV_Line_506_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_506 ;
  :text "But tyranny has many blessings—"^^xsd:string .

# --- 507 ---

:TV_Line_507_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_507 ;
  :text "In particular it can do and say whatever it wants."^^xsd:string .

# --- 508 ---

:TV_Line_508_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_508 ;
  :text "You’re the only one in Thebes who sees things this way."^^xsd:string .

# --- 509 ---

:TV_Line_509_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_509 ;
  :text "They all see it but they hold their tongues for you."^^xsd:string .

# --- 510 ---

:TV_Line_510_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_510 ;
  :text "Wouldn’t you be ashamed if they disagreed with you?"^^xsd:string .

# --- 511 ---

:TV_Line_511_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_511 ;
  :text "There’s no shame in respecting one’s own flesh and blood."^^xsd:string .

# --- 512 ---

:TV_Line_512_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_512 ;
  :text "Didn’t he die fighting his own flesh and blood?"^^xsd:string .

# --- 513 ---

:TV_Line_513_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_513 ;
  :text "A brother from the same mother and the same father, yes."^^xsd:string .

# --- 514 ---

:TV_Line_514_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_514 ;
  :text "Then how can you heap praises on someone so godless?"^^xsd:string .

# --- 515 ---

:TV_Line_515_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_515 ;
  :text "The dead man would not agree with that."^^xsd:string .

# --- 516 ---

:TV_Line_516_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_516 ;
  :text "If you honor him with equal fervor, you disgrace Eteocles."^^xsd:string .

# --- 517 ---

:TV_Line_517_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_517 ;
  :text "It was his brother, not some slave who perished."^^xsd:string .

# --- 518 ---

:TV_Line_518_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_518 ;
  :text "One ravaged this land. The other died defending it."^^xsd:string .

# --- 519 ---

:TV_Line_519_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_519 ;
  :text "Nevertheless, Hades demands these rites."^^xsd:string .

# --- 520 ---

:TV_Line_520_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_520 ;
  :text "But this man, good for nothing but evil, wants equal honor."^^xsd:string .

# --- 521 ---

:TV_Line_521_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_521 ;
  :text "Who knows what the gods consider holy?"^^xsd:string .

# --- 522 ---

:TV_Line_522_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_522 ;
  :text "Your enemy’s never your friend, not even when he’s dead."^^xsd:string .

# --- 523 ---

:TV_Line_523_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_523 ;
  :text "I was born to join in love, not in hate."^^xsd:string .

# --- 524 ---

:TV_Line_524_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_524 ;
  :text "Why don’t you love them when you’re down there yourself,"^^xsd:string .

# --- 525 ---

:TV_Line_525_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_525 ;
  :text "If you must love them! As long as I live, no woman shall rule me."^^xsd:string .

# --- 526 ---

:TV_Line_526_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_526 ;
  :text "Behold! Ismene before the palace gates,"^^xsd:string .

# --- 527 ---

:TV_Line_527_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_527 ;
  :text "Letting her brother-loving tears flow:"^^xsd:string .

# --- 528 ---

:TV_Line_528_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_528 ;
  :text "A cloud over her brow"^^xsd:string .

# --- 529 ---

:TV_Line_529_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_529 ;
  :text "disfigures her countenance Red as blood,"^^xsd:string .

# --- 530 ---

:TV_Line_530_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_530 ;
  :text "drenching her fair cheek."^^xsd:string .

# --- 531 ---

:TV_Line_531_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_531 ;
  :text "You, sitting in the palace like a viper, lurking,"^^xsd:string .

# --- 532 ---

:TV_Line_532_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_532 ;
  :text "Sucking my blood dry while you went unnoticed—did I miss some sign"^^xsd:string .

# --- 533 ---

:TV_Line_533_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_533 ;
  :text "When I raised you two leeches, some sign that you’d be Rebels against the throne?"^^xsd:string .

# --- 534 ---

:TV_Line_534_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_534 ;
  :text "Come, say it to me! You’ll say you also Had a hand in the burial..."^^xsd:string .

# --- 535 ---

:TV_Line_535_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_535 ;
  :text "or will you swear you knew nothing of it?"^^xsd:string .

# --- 536 ---

:TV_Line_536_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_536 ;
  :text "I did the deed, if she’ll agree,"^^xsd:string .

# --- 537 ---

:TV_Line_537_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_537 ;
  :text "And I’ll share the blame."^^xsd:string .

# --- 538 ---

:TV_Line_538_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_538 ;
  :text "But justice won’t let you, since you refused help,"^^xsd:string .

# --- 539 ---

:TV_Line_539_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_539 ;
  :text "And I did not consult with you."^^xsd:string .

# --- 540 ---

:TV_Line_540_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_540 ;
  :text "I’m not ashamed to sail alongside you"^^xsd:string .

# --- 541 ---

:TV_Line_541_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_541 ;
  :text "Through your ocean of perils."^^xsd:string .

# --- 542 ---

:TV_Line_542_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_542 ;
  :text "Hades and the dead below know whose deed this is."^^xsd:string .

# --- 543 ---

:TV_Line_543_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_543 ;
  :text "A friend in words alone is no friend of mine."^^xsd:string .

# --- 544 ---

:TV_Line_544_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_544 ;
  :text "At least, sister, you should not strip me of the honor"^^xsd:string .

# --- 545 ---

:TV_Line_545_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_545 ;
  :text "Of both dying and cleansing the dead with you!"^^xsd:string .

# --- 546 ---

:TV_Line_546_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_546 ;
  :text "Don’t die for my sake, and don’t claim something"^^xsd:string .

# --- 547 ---

:TV_Line_547_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_547 ;
  :text "You never even tried to do. My death will suffice."^^xsd:string .

# --- 548 ---

:TV_Line_548_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_548 ;
  :text "And what would my life be without you?"^^xsd:string .

# --- 549 ---

:TV_Line_549_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_549 ;
  :text "Ask Creon! Your concern clearly lies with him!"^^xsd:string .

# --- 550 ---

:TV_Line_550_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_550 ;
  :text "Why are you mocking me like this? It’s not helpful at all."^^xsd:string .

# --- 551 ---

:TV_Line_551_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_551 ;
  :text "If I’m mocking you, it’s my loss."^^xsd:string .

# --- 552 ---

:TV_Line_552_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_552 ;
  :text "But really! Even now, what can I do to help you?"^^xsd:string .

# --- 553 ---

:TV_Line_553_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_553 ;
  :text "Save yourself. I will not resent your escape."^^xsd:string .

# --- 554 ---

:TV_Line_554_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_554 ;
  :text "Oh misery! Will I not share in your fate?"^^xsd:string .

# --- 555 ---

:TV_Line_555_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_555 ;
  :text "You chose to live, and I chose to die."^^xsd:string .

# --- 556 ---

:TV_Line_556_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_556 ;
  :text "But not without hearing what I had to say."^^xsd:string .

# --- 557 ---

:TV_Line_557_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_557 ;
  :text "Some people took your side, some people took mine."^^xsd:string .

# --- 558 ---

:TV_Line_558_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_558 ;
  :text "But both of us have equal guilt!"^^xsd:string .

# --- 559 ---

:TV_Line_559_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_559 ;
  :text "Be strong! You are still living,"^^xsd:string .

# --- 560 ---

:TV_Line_560_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_560 ;
  :text "but my life ended long ago, So that I might serve the dead."^^xsd:string .

# --- 561 ---

:TV_Line_561_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_561 ;
  :text "I gather so far that one of you has just gone mad,"^^xsd:string .

# --- 562 ---

:TV_Line_562_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_562 ;
  :text "While the other has been mad from the start."^^xsd:string .

# --- 563 ---

:TV_Line_563_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_563 ;
  :text "Yes, my lord, the sanity we’re born with doesn’t stay"^^xsd:string .

# --- 564 ---

:TV_Line_564_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_564 ;
  :text "When things go badly. It wanders off."^^xsd:string .

# --- 565 ---

:TV_Line_565_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_565 ;
  :text "Certainly for you, when you chose to do such evil things with such evil people."^^xsd:string .

# --- 566 ---

:TV_Line_566_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_566 ;
  :text "What kind of life could I live, alone, separated from her?"^^xsd:string .

# --- 567 ---

:TV_Line_567_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_567 ;
  :text "Don’t speak of her. She’s yours no more."^^xsd:string .

# --- 568 ---

:TV_Line_568_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_568 ;
  :text "You’re really going to kill your own son’s bride?"^^xsd:string .

# --- 569 ---

:TV_Line_569_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_569 ;
  :text "He can plow other fields."^^xsd:string .

# --- 570 ---

:TV_Line_570_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_570 ;
  :text "No one is as well matched to him as she is."^^xsd:string .

# --- 571 ---

:TV_Line_571_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_571 ;
  :text "I hate it when sons take horrid wives."^^xsd:string .

# --- 572 ---

:TV_Line_572_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_572 ;
  :text "O Haemon dear, how your father insults you!"^^xsd:string .

# --- 573 ---

:TV_Line_573_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_573 ;
  :text "I’ve had enough of you and that marriage."^^xsd:string .

# --- 574 ---

:TV_Line_574_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_574 ;
  :text "Will you really deprive your son of his own wife?"^^xsd:string .

# --- 575 ---

:TV_Line_575_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_575 ;
  :text "I won’t have to: Hades will to stop this marriage for me."^^xsd:string .

# --- 576 ---

:TV_Line_576_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_576 ;
  :text "It’s settled, then. She is to die."^^xsd:string .

# --- 577 ---

:TV_Line_577_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_577 ;
  :text "Yes, it’s settled... settled for both of us, so there’s no point"^^xsd:string .

# --- 578 ---

:TV_Line_578_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_578 ;
  :text "In arguing any further. Bring her inside, slaves."^^xsd:string .

# --- 579 ---

:TV_Line_579_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_579 ;
  :text "From now on you are not to leave these women alone."^^xsd:string .

# --- 580 ---

:TV_Line_580_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_580 ;
  :text "For even brave men, I tell you, flee"^^xsd:string .

# --- 581 ---

:TV_Line_581_en
  a owl:NamedIndividual, :TranslationVariant ;
  :relatedTo :Line_581 ;
  :text "when they see Hades standing beside them so soon."^^xsd:string .


